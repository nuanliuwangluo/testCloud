let uniqueId = 0;

function memoize(fn) {
    const cache = new Map(); // 创建缓存对象，用于存储已计算的结果
    const functionName = fn.name || `anonymous_${uniqueId++}`; // 为匿名函数生成唯一的名称

    return function (...args) {
        const key = `${functionName}:${JSON.stringify(args)}`; // 将函数名和参数序列化为字符串作为缓存键
        if (cache.has(key)) { // 如果缓存中有结果，直接返回
            return cache.get(key);
        }
        const result = fn.apply(this, args); // 调用原函数并获取结果
        cache.set(key, result); // 将结果存入缓存
        return result;
    };
}

