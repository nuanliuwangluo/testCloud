let effectUtils = {
    async breathe(instance, normalScale, maxScale, time) {
        if (instance.isBreathe) return;
        instance.scaleX = normalScale
        instance.scaleY = normalScale
        instance.isBreathe = true
        await __tool.tweenp(instance, { scaleX: maxScale, scaleY: maxScale }, time)
        await __tool.tweenp(instance, { scaleX: normalScale, scaleY: normalScale }, time)
        instance.isBreathe = false
        this.breathe(instance, normalScale, maxScale, time)
    },
    stopBreathe(instance) {
        instance.isBreathe = false
        instance.scaleX = 1;
        instance.scaleY = 1;
        Laya.Tween.clearAll(instance)
    }
}

