class SortUtils {
    static sort(list, descend = false, field = '') {
        list.sort((a, b) => {
            if (descend) {
                if (field && typeof a == 'object' && typeof b == 'object') {
                    return b[field] - a[field];
                } else {
                    return b - a;
                }
            } else {
                if (field && typeof a == 'object' && typeof b == 'object') {
                    return a[field] - b[field];
                } else {
                    return a - b;
                }
            }
        })
    }
}


class ImageFont extends Laya.Sprite {
    constructor(urls__, align, valign, distance) {
        super();
        if (urls__) this.init(urls__, align, valign, distance);
    }

    set skins(value) { this.urls__ = value; }

    init(urls__, align, valign, distance) {
        this.urls__ = urls__;
        this._text = 0;
        this._id = Laya.Pool.getItemByClass('ImageFont_Image', Laya.Image);
        this._width$ = 0;
        this._height$ = 0;
        this._distance = distance ? distance : 0;
        //2张图片文本间隔
        this.dis = 0;
        this.align = align || 'left';
        this.valign = valign || 'top';
        this.container = new Laya.Sprite();
        this.addChild(this.container);
    }

    get text() {
        return this._text;
    }
    set text(value) {
        this._text = value;

        let __fontContainer = this.__createFont();
        this.container.addChild(__fontContainer);
        this.size(__fontContainer.width, __fontContainer.height);

        if (this.align == 'left') this.container.x = 0;
        else if (this.align == 'right') this.container.x = -this.width;
        else if (this.align == 'center') { this.container.x = -this.width / 2; }


        if (this.valign == 'top') this.container.y = 0;
        else if (this.valign == 'bottom') this.container.y = -this.height;
        else if (this.valign == 'center') { this.container.y = -this.height / 2; }
    }


    set numberText(value) {

    }



    __createFont() {
        this._width$ = this._height$ = 0;
        this.__sp = this.__sp || new Laya.Sprite();
        try {
            while (this.__sp.numChildren) {
                let node = this.__sp.removeChildAt(0);
                node.skin = '';
                Laya.Pool.recover('ImageFont_Image', node);
            }
        } catch (e) {
            if (this.__sp) {
                this.__sp.destroy();
                this.__sp = null;
            }
            this.__sp = new Laya.Sprite();
            log('创建字体容器错误：', e);
        }

        var str = String(this._text);
        var l = str.length;
        //根据str内容重新排序数字
        for (var i = 0; i < l; i++) {
            var a = str.charAt(i);
            var s = Laya.Pool.getItemByClass('ImageFont_Image', Laya.Image);
            if (!this.urls__[a]) throw new Error("NumText 字符 " + a + " 没有对应URL");
            s.skin = this.urls__[a];
            this.__sp.addChild(s);
            // var d = i >= 1 ? this.dis : 0;
            // s.x = this._width$ + d + this._distance;
            // this._width$ = this._width$ + s.width + d + this._distance;

            var d = i >= 1 ? this._distance : 0;
            s.x = this._width$ + d;
            this._width$ = this._width$ + s.width + d;
            this._height$ = Math.max(this._height$, s.height);
        }

        this.__sp.size(this._width$, this._height$);
        return this.__sp;
    }
}


/**
 * 数值转换工具
 */
class GoldFormatUtils {

    /**
     * 字符串数值
     * @param {*} value 要转换的数值
     * @param {*} toFixed 转换后是否需要已小数显示 0 不显示 >0 小数显示的位数
     * @param {*} rule 格式规则，默认 万，千万
     * @returns 
     */
    static format(value = '', toFixed = 0, rule = GoldFormatUtils.FORMATRULE) {
        value = value.toString();
        // 是否为负值
        GoldFormatUtils._minus = value.indexOf('-') === 0 ? '-' : '';
        // 如果为负值 扣除负号进行格式化
        value = value.indexOf('-') === 0 ? value.substring(1) : value;

        toFixed = toFixed;
        let formatValue, tempValue;
        /**
         * 当前value是否为小数
         */
        let _decimalIndex = this.decimalIndex(value);
        // 不是小数
        if (_decimalIndex == -1) {
            formatValue = this._formatByRule(value, toFixed, rule);
        } else { // 是小数
            tempValue = value.substring(0, _decimalIndex);
            formatValue = this._formatByRule(tempValue, toFixed, rule);
        }
        // console.log('数值转换：' + value + '--->' + formatValue);
        return GoldFormatUtils._minus + formatValue;
    }

    /**
     * 是否为小数
     * @param {*} value 
     * @returns -1不是小数 > -1 为小数点得index
     */
    static decimalIndex(value) {
        return value.toString().indexOf('.');
    }

    /**
     * 根据规则进行检测
     * @param {*} value 
     * @param {*} toFixed 
     * @returns 
     */
    static _formatByRule(value, toFixed, rule) {
        for (let i = 0; i < rule.length; i++) {
            let ruleValue = rule[i].value;
            // 字符串长度不匹配  继续下一个检测
            if (value.length < ruleValue.length) { continue }
            // 长度匹配
            else {
                /**
                 * 获取整数值
                 * value 取0~(value.length-ruleValue.length+1)  长度差值+1 为数值的末尾位置
                 */
                let _intValue = value.substring(0, value.length - ruleValue.length + 1);
                /**
                 * 获取小数值 取(value.length-ruleValue.length+1)~(value.length-ruleValue.length+1+toFixed)  整数值的末尾加上要取得长度
                 */
                let _decimalValue = this._checkFixed(value.substring(value.length - ruleValue.length + 1, value.length - ruleValue.length + 1 + toFixed));
                /**
                 * 返回拼接的新字符
                 */
                return _intValue + _decimalValue + rule[i].name;
            }
        }
        /**
         * 如果没有满足的情况 反馈原始值
         */
        return value;
    }

    /**
     * 校验小数值 全部是0返回空字符   有一位不是0返回原始值
     * @param {string} value 
     * @returns 
     */
    static _checkFixed(value) {
        if (value && value.length) {
            while (true) {
                let code = parseInt(value.charAt(value.length - 1));
                if (code == 0) {
                    value = value.substring(0, value.length - 1);
                } else {
                    break;
                }
            }
        }
        for (let i = value.length - 1; i >= 0; i++) {
            let code = parseInt(value.charAt(i));
            if (code > 0) { return '.' + value; }
        }
        return '';
    }
}
