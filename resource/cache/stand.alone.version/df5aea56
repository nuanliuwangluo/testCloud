// 计时器
class TimerUtils {
    static start() {
        if (TimerUtils.running) {
            return
        }
        TimerUtils.running = true;
        Laya.timer.loop(1000, this, this.__update);
    }

    /**
     * 刷新列表
     */
    static __update() {
        for (let i in TimerUtils.list) {
            TimerUtils.list[i] && TimerUtils.list[i]();
        }


        let __event = (TimerUtils.attrList.length) ? true : false;
        // 倒计时的一些值
        for (let i = 0; i < TimerUtils.attrList.length; i++) {
            let __value = TimerUtils.attrList[i].value;
            let __name = TimerUtils.attrList[i].name;
            // 倒计时 如果为0 结束了
            if (parseInt(__value[__name]) - 1 <= 0) {
                __value[__name] = 0;
                TimerUtils.attrList.splice(i, 1);
                i--;
                // 通知计算结束
                if (__value.event) { // 指定结束事件
                    game.cb.event(__value.event);
                } else { // 统一结束事件
                    game.cb.event(TimerUtils.TIMERUTILS_COMPLETE_EVENT);
                }
            } else {
                __value[__name] = parseInt(__value[__name]) - 1;
            }
        }
        if (__event) game.cb.event(TimerUtils.TIMERUTILS_SECOND_EVENT);
    }


    /**
     * 函数添加到列表内
     * @param {*} __name 
     * @param {*} func 
     */
    static addFunc(__name, func) {
        TimerUtils.list[__name] = func;
    }

    /**
     * 删除列表内的函数
     *  @param {*} __name 
     *  @param {*} func 
     */
    static removeFunc(__name) {
        if (TimerUtils.list[__name]) TimerUtils.list[__name] = null;
    }


    /**
     * 添加可倒计时的
     * @param {object} value object属性所在的对象
     * @param {string} attrName 属性名
     * @param {string} eventName 计时归零后派发事件名
     */
    static pushAttr(value, attrName, zeroEventName) {
        let __inValue = TimerUtils.attrList.some(a => {
            return a.value == value && a.name == attrName
        });
        // 如果 列表里没有这个属性
        if (!__inValue) {
            TimerUtils.attrList.push({
                value: value,
                name: attrName,
                event: zeroEventName
            })
        }
    }
}
