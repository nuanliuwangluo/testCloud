// 对象皮肤工具类
class SkinUtils {

    /**
     * 用户头像
     * @param {Laya.Sprite} target 
     * @param {皮肤地址} skinUrl 
     */
    static load(target, skinUrl) {
        this.setSkin(target, skinUrl)
    }

    /**
     * @param {Laya.Sprite} target 
     * @param {string} skinUrl 
     * @param {Boolean} noneUrlDebugger 
     */
    static setSkin(target, skinUrl, noneUrlDebugger = false) {
        if (!target) throw new Error('SkinUtils the target is null.');
        else {
            if (noneUrlDebugger) {
                let t = Laya.loader.getRes(skinUrl);
                if (!t) debugger;
            }
            if (target instanceof Laya.Image) {
                if (target.skin != skinUrl) {
                    target.skin = skinUrl;
                }
            } else if (target instanceof Laya.Sprite) {
                target.SHOWURL = skinUrl;
                if (skinUrl) {
                    let t = Laya.loader.getRes(skinUrl);
                    if (t) {
                        target.texture = t;
                    } else {
                        Laya.loader.load(skinUrl, Laya.Handler.create(this, (view, url) => {
                            if (view.SHOWURL == url) {
                                let texture = Laya.loader.getRes(url);
                                target.texture = texture;
                            }
                        }, [target, skinUrl]), undefined, Laya.Loader.IMAGE);
                    }
                } else {
                    target.texture = skinUrl;
                }
                // if (!target.texture) {
                //     target.texture = skinUrl;
                // } else {
                //     if (!target.texture.url) {
                //         target.texture = skinUrl;
                //     } else if (target.texture.url != skinUrl) {
                //         target.texture = skinUrl;
                //     }
                // }
            }
        }
    }

    /**
     * 元素添加灰色滤镜
     * @param {Node} __target  变灰的元素
     * @param {boolean} __gray 是否为变灰  默认true
     * @param {boolean} __mouseEnabled 是否接收鼠标事件 默认false 不接受
     */
    static gray(__target, __gray, __mouseEnabled) {
        SkinUtils.grayFilter = this.__getGrayFilter();
        if ('filters' in __target) {
            if (__gray || __gray == null) {
                __target.filters = [SkinUtils.grayFilter];
                __target.mouseEnabled = __mouseEnabled ? __mouseEnabled : false;
            } else {
                __target.filters = [];
                __target.mouseEnabled = true;
            }
        }
    }

    /**
     * 创建一个灰色滤镜
     * @returns 
     */
    static __getGrayFilter() {
        if (SkinUtils.grayFilter) {
            return SkinUtils.grayFilter;
        } else {
            SkinUtils.grayFilter = new Laya.ColorFilter();
            SkinUtils.grayFilter.gray();
            return SkinUtils.grayFilter;
        }
    }
}
