class RankUtils {

    /**
     * 是否发生段位变化
     * @param {number} cup1 
     * @param {number} cup2 
     * @return {Boolean} true 发生变化  false 没有发生变化
     */
    static rankDrop(cup1, cup2) {
        let cityId = this.getCityId(__data.uid);
        let data1 = RankUtils.getRankLvDataByScore(cup1, __data.uid, cityId);
        let data2 = RankUtils.getRankLvDataByScore(cup2, __data.uid, cityId);
        // 都是雀神
        if (data1.toNextLevelNeedCup == 0 && data2.toNextLevelNeedCup == 0) { return false; }
        if (data1.name != data2.name) {
            return true;
        }
        return false;
    }

    static async getCityId(uid) {
        if (__data.othersVO[uid])
            return __data.othersVO[uid].area;
        else {
            await game.server.send(2005, uid);
            return __data.othersVO[uid].area;
        }
    }

    static getPlayerAreaRank(uid) {
        if (__data.othersVO[uid] && __data.othersVO[uid].scores) {
            let cups = __data.othersVO[uid].scores[__data.othersVO[uid].area];
            return RankUtils.getRankLvDataByScore(cups, uid, __data.othersVO[uid].area);
        }
        return {};
    }

    static getRankLvDataByScore(score, uid = __data.uid, cityId = null, useLastLegend = false) {
        if (!score) return __data.rankLvData[0];
        for (let index = 0, length = __data.rankLvData.length; index < length; index++) {
            let e = __data.rankLvData[index];
            let ne = __data.rankLvData[index + 1];
            if (!ne || (score >= e.minCup && score < ne.minCup)) {
                if (e.toNextLevelNeedCup == 0 && __data.rank.xingyaoQueshen.minCup == 0) {
                    __data.rank.xingyaoQueshen.minCup = e.minCup
                    __data.rank.chuanqiQueshen.minCup = e.minCup
                }
                if (e.toNextLevelNeedCup == 0 && score - e.minCup >= __data.rank.rank_exceed_queshen_score) {
                    // 使用前一个传奇雀神
                    if (useLastLegend) {
                        if (uid == __data.chuanqi.lastPlayer.uid && cityId == __data.chuanqi.lastPlayer.cityId)
                            return __data.rank.chuanqiQueshen;
                        // e.name = '传奇雀神'
                        else
                            return __data.rank.xingyaoQueshen;
                        // e.name = '星耀雀神'
                    }
                    else {
                        if (uid == __data.chuanqi.player.uid && cityId == __data.chuanqi.player.cityId)
                            return __data.rank.chuanqiQueshen;
                        // e.name = '传奇雀神'
                        else
                            return __data.rank.xingyaoQueshen;
                        // e.name = '星耀雀神'
                    }
                } else
                    return e;
            }
        };
    }

    static isSpecialRank(score, uid = __data.uid, cityId = null) {
        if (!score) return false;
        let rd = this.getRankLvDataByScore(score, uid, cityId);
        if (rd) {
            if (rd.name == __data.rank.chuanqiQueshen.name || rd.name == __data.rank.xingyaoQueshen.name) {
                return true;
            }
        }
        return false;
    }


    static getRankLvDataByLv(lv) {
        for (let index = 0, length = __data.rankLvData.length; index < length; index++) {
            let e = __data.rankLvData[index];
            if (e.level == lv) return e
        };
