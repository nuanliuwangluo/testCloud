class HtmlTextUtils {
    static text() {
        var htmlTxt = arguments[0];
        var htmlStyle = arguments[1];
        var strArr = []; //存储 文本内容
        var customArr = []; //存储文本样式
        var defaultColor = htmlStyle['color'] ? htmlStyle['color'] : '#ffffff';

        for (let index in htmlStyle) {
            htmlTxt[index] = htmlStyle[index];
            htmlTxt.style[index] = htmlStyle[index];
        }

        for (let i = 2; i < arguments.length; i++) {
            strArr.push(arguments[i]);
            customArr.push(arguments[i + 1]);
            i += 1;
        }

        var htmlStr = ''
        for (let i = 0; i < strArr.length; i++) {
            var color = customArr[i].color ? customArr[i].color : defaultColor;
            var underline = customArr[i].underline ? "href='" + customArr[i].underline + "'" : "";
            var bold = customArr[i].bold ? 'bold' : 'normal';

            var br = strArr[i].toString().match('/br');
            if (br) {
                var __son_str = strArr[i].toString().split('/br');
                for (let j = 0; j < __son_str.length; j++) {
                    htmlStr += "<span color='" + color + "' style='font-weight:" + bold + "' " + underline + ">" + __son_str[j] + "</span>";
                    htmlStr += "<br/>";
                }
            } else {
                htmlStr += "<span color='" + color + "' style='font-weight:" + bold + "' " + underline + ">" + strArr[i] + "</span>"
            }
        }
        htmlTxt.innerHTML = htmlStr;
    }
}

