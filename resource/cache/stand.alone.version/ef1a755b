___frame.MsgSend = {
    body: [],
    content: "",
    send(id_, net) {
        let sendMsgKey = id_ != 99 ? net.sendMsgKey++ : 0; //99消息 不涨编号
        let body = [
            ...___frame.byte.intToBytes(sendMsgKey),
            ...___frame.byte.intToBytes(id_),
            ...___frame.byte.stringToBytes(___frame.locationModule.longitude),
            ...___frame.byte.stringToBytes(___frame.locationModule.latitude),
            ...this.body,
        ]
        let length = body.length;
        let msg = [
            ...___frame.byte.intToBytes(net.head),
            ...___frame.byte.intToBytes(length),
            ...body,
        ];
        net.socket.postToServer(sendMsgKey, id_, msg)
        net.noPrintIDArr.indexOf(id_) == -1 && trace("%c发送>>>-ID-" + id_ + "-length-" + this.body.length + "-sendMsgKey-" + sendMsgKey, "color:#8a2be2;font-weight:bold")
        net.noPrintIDArr.indexOf(id_) == -1 && trace("发送内容：" + id_ + " " + this.content)
        this.clear()
    },
    clear() {
        this.body.splice(0)
        this.content = ""
    },
    set int(value) {
        this.content += value + " "
        this.body = this.body.concat(___frame.byte.intToBytes(value))
    },
    set long(value) {
        this.content += value + " "
        this.body = this.body.concat(___frame.byte.longToBytes(value))
    },
    set byte(value) {
