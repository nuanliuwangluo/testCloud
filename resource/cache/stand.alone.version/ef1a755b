___frame.Net = function () {
    var that = this;
    this.reConnectMaxCount = 3
    this.reConnectCount = this.reConnectMaxCount
    this.noPrintIDArr = [99, 998, 3010, 3314, 3315, 3319];
    // this.noPrintIDArr = [];
    this.sendList = [];
    this.readList = [];
    this.resArray = {};
    this.socket = null;
    this.sendMsgKey = 1;
    this.readMsgKey = 1;
    this.ip = ''; //该socket玩家ip
    this.head = 10242048;
    this.reSendList = [];
    this.hasDealMsg = [];
    this.ing = false
    this.connect = function (protocol, ip, port) {
        if (this.socket) this.socket.close()
        this.socket = new ___frame.Socket(protocol, ip, port, this)
    }
    this.close = function () {
        this.reSendList = []
        this.hasDealMsg = []
        this.ing = false;
        this.sendMsgKey = 1;
        this.readMsgKey = 1;
        if (this.socket) this.socket.close()
        this.socket = null;
        this.reSendStop();
        __heartbeat.stop()
        game.cb.dispatchEvent('no_socket')
    }
    this.clear = function () {
        this.reConnectCount = this.reConnectMaxCount
        this.reSendList = []
        this.hasDealMsg = []
        this.ing = false;
        this.sendList = [];
        this.readList = [];
        this.sendMsgKey = 1;
        this.readMsgKey = 1;
        if (this.socket) this.socket.close()
        this.socket = null;
        this.reSendStop();
        __heartbeat.stop()
        game.cb.dispatchEvent('no_socket')
    }
    this.registeSendMsg = function () {
        this.sendList.push(...arguments)
        this.sendList = [...new Set(this.sendList)]
    }
    this.registeReadMsg = function () {
        this.readList.push(...arguments)
        this.readList = [...new Set(this.readList)]
    }
    this.logoutSendMsg = function () {
        let list = arguments;
        for (let i = 0; i < list.length; i++) {
            for (let j = 0; j < this.sendList.length; j++) {
                if (list[i] == this.sendList[j]) {
                    this.sendList.splice(j, 1);
                    break;
                }
            }
        }
    }
    this.logoutReadMsg = function () {
        let list = arguments;
        for (let i = 0; i < list.length; i++) {
            for (let j = 0; j < this.readList.length; j++) {
                if (list[i] == this.readList[j]) {
                    this.readList.splice(j, 1);
                    break;
                }
            }
        }
    }
    this.send = function (params____________) {
        return new Promise(async (res, rej) => {
            try {
                if (!this.ing) {
                    console.warn('SOCKET 未实例化... or 未连接...');
                    return;
                }
                if (!arguments.length) throw new Error("参数最少传入一个消息ID")
                let body = [...arguments];
                let id = body.shift();
                let msg_g = this.sendList.find(function (item) {
                    return (id in item)
                })
                if (!msg_g) {
                    console.warn("send msg " + id + " 不存在")
                    return
                }
                let msg_fn = msg_g[id]
                ___frame.MsgSend.body.splice(0);
                msg_fn.apply(___frame.MsgSend, body)
                ___frame.MsgSend.send(id, this)
                this.resArray[id] = this.resArray[id] || [];
                this.resArray[id].push(res)
                return true
            } catch (error) {
                res(null)
                console.error('net.send', error)
            }
        });
    }
    this.reSendTime = null
    this.reSendStart = function () {
        // clearInterval(this.reSendTime)
        // this.reSendTime = setInterval(this.reSendServer, 2000)
    }
    this.reSendServer = function () {
        for (var id in that.reSendList) {
            trace(id, that.reSendList[id])
            that.socket.reSend(id, that.reSendList[id])
        }
    }
    this.reSendStop = function () {
        clearInterval(this.reSendTime)
    }
}
___frame.Socket = function (protocol, ip, port, net) {
    var that = this;
    this.socket = new WebSocket(protocol + ip + ":" + port + '/ws');
    this.socket.socketid = this.socketid;
    this.socket.binaryType = "arraybuffer";
    this.aDataArray = [];
    trace("开始连接服务器...")
    trace("连接地址：" + protocol + ip + ':' + port)
    this.socket.onopen = function () {
        net.resArray = {};
        net.ing = true
        net.reConnectCount = net.reConnectMaxCount;
        clearTimeout(that.timeout);
        __heartbeat.start()
        ___frame.cb.dispatchEvent("socketConnect")
        net.reSendStart()
    };
    this.socket.onmessage = function (message) {
        // __heartbeat.reset();
        // trace('收到消息《《《《《《《《《《《《《《《《《《《《《《《《《《《《《《')
        var barray = new Int8Array(message.data);
        for (var i = 0; i < barray.length; i++) {
            that.aDataArray.push(barray[i]);
        }
        that.read()
    };
    var serverid = 0;
    var length = 0;
    var key = 0;
    var body = null;
    this.read = function () {
        //key length id1 id2 uid 后面都是变动的需求了
        //key服务判断 length长度 id1 服务标志 id2服务消息号解析用 uid当前socket玩家id
        if (key == 0 && that.aDataArray.length >= 8) {
            key = ___frame.byte.readInt(that.aDataArray)
            length = ___frame.byte.readInt(that.aDataArray);
        }
        // trace('key length', key, length)
        if (length > 0) {
            if (key == net.head) {
                if (length <= this.aDataArray.length) {
                    body = this.aDataArray.splice(0, length)
                    var nmk = ___frame.byte.readInt(body);
                    // net.readMsgKey = ___frame.byte.readInt(body);
                    serverid = ___frame.byte.readInt(body);
                    net.noPrintIDArr.indexOf(serverid) == -1 && trace("%c接受<<<-ID-" + serverid + "-length-" + length + '-readMsgKey-' + nmk, "color:#0000ff")
                    if (serverid == 99 || serverid == 88) {
                        this.manageMessage(serverid, body, net);
                    } else if (!net.hasDealMsg[nmk] && net.readMsgKey == nmk) { //这个服务是否已经处理
                        net.hasDealMsg[nmk] = 1;
                        net.readMsgKey++;
                        net.send(99, nmk)
                        this.manageMessage(serverid, body, net);
                    } else if (net.hasDealMsg[nmk]) {
                        trace('已处理')
                        net.send(99, nmk)
                    }
                }
                key = length = 0;
                this.read();
            } else {
                miniApi.alert('提示', '服务数据错乱 请重新登录...')
                _game_init_();
            }
        }
    }
    this.manageMessage = function (serverid, info, net) {
        let msg_group = net.readList.find((item) => {
            return item && (serverid in item)
        })
        if (msg_group) {
            let msg_fn = msg_group[serverid]
            ___frame.MsgRead.body = info;
            try {
                msg_fn.apply(___frame.MsgRead)
                if (net.resArray[serverid] && net.resArray[serverid].length) {
                    net.resArray[serverid].shift()(1)
                    // serverid > 2000 && trace(serverid, net.resArray[serverid].length)
                    if (!net.resArray[serverid].length) {
                        delete net.resArray[serverid]
                    }
                }
            } catch (e) {
                console.error(e)
            }
        } else {
            net.noPrintIDArr.indexOf(serverid) == -1 && trace("msg read " + serverid + " 不存在")
        }
    }
    this.postToServer = function (sendMsgKey, serverid, value) {
        var sendByte = new Int8Array(value.length);
        for (var i = 0; i < value.length; i++) {
            sendByte[i] = value[i];
        }
        this.send(sendByte.buffer)
        if (serverid != 99 && serverid != 998) {
            net.reSendList[sendMsgKey] = sendByte.buffer;
            // net.reSendStart()
        }
    }
    this.reSend = function (id, buffer) {
        if (!net.ing) {
            console.warn('SOCKET 未实例化... or 未连接...');
            return;
        }
        trace('重发消息: ' + id)
        this.send(buffer)
    }
    this.send = function (buffer) {
        if (!this.socket) {
            console.warn("服务器未连接。。。")
        } else
            if (this.socket.readyState != 1) {
                console.warn('SOCKET 未实例化... or 未连接...')
            } else {
                this.socket && this.socket.send(buffer);
            }
    }
    this.socket.onerror = function (e) {
        trace('<> ' + JSON.stringify(e))
        that.close()
        __heartbeat.stop()
        net.ing = false
        net.reSendStop()
        net.reConnectCount--
        if (net.reConnectCount >= 0) {
            ___frame.cb.dispatchEvent("socketError")
        } else {
            ___frame.cb.dispatchEvent("socketFail")
        }
    };
    this.socket.onclose = function () {
        that.close()
        __heartbeat.stop()
        net.ing = false
        net.reSendStop()
        net.reConnectCount--
        if (net.reConnectCount >= 0) {
            ___frame.cb.dispatchEvent("socketClose")
        } else {
            ___frame.cb.dispatchEvent("socketFail")
        }
    };
    this.close = function () {
        this.socket.onopen = null;
        this.socket.onmessage = null;
        this.socket.onerror = null;
        this.socket.onclose = null;
        this.socket.close()
        clearTimeout(that.timeout)
    }
    this.timeout = setTimeout(function () {
        //连接socket超时
        that.close();
        net.ing = false
        net.reSendStop()
        net.reConnectCount--
        if (net.reConnectCount >= 0) {
            ___frame.cb.dispatchEvent("socketTimeOut")
        } else {
            ___frame.cb.dispatchEvent("socketFail")
        }
    }, 2000)
}

