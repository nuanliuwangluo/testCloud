        this.mixedSortHandler = function (value, huPai, wfArr) {
            let __wf = wfArr && wfArr.length > 0 ? wfArr.toString() : '';
            var zArr = []
            for (var k = 0; k < __data.deskData.roomVo.mixedArr.length; k++) {
                for (var i = 0; i < value.length; i++) {
                    if (parseInt(__data.deskData.roomVo.mixedArr[k]) == parseInt(value[i])) {
                        zArr.push(value[i])
                    }
                }
            }

            if (__data.deskData.roomVo.mixedArr.indexOf(huPai) != -1) {
                zArr.push(huPai)
            }

            //富锦带混玩法
            // let __area = wfArr.some(function (value) {
            //     return value.toString() == '98'
            // });
            let __area = true;
            if (__area) {
                let __hzPlay = wfArr.some(function (value) {
                    return value.toString() == '12'
                });
                if (__hzPlay && zArr.length > 0) //如果混数量大于1   则使用混的数量    否则当一个混来计算
                    return zArr.length
                else if (__hzPlay)
                    return 1
                else {
                    if (parseInt(__data.deskData.roomVo.mixed) == 40) {
                        return (zArr.length >= 1) ? zArr.length * 10 : 10
                    } else {
                        return (zArr.length >= 1) ? zArr.length : 10
                    }
                }
            }

            return 10
        }

