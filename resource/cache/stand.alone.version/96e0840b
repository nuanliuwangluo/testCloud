// 背包信息
class BagData {

    static clear() { BagData._list = []; }

    static get list() {
        if (BagData._list.length < this._min) {
            let gap = this._min - BagData._list.length;
            for (let i = 0; i < gap; i++) {
                BagData._list.push({
                    type: 0,
                    number: 0
                });
            }
        }
        return BagData._list;
    }

    static getPropNumber(typeOrId) {
        let n = BagData.list.find((e) => {
            return typeOrId == e.type;
        })
        return n ? n.number : 0;
    }

    static addProp(propId, num) {
        let n = BagData.list.find((e1) => {
            return propId == e1.type
        })
        n.number += num;
    }

    static reduceProp(propId, num) {
        let n = BagData.list.find((e1) => {
            return propId == e1.type
        })
        n.number -= num;
    }

    static get gifts() { return ['501', '502', '503', '504', '505'] }
}
