                    var othervo = this.getPlayer(i);
                    if (!othervo) {
                        continue
                    } else if (othervo.id != __data.uid && othervo.position > vo.position) {
                        //另一个人放在最上方的位置
                        othervo.seat = othervo.position - vo.position + this.countSeatBaseValue + this.seatInitPosition;
                        this.addPlayer(othervo)
                    } else if (othervo.id != __data.uid && othervo.position < vo.position) {
                        //另一个人放在最上方的位置
                        othervo.seat = othervo.position + 4 - vo.position + this.countSeatBaseValue + this.seatInitPosition;
                        this.addPlayer(othervo)
                    }
                }
                this.addPlayer(vo)
            } else if (this.roomPlayer == 4) {
                trace("四人场游戏排位")
                var vo = this.getPlayer(__data.uid);
                if (!vo) {
                    return
                }
                //我的位置在最下方
                vo.seat = this.countSeatBaseValue + this.seatInitPosition;
                for (var i = this.seatInitPosition; i < this.seatInitPosition + 4; i++) {
                    var othervo = this.getPlayer(i);
                    if (othervo) trace(othervo.id, othervo.position)
                    if (!othervo) {
                        continue
                    } else if (othervo.id != __data.uid && othervo.position > vo.position) {
                        //另一个人放在最上方的位置
                        othervo.seat = othervo.position - vo.position + this.countSeatBaseValue + this.seatInitPosition;
                        this.addPlayer(othervo)
                    } else if (othervo.id != __data.uid && othervo.position < vo.position) {
                        //另一个人放在最上方的位置
                        othervo.seat = othervo.position + 4 - vo.position + this.countSeatBaseValue + this.seatInitPosition;
                        this.addPlayer(othervo)
                    }
                }
                this.addPlayer(vo)
            }
        }

        for (var i = this.countSeatBaseValue + this.seatInitPosition; i < this.countSeatBaseValue + this.seatInitPosition + 4; i++) {
            var vo = this.getPlayer(i);
            if (vo) {
                if (i == this.countSeatBaseValue + this.seatInitPosition) {
                    vo.seat_tag = 'down'
                } else if (i == this.countSeatBaseValue + this.seatInitPosition + 1) {
                    vo.seat_tag = 'right'
                } else if (i == this.countSeatBaseValue + this.seatInitPosition + 2) {
                    vo.seat_tag = 'up'
                } else if (i == this.countSeatBaseValue + this.seatInitPosition + 3) {
                    vo.seat_tag = 'left'
                }
            }
            if (vo) trace("id：" + vo.id, "seat：" + vo.seat, "position：" + vo.position)
            if (vo) trace("vo：", vo)
        }
        trace("执行游戏排位结束")
        trace("----------------------------------------------------------------------------")
    },

