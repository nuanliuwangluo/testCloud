window.__sound = window.__sound || {};
__sound.bgm = {};
/**
 * 背景音乐播放的位置
 */
__sound.bgm.position = 0;
/**
 * 是否正在播放音乐
 * @type {Boolean}
 */
__sound.isPlaying = false;
/**
 * App是否在前台运行  1 为在前台运行   0   为在后台运行
 */
__sound.isFrontStage = 1;
/**
 * 音乐是否开启    1 为开启  0 为关闭
 */
__sound.yyVolume = 1;
/**
 * 音效是否开启    1 为开启  0 为关闭
 */
__sound.yxVolume = 1;
/**
 * 音乐文件的有效路径前缀
 */
__sound.urlPrefix = "sound/";
/**
 * 上一次播放的背景音乐
 * @type {String}
 */
__sound.last_url = ""

__sound.musicUrl = ""
__sound.k = 0;

