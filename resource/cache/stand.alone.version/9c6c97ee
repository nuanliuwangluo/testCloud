    inc_show_shareBtnNumber() {
        let a = miniApi.getItem(__data.uid + ':show_shareBtnNumber')
        a = parseInt(a)
        a = Number.isFinite(a) ? a : 0;
        a++;
        miniApi.setItem(__data.uid + ':show_shareBtnNumber', a)

        if (a >= 10) {
            let a1 = {
                isLowShareValueUser: this.isLowShareValueUser ? 1 : 0,
                isLowShareWishUser: 1,
            }
            game.server.send(16028, JSON.stringify(a1))
        }
    },
    clr_show_shareBtnNumber() {
        miniApi.setItem(__data.uid + ':show_shareBtnNumber', 0)

        let a = {
            isLowShareValueUser: this.isLowShareValueUser ? 1 : 0,
            isLowShareWishUser: 0,
        }
        game.server.send(16028, JSON.stringify(a))
    },
    get isLowShareValueUser() {
        let c = this.shareGroupItem;
        return c.lowValueGnum >= 3;
    },
    get isLowShareWishUser() {
