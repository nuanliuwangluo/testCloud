    shareGroupFailPrompt() {
        // 分享失败，请分享到不同的群
        if (window.wx && window.wx.showModal) {
            wx.showModal({
                content: '分享失败，请分享到不同的群',
                showCancel: true,
                cancelText: '取消',
                cancelColor: '#ff0000',
                confirmText: '分享',
                confirmColor: '#000000',
                success: function (res) {
                    // trace('取消' + JSON.stringify(res))
                    if (res.confirm == true) {
                        miniApi.share(miniApi.shareParamsInfo)
                    } else {
                        miniApi.shareGroupClickCallback = null;
                    }
                    // else if (res.cancel == true && cancelCallback) cancelCallback()
                },
                fail: function (res) {
                    // trace('确定')
                },
                complete: function (res) {
                    // trace('complete')
                },
            })
        } else {
            __showScene.show_prompt_select('分享失败，请分享到不同的群', () => {
                miniApi.share(miniApi.shareParamsInfo)
            }, null, '分享', '取消')
        }
    },
    async shareGroupCallback(opengid) {
        if (!miniApi.shareGroupClickCallback) return;
        await game.server.send(16027)
        let c = __data.shareVideoRule.shareGroupItem;

        if (c.dealgid[opengid]) {
            this.shareGroupFailPrompt()
        } else {
            c.gday[opengid] = c.gday[opengid] || {};
            c.gday[opengid][__tool.getDayCount(Date.now())] = __data.shareVideoRule.invite_playerCount
            let a = Object.values(c.gday[opengid])
            if (a.length <= 3) {
                miniApi.shareGroupClickCallback && miniApi.shareGroupClickCallback()
                __data.shareVideoRule.clr_show_shareBtnNumber()
            }
            else if (a[0] != a.at(-1)) {
                // else if (a[0] != a[a.length - 1]) {
                c.gday[opengid] = {};
                miniApi.shareGroupClickCallback && miniApi.shareGroupClickCallback()
                __data.shareVideoRule.clr_show_shareBtnNumber()
            }
            else if (a[0] == a.at(-1)) {
                // else if (a[0] == a[a.length - 1]) {
                c.dealgid[opengid] = 1;
                c.lowValueGnum++;

                if (c.lowValueGnum >= 3) {
                    // 通知后台存低价值用户标志
                    let a = {
                        isLowShareValueUser: 1,
                        isLowShareWishUser: this.isLowShareWishUser ? 1 : 0,
                    }
                    game.server.send(16028, JSON.stringify(a))
                }
                this.shareGroupFailPrompt()
            }
        }

        miniApi.setItem(__data.uid + ":groupShareOB", JSON.stringify(c))
        miniApi.shareGroupClickCallback = null
    },
    test_clear_lowValueUser() {
        let c = this.shareGroupItem;
        if (c.lowValueGnum >= 3) {
            let pgn = c['playerGIN'] || 0
            if (pgn != __data.shareVideoRule.invite_playerCount) {
                c.lowValueGnum = 0;
                // 通知后台低价值用户变更
                let a = {
                    isLowShareValueUser: 0,
                    isLowShareWishUser: this.isLowShareWishUser ? 1 : 0,
                }
                game.server.send(16028, JSON.stringify(a))
            }
        }
        c['playerGIN'] = __data.shareVideoRule.invite_playerCount
        miniApi.setItem(__data.uid + ":groupShareOB", JSON.stringify(c))
    },
