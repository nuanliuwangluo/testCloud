var __voice = __voice || { myUid:null }

__voice.protocol = 'wss://'


__voice.readyPlayUserId = null
__voice.readyPlayTime = null
    //录音允许的最大时间
__voice.allowMaxRecordTime = 30000
__voice.readyPlayVoice = function(userId) {
    __voice.readyPlayUserId = userId;
    document.body.addEventListener('touchend', __voice.touchendEvent)
}
__voice.touchendEvent = function(e) {

    if (__voice.readyPlayUserId) {
        __voice.playVoice(__voice.readyPlayUserId)
    }
    __voice.readyPlayUserId = null
    __voice.readyPlayTime = null
    document.body.removeEventListener('touchend', __voice.touchendEvent)
}

__voice.startRecordTime = null
__voice.maxRecordTimer = null
__voice.startRecord = function() {
    __voice.startRecordTime = Date.now()

    __voice.stopVoice()
    __sound.pause()

    __voice.playing = false;
    Laya.SoundManager.stopAllSound();
    if (__voice.playingInfo && __voice.playingInfo.userId) game.cb.dispatchEvent('play_voice_complete', [__voice.playingInfo.userId])

    if (game.runScene == 'wx') { trace('微信开始录音');
        wx.startRecord(); } else if (game.runScene == 'mw') { trace('默往开始录音');
        MostOneJSApis.startRecord() }

    __voice.maxRecordTimer = setTimeout(function() {
        __voice.stopRecord()
    }, __voice.allowMaxRecordTime)
}
__voice.stopRecord = function() {
    clearTimeout(__voice.maxRecordTimer)
    if (Date.now() - __voice.startRecordTime < 1000) {
        trace('少于1秒，1.5秒后自动停止录音', game.runScene)
            // 如果录音过短 startRecord后1.5s再stopRecord 保证stopRecord不崩掉
        setTimeout(function() {
            if (game.runScene == 'wx') {
                wx.stopRecord({ success: function(res) {} })
            } else if (game.runScene == 'mw') { MostOneJSApis.stopRecord() }

            __sound.working();
        }, 1500)
    } else {
        trace('主动停止录音', game.runScene)
        if (game.runScene == 'wx') {
            wx.stopRecord({
                success: function(res) {
                    var localId = res.localId;
                    trace('微信停止录音，开始上传...localId', localId)
                    wx.uploadVoice({
                        localId: localId, // 需要上传的音频的本地ID，由stopRecord接口获得
                        isShowProgressTips: 0, // 默认为1，显示进度提示
                        success: function(res) {
                            var serverId = res.serverId; // 返回音频的服务器端ID
                            trace('录音服务器serverId', serverId);

                            VoiceemitAmr(serverId);
                        }
                    });
                }
            });
        } else if (game.runScene == 'mw') { trace('默往停止录音');
            MostOneJSApis.stopRecord() }

        __sound.working();
    }
}

__voice.voiceInfoArray = []
__voice.playing = false
__voice.addQueue = function(info) {
    __voice.voiceInfoArray.push(info);
    // __voice.voiceInfoArray[info.userId] = info;
    // info.userId != __data.ivo.id && game.cb.dispatchEvent(__eh+'have_new_voice', [info.userId])
}
// 播放中的音频信息
__voice.playingInfo = null
// 播放结束计时器
__voice.endVoiceTimer = null
__voice.playVoice = function(userId) {
    /*
    音频格式: base64 格式的 AMR
    完整示例音频: https://cdn.ronghub.com/voice-amr-base64.json
    */
    // 只能播放一个声音 如果有在播放 就种植掉
    if (!__voice.voiceInfoArray.length) { __sound.working(); }
    if (__voice.playing || !__voice.voiceInfoArray.length) { return }

    __voice.stopVoice();

    __voice.playingInfo = __voice.voiceInfoArray.shift();
    // __voice.playingInfo = __voice.voiceInfoArray[userId];
    // __voice.voiceInfoArray[userId] = null;
    if (!__voice.playingInfo) return;
    __sound.pause()
    __voice.playing = true;

    game.cb.dispatchEvent('play_voice_start', [__voice.playingInfo.userId]);

    if(window.APP_PACKAGE && window.APP_PACKAGE == window.ORIGIN_APP){
        AppBridge.playVoice("https://" + game.voiceConfig.ip + "/MessageServer/upload/" + __voice.playingInfo.mp3Url, ()=>{
            __voice.playing = false
            game.cb.dispatchEvent('play_voice_complete', [__voice.playingInfo.userId])
            __voice.playVoice();
        });
    }else{
        Laya.SoundManager.setSoundVolume(1);
        Laya.SoundManager.playSound("https://" + game.voiceConfig.ip + "/MessageServer/upload/" + __voice.playingInfo.mp3Url, 1);
        setTimeout(function() {
            __voice.playing = false
            game.cb.dispatchEvent('play_voice_complete', [__voice.playingInfo.userId])
            __voice.playVoice();
        }, __voice.playingInfo.duration * 1000)
    }
}

// 停止当前播放的语音
__voice.stopVoice = function() {
    if (__voice.playing && __voice.playingInfo) {
        if (__voice.playingInfo.userId == __voice.myUid) {
            Laya.SoundManager.stopSound(__voice.playingInfo.mp3Url)
            __voice.playing = false
            game.cb.dispatchEvent('play_voice_complete', [__voice.playingInfo.userId])
            __sound.working()
        } else {

        }
    }
}

// 语音播放正常结束
__voice.endVoice = function() {
    __voice.playing = false
    clearTimeout(__voice.endVoiceTimer)
    game.cb.dispatchEvent('play_voice_complete', [__voice.playingInfo.userId])
    // 播放完毕 再 检查是否有新消息 进行新消息 提示
    if (__voice.voiceInfoArray[__voice.playingInfo.userId]) game.cb.dispatchEvent(__eh + 'have_new_voice', [__voice.playingInfo.userId])
}







































