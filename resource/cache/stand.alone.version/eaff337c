        // body = body.concat(___frame.byte.stringToBytes(net.uid))
        // body = body.concat(___frame.byte.stringToBytes(this.gameid))
        // body = body.concat(this.body)
        // var length = body.length;
        var msg = [___frame.byte.byteToBytes(id_)];
        // msg = msg.concat(___frame.byte.intToBytes(net.head))
        // msg = msg.concat(___frame.byte.intToBytes(length))
        msg = msg.concat(this.body)
            // net.socket.postToServer(sendMsgKey, id_, msg)
        net.socket.postToServer(id_, msg)
        net.noPrintIDArr.indexOf(id_) == -1 && trace("%c发送>>>-ID-" + id_ + "-length-" + this.body.length, "color:#039058;font-weight:bold")
        net.noPrintIDArr.indexOf(id_) == -1 && trace("发送内容：" + id_ + " " + this.content)
        clear()
    }

    function clear(params) {
        that.body.splice(0, that.body.length)
        that.content = ""
    }

    this.writeInt = function(value) {
        that.content += value + " "
        that.body = that.body.concat(___frame.byte.intToBytes(value))
    }

    this.writeLong = function(value) {
        that.content += value + " "
        that.body = that.body.concat(___frame.byte.longToBytes(value))
    }

    this.writeByte = function(value) {
        that.content += value + " "
        that.body = that.body.concat(___frame.byte.byteToBytes(value))
    }

    this.writeString = function(value) {
        value = value.toString()
        that.content += value + " "
        that.body = that.body.concat(___frame.byte.stringToBytes(value))
    }

    for (var name in this) {
        if (name.indexOf("send_") != -1) {
            var func = this[name];
            var id = name.replace("send_", "")
            if (net.sendList[id]) throw new Error("send msg " + id + " 已存在");
            net.sendList[id] = func;
            net.sendList[id].msg = this;
        }
    }
}

