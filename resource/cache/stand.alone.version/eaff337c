            // game.cb.dispatchEvent('no_socket')
    }
    this.registeSendList = function(params____________) {
        for (var i = 0; i < arguments.length; i++) {
            new arguments[i](this)
        }
    }
    this.registeReadList = function(params____________) {
        for (var i = 0; i < arguments.length; i++) {
            new arguments[i](this)
        }
    }
    this.send = function(params____________) {
        if (!this.ing) { console.warn('SOCKET 未实例化... or 未连接...'); return; }
        if (!arguments.length) throw new Error("参数最少传入一个消息ID")
        var id = arguments[0]
        if (!this.sendList[id]) {
            // throw new Error("send msg "+id+" 不存在")
            console.warn("send msg " + id + " 不存在")
            return
        }
        var params = [];
        //index 从1 开始 默认删除id
        for (var i = 1; i < arguments.length; i++) {
            params.push(arguments[i])
        }
        this.sendList[id].apply(this.sendList[id].msg, params)
        this.sendList[id].msg.send(arguments[0])
        return true
    }
    this.reSendTime = null
    this.reSendStart = function() {
        clearInterval(this.reSendTime)
        this.reSendTime = setInterval(this.reSendServer, 2000)
    }
    this.reSendServer = function() {
        for (var id in that.reSendList) {
            trace(id, that.reSendList[id])
            that.socket.reSend(id, that.reSendList[id])
        }
    }
    this.reSendStop = function() {
        clearInterval(this.reSendTime)
    }
}
___frame.VoiceSocket = function(protocol, ip, port, net) {
    var that = this;
    this.socket = new WebSocket(protocol + ip + ":" + port);
    this.socket.socketid = this.socketid;
    this.socket.binaryType = "arraybuffer";
    this.aDataArray = [];
    trace("开始连接语音服务器：", protocol + ip + ":" + port)
    this.socket.onopen = function() {
        net.ing = true
        net.reConnectCount = 3;
        clearTimeout(that.timeout);
        __voiceHeartbeat.start()
            // ___frame.cb.dispatchEvent("socketConnect")
        net.reSendStart()
        trace("语音服务器连接成功.")
        net.send(2, ___frame.voiceConfig.appKey, __voice.myUid, ___frame.voiceConfig.token)
    };
    this.socket.onmessage = function(message) {
        // __voiceHeartbeat.reset();
        var barray = new Int8Array(message.data);
        for (var i = 0; i < barray.length; i++) {
            that.aDataArray.push(barray[i]);
        }
        that.read()
    };
    var serverid = 0;
    var length = 0;
    var key = 0;
    var body = null;
    this.read = function() {
        //length id1 id2 uid 后面都是变动的需求了
        //key服务判断 length长度 id1 服务标志 id2服务消息号解析用 uid当前socket玩家id
        if (that.aDataArray.length >= 8) {
            length = ___frame.byte.readInt(that.aDataArray);
        }
        if (length > 0) {
            if (length <= this.aDataArray.length) {
                body = this.aDataArray.splice(0, length)
                serverid = ___frame.byte.readByte(body);
                net.noPrintIDArr.indexOf(serverid) == -1 && trace("%c接受<<<-ID-" + serverid + "-length-" + length, "color:#039058")
                this.manageMessage(serverid, body, net);
                // if(serverid == 99 || serverid == 88){
                //     this.manageMessage(serverid, body, net);
                // }else if(!net.hasDealMsg[nmk] && net.readMsgKey == nmk){//这个服务是否已经处理
                //     this.manageMessage(serverid, body, net);
                //     net.hasDealMsg[nmk] = 1;
                //     net.send(99, nmk)
                //     net.readMsgKey++;
                // }else if(net.hasDealMsg[nmk]){
                //     net.send(99, nmk)
                // }
            }
            key = length = 0;
            this.read();
        }
    }
    this.manageMessage = function(serverid, info, server) {
            if (net.readList[serverid]) {
                net.readList[serverid].msg.body = info
                try {
                    net.readList[serverid].apply(net.readList[serverid].msg)
                } catch (e) {
                    console.error(e)
                }
            } else { net.noPrintIDArr.indexOf(serverid) == -1 && trace("msg read " + serverid + " 不存在") }
        }
        // this.postToServer = function(sendMsgKey, serverid, value){
    this.postToServer = function(serverid, value) {
        var sendByte = new Int8Array(value.length);
        for (var i = 0; i < value.length; i++) {
            sendByte[i] = value[i];
        }
        this.send(sendByte.buffer)
            // if(serverid != 99 && serverid != 998){
            //     net.reSendList[sendMsgKey] = sendByte.buffer;
            // net.reSendStart()
            // }
    }
    this.reSend = function(id, buffer) {
        trace('重发消息: ' + id)
        this.send(buffer)
    }
    this.send = function(buffer) {
        if (!this.socket) {
            console.warn("服务器未连接。。。")
        } else if (this.socket.readyState != 1) {

        } else {
            this.socket && this.socket.send(buffer);
        }
    }
    this.socket.onerror = function(e) {
        trace('<> ' + JSON.stringify(e))
        that.close()
        __voiceHeartbeat.stop()
        net.ing = false
        net.reSendStop()
        net.reConnectCount--
            setTimeout(that.voiceSocketConnect, 5000)
    };
    this.socket.onclose = function() {
        that.close()
        __voiceHeartbeat.stop()
        net.ing = false
        net.reSendStop()
        net.reConnectCount--
        setTimeout(that.voiceSocketConnect, 5000)
    };
    this.close = function() {
        trace('语音服务器已断开.')
        this.socket.close()
        this.socket.onopen = null;
        this.socket.onmessage = null;
        this.socket.onerror = null;
        this.socket.onclose = null;
        clearTimeout(that.timeout)
    }
    this.timeout = setTimeout(function() {
        trace('语音服务器连接超时')
        //连接socket超时
        that.close();
        net.ing = false
        net.reSendStop()
        net.reConnectCount--
        setTimeout(that.voiceSocketConnect, 5000)
    }, 6666)

    this.voiceSocketConnect = function() {
        // game.server.send(993)
        // game.voiceServer.connect(game.voiceConfig.ip, game.voiceConfig.port)
    }
}

___frame.VoiceMsgSend = function VoiceMsgSend(net) {
    var that = this
    this.body = [];
