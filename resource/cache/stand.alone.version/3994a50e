class CheckUpgradeRank {
    static check(result, oldCup, newCup) {
        if (!result) { return false; }
        // 必须胜利才有  失败没有
        let oldRank = RankUtils.getRankLvDataByScore(oldCup, __data.uid, HallPlay.lastCityId);
        let newRank = RankUtils.getRankLvDataByScore(newCup, __data.uid, HallPlay.lastCityId);

        let oldName = RankUtils.getCnReg(oldRank.name);
        let newName = RankUtils.getCnReg(newRank.name);

        // 确实提升段位了， 今天还没有弹出
        if (oldName != newName && !RankUtils.getTodayRecord(newName)) {
            __showScene.show_gameMain_uplv(newRank, HallPlay.lastCityId);
            RankUtils.setTodayRecord(newName);
            return true;
        }

        return false;
    }


    static checkQs(result, oldCup, newCup) {
        if (!result) { return false; }
        // 必须胜利才有  失败没有
        let oldRank = RankUtils.getRankLvDataByScore(oldCup, __data.uid, HallPlay.lastCityId);
        let newRank = RankUtils.getRankLvDataByScore(newCup, __data.uid, HallPlay.lastCityId);

        let oldName = RankUtils.getCnReg(oldRank.name);
        let newName = RankUtils.getCnReg(newRank.name);

        // 提升段位了  且可以领取雀神之路奖励
        if (oldName != newName && __data.queShenRoad.isRed) {
            __showScene.show_gameMain_uplv(newRank, HallPlay.lastCityId, true);
            RankUtils.setTodayRecord(newName);
            return true;
        }

        return false;
    }


    static share() {
        if (!__data.deskData.roomVo.smallResultData) { return false; }
        // 触发3倍数连胜分享
        if (__data.deskData.roomVo.smallResultData.keepWinNumber >= gameConfig.keepWinRule) {
            if (__data.deskData.roomVo.smallResultData.keepWinNumber == 3 && !LocalUtils.getByToday(ResultPanelManager.KEEP_WIN_THREE_TIMES)) {
                LocalUtils.saveByToday(ResultPanelManager.KEEP_WIN_THREE_TIMES, 'true');
                game.scene.add(MahjongResultShare, [__data.deskData.roomVo.smallResultData.keepWinNumber])
                return true;
            } else if (__data.deskData.roomVo.smallResultData.keepWinNumber == 5) {
                game.scene.add(MahjongResultShare, [__data.deskData.roomVo.smallResultData.keepWinNumber])
                return true;
            } else if (__data.deskData.roomVo.smallResultData.keepWinNumber == 7) {
                game.scene.add(MahjongResultShare, [__data.deskData.roomVo.smallResultData.keepWinNumber])
                return true;
            } else if (__data.deskData.roomVo.smallResultData.keepWinNumber == 9) {
                game.scene.add(MahjongResultShare, [__data.deskData.roomVo.smallResultData.keepWinNumber])
                return true;
            }
        }
        return false;
    }
}


