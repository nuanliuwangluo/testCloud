    }

    updateWords(cups) {

        let rd = RankUtils.getRankLvDataByScore(__data.hashCityLevelCup[HallPlay.lastCityId].cup, __data.uid, HallPlay.lastCityId);
        if (cups > 0) {
            this.txt_tt_cup.text = `本局+${Math.abs(cups)}`;
            this.txt_tt_cup.color = '#ffd922';
            // HtmlTextUtils.text(
            //     this.txt_uplv_info, { align: 'center', valign: 'top', stroke: 4, strokeColor: '#000000', fontSize: 30, bold: true, width: this.frame_info.width, color: '#ffffff' },
            //     '再赢&nbsp;', { color: '#e8ce72' },
            //     rd.toNextLevelNeedCup - (__data.hashCityLevelCup[HallPlay.lastCityId].cup - rd.minCup), { color: '#fe7f7f' },
            //     '&nbsp;奖杯升段', { color: '#e8ce72' }
            // )
        } else {
            this.txt_tt_cup.text = `本局-${Math.abs(cups)}`;
            this.txt_tt_cup.color = '#aaaebe';
            // HtmlTextUtils.text(
            //     this.txt_uplv_info, { align: 'center', valign: 'top', stroke: 4, strokeColor: '#000000', fontSize: 30, bold: true, width: this.frame_info.width, color: '#ffffff' },
            //     '再输&nbsp;', { color: '#e8ce72' },
            //     __data.hashCityLevelCup[HallPlay.lastCityId].cup - rd.minCup + 1, { color: '#fe7f7f' },
            //     '&nbsp;奖杯降段', { color: '#e8ce72' }
            // )
        }
        // 不能升段 或者掉段了
        if (rd.toNextLevelNeedCup == 0 || (rd.minCup == 0 && cups <= 0)) {
            // HtmlTextUtils.text(
            //     this.txt_uplv_info, { align: 'center', valign: 'top', fontSize: 30, bold: true, width: this.frame_info.width, color: '#ffffff' },
            //     '', { color: '#e8ce72' }
            // )
        }
        Laya.timer.callLater(this, this.relocationUI);
    }

    relocationUI() {
        let space = 20;
        let list_w = this.list.array.length ? this.list.width : 0
        let w = this.txt_tt_cup.width + this.txt_base_cup.width + list_w + this.txt_end.width + 8;

        let start_x = this.width - w >> 1;
        this.txt_tt_cup.x = start_x;
        this.txt_base_cup.x = this.txt_tt_cup.x + this.txt_tt_cup.width + 8;
        this.list.x = this.txt_base_cup.x + this.txt_base_cup.width;
        this.txt_end.x = this.list.x + this.list.width;

        this.txt_uplv_info.x = this.width - this.txt_uplv_info.displayWidth >> 1;
    }

    initText() {
        if (!this.txt_cup) {
            let numbers = {};
            for (var i = 0; i < 10; i++) numbers[i] = "local/cupNum/cupNum/" + i + ".png";

            this.txt_cup = new ImageFont(numbers, 'center', 'center', -2);
            this.cup_c.addChild(this.txt_cup);
        }
    }

    onEnable() {
        this.initUI();
    }

    initUI() {
        this.dropAni.gotoAndStop(0);
        this.upgradings = [];
        this.initText();
        // this.hideInfo();
        this.showInfo();
        game.utils.remove(this._sprite);
        SkinUtils.setSkin(this.signUI, '');
        SkinUtils.setSkin(this.low_signUI, '');
        this.light.alpha = 0;

        this.mk = this.mk || new Laya.Sprite();
        this.mk.graphics.drawRect(0, 0, 420, 400, '#0');
        this.mk.size(420, 400);
        this.ui.mask = null;
    }


    ready(result) {
        SkinUtils.setSkin(this.frame, result ? 'cdn/mahjong_result/mahjong_result/img_r_dwa.png' : 'cdn/mahjong_result/mahjong_result/img_r_dwb.png');
    }

    init(cup, getCup) {
        this.initUI();
        this.clearTween();

        this.initCup = cup;
        // 排位数据
        this.rankData = RankUtils.getRankLvDataByScore(cup, __data.uid, HallPlay.lastCityId);

        this.upCupText(cup, this.rankData);
        // this.rect.setTo(0, 0, this.cup_c.width, this.cup_c.height);

        this.updatelocation();

        // this.lineComponent.setCup(getCup, this.rankData.toNextLevelNeedCup == 0);
        // this.lineComponent.setProgress(cup - this.rankData.minCup, this.rankData.toNextLevelNeedCup);

        this.updateRankIcons(this.rankData);

        this.channelUI();
    }


    clearTween() {
        this.tween && this.tween.clear();
        this.dropTween && this.dropTween.clear();
        this.spTween && this.spTween.clear();
        this.iconTween && this.iconTween.clear();
    }

    upCupText(cup, data) {
        data = data || RankUtils.getRankLvDataByScore(cup, __data.uid, HallPlay.lastCityId);
        this.txt_cup_line.text = `${cup - data.minCup}/${data.toNextLevelNeedCup}`;
        this.barRect.width = (cup - data.minCup) / data.toNextLevelNeedCup * this.lineBar.width;
        this.txt_cup.text = cup - data.minCup;
        this.updatelocation();
    }

    channelUI(rd) {
        rd = rd || this.rankData;
        this.low_cup_c.visible = false;
        this.frame.visible = false;
        this.cup_c.visible = false;
        // 已经雀神了
        if (rd.toNextLevelNeedCup == 0) {
            this.frame.visible = true;
            this.cup_c.visible = true;
        } else {
            this.low_cup_c.visible = true;
            // this.low_signUI.visible = false;
        }
    }

    to(cup, complete) {
        this._complete = complete;
        this.targetCup = cup;
        this.tweenCup = this.initCup;
        this.tween = this.tween || new Laya.Tween();
        this.dropTween = this.dropTween || new Laya.Tween();
        this.channelAni();
        // this._enlargeComplete();
    }

    channelAni() {
        // 增长 减少音效
        if (this.targetCup > this.initCup) {
            // 已经雀神了
            if (this.rankData.toNextLevelNeedCup == 0) {
                Laya.Tween.to(this.cupUI, { scaleX: 1.2, scaleY: 1.2 }, 100);
                this.tween.to(this.txt_cup, { scaleX: 1.2, scaleY: 1.2 }, 100, null, Laya.Handler.create(this, this._enlargeComplete));
            } else {
                this._enlargeComplete();
            }
        } else if (this.targetCup == this.initCup) {
            this._enlargeComplete();
        } else {
            // 已经雀神了
            if (this.rankData.toNextLevelNeedCup == 0) {
                SkinUtils.setSkin(this.signUI, 'cdn/mahjong_result/mahjong_result/img_jt22.png');
                this._enlargeComplete();
                // this.tween.to(this.txt_cup, { y: 50, alpha: 0 }, 300, Laya.Ease.expoIn, Laya.Handler.create(this, this._enlargeComplete));
            } else {
                this._enlargeComplete();
            }
        }
    }

    _enlargeComplete() {
        // 增长 减少音效
        if (this.targetCup > this.initCup) {
            __sound.gameSound("cupup");
            this.tween.to(this, { tweenCup: this.targetCup }, 1500, null, new Laya.Handler(this, this._toComplete));
            this.tween.update = Laya.Handler.create(this, this._onUpdateCup, null, false);
        } else if (this.targetCup == this.initCup) {
            this.tweenCup = this.targetCup;
            this._onUpdateCup();
            this._toComplete();
        } else if (this.targetCup < this.initCup) {
            __sound.gameSound("cupdown");
            // this.tweenCup = this.targetCup;
            this.dropTween.to(this, { tweenCup: this.targetCup }, 1500, null, new Laya.Handler(this, this._toComplete));
            this.dropTween.update = Laya.Handler.create(this, this._onUpdateCup, null, false);
            // this._onUpdateCup();
            // this.txt_cup.y = this.cup_c.height / 2 - 50;
            // this.tween.to(this.txt_cup, { y: this.cup_c.height / 2, alpha: 1 }, 100, Laya.Ease.expoIn, Laya.Handler.create(this, this._downComplete));
        }
    }

    _toComplete() {
        this.clearSignSkin();
        Laya.Tween.to(this.cupUI, { scaleX: 1, scaleY: 1 }, 100);
        this.tween.to(this.txt_cup, { scaleX: 1, scaleY: 1 }, 100, Laya.Ease.expoOut, Laya.Handler.create(this, this._growComplete));
    }

    _downComplete() {
        // this.clearSignSkin();
        // Laya.timer.once(200, this, this.clearSignSkin);
        Laya.Tween.to(this.cupUI, { scaleX: 1, scaleY: 1 }, 100);
        this.tween.to(this.txt_cup, { scaleX: 1, scaleY: 1 }, 100, Laya.Ease.expoOut, Laya.Handler.create(this, this._growComplete));
    }

    _growComplete() {
        this.updatelocation();
        Laya.timer.once(300, this, this._doComplete);
    }

    _doComplete() {
        this._complete && this._complete();
    }

    clearSignSkin() {
        SkinUtils.setSkin(this.signUI, '');
        SkinUtils.setSkin(this.low_signUI, '');
    }

    updateSignSkin() {
        if (this.tweenCup > this.initCup) {
            SkinUtils.setSkin(this.signUI, 'cdn/mahjong_result/mahjong_result/img_jt11.png');
            SkinUtils.setSkin(this.low_signUI, 'cdn/mahjong_result/mahjong_result/img_jt11.png');
        } else if (this.tweenCup == this.initCup) {
            SkinUtils.setSkin(this.signUI, '');
            SkinUtils.setSkin(this.low_signUI, '');
        } else {
            SkinUtils.setSkin(this.signUI, 'cdn/mahjong_result/mahjong_result/img_jt22.png');
            SkinUtils.setSkin(this.low_signUI, 'cdn/mahjong_result/mahjong_result/img_jt22.png');
        }
    }

    _onUpdateCup() {
        this.tweenCup = Math.floor(this.tweenCup);
        let rankData = RankUtils.getRankLvDataByScore(this.tweenCup, __data.uid, HallPlay.lastCityId);
        this.upCupText(this.tweenCup, rankData);

        // this.lineComponent.setProgress(this.tweenCup - rankData.minCup, rankData.toNextLevelNeedCup);
        // this.lineComponent.setLine(this.lineState);
        this.updateSignSkin();
        if (rankData.name != this.rankData.name && this.upgradings.indexOf(rankData.name) == -1) {
            this.upgradings.push(rankData.name);
            this.upgradingRank(rankData);
            this.channelUI(rankData);
        }
    }

    updatelocation() {
        this.txt_cup.x = this.cupUI.x + this.cupUI.width / 2 * this.cupUI.scaleX + this.txt_cup.width / 2 + 5;
        this.txt_cup.y = this.cup_c.height / 2;
        this.cup_c.width = this.txt_cup.x + this.txt_cup.width / 2;
        this.cup_c.x = this.centerx - this.cup_c.width / 2;
        try {
            let _signW = Laya.loader.getRes('cdn/mahjong_result/mahjong_result/img_jt11.png').width;
            this.signUI.x = this.txt_cup.x + this.txt_cup.width / 2 + _signW / 2;
        } catch (e) { }
    }

    relocationTxt(cup) {
        this.upCupText(cup);
        this.upCupText(this.initCup);
    }

    upgradingRank(rankData) {
        if (this.isUpgrading) { return }
        if (this.targetCup > this.initCup) { // 增长
            __sound.gameSound("levelup");
            this.light.alpha = 1;
            this.isUpgrading = true;
            this.lightAni.play(0, false);
            this.lightAni.on(Laya.Event.COMPLETE, this, this._lightAniComplete);
            this.updateRankIcons(rankData);
        } else if (this.targetCup < this.initCup) { // 减少音效
            __sound.gameSound("regret");
            this.ui.mask = this.mk;
            this._sprite = this._sprite || new Laya.Sprite();
            this._sprite.texture = this.icons.drawToTexture(this.mk.width, this.mk.height, 0, 0);
            this.icons.parent.addChild(this._sprite).pos(0, 0);
            this.icons.pos(0, -this.mk.height);
            this.spTween = this.spTween || new Laya.Tween();
            this.iconTween = this.iconTween || new Laya.Tween();
            this.spTween.to(this._sprite, { y: this.mk.height }, 200);
            this.iconTween.to(this.icons, { y: 0 }, 200, null, Laya.Handler.create(this, this._dropComplete));
            this.updateRankIcons(rankData);

            // this.updateRankIconsCopy(rankData);
            // this.dropAni.play(0, false);
            // this.dropAni.on(Laya.Event.COMPLETE, this, this._dropComplete);
        }
    }

    _dropComplete() {
        this.ui.mask = null;
        game.utils.remove(this._sprite);
        this.dropAni.gotoAndStop(0);
        let rankData = RankUtils.getRankLvDataByScore(this.tweenCup, __data.uid, HallPlay.lastCityId);
        this.updateRankIcons(rankData);
        this._downComplete();
    }

    _lightAniComplete() {
        this.light.alpha = 0;
        this.isUpgrading = false;
    }

    updateRankIcons(rankData) {
        // icon
        SkinUtils.setSkin(this.icon, `cdn/rank_sign/img_rank_sign_${rankData.iconIndex}.png`);
        SkinUtils.setSkin(this.rankBg, `local/lvNameBg/1/rank_${rankData.iconIndex}.png`);
        this.txt_rankName.text = rankData.name;
        // 雀神不显示这个
        if (rankData.toNextLevelNeedCup == 0) {
            SkinUtils.setSkin(this.cupUI, `local/lvNameBg/1/img_qsjb.png`);
            SkinUtils.setSkin(this.low_cupUI, `local/lvNameBg/1/img_qsjb.png`);
            this.txt_rankLevel.text = '';
            this.crown.visible = true;
        } else {
            SkinUtils.setSkin(this.cupUI, `cdn/mahjong_result/mahjong_result/img_jb.png`);
            SkinUtils.setSkin(this.low_cupUI, `cdn/mahjong_result/mahjong_result/img_jb.png`);
            this.txt_rankLevel.text = rankData.level;
            this.crown.visible = false;
        }
    }

    updateRankIconsCopy(rankData) {
        // icon
        SkinUtils.setSkin(this.icon_copy, `cdn/rank_sign/img_rank_sign_${rankData.iconIndex}.png`);
        SkinUtils.setSkin(this.rankBg_copy, `local/lvNameBg/1/rank_${rankData.iconIndex}.png`);
        this.txt_rankName_copy.text = rankData.name;
        // 雀神不显示这个
        if (rankData.toNextLevelNeedCup == 0) {
            SkinUtils.setSkin(this.cupUI, `local/lvNameBg/1/img_qsjb.png`);
            SkinUtils.setSkin(this.low_cupUI, `local/lvNameBg/1/img_qsjb.png`);
            this.txt_rankLevel_copy.text = '';
            this.crown_copy.visible = true;
        } else {
            SkinUtils.setSkin(this.cupUI, `cdn/mahjong_result/mahjong_result/img_jb.png`);
            SkinUtils.setSkin(this.low_cupUI, `cdn/mahjong_result/mahjong_result/img_jb.png`);
            this.txt_rankLevel_copy.text = rankData.level;
            this.crown_copy.visible = false;
        }
    }

    set lineState(value) {
        this._lineState = value;
        // this.lineComponent.setLine(this.lineState);
    }
    get lineState() { return this._lineState; }
}

class FlowAniScript extends Laya.Script {
    start(point, callback) {
        this.callback = callback;
        this.owner.visible = true;
        Laya.Tween.to(this.owner, { x: point.x, y: point.y }, 200, null, Laya.Handler.create(this, this._moveComplete));
    }

    _moveComplete() {
        Laya.Tween.to(this.owner, { alpha: 0 }, 100, null, Laya.Handler.create(this, this._disappearComplete));
    }

    _disappearComplete() {
        this.callback && this.callback();
        this.owner.alpha = 1;
        this.owner.visible = false;
    }
}

