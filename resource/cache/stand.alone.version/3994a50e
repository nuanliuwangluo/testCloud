    // 奖杯多多
    static async moreCup() {
        let rs = LocalUtils.getByToday(this.RANK_MORE_CUP_TODAYISSHOW);

        // 结算数据
        let rd = __data.deskData.roomVo.smallResultData;
        if (!rd) { return false; }
        // 输赢结果
        let result = rd.myResult;

        // 输了 不继续处理了
        if (!result) {
            return false;
        }

        // 不是vip的情况下  考虑弹窗
        if (!__data.vip.isVip) {

            // // 今日弹出过此界面
            // if (rs) { return false; }

            // 赢了  且增加的奖杯 可以升段 弹出提示
            let cup = __data.hashCityLevelCup[HallPlay.lastCityId].cup;
            let r_d = RankUtils.getRankLvDataByScore(cup);

            // 非VIP有富贵竹：（获得奖杯数/(1+60%)）*50%>=升段所差奖杯，则弹出奖杯多多弹窗
            if (rd.bamboo) {
                let upNeed = r_d.toNextLevelNeedCup - (cup - r_d.minCup);
                if (r_d.toNextLevelNeedCup > 0 && Math.ceil(Math.floor(rd.cup / (1 + 0.6)) * 0.5) >= upNeed) {
                    if (__data.vip.addUpToLoginDayNum <= 3) {
                        if (rs) { return false; }
                        LocalUtils.saveByToday(this.RANK_MORE_CUP_TODAYISSHOW, 'true');
                        game.scene.add(RankCupMore);
                        return true;
                    } else if (__data.vip.addUpToLoginDayNum > 3) {
                        let isHit = this.hitOdds(0.3); // 0.3
                        if (isHit) {
                            game.scene.add(RankCupMore);
                            return true;
                        }
                    }
                }
            }
            // 非VIP无富贵竹：获得奖杯数*50%>=升段所差奖杯，则弹出奖杯多多弹窗
            else {
                let upNeed = r_d.toNextLevelNeedCup - (cup - r_d.minCup);
                if (r_d.toNextLevelNeedCup > 0 && Math.ceil(rd.cup * 0.5) >= upNeed) {
                    if (__data.vip.addUpToLoginDayNum <= 3) {
                        if (rs) { return false; }
                        LocalUtils.saveByToday(this.RANK_MORE_CUP_TODAYISSHOW, 'true');
                        game.scene.add(RankCupMore);
                        return true;
                    } else if (__data.vip.addUpToLoginDayNum > 3) {
                        let isHit = this.hitOdds(0.3); // 0.3
                        if (isHit) {
                            game.scene.add(RankCupMore);
                            return true;
                        }
                    }
                }
            }

            // 有下一个段位可以升级  且 当前段位升到下一个段位所差的 杯数 <= 10 (3.1.8版本弃用)
            // if (rd.toNextLevelNeedCup > 0 && rd.toNextLevelNeedCup - (cup - rd.minCup) <= 10) {
            //     game.scene.add(RankCupMore);
            //     return true;
            // }
        }
        return false;
    }

