    // 升段炫耀
    static show_uplv_rewards(oldCup, newCup) {
        // 结算数据
        let rd = __data.deskData.roomVo.smallResultData;
        if (!rd) { return false; }
        // 输赢结果
        let result = rd.myResult;

        // 输了 不继续处理了
        if (!result) {
            return false;
        }

        // 输赢奖杯
        let cup = rd.cup;

        // 原始奖杯(未结算前奖杯)
        let originCup = oldCup ? oldCup : result == 1 ? __data.hashCityLevelCup[HallPlay.lastCityId].cup - cup : __data.hashCityLevelCup[HallPlay.lastCityId].cup + cup;
        // 当前奖杯
        let realCup = newCup ? newCup : __data.hashCityLevelCup[HallPlay.lastCityId].cup;

        // 弹出升段炫耀
        let r = CheckUpgradeRank.checkQs(result, originCup, realCup);
        return r;
    }

