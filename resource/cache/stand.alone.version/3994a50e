    init(scaleRate, time, done) {
        this._scaleRate = scaleRate;
        this._scaleTime = time;
        this._done = done;

        this.fdTime = this._scaleTime * 0.7;
        this.stayTime = 80;
        this.edTime = this._scaleTime - this.fdTime;
    }

    start() {
        this.owner.scale(0, 0);
        Laya.Tween.to(this.owner, { scaleX: this._scaleRate, scaleY: this._scaleRate }, this.fdTime, null, Laya.Handler.create(this, this._toEnd));
    }

    _toEnd() {
        // Laya.Tween.to(this.owner, { scaleX: 1, scaleY: 1 }, this.edTime, null, Laya.Handler.create(this, this._complete), this.stayTime);
        Laya.Tween.to(this.owner, { scaleX: 1, scaleY: 1 }, this.edTime, Laya.Ease.expoIn, Laya.Handler.create(this, this._complete), this.stayTime);
    }

    _complete() {
        this._done && this._done();
    }
}




class BreathScript extends Laya.Script {
    onEnable() {
        this.init();
        this.start();
    }

    onDisable() {
        this.stop();
    }

    onMouseOut() {
        this.start();
    }

    onStageMouseUp() {
        this.start();
    }

    init() {
        this.minScaleX = this.owner.scaleX;
        this.minScaleY = this.owner.scaleY;
        this.maxScaleX = this.owner.scaleX * 1.1;
        this.maxScaleY = this.owner.scaleY * 1.1;
    }

    start() {
        if (!this.owner) { return }
        this.breatheIn();
    }

    stop() {
        Laya.Tween.clearAll(this.owner);
    }

    breatheIn() {
        this.owner.scale(this.minScaleX, this.minScaleY);
        Laya.Tween.to(this.owner, { scaleX: this.maxScaleX, scaleY: this.maxScaleY }, 1000, Laya.Ease.sineOut, Laya.Handler.create(this, this.breatheOut));
    }

    breatheOut() {
        Laya.Tween.to(this.owner, { scaleX: this.minScaleX, scaleY: this.minScaleY }, 1000, Laya.Ease.sineOut, Laya.Handler.create(this, this.breatheIn));
    }
}