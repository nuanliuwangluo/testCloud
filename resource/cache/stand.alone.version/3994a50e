        if (this.__data.propertyState == -2) {
            // let img = Laya.Pool.getItemByClass('RESULT_PROPERTYS', Laya.Image);
            // // SkinUtils.setSkin(img, 'local/game_common/1/img_fd.png');
            // SkinUtils.setSkin(img, this.side == 'left' ? 'local/game_common/1/img_sx.png' : 'local/game_common/1/img_sx2.png');
            // img.on(Laya.Event.CLICK, this, this._lookBzexplain, ['FENGDING']);
            // imgs.push(img);
        }

        // 输的人 才显示上限
        if (!this.__data.winner) {
            // 如果输的金币超出256倍
            if (this.rates.rate >= GoldMatchMaxRate) {
                let img = Laya.Pool.getItemByClass('RESULT_PROPERTYS', Laya.Image);
                SkinUtils.setSkin(img, this.side == 'left' ? 'local/game_common/1/img_sx.png' : 'local/game_common/1/img_sx2.png');
                img.on(Laya.Event.CLICK, this, this._lookBzexplain, ['SHANGXIAN']);
                imgs.push(img);
            }
        }


        // 输了 且  是封顶开始游戏
        // if (parseInt(this.__data.isMaxMatch) && this.__data.winPosition.indexOf(this.__data.position) == -1) {
        // 封顶开始匹配  且  是输家  且 输的实际分数 超出结算分数
        if (this.__data.score < 0) {
            if (parseInt(this.__data.originScore) > parseInt(this.__data.initScore) && (this.winnerVip() || Math.abs(this.__data.realScore) > Math.abs(this.__data.initScore))) {
                let img = Laya.Pool.getItemByClass('RESULT_PROPERTYS', Laya.Image);
                SkinUtils.setSkin(img, this.side == 'left' ? 'local/game_common/1/img_fdbz.png' : 'local/game_common/1/img_fdbz2.png');
                img.on(Laya.Event.CLICK, this, this._lookBzexplain, ['FD']);
                imgs.push(img);
            }
        }

        // 门票补贴
        if (this.__data.propertyState == 2) {
            let img = Laya.Pool.getItemByClass('RESULT_PROPERTYS', Laya.Image);
            SkinUtils.setSkin(img, this.side == 'left' ? 'local/game_common/1/img_mpbt.png' : 'local/game_common/1/img_mpbt2.png');
            img.on(Laya.Event.CLICK, this, this._lookBzexplain, ['BT']);
            imgs.push(img);
        }
        // 胡的位置  且是 vip 用户 
        else if (this.__data.winPosition.indexOf(this.__data.position) != -1 && this.__data.isVip) {
            // 触发了 全额保障
            if (ResultPanelManager.compensateGold()) {
                let img = Laya.Pool.getItemByClass('RESULT_PROPERTYS', Laya.Image);
                SkinUtils.setSkin(img, this.side == 'left' ? 'local/game_common/1/img_qebz.png' : 'local/game_common/1/img_qebz2.png');
                img.on(Laya.Event.CLICK, this, this._lookBzexplain, ['QE']);
                imgs.push(img);
            }
        }

        while (this.c_img.numChildren) {
            let node = this.c_img.removeChildAt(0);
            node.off(Laya.Event.CLICK, this, this._lookBzexplain);
            Laya.Pool.recover('RESULT_PROPERTYS', node);
        }

        this.c_img.height = 0;
        for (let i = 0; i < imgs.length; i++) {
            this.c_img.addChild(imgs[i]);
            imgs[i].x = this.side == 'left' ? 0 : -imgs[i].width; // this.c_img.width == 0 ? this.c_img.width : this.c_img.width + 10;
            imgs[i].y = this.c_img.height == 0 ? 0 : this.c_img.height + 5; // this.c_img.height - imgs[i].height >> 1;
            this.c_img.height = imgs[i].y + imgs[i].height;
        }
    }


    // 胜利的用户全额保障
    winnerVip() {
        for (let i = 0; i < __data.deskData.roomVo.smallResultData.playerArray.length; i++) {
            let player = __data.deskData.roomVo.smallResultData.playerArray[i];
            if (player.winPosition.indexOf(player.position) != -1) {
                if (player.isVip) {
                    return true;
                } else {
                    return false;
                }
            }
        }
        return false;
    }

    // 触发系统补偿用户
    triggerCompensateGroups() {
        let list = [];
        for (let i = 0; i < __data.deskData.roomVo.smallResultData.playerArray.length; i++) {
            let pochan = __data.deskData.roomVo.smallResultData.playerArray[i].propertyState == -1; // 破产状态
            // let realScore = parseInt(__data.deskData.roomVo.smallResultData.playerArray[i].realScore);
            let initScore = parseInt(__data.deskData.roomVo.smallResultData.playerArray[i].initScore);
            let score = parseInt(__data.deskData.roomVo.smallResultData.playerArray[i].score);
            // 真实输掉的 超出了自己拥有的
            if (pochan && Math.abs(initScore) > Math.abs(score))
                list.push(__data.deskData.roomVo.smallResultData.playerArray[i]);
        }
        return list;
    }

    showSign(position) {
        if (this.__data.position == position) {
            game.cb.event('result_player_card', [this.__data]);
        }
    }

    _lookPlayer(e) {
        e && e.stopPropagation();
        game.cb.event('result_item_look_player', [this.__data, this.side, this.localToGlobal(new Laya.Point(this.btn_look.x, this.btn_look.y + this.btn_look.height / 2))]);
    }

    _lookBzexplain(type, e) {

        // 破产
        if (type == 'POCHAN') {
            let point = this.localToGlobal(new Laya.Point(this.c_img.x + e.currentTarget.x + e.currentTarget.width / 2, this.c_img.y + e.currentTarget.y + e.currentTarget.height));
            BagInfoUtils.init('prefab/ResultExplainTips.json', true);
            BagInfoUtils.show('金币都输光了~', point, game.scene.layer['panel'].c);
        }

        // 上限
        if (type == 'SHANGXIAN' || type == 'FENGDING') {
            let point = this.localToGlobal(new Laya.Point(this.c_img.x + e.currentTarget.x + e.currentTarget.width / 2, this.c_img.y + e.currentTarget.y + e.currentTarget.height));
            BagInfoUtils.init('prefab/ResultExplainTips.json', true);
            BagInfoUtils.show(`本场失败损失上限${GoldMatchMaxRate}倍`, point, game.scene.layer['panel'].c);
        }



        // 封顶开始游戏 且 输了的玩家  
        // if (parseInt(this.__data.isMaxMatch) && this.__data.winPosition.indexOf(this.__data.position) == -1) {
        if (type == 'FD') {
            miniApi.trackEvent('Mj_UIClick', { 'Mj_ClickScene': '封顶开始说明' });
            let point = this.localToGlobal(new Laya.Point(this.c_img.x + e.currentTarget.x + e.currentTarget.width / 2, this.c_img.y + e.currentTarget.y + e.currentTarget.height));
            BagInfoUtils.init('prefab/ResultExplainTips.json', true);
            BagInfoUtils.show('此玩家已激活封顶保障，损失金币以赢家拥有金币为封顶上限', point, game.scene.layer['panel'].c);
        }

        // 门票补贴
        if (type == 'BT') {
            // miniApi.trackEvent('Mj_UIClick', { 'Mj_ClickScene': '封顶开始说明' });
            let point = this.localToGlobal(new Laya.Point(this.c_img.x + e.currentTarget.x + e.currentTarget.width / 2, this.c_img.y + e.currentTarget.y + e.currentTarget.height));
            BagInfoUtils.init('prefab/ResultExplainTips.json', true);
            BagInfoUtils.show('赢家获得金币少于门票时，差额由系统补贴', point, game.scene.layer['panel'].c);
        }

        // 胡的位置  且是 vip 用户 
        // if (this.__data.winPosition.indexOf(this.__data.position) != -1 && this.__data.isVip) {
        if (type == 'QE') {
            // 触发了 全额保障
            // if (ResultPanelManager.compensateGold()) {
            miniApi.trackEvent('Mj_UIClick', { 'Mj_ClickScene': '全额保障说明' });
            game.scene.add(MahjongResultCompensateExplain, [this.triggerCompensateGroups()])
            // }
        }
    }

    /**
     * 输赢分数的颜色
     * @param {int} score 
     * @returns 
     */
    _scoreColor(score) {
        if (score > 0)
            return '#6caa01';
        else
            return '#ea7779';
    }
}


