            let uplvneedcup = rd.toNextLevelNeedCup - (__data.hashCityLevelCup[HallPlay.lastCityId].cup - rd.minCup);
            let x = Math.ceil(uplvneedcup / cup);
            x = Math.max(1, x);
            if (x < 100) this.txt_surpass.text = `预计再赢${x}场可升段`;
        }
