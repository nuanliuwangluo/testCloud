        this._value = value;
        this._updateUI();
    }

    _updateUI() {
        if (parseInt(this._value) >= 0) {
            //设置宝的皮肤
            let __custom = __data.mahjong_set.modelIndex.toString() === '0' ? __data.mahjong_set.cardIndex : __data.mahjong_set.cardIndex + 2
            let __skin = this._value == 255 ? 'local/mahjong_common/1/' + __data.mahjong_set.cardIndex % 2 + '_ag.png' : Mahjong2DRes.getRes('own', this._value)
            this.baoImg.texture = __skin
            this.mark.visible = false;
            // 广东处理一下中的马
            if (this._isHorse) { this.horseHandle(); }
        }
    }

    horseHandle() {
        let bingo = GdHorseInfo.horses.get.some(value => value == this._value);
        if (bingo) { this.mark.visible = false; }// 中了
        else { this.mark.visible = true; }// 没中
    }

    _onClickFlag() {
        if (this._value) {
            this._value.clickDo && this._value.clickDo();
        }
    }
}

