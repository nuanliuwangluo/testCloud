        // this.addComponent(Click_Stage_Remove_UI);
    }

    onAwake() { }

    get dataSource() { return this.value }
    set dataSource(value) {
        if (!value) { return }
        this.__data = value;
        //用来计算位置
        this.__width = 0;
        //牌距
        this.__offx = 10;
        // 缩放
        this.__scale = 1;
        //牌的显示容器
        this.container = this.container || new Laya.Sprite();
        while (this.container.numChildren) this.container.removeChildAt(0)
        this.addChild(this.container);
        //显示牌列表
        this.updateCardList();
        this.container.width = this.__width;
        // this.container.x = this.width - this.container.width * this.__scale >> 1;
        this.container.scale(this.__scale, this.__scale);
        this.width = this.bg.width = this.container.x * 2 + this.container.width;
        // this.fjmj_box.x = this.txt_info.x + this.txt_info.width + 30;
    }

    set side(value) {
        if (value == 'left')
            this.sign.x = 150;
        else
            this.sign.x = this.width - 150;
    }

    get offx() {
        return this.sign.x;
    }

    //显示牌
    updateCardList() {
        this.showDoor();
        this.showHand();
        this.showHu();
    }

    // 门前忽略信息
    isMqIgnore(value) {
        let list = value.split(',');
        let type = list.shift();
        if (type == 83)
            return true;
        else
            return false;
    }

    //显示门前牌
    showDoor() {
        let __doordata = this.__data.tileGroupArray
        for (let i = 0; i < __doordata.length; i++) {
            if (this.isMqIgnore(__doordata[i])) { continue; }
            let __v = Laya.Pool.getItemByClass(__cName.udoor, MahjongResultDoor)
            __v.open = true
            __v.group = __doordata[i]
            __v.x = this.__width
            this.__width += (__v.width + 5)
            this.container.addChild(__v)
            // 芜湖
            ComponentUtils.clearScript(__v, WuhuCompassInfo);
            if (__v.position != 5 && __v.type != 81 && __v.type != 82 && __v.type != 83) {// position 不能是5 代表暗杠什么的  指向的是自己
                let targetId = __data.deskData.roomVo.isRecordPlaying ? __data.deskData.recordViewerID : __data.uid;
                let targetVo = __data.deskData.roomVo.getResultPlayer(targetId);
                targetVo && __v.addComponent(WuhuCompassInfo).bind(targetVo.position, __v.position, WuhuCompassInfo.DOOR);
            }
        }
    }

    showHand() {
        let __handdata = __compUtils.sort(this.__data.handTileArray, __data.deskData.roomVo.mixedArr)
        //富锦特殊处理  胡的人把混单独提出来
        if (this.__data.winner) {
            let __handle = this.pickHun(__handdata, __data.deskData.roomVo.mixedArr);
            this.showHun(__handle.retArr)
            let __oriArr = __handle.oriArr;
            for (let i = 0; i < __oriArr.length; i++) {
                let __v = Laya.Pool.getItemByClass(__cName.rhand, MahjongResultHand)
                __v.x = this.__width
                this.__width += __v.width
                this.container.addChild(__v).skin = __oriArr[i]
            }
        } else {
            for (let i = 0; i < __handdata.length; i++) {
                let __v = Laya.Pool.getItemByClass(__cName.rhand, MahjongResultHand)
                __v.x = this.__width
                this.__width += __v.width
                this.container.addChild(__v).skin = __handdata[i]
            }
        }
    }

    showHun(hArr) {
        this.__width += __data.deskData.roomVo.cInterval;

        for (let i = 0; i < hArr.length; i++) {
            let __v = Laya.Pool.getItemByClass(__cName.rhand, MahjongResultHand)
            __v.x = this.__width
            this.__width += __v.width
            this.container.addChild(__v).skin = hArr[i]
        }
    }

    showHu() {
        //开牌炸 不在继续进行 可能没有胡的牌？
        if (this.__data.scoreInfo.indexOf("开牌炸") > -1) return;
        //没有胡牌  流局？
        if (this.__data.huPai == 255) return;

        if (this.__data.winPosition.indexOf(this.__data.position) > -1) {
            //赢家
            let __v = Laya.Pool.getItemByClass(__cName.rhand, MahjongResultHand)
            __v.x = this.__width + this.__offx
            this.__width += __v.width
            this.container.addChild(__v).skin = this.__data.huPai
        }
    }


    pickHun(originalArr, ruleArr) {
        trace('混数组：', ruleArr)
        let __returnArr = [];
        let __orginalArr = [].concat(originalArr);
        if (ruleArr && ruleArr.length > 0) {
            for (let s = 0; s < __orginalArr.length; s++) {
                for (let i = 0; i < ruleArr.length; i++) {
                    if (ruleArr[i].toString() == __orginalArr[s].toString()) {
                        __returnArr.push(__orginalArr[s]);
                        __orginalArr.splice(s, 1);
                        s--;
                        break;
                    }
                }
            }
        }

        trace('提取出来得混数组：', __returnArr, this.__data)

        trace('原数组：', originalArr, this.__data)
        return { oriArr: __orginalArr, retArr: __returnArr }
    }
}




