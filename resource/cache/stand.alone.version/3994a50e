        game.cb.off(__eh + 'update_user_info', this, this.refresh);
    }

    added(list) {
        this.list = list;
        this.refresh();
        // if (__data.vip.isVip) { SkinUtils.gray(this.btn_buy, true, false); }
    }

    refresh() {
        if (this.list) {
            let ts = this.transformString(this.list);
            this.txt_explain.text = ts;
            this.btn_buy.y = this.txt_explain.y + this.txt_explain.height + this.btn_buy.height / 2 + 30;
            this.height = this.bg.height = this.btn_buy.y + this.btn_buy.height / 2 + 60;

            this.comp_addedParams_updatePosition.updatePosition();
        }
    }

    transformString(list) {
        let strs = [];

        let index = 0;
        for (let i = 0; i < list.length; i++) {
            index++;
            let name = __data.othersVO[list[i].id] ? __data.othersVO[list[i].id].name : '';
            // let realScore = Math.abs(list[i].realScore);
            let initScore = Math.abs(list[i].initScore);
            let score = Math.abs(list[i].score);
            strs.push(`${index}、玩家[${name}]应输${initScore}金币，由于破产，故只能支付${score}金币，剩余${initScore - score}金币由系统补足。`);
        }
        return strs.length ? strs.join('\n\n') : '';
    }

