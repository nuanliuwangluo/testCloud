class MahjongResultRankComponent extends game.ModuleBase {
    constructor() {
        super()
        this.createView(game.uiMap['scene_game/result/MahjongResultRankComponent']);
        this.centerx = this.rankUI.x + (this.rankUI.width * this.rankUI.scaleX) / 2;
        this.mouseThrough = true;
    }

    onEnable() {
        this.useUI();
        this.initUI();
        game.cb.on(MahjongResultRankComponent.EXTRA_CUP, this, this.extraCupAni);
        game.cb.on(MahjongResultRankComponent.PROTECT_CUP, this, this.protectCupAni);
        game.cb.on('RESULT_RANK_ANI_COMPLETE', this, this._showUI);
    }

    onDisable() {
        game.cb.off(MahjongResultRankComponent.EXTRA_CUP, this, this.extraCupAni);
        game.cb.off(MahjongResultRankComponent.PROTECT_CUP, this, this.protectCupAni);
        game.cb.off('RESULT_RANK_ANI_COMPLETE', this, this._showUI);
    }

    _showUI() {
        // this.container.visible = true;
    }

    initUI(initCup) {
        // this.container.visible = false;
        let result = __data.deskData.roomVo.smallResultData.myResult;
        let cup = __data.deskData.roomVo.smallResultData.cup;

        initCup = initCup || __data.hashCityLevelCup[HallPlay.lastCityId].cup;
        this.rankUI.ready(result);
        this.rankUI.init(initCup, result ? Math.abs(cup) : -Math.abs(cup));

        // 赢了  算出最开始的时候的奖杯  如果有进度条就一直显示
        if (result) {
            let lastCup = __data.hashCityLevelCup[HallPlay.lastCityId].cup - Math.abs(cup);
            let lastRankData = RankUtils.getRankLvDataByScore(lastCup, __data.uid, HallPlay.lastCityId);
            let haveLine = lastRankData.toNextLevelNeedCup != 0 ? true : false;
            this.rankUI.lineState = haveLine;
        } else { // 输了  看当前奖杯是否有进度条    如果有进度条就一直显示
            let lastCup = __data.hashCityLevelCup[HallPlay.lastCityId].cup;
            let lastRankData = RankUtils.getRankLvDataByScore(lastCup, __data.uid, HallPlay.lastCityId);
            let haveLine = lastRankData.toNextLevelNeedCup != 0 ? true : false;
            this.rankUI.lineState = haveLine;
        }

        this.rankUI.showInfo();
        // this.rankUI.updateWords(result ? Math.abs(cup) : -Math.abs(cup));
        // this.rankUI.updateIcons();
    }


    useUI() {
        let result = __data.deskData.roomVo.smallResultData.myResult;
        SkinUtils.setSkin(this.bg, result ? 'cdn/mahjong_br/mahjong_br/bg_js1a.png' : 'cdn/mahjong_br/mahjong_br/bg_js2a.png');
        this.light.visible = result ? true : false;
        // this.frame.visible = false;
    }

    /**
     * 
     * @param {*} cup 
     */
    extraCupAni(cup, oldCup, newCup) {
        game.scene.remove(RankCupMore);
        this.rankUI.init(oldCup, cup + __data.deskData.roomVo.smallResultData.cup);
        this.rankUI.updateIcons(MahjongResultRankComponent.EXTRA_CUP);
        this.rankUI.updateWords(cup + __data.deskData.roomVo.smallResultData.cup);
        this.rankUI.to(newCup, () => {
            // CheckUpgradeRank.check(1, oldCup, newCup);
            ResultPanelManager.show_uplv_rewards(oldCup, newCup);
        });
    }

    /**
     * 段位保护 
     * @param {*} cup 
     */
    protectCupAni(cup, oldCup, newCup) {
        ResultPanelManager.resumeProtectOdds();
        game.scene.remove(RankCupProtect);
        // let lostCup = Math.abs(rankData.toNextLevelNeedCup - (oldCup - rankData.minCup)) - Math.abs(__data.deskData.roomVo.smallResultData.cup);
        let lostCup = newCup - (oldCup + Math.abs(__data.deskData.roomVo.smallResultData.cup));
        this.rankUI.init(oldCup, lostCup);
        this.rankUI.updateIcons(MahjongResultRankComponent.PROTECT_CUP);
        this.rankUI.updateWords(lostCup);
        this.rankUI.to(newCup);
    }

    to(cup, complete) {
        this.rankUI.to(cup, complete);
    }

    /**
     * 额外奖杯
     */
    static get EXTRA_CUP() { return "EXTRA_CUP"; }

    /**
     * 受保护
     */
    static get PROTECT_CUP() { return "PROTECT_CUP" }
}




