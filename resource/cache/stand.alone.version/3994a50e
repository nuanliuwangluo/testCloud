        // 输赢结果
        // let result = rd.myResult;

        // 211.212.213，无论输赢每5局触发一次，如被其他弹窗耽误，则顺延弹出后重新计数
        let fives = [211, 212, 213];
        if (this.gameAdFightNumber >= 5) {
            let value = fives.find((value) => value == __data.userType);
            if (value) {// 满足条件，弹出广告
                miniApi.showPopupAd(this.adRandom());
                this.clearGameAdFightNumber();
                return true;
            }
        }
        // 311.312.313，无论输赢每3局触发一次，如被其他弹窗耽误，则顺延，弹出后重新计数
        let threes = [311, 312, 313];
        if (this.gameAdFightNumber >= 3) {
            let value = threes.find((value) => value == __data.userType);
            if (value) {// 满足条件，弹出广告
                miniApi.showPopupAd(this.adRandom());
                this.clearGameAdFightNumber();
                return true;
            }
        }

        return false;
    }

