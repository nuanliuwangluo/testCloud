class S_garden_show_dailySelect extends Laya.Script {
    onClick() {
        if (this.owner.skin == 'cdn/garden_ui/bt_mrjx2.png') {
            __tips('完成花园前院建设解锁')
        } else {
            __showScene.show_garden_dailySelect()
        }
    }
}
class S_garden_show_collect extends Laya.Script {
    onClick() {
        __showScene.show_collect('gardenDress')
    }
    onEnable() {
        game.cb.on('garden_add_new_dress', this, this.garden_add_new_dress)
        __data.garden.testNewDress()
    }
    onDisable() {
        game.cb.off('garden_add_new_dress', this, this.garden_add_new_dress)
    }
    garden_add_new_dress() {
        if (__data.garden.newDress.length) {
            this.owner.getChildByName('img_new').visible = true
        } else {
            this.owner.getChildByName('img_new').visible = false
        }
    }
}
class S_garden_build extends Laya.Script {
    onClick() {
        if (__data.garden.task.isNoTask && __data.garden.task.rewardType_chapter != 1) {
            game.scene.add(GardenNoTask)
        } else {
            __showScene.show_garden_task()
        }
    }
    onEnable() {
        this.update_sign()
        game.cb.on('update_star', this, this.update_sign)
        game.cb.on('update_garden_build_question', this, this.update_sign)
    }
    onDisable() {
        game.cb.off('update_star', this, this.update_sign)
        game.cb.off('update_garden_build_question', this, this.update_sign)
    }
    update_sign() {
        // 检测当前任务小号显示感叹号
        this.owner.getChildByName('img_question').visible = __data.garden.task.isRedPoint;
    }
}
