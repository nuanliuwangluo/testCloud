class GardenMainUI_leftUp_res extends game.ModuleBase {
    constructor() {
        super({
            map: 'garden/Garden_mainUI_leftUp_res',
            layer: 'middle',
            left: true,
            up: true,
            offx: () => {
                return miniApi.statusBarRatio() * Laya.stage.width;
            },
        })
        this.txt_star.addComponent(S_hall_tween_star)
        this.txt_buildValue.addComponent(S_hall_tween_buildValue)

        this.img_bv.addComponent(S_click_show_des_set).init('繁荣度：可通过建设花园任务及解锁特殊装饰提升。', 0, 25)
        this.img_star.addComponent(S_click_show_des_set).init('雀神之星：可通过每日挑战、日常任务、吃碰消消乐获得。')
    }
    async added() {
        // let a = game.scene.get(GardenMainUI_leftUp_res);
        // if (a && a.parent) {
        // }
        this.y -= this.height;
        game.scene.layer['middle'].c.addChild(this)
        game.cb.on('garden_remove_main_ui', this, this.garden_remove_main_ui)
        game.cb.on('garden_main_ui_res_updateLayer', this, this.garden_main_ui_res_updateLayer)
        await __tool.tweenp(this, { y: 0 }, 200)
        if (gardenEffect.buildValueEffect_setAddv > 0) {
            gardenEffect.startBuildValueEffect()
            __sound.playGameYx("getp");
        }
    }
    onDisable() {
        game.cb.off('garden_remove_main_ui', this, this.garden_remove_main_ui)
        game.cb.off('garden_main_ui_res_updateLayer', this, this.garden_main_ui_res_updateLayer)
        if (this.clearAwait) this.clearAwait()
    }
    garden_main_ui_res_updateLayer() {
        game.scene.layer['middle'].c.addChild(this)

        let a = game.scene.get(GardenTask)
        if (a && a.parent) {
            game.scene.layer['tips'].c.addChild(this)
        }
        game.cb.on('garden_remove_main_ui', this, this.garden_remove_main_ui)
        game.cb.on('garden_main_ui_res_updateLayer', this, this.garden_main_ui_res_updateLayer)
    }
    async garden_remove_main_ui() {
        await __tool.tweenp(this, { y: this.y - this.height }, 200)
        game.scene.remove(this)
    }
}
class GardenMainUI_leftDown extends game.ModuleBase {
    constructor() {
        super({
            map: 'garden/Garden_mainUI_leftDown',
            layer: 'middle',
            left: true,
            down: true,
            offx: () => {
                return miniApi.statusBarRatio() * Laya.stage.width;
            },
        })
        this.btn_rank.addComponent(S_garden_show_rank)
        this.btn_collect.addComponent(S_garden_show_collect)
        this.btn_dailySelect.addComponent(S_garden_show_dailySelect)
    }
    added() {
        this.toy = this.toy || this.y;
        this.y += this.height;
        Laya.Tween.to(this, { y: this.toy }, 200)
        game.cb.on('garden_remove_main_ui', this, this.garden_remove_main_ui)
        this.update_dailySelect_icon()
        game.cb.on('update_dailySelect_icon', this, this.update_dailySelect_icon)
    }
    onDisable() {
        game.cb.off('garden_remove_main_ui', this, this.garden_remove_main_ui)
        game.cb.off('update_dailySelect_icon', this, this.update_dailySelect_icon)
    }
    async garden_remove_main_ui() {
        await __tool.tweenp(this, { y: this.y + this.height }, 200)
        game.scene.remove(this)
    }
    update_dailySelect_icon() {
        this.btn_dailySelect.skin = parseInt(__data.garden.task.curChapterId) >= 2 ? 'cdn/garden_ui/bt_mrjx.png' : 'cdn/garden_ui/bt_mrjx2.png'
    }
}
class GardenMainUI_rightDown extends game.ModuleBase {
    constructor() {
        super({
            map: 'garden/Garden_mainUI_rightDown',
            layer: 'middle',
            right: true,
            down: true,
            offx: () => {
                return -miniApi.statusBarRatio() * Laya.stage.width;
            },
        })
        this.btn_build.addComponent(S_garden_build)
        this.img_hand.visible = false;
    }
    async added() {
        this.toy = this.toy || this.y;
        this.y += this.height;
        game.cb.on('garden_remove_main_ui', this, this.garden_remove_main_ui)
        game.cb.on('garden_build_remove_hand', this, this.garden_build_remove_hand)
        game.cb.on('garden_build_add_hand', this, this.garden_build_add_hand)
        await __tool.tweenp(this, { y: this.toy }, 200)
        if (!__data.serverRecord.isHasLookGardenUplvPanel3110) { }
        else this.garden_build_add_hand()
    }
    onDisable() {
        game.cb.off('garden_remove_main_ui', this, this.garden_remove_main_ui)
        game.cb.off('garden_build_remove_hand', this, this.garden_build_remove_hand)
        game.cb.off('garden_build_add_hand', this, this.garden_build_add_hand)
        this.garden_build_remove_hand()
        Laya.Tween.clearAll(this)
        this.clearAwait && this.clearAwait()
    }
    garden_build_add_hand(force = 0) {
        if (force == 1) {
            this.img_hand.visible = true;
            this.img_hand.clipPlay(0)
            return;
        }
        let a = game.scene.get(GardenTalk)
        if (a && a.parent) {
            this.img_hand.visible = false;
            this.img_hand.clipStop()
            return;
        }
        if (__data.garden.task.isShowHandGuide) {
            this.img_hand.visible = true;
            this.img_hand.clipPlay(0)
        }
    }
    garden_build_remove_hand() {
        this.img_hand.visible = false;
        this.img_hand.clipStop()
    }
    async garden_remove_main_ui() {
        await __tool.tweenp(this, { y: this.y + this.height }, 200)
        game.scene.remove(this)
    }
}
class S_hall_tween_buildValue extends Laya.Script {
    onEnable() {
        this.owner.text = __data.garden.buildValue
        this.star_v = __data.garden.buildValue
        game.cb.on('update_buildValue', this, this.update_buildValue)
    }
    onDisable() {
        game.cb.off('update_buildValue', this, this.update_buildValue)
    }
    update_buildValue() {
        let start_ob = {
            v: Number(this.star_v)
        };
        let t = Laya.Tween.to(start_ob, {
            v: Number(__data.garden.buildValue)
        }, 200)
        t.update = new Laya.Handler(this, function () {
            this.owner.text = Math.floor(start_ob.v)
        })
    }
}
