            game.scene.add(GameMainVipNew1, [__data.vip.vipType])
            if (__data.vip.count_protectAll) {
                let a = miniApi.getItem(__data.uid + ':vip_offline_protectAll')
                if (a != '1') {
                    game.scene.add(GameMainVipOffline_protectAll)
                }
                miniApi.setItem(__data.uid + ':vip_offline_protectAll', 1)
            }
            // }
        }
    }
