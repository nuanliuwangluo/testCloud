    class ModuleBase_s extends Laya.Script {
        onEnable() {
            game.cb.on('resize', this, this.onResize)
            this.onShow()
        }
        onDisable() {
            game.cb.off('resize', this, this.onResize)
            // this.owner.removed && this.owner.removed()
        }
        onResize() {
            if (!this.owner.params) {
                return
            }
            this.updatePosition()
        }
        onShow() {
            this.updatePosition()
            let pta = this.owner.getComponent(Panel_Tween_Add)
            pta && pta.startTween()
        }
        updatePosition() {
            if (!this.owner.params) {
                return
            }
            if (this.owner.params.scaleType == 'min') {
                this.owner.scale(game.scale, game.scale);
            } else if (this.owner.params.scaleType == 'width') {
                this.owner.scale(game.scaleW, game.scaleW);
            } else {
                this.owner.scale(game.scaleMax, game.scaleMax);
            }
            this.owner.x = 0;
            this.owner.y = 0;
            var w = this.owner.width * this.owner.scaleX
            var h = this.owner.height * this.owner.scaleY
            this.owner.params.centerx && (this.owner.x = (Laya.stage.width - w) / 2)
            this.owner.params.centery && (this.owner.y = (Laya.stage.height - h) / 2)
            this.owner.params.up && (this.owner.y = 0)
            this.owner.params.down && (this.owner.y = Laya.stage.height - h)
            this.owner.params.left && (this.owner.x = 0)
            this.owner.params.right && (this.owner.x = Laya.stage.width - w)
            // this.owner.x += (this.owner.pivotX || 0)
            // this.owner.y += (this.owner.pivotY || 0)
            let pta = this.owner.getComponent(Panel_Tween_Add)
            pta && pta.updateXY()
            this.owner.x += (typeof this.owner.params.offx == 'function' ? this.owner.params.offx() : this.owner.params.offx);
            this.owner.y += (typeof this.owner.params.offy == 'function' ? this.owner.params.offy() : this.owner.params.offy);

        }
    }
