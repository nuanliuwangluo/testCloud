        }
        play(actionName, loop, isRePlay) {
            !actionName && (actionName = 'ani1')
            if (!isRePlay && this.ing && actionName == this.actionName) return;
            this.stop();
            // this.target.visible = true;
            this.frame = 0;
            this.tolFrame = 0;
            this.actionName = actionName;
            loop == undefined && (loop = true)
            this.loop = loop;
            this.target.__effect_offx = this.target.__effect_offx || this.target.x
            this.target.__effect_offy = this.target.__effect_offy || this.target.y
            for (var i = 0; i < this.data.animations.length; i++) {
                if (actionName == this.data.animations[i].name) {
                    this.animation = this.data.animations[i];
                    for (var i in this.animation.nodes[0].keyframes) {
                        var keys = this.animation.nodes[0].keyframes[i]
                        this.tolFrame = keys[keys.length - 1].index > this.tolFrame ? keys[keys.length - 1].index : this.tolFrame;
                    }
                    break;
                }
            }
            // 如果不++最后一帧渲染不出来
            this.tolFrame++;
            if (this.timeSpeed) Laya.timer.loop(this.timeSpeed, this, this.update)
            else Laya.timer.frameLoop(1, this, this.update)
            this.ing = true
        }
        stop() {
            this.ing = false
            // this.target.visible = false
            Laya.timer.clear(this, this.update)
        }
        update() {
            var frame = this.frame % this.tolFrame;
            // trace(frame, this.frame, this.tolFrame)
            for (var i in this.animation.nodes[0].keyframes) {
                var key = i
                var keys = this.animation.nodes[0].keyframes[key]
                var value = 0
                var start_value = 0
                var end_value = 0
                var tolTime = 0
                var last_time = 0
                for (var j = keys.length - 1; j >= 0; j--) {
                    // trace(frame, keys[j].index)
                    if (frame >= keys[j].index) {
                        start_value = keys[j].value;
                        end_value = keys[j + 1] ? keys[j + 1].value : keys[0].value
                        tolTime = keys[j + 1] ? keys[j + 1].index : keys[j].index
                        last_time = keys[j].index;
                        var easeFun = Laya.Ease[keys[j].tweenMethod];
                        if (easeFun == null) {
                            easeFun = Laya.Ease.linearNone;
                        }
                        // if(tolTime == 0)value = start_value
                        if (frame == keys[j].index) value = start_value
                        else if (end_value - start_value == 0) value = start_value
                        else value = easeFun(frame - last_time, start_value, end_value - start_value, tolTime - last_time)

                        // trace('value', value, frame-last_time, start_value, end_value-start_value, tolTime-last_time, tolTime, last_time, j, this.frame, this.tolFrame)
                        // if(j==4)debugger;
                        // trace(frame-keys[j].index, start_value, end_value-start_value, tolTime)
                        break;
                    }
                }
                var offValue = 0
                if (key == 'x') offValue = this.target.__effect_offx
                else if (key == 'y') offValue = this.target.__effect_offy
                this.target[key] = value + offValue
            }
            this.frame++;
            if (this.frame % this.tolFrame == 0 && !this.loop) this.stop();
        }
    }

