class MM_comebacklife extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_mjMatch/MM_comebacklife',
            layer: 'panel'
        })
        this.btn_stone.addComponent(S_mm_cbl_stone)
        this.btn_video.addComponent(S_mm_cbl_video)
        this.btn_close.addComponent(S_mm_cbl_giveuplife)

        game.utils.remove(this.txt_canAddPropCount1)
        game.utils.remove(this.txt_canAddPropCount2)
    }
    added(title, des, func, type) {
        __sound.playGameYx('regret')
        this.func = func;
        this.ix_stone = this.ix_stone || this.sp_stone.x;
        this.ix_video = this.ix_video || this.sp_video.x;

        this.func = func;
        this.img_des.skin = `cdn/mjSmallGame/img_fh${type}.png`

        // IOS能支付修改
        // if (miniApi.isIOS && miniApi.clientType == 'wx') {
        //     this.btn_stone.visible = false
        //     this.btn_video.x = this.width / 2 //- this.btn_video.width / 2
        //     this.btn_video.visible = __data.mjSmallGame.comebacklife_video > 0
        // } else {
        this.sp_stone.visible = true
        this.sp_stone.x = this.ix_stone;
        this.sp_video.x = this.ix_video;
        this.sp_stone.visible = __data.mjSmallGame.comebacklife_stone > 0
        this.sp_video.visible = __data.mjSmallGame.comebacklife_video > 0

        if (!this.sp_stone.visible) {
            this.sp_video.x = this.width / 2 - this.btn_stone.width / 2
        }
        if (!this.sp_video.visible) {
            this.sp_stone.x = this.width / 2 - this.btn_stone.width / 2
        }
        // }

    }
    clickMask() { }
}
class S_mm_cbl_giveuplife extends Laya.Script {
    onClick(e) {
        game.scene.remove(this.owner.parent)
        game.scene.add(MM_fail)
    }
}
class S_mm_cbl_stone extends Laya.Script {
    onClick(e) {
        e && e.stopPropagation();
        if (__data.stone <= 0) {
            return __tips(__lang.stone_no_enough)
        }
        game.scene.remove(MM_comebacklife)
        game.server.send(2404, 10136)
        mm_stone_buy_callback = mm_stone_buy_comebacklife
    }
}
class S_mm_cbl_video extends Laya.Script {
    async onClick(e) {
        e && e.stopPropagation();

        let n = __data.vip.isVip ? 'VIP领取' : '参与广告'
        miniApi.trackEvent('Mj_ADClick', {
            Mj_ADPreference: miniApi.adUserValueLevel,
            'Mj_ADScene': '消消乐复活',
            'Mj_Participation': n,
            'Mj_ADNotes': __data.mjSmallGame.level,
        })

        let adunitId = 'adunit-smallGame_relife';
        await miniApi.video_ready(adunitId);
        // let a23 = game.scene.get(MjMatch_ui_left)
        // a23 && a23.removeTimer()
        miniApi.video_show(adunitId, () => {
            // __tips('📨 发送消息视频购买复活')
            // a23 && a23.resumeTimer()
            mm_video_buy_comebacklife()
        }, () => {
            // a23 && a23.resumeTimer()
            __tips('暂无广告，请稍后再试或开通VIP')
        }, 0, () => {
            // a23 && a23.resumeTimer()
        });
    }
}
let mm_stone_buy_comebacklife = () => {
    game.scene.remove(MM_comebacklife)
    __data.mjSmallGame.comebacklife_stone--;
    game.scene.get(MM_comebacklife).func()
}
let mm_video_buy_comebacklife = () => {
    game.scene.remove(MM_comebacklife)
    __data.mjSmallGame.comebacklife_video--;
    game.scene.get(MM_comebacklife).func()
}