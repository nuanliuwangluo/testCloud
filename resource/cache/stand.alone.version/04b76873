class S_shop_buy extends Laya.Script {
    async onClick(e) {
        let goodsId = this.owner.parent.__vo.goodsId
        if (this.owner.parent.__vo.limit_count >= 1 && this.owner.parent.__vo.buyNum >= this.owner.parent.__vo.limit_count) {
            __tips('今日已购买')
            return;
        }
        if (shopConfig.stone[goodsId]) {
            // 购买钻石
            if (__data.pay_curValue + shopConfig.stone[goodsId].price > __data.pay_maxValue) {
                __tips(__lang.pay_over_max)
                return;
            }
        }

        if (this.owner.parent.__vo.video) {
            // if (__data.vip.isVip) {
            //     // 购买金币
            //     game.server.send(2404, goodsId)
            // } else {
            if (this.owner.parent.img_video.visible) {
                let adunitId = 'adunit-0d2990e2b4b2f487'
                await miniApi.video_ready(adunitId)
                miniApi.video_show(adunitId, () => {
                    game.server.send(2404, goodsId, 1, 1)
                }, () => {
                    __tips('暂无广告，请稍后再试或开通VIP')
                }, 0);
                let n = __data.vip.isVip ? 'VIP领取' : '参与广告'
                miniApi.trackEvent('Mj_ADClick', { Mj_ADPreference: miniApi.adUserValueLevel, 'Mj_ADScene': '商城奖励', 'Mj_Participation': n })
            } else {
                // __data.shareVideoRule.total_clickShareCount()
                miniApi.share({
                    titleId: __tool.randomRange(1, 9),
                    shareVerifyOnShowFnTime: __data.shareVideoRule.isVerifyShareOnShowTime,
                    shareGroupClickCallback: () => {
                        game.server.send(2404, goodsId, 1, 2)
                        game.scene.remove(GameMainRedPacket_2)
                    },
                    shareOnShowCallback: () => {
                        game.scene.add(GameMainRedPacket_2)
                    },
                    params: `uid=${__data.uid}&shareRewardType=shopShare&myCityId=${__data.myCityId}`,
                })
                miniApi.trackEvent('Mj_ShareClick', { Mj_ADPreference: miniApi.adUserValueLevel, 'Mj_ShareScene': '商城奖励', 'Mj_Participation': '参与分享' })
            }
            // }
        } else {
            console.log(`发送RMB-购买命令`, this.owner.parent.__vo.goodsId);
            if (shopConfig.prop[goodsId]) {
                // 购买道具
                game.scene.add(GameMainShopNum, [goodsId])
            } else if (shopConfig.discount[goodsId]) {
                // 购买特惠金币
                game.server.send(2404, goodsId)
            } else if (shopConfig.gold[goodsId]) {
                // 购买金币
                game.server.send(2404, goodsId)
            } else if (shopConfig.stone[goodsId]) {
                pay_stone_logic(goodsId)
            }
        }
    }
}

let pay_stone_logic = async (goodsId) => {
    await game.server.send(16020);
    if (__data.onoff_pay != 1) return __tips(__lang.nocan_pay)
    // 购买钻石
    if (__data.isSupportUser == 1) {
        game.server.send(17002, goodsId)
    }
    else if (window['wx'] || window.IOSPay || (window.APP_PACKAGE && window.APP_PACKAGE == window.ORIGIN_APP)) {
        // 获取订单信息
        // IOS能支付修改
        // if (miniApi.isIOS) return 1;
        game.scene.add(LoadingSmall)
        miniApi.pay({
            goodsId,
            successCallback: () => {
                game.scene.remove(LoadingSmall)
            },
            failCallback: () => {
                game.scene.remove(LoadingSmall)
            }
        })
        if (__data.isSupportUser != 1) {
            miniApi.trackEvent('Mj_Pay', {
                Mj_ADPreference: miniApi.adUserValueLevel,
                'Mj_PayName': shopConfig.stone[goodsId].md_mj_pay_name,
                'Mj_PayPrice': shopConfig.stone[goodsId].price,
                'Mj_Paytype': '点击',
                'Mj_UserID': String(__data.uid),
            })
        }
    } else {
        game.scene.add(LoadingSmall)
        game.server.send(2406, goodsId)
    }
}

class GameMainShopNum extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_shopNum',
            layer: 'panel'
        })
        this.btn_buy.addComponent(S_shopNum_buy)
        this.btn_add.addComponent(S_shopNum_add)
        this.btn_reduce.addComponent(S_shopNum_reduce)
        this.sp_des.visible = false;
    }
    added(goodsId) {
        let vo = shopConfig.prop[goodsId];
        let buyMoneyId = vo.buyMoneyId || 2
        this.img_buy.skin = PropIcon.icon[buyMoneyId].skin;
        this.goodsId = goodsId;
        this.txt_name.text = shopConfig.prop[goodsId].name || PropIcon.icon[vo.propId].name;
        this.txt_waterValue.text = '+' + PropIcon.icon[vo.propId].waterValue
        S_shopNum_buy.buyNum = 1;

        let useMoney;
        if (buyMoneyId == 1) {
            useMoney = __data.gold;
        } else if (buyMoneyId == 2) {
            useMoney = __data.stone;
        } else if (buyMoneyId == 5) {
            useMoney = __data.garden.star;
        }

        S_shopNum_buy.maxNum = Math.floor(useMoney / vo.price);
        if (S_shopNum_buy.buyNum > S_shopNum_buy.maxNum) {
            S_shopNum_buy.buyNum = S_shopNum_buy.maxNum
        }
        if (S_shopNum_buy.buyNum < 1) {
            S_shopNum_buy.buyNum = 1
        }
        this.modifyNum();
        this.scene_prop.vo = {
            propId: vo.propId
        }
        this.txt_des.text = PropIcon.icon[vo.propId].describe
    }
    onDisable() { }
    modifyNum() {
        let needStoneNum = shopConfig.prop[this.goodsId].price * S_shopNum_buy.buyNum;
        this.txt_need.text = needStoneNum;
        if (S_shopNum_buy.buyNum == 1) {
            this.btn_reduce.disabled = true;
            this.btn_add.disabled = false;
        } else if (S_shopNum_buy.buyNum == S_shopNum_buy.maxNum) {
            this.btn_reduce.disabled = false;
            this.btn_add.disabled = true;
            if (S_shopNum_buy.maxNum == 0) {
                this.btn_reduce.disabled = true;
            }
        } else {
            this.btn_reduce.disabled = false;
            this.btn_add.disabled = false;
        }

        let vo = shopConfig.prop[this.goodsId];
        let buyMoneyId = vo.buyMoneyId || 2
        let useMoney;
        if (buyMoneyId == 1) {
            useMoney = __data.gold;
        } else if (buyMoneyId == 2) {
            useMoney = __data.stone;
        } else if (buyMoneyId == 5) {
            useMoney = __data.garden.star;
        }

        if ((S_shopNum_buy.buyNum + 1) * shopConfig.prop[this.goodsId].price > useMoney) {
            this.btn_add.disabled = true;
        }
        this.txt_num.text = S_shopNum_buy.buyNum
    }
}
class S_shopNum_add extends Laya.Script {
