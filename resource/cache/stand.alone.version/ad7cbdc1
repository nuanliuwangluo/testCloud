class S_click_gmcgti_look extends Laya.Script {
    async onClick(e) {
        e.stopPropagation()
        if (this.owner.parent.img_lock.visible) {
            __tips('区域尚未解锁')
            return
        }
        game.scene.remove(GameMainCollect)
        let lastSceneFunction;
        if (game.scene.get(Hall) && game.scene.get(Hall).parent) {
            lastSceneFunction = async () => {
                await __showScene.show_hall()
                await __showScene.show_collect('gardenDress')
                game.scene.get(GameMainCollect).showTheme()
            }
        }
        if (game.scene.get(Garden_groud) && game.scene.get(Garden_groud).parent) {
            lastSceneFunction = async () => {
                game.cb.event('garden_groud_toOtherGarden', [__data.uid, __data.garden.hashUsePositionIdCompId]);
                game.scene.add(GardenMainUI_leftUp_return)
                game.scene.add(GardenMainUI_leftUp_res)
                game.scene.add(GardenMainUI_leftDown)
                game.scene.add(GardenMainUI_rightDown)
                game.scene.get(GardenOther_centerDown).removeUI()
                game.scene.remove(GardenBuildMask)
                await __showScene.show_collect('gardenDress')
                game.scene.get(GameMainCollect).showTheme(2)
            }
        }
        let v = this.owner.parent.vo;
        // game.cb.event('collect_theme_look', [v])
        if (!game.scene.get(Garden_groud) || !game.scene.get(Garden_groud).parent) {
            __data.lastSceneQueue.push(lastSceneFunction)
            await __showScene.show_garden(true)
        }
        for (const compId of v.compIdArray) {
            game.cb.event('garden_groud_change_map_compId', [compId]);
        }
        game.scene.remove(GardenMainUI_leftUp_return)
        game.scene.remove(GardenMainUI_leftUp_res)
        game.scene.remove(GardenMainUI_leftDown)
        game.scene.remove(GardenMainUI_rightDown)
        // game.scene.add(GardenBuildMask);
        game.scene.add(GardenOther_centerDown, ['themeLook'])

        let compId = v.compIdArray[0]
        let taskId = __data.excelConfig.hashGardenDress[compId].positionId;
        let d132 = __data.excelConfig.hashGardenPositionArea[taskId]
        game.scene.get(Garden_groud).moveTo(...d132.centerXY.toArray('_'), true)
    }
}