class S_click_collect_use_gardenDress extends Laya.Script {
    async onClick(e) {
        let a = game.scene.get(GameMainCollect)
        let compId = a.show_vos_gardenDress[0].id
        let d1 = __data.excelConfig.hashGardenDress[compId]
        if (d1.typeId) {
            game.scene.add(GameMainCollectDressSelect, [d1.typeId])
        } else {
            S_click_collect_use_gardenDress.changeDress(compId)
            game.scene.remove(Garden_dailySelect)
        }
    }
}
S_click_collect_use_gardenDress.changeDress = async (compId) => {
    // if (__data.garden.isDressLock(compId)) return __tips('装饰尚未解锁');
    let m = __data.excelConfig.hashGardenDress[compId].positionId;
    if (__data.garden.task.branchTaskId <= m) {
        return __tips('装饰所在任务尚未开启')
    }
    game.scene.remove(GameMainCollectDressSelect)

    let b = game.scene.get(GardenMainUI_leftUp_res)
    let taskId;
    // let m = __data.excelConfig.hashGardenDress[compId].positionId;
    for (const key in __data.excelConfig.hashGardenTaskBranch) {
        let e = __data.excelConfig.hashGardenTaskBranch[key]
        if (e.positionId == m) {
            taskId = key
            break;
        }
    }
    if (taskId) {
        game.scene.remove(GameMainCollect)
        game.scene.remove(Garden_dailySelect)
        if (b && b.parent) {
        } else {
            __data.lastSceneQueue.push(__showScene.show_hall)
            await __showScene.show_garden(true)
        }
        game.scene.remove(GardenMainUI_leftUp_return)
        game.scene.remove(GardenMainUI_leftUp_res)
        game.scene.remove(GardenMainUI_leftDown)
        game.scene.remove(GardenMainUI_rightDown)
        game.scene.add(GardenBuildMask);
        let d132 = __data.excelConfig.hashGardenPositionArea[taskId]
        await game.scene.get(Garden_groud).moveTo(...d132.centerXY.toArray('_'), true)
        game.scene.add(GardenBuild, [taskId, 'collect'])
        game.cb.event('garden_groud_add_filter_ani', [taskId])
        game.cb.event('garden_groud_scale', ['min', true])
    }
}

class S_click_collect_location extends Laya.Script {
    async onClick(e) {
        let a = game.scene.get(GameMainCollect)
        // if (__data.garden.isDressLock(a.show_vos_gardenDress[0].id)) return;
        let b = game.scene.get(GardenMainUI_leftUp_res)
        let taskId
        let m = __data.excelConfig.hashGardenDress[a.show_vos_gardenDress[0].id].positionId;
        // 对于尚未开始建设的位置，点击“定位”时不应该切换界面，而是应该提示“装饰所在任务尚未开启”
        if (!__data.garden.hashUsePositionIdCompId[m])
            return __tips('装饰所在任务尚未开启')

        for (const key in __data.excelConfig.hashGardenTaskBranch) {
            let e = __data.excelConfig.hashGardenTaskBranch[key]
            if (e.positionId == m) {
                taskId = key
                break;
            }
        }
        if (taskId) {
            game.scene.remove(GameMainCollect)
            if (b && b.parent) {
            } else {
                __data.lastSceneQueue.push(__showScene.show_hall)
                await __showScene.show_garden(true)
            }

            let d132 = __data.excelConfig.hashGardenPositionArea[taskId]
            game.scene.get(Garden_groud).moveTo(...d132.centerXY.toArray('_'), true)
        }
    }
}

