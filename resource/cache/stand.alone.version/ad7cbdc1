class GameMainCollect extends game.ModuleBase {
    static get loadResFolder() {
        this._r1 = this._r1 ||
            ['cdn.collect', 'cdn.headFrame'];
        return this._r1
    }
    static get clearResFolder() {
        this._r2 = this._r2 ||
            ['cdn.collect', 'cdn.headFrame', 'cdn.collect_delay', 'cdn.collect_gardenDress'];
        return this._r2
    }
    constructor() {
        super({
            map: 'scene_hall/gameMain_collect',
            layer: 'panel',
        })
        this.btn_return.addComponent(S_click_GameMainCollect_close)
        this.__list_headFrame.vScrollBarSkin = ''
        this.__list_dress.vScrollBarSkin = ''
        this.__listTheme.vScrollBarSkin = ''
        this.__tab.selectHandler = new Laya.Handler(this, this.onSelect);
        this.btn_show_use_headFrame.addComponent(S_click_collect_use_headFrame)
        this.btn_show_use_gardenDress.addComponent(S_click_collect_use_gardenDress)
        this.btn_location.addComponent(S_click_collect_use_gardenDress)

        this.btn_filter.addComponent(S_clickBtnShow_clickOtherRemove).init(this.img_filter)
        this.img_filter.addComponent(S_stopPropagation_mousedown)
        this.s_combobox = this.addComponent(S_combobox).init('collect', this.btn_filter, this.img_filter)

        this.btn_theme.addComponent(S_collect_theme_open)
        this.btn_closeTheme.addComponent(S_collect_theme_close)

        this.drawCallOptimize = true;
    }
    added(type, shareCardId) {
        S_click_GameMainCollectHeadFrameItem.lastSelectItem = null;
        S_click_GameMainCollectGardenDressItem.lastSelectItem = null;
        miniApi.trackEvent('Mj_UIExposure', { 'Mj_ExposureScene': `收集界面` })

        game.cb.on('collect_update_headFrameInfo', this, this.collect_update_headFrameInfo)
        game.cb.on('update_headFrame', this, this.update_headFrame)
        // this.update_headFrame()
        game.cb.on('collect_update_gardenDressInfo', this, this.collect_update_gardenDressInfo)
        game.cb.on('update_gardenDress', this, this.update_gardenDress)
        game.cb.on('update_garden_unlockDressList', this, this.update_gardenDress)
        // this.update_gardenDress()
        game.cb.on('combobox_update_index_' + this.s_combobox.comboboxName, this, this.update_combobox_index)
        game.cb.on('collect_theme_info', this, this.collect_theme_info)

        this.closeTheme()
        this.__tab.selectedIndex = -1;
        if (type == 'headFrame') {
            this.__tab.selectedIndex = 0
        } else if (type == 'gardenDress') {
            this.__tab.selectedIndex = 1
        }
    }
    onDisable() {
        game.cb.off('collect_update_headFrameInfo', this, this.collect_update_headFrameInfo)
        game.cb.off('update_headFrame', this, this.update_headFrame)
        game.cb.off('collect_update_gardenDressInfo', this, this.collect_update_gardenDressInfo)
        game.cb.off('update_gardenDress', this, this.update_gardenDress)
        game.cb.off('update_garden_unlockDressList', this, this.update_gardenDress)
        game.cb.off('combobox_update_index_' + this.s_combobox.comboboxName, this, this.update_combobox_index)
        game.cb.off('collect_theme_info', this, this.collect_theme_info)

        if (this.__list_dress.visible == true) {
            __data.garden.newDress = [];
        }
        game.cb.event('garden_add_new_dress')
        ResUtils.clearClassTextureRes(GameMainCollect)
        ResUtils.clearAtlas('res/atlas/cdn/collect.atlas')
    }
    update_combobox_index() {
        this.update_content()
    }
    collect_update_headFrameInfo(vo) {
        if (!vo) {
            this.img_show_0.visible = false
            return
        }
        this.img_show_0.visible = true;
        this.img_show_headFrame.skin = PropIcon.icon[vo.propId].skin;
        this.txt_show_headFrameName.text = PropIcon.icon[vo.propId].name;
        this.txt_show_des_headFrame.text = PropIcon.icon[vo.propId].describe;

        if (vo.isLock) {
            this.img_show_status_headFrame.skin = 'cdn/collect/img_whq.png'
            this.btn_show_use_headFrame.visible = false
        } else if (vo.isUseing) {
            this.img_show_status_headFrame.skin = 'cdn/collect/img_syz.png'
            this.btn_show_use_headFrame.visible = false
        } else {
            this.img_show_status_headFrame.skin = 'cdn/collect/bt_sy.png'
            this.btn_show_use_headFrame.visible = true;
        }
        this.show_vo_headFrame = vo;
    }
    update_headFrame() {
        let curData = __data.othersVO[__data.uid]
        if (!curData) {
            this.dd_headFrame_all = []
            this.dd_headFrame_lock = []
            this.dd_headFrame_unlock = []
            this.s_combobox.array = [
                `全部(${this.dd_headFrame_all.length})`,
                `已解锁(${this.dd_headFrame_unlock.length})`,
                `未解锁(${this.dd_headFrame_lock.length})`,
            ]
            this.s_combobox.selectedIndex = 0
            return;
        }
        let dd123 = [];
        for (const key in PropIcon.icon) {
            if (PropIcon.icon[key].isHeadFrame) {
                dd123.push({
                    propId: key,
                    isUseing: curData.headFrameId == key,
                    isLock: !curData.haveHeadFrameIds.includes(parseInt(key)),
                })
            }
        }
        this.img_head.skin = __data.getHeadTestDefault(curData.headUrl)

        this.dd_headFrame_all = dd123;
        this.dd_headFrame_lock = dd123.filter((e) => {
            return e.isLock
        });
        this.dd_headFrame_unlock = dd123.filter((e) => {
            return !e.isLock
        });
        if (this.__tab.selectedIndex == 0) {
            this.s_combobox.array = [
                `全部(${this.dd_headFrame_all.length})`,
                `已解锁(${this.dd_headFrame_unlock.length})`,
                `未解锁(${this.dd_headFrame_lock.length})`,
            ]
            this.s_combobox.selectedIndex = 0
        }
    }
    collect_update_gardenDressInfo(vos) {
        let vo = vos && vos[0]
        if (!vo) {
            this.img_show_1.visible = false
            return
        }
        if (this.__listTheme.visible == true) {
            this.img_show_1.visible = false
            return
        };
        this.img_show_1.visible = true;
        let d1 = __data.excelConfig.hashGardenDress[vo.id]
        let propId = d1.gardenDressId
        this.img_show_gardenDress.skin = `cdn/collect_gardenDress/${propId}.png`;
        this.txt_show_gardenDress_name.text = d1.gardenDressName;
        this.txt_show_gardenDress_lockDes.text = d1.gardenDressDes2;
        let name2 = ''
        let tn = __tool.gdp(__data, `excelConfig.hashGardenTheme[${d1.themeId || 0}].themeName`)
        if (tn) {
            name2 = String(tn).toArray('-')[0] + '主题皮肤'
        }
        this.txt_theme.text = name2
        if (vos.length > 1) {
            this.txt_show_gardenDress_des.text = `共${vos.length}处可用`
        } else {
            this.txt_show_gardenDress_des.text = d1.gardenDressDes;
        }
        if (__data.garden.isDressLock(vo.id)) {
            this.img_show_status_gardenDress.skin = 'cdn/collect/img_whq.png'
            this.btn_show_use_gardenDress.visible = false
        }
        else {
            this.img_show_status_gardenDress.skin = 'cdn/collect/bt_sy.png'
            this.btn_show_use_gardenDress.visible = true;
        }
        this.show_vos_gardenDress = vos;
        this.txt_buildValue.text = '+' + d1.buildValue;
        __tool.labelParentCenterAndSetXY(this.sp_buildValue, this.img_show_1.width / 2, 5)
    }
    update_gardenDress() {
        let dd123 = [];
        let typeArr = {};

        let hgd;
        if (this.look_theme_vo) {
            hgd = this.look_theme_vo.compIdArray.map((e) => {
                return __data.excelConfig.hashGardenDress[e]
            })
        } else {
            hgd = __data.excelConfig.hashGardenDress
        }
        for (const key in hgd) {
            let e = hgd[key];

            if (!this.look_theme_vo) {
                if (e.gardenDressId >= 100000) continue;
                if (e.lockConditions != 2 &&
                    !e.lockConditions.includes('3_') &&
                    !e.lockConditions.includes('4_') &&
                    !e.lockConditions.includes('5_')
                ) continue;
            }

            if (e.typeId) {
                // 有分类
                typeArr[e.typeId] = typeArr[e.typeId] || [];
                typeArr[e.typeId].push({
                    typeId: e.typeId,
                    id: e.compId,
                    positionId: parseInt(e.positionId),
                    isLock: __data.garden.isDressLock(e.compId),
                })
                if (!dd123.includes(typeArr[e.typeId]))
                    dd123.push(typeArr[e.typeId])
            } else {
                // 没有分类
                dd123.push([{
                    id: e.compId,
                    positionId: parseInt(e.positionId),
                    isLock: __data.garden.isDressLock(e.compId),
                }])
            }
        }
        dd123.sort((a, b) => {
            return a[0].positionId - b[0].positionId
        })
        this.dd_dress_all = dd123;
        this.dd_dress_lock = dd123.filter((e) => {
            return e[0].isLock
        });
        this.dd_dress_unlock = dd123.filter((e) => {
            return !e[0].isLock
        });
        if (this.__tab.selectedIndex == 1) {
            this.s_combobox.array = [
                `全部(${this.dd_dress_all.length})`,
                `已解锁(${this.dd_dress_unlock.length})`,
                `未解锁(${this.dd_dress_lock.length})`,
            ]
            this.s_combobox.selectedIndex = 0
        }
    }
    onSelect(index) {
        this.__list_headFrame.visible = false;
        this.__list_dress.visible = false;
        this.img_show_0.visible = false;
        this.img_show_1.visible = false;
        if (this.__tab.selectedIndex == 0) {
            this.__list_headFrame.visible = true;
            this.img_show_0.visible = true
            this.btn_theme.visible = false;
        } else if (this.__tab.selectedIndex == 1) {
            this.img_show_1.visible = true
            this.__list_dress.visible = true;
            this.btn_theme.visible = true;
            __data.garden.testNewDress()
        }
        if (index == 0) this.update_headFrame()
        else this.update_gardenDress()

    }
    update_content() {
        if (this.__tab.selectedIndex == 0) {
            let dd123;
            if (this.s_combobox.selectedIndex == 0) {
                dd123 = this.dd_headFrame_all
            }
            else if (this.s_combobox.selectedIndex == 1) {
                dd123 = this.dd_headFrame_unlock
            }
            else if (this.s_combobox.selectedIndex == 2) {
                dd123 = this.dd_headFrame_lock
            }
            let isHaveSelect
            for (let index = 0, length = dd123.length; index < length; index++) {
                const e = dd123[index];
                if (GameMainCollectHeadFrameItem.selectVO) {
                    if (GameMainCollectHeadFrameItem.selectVO.propId == e.propId) {
                        this.collect_update_headFrameInfo(e)
                        isHaveSelect = 1
                        break;
                    }
                }
                else if (e.isUseing) {
                    GameMainCollectHeadFrameItem.selectVO = e;
                    this.collect_update_headFrameInfo(e)
                    isHaveSelect = 1
                    break;
                }
            };
            if (!isHaveSelect) {
                GameMainCollectHeadFrameItem.selectVO = dd123[0];
                this.collect_update_headFrameInfo(dd123[0])
            }
            this.__list_headFrame.array = dd123
        } else if (this.__tab.selectedIndex == 1) {
            let dd123;
            if (this.s_combobox.selectedIndex == 0) {
                dd123 = this.dd_dress_all
            }
            else if (this.s_combobox.selectedIndex == 1) {
                dd123 = this.dd_dress_unlock
            }
            else if (this.s_combobox.selectedIndex == 2) {
                dd123 = this.dd_dress_lock
            }
            let isHaveSelect;
            if (GameMainCollectGardenDressItem.selectVO) {
                for (let index = 0, length = dd123.length; index < length; index++) {
                    const e = dd123[index];
                    if (e[0].id == GameMainCollectGardenDressItem.selectVO[0].id) {
                        // e.isSelect = true;
                        this.collect_update_gardenDressInfo(e)
                        isHaveSelect = 1;
                        break;
                    }
                };
            }
            if (!isHaveSelect) {
                // dd123[0].isSelect = true;
                GameMainCollectGardenDressItem.selectVO = dd123[0]
                this.collect_update_gardenDressInfo(dd123[0])
            }
            this.__list_dress.array = dd123
        }
    }
    collect_theme_info(vo) {
        this.__listTheme.visible = false
        this.look_theme_vo = vo;
        this.__tab.selectedIndex = -1;
        this.__tab.selectedIndex = 1;
    }
    showTheme(t) {
        this.look_theme_vo = null;
        this.btn_closeTheme.visible = true;
        this.btn_theme.visible = false
        this.__tab.mouseEnabled = false;
        this.btn_filter.visible = false;
        this.img_filter_tips.visible = false;
        this.__listTheme.visible = true;

        this.img_show_0.visible = false
        this.img_show_1.visible = false
        this.__list_dress.visible = false;
        this.__list_headFrame.visible = false;

        let n = Object.values(__data.excelConfig.hashGardenTheme)
        this.__listTheme.array = n;

        if (t == 2) {

        }
    }
    closeTheme(isClick) {
        if (this.btn_closeTheme.visible == true && isClick && this.__list_dress.visible == true) {
            // 点击主题显示列表 返回后 需要返回 主题列表
            this.showTheme()
            return
        }
        this.look_theme_vo = null;
        this.btn_closeTheme.visible = false;
        this.btn_theme.visible = true;
        this.__tab.mouseEnabled = true;
        this.btn_filter.visible = true;
        this.img_filter_tips.visible = true;
        this.__listTheme.visible = false
        if (isClick) {
            let index11 = this.s_combobox.selectedIndex
            this.onSelect(this.__tab.selectedIndex)
            this.s_combobox.selectedIndex = index11;
        }
    }
}

