}
class S_login_account extends Laya.Script {
    onClick(e) {
        if (!this.owner.parent.btn_select.select()) {
            return __tips('请同意须知')
        }
        game.scene.add(AppLoginAccount)
    }
}
class S_login_xieyi extends Laya.Script {
    onClick(e) {
        let txt = [{
            "url": `${config.urlHead}rule/yhxy.txt` + __version.res,
            "type": Laya.Loader.TEXT
        }]
        __tool.load(txt, function () {
            // game.scene.remove(LoadingSmall);
            game.scene.add(GameMainSet1)
        }, function (v) {
        })
    }
}
