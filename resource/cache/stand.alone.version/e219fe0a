class S_mm_show_rule extends Laya.Script {
    onClick(e) {
        game.scene.add(MM_remove_rule)
    }
}
class S_mm_stop extends Laya.Script {
    onClick(e) {
        if (S_3D_mjMatch.sendCarding) return __tips('请等待发牌结束')
        this.owner.parent.removeTimer()
        game.scene.add(MM_pause)
    }
}
