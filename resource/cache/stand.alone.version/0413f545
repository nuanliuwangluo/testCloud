class PromptFrame extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/promptFrame',
            layer: 'panel'
        })
        this.btn_no.addComponent(S_prompt_frame_select_cancel)
        this.btn_yes.addComponent(S_prompt_frame_select_sure)
    }
    added(v) {
        let {
            content, success = null, fail = null, txt_sure = '确定',
            txt_cancel = '取消', title = '提示', btn_num = 2,
        } = v
        this.title.text = title
        this.txt.text = content;

        this.txt_sure.text = txt_sure
        this.txt_cancel.text = txt_cancel

        this.sureFN = success
        this.cancelFN = fail;

        this.btn_yes.visible = true;
        this.btn_yes.x = this.width / 2;
        this.btn_no.visible = false;
        if (btn_num == 2) {
            this.btn_no.visible = true;
            this.btn_no.x = 300 + this.btn_no.width / 2;
            this.btn_yes.x = 750 + this.btn_yes.width / 2;
        }
    }
    clickMask() { }
}
class S_prompt_frame_select_sure extends Laya.Script {
    onClick(e) {
        this.owner.parent.sureFN && this.owner.parent.sureFN()
    }
}
class S_prompt_frame_select_cancel extends Laya.Script {
