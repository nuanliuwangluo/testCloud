class GameMainComplaint extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_complaint',
            layer: 'panel'
        })
        game.utils.updateLabelY(this.txt_content)
        game.utils.updateLabelY(this.txt_contact)
        this.btn_submit.addComponent(S_complaint_submit)
        // this.btn_regionCooperation.addComponent(S_complaint_regionCooperation)
    }
    onAwake() {

    }
    onEnable() {
        // if (__data.myCityName == '方正' || __data.myCityName == '通河') {
        //     this.btn_regionCooperation.visible = true
        // } else this.btn_regionCooperation.visible = false

        let time = miniApi.getItem(__data.uid + ':complaint_time')
        if (__tool.isSameDay(new Date(), new Date(Number(time || 0)))) {
            let type = miniApi.getItem(__data.uid + ':complaint_type')
            let content = miniApi.getItem(__data.uid + ':complaint_content')
            let contact = miniApi.getItem(__data.uid + ':complaint_contact')
            if (type)
                this.__radio.selectedIndex = Number(type) - 1
            if (content)
                this.txt_content.text = content
            if (contact)
                this.txt_contact.text = contact
            this.btn_submit.gray = true
        } else {
            this.btn_submit.gray = false;
        }
    }
}
