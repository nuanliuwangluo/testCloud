class S_complaint_submit extends Laya.Script {
    onClick() {
        let time = miniApi.getItem(__data.uid + ':complaint_time')
        if (__tool.isSameDay(new Date(), new Date(Number(time || 0)))) {
            __tips(__lang.submit_gray)
            return;
        }

        let type = this.owner.parent.__radio.selectedIndex + 1;
        trace(`投诉类型 type ${type}`)

        let content = this.owner.parent.txt_content.text;
        let contact = this.owner.parent.txt_contact.text;
        if (String(content).length > 200) {
            __tips(__lang.complaint_content_too_length)
            return
        }
        if (String(contact).length > 20) {
            __tips(__lang.complaint_contact_too_length)
            return
        }
        if (String(content).length <= 0) {
            __tips(__lang.complaint_content_too_less)
            return
        }
        if (String(contact).length <= 0) {
            __tips(__lang.complaint_contact_too_less)
            return
        }
        game.server.send(3336, type, content, contact)
        miniApi.setItem(__data.uid + ':complaint_type', type)
        miniApi.setItem(__data.uid + ':complaint_content', content)
        miniApi.setItem(__data.uid + ':complaint_contact', contact)
        miniApi.setItem(__data.uid + ':complaint_time', Date.now())
        game.scene.remove(this.owner.parent)
    }
}