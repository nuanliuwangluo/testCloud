class GameMainChuanqiReward extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_chuanqiReward',
            layer: 'panel'
        })
        this.btn_silver.addComponent(S_chuanqi_share_silver)
        this.btn_gold.addComponent(S_chuanqi_share_gold)
        this.s1 = this.t1.addComponent(S_click_show_des_set).init('必得金币*888\n富贵竹*1', 0, 0, 'up')
        this.s2 = this.t2.addComponent(S_click_show_des_set).init('必得金币*2888\n富贵竹*3', 0, 0, 'up')

        this.s11 = this.btn_silver.addComponent(S_click_show_des_set).init('', -20, 0, 'up')
        this.s22 = this.btn_gold.addComponent(S_click_show_des_set).init('', -20, 0, 'up')
        this.btn_close.addComponent(S_chuanqia_close123)
    }
    added() {
        miniApi.setItem(__data.uid + ':' + new Date().toDateString() + ':show_panel_chuanqiReward', 1)
        this.update()
        game.cb.on('update_chuanqi_data', this, this.update)
        game.cb.on('update_myCityId', this, this.update)
    }
    onDisable() {
        game.cb.off('update_chuanqi_data', this, this.update)
        game.cb.off('update_myCityId', this, this.update)
        ResUtils.clearTextureRes(['cdn.chuanqiReward', 'cdn.ui1', 'cdn.shareReceiveTips'])
    }
    update() {
        this.s1.useDes = ''
        this.s2.useDes = ''
        for (let index = 0, length = __data.chuanqi.reward.silver.length; index < length; index++) {
            const e = __data.chuanqi.reward.silver[index];
            let name;
            try {
                name = PropIcon.icon[e.id].name
            } catch (error) {

            }
            this.s1.useDes += name + '×' + e.count + '\n';
        };
        for (let index = 0, length = __data.chuanqi.reward.gold.length; index < length; index++) {
            const e = __data.chuanqi.reward.gold[index];
            let name;
            try {
                name = PropIcon.icon[e.id].name
            } catch (error) {

            }
            this.s2.useDes += name + '×' + e.count + '\n';
        };
        this.s1.useDes = this.s1.useDes.slice(0, -1);
        this.s2.useDes = this.s2.useDes.slice(0, -1);

        if (__data.chuanqi.player.uid) {
            let vo = __data.chuanqi.player;
            LabelHiddenUtils.getAdapterContent(this.txt_rank_name, vo.name)
            this.txt_mjName.text = excelUtils.getCityName_mj(vo.cityId)
            this.img_head_frame.skin = PropIcon.icon[vo.headBorderId || 301].skin
            this.img_head.skin = __data.getHeadTestDefault(vo.headUrl)
            this.sp_player.visible = true;
            this.txt_noPlayer.visible = false;
        } else {
            this.sp_player.visible = false;
            this.txt_noPlayer.visible = true;
        }

        this.btn_silver.visible = false
        this.btn_gold.visible = false
        this.btn_silver_has.visible = false
        this.btn_gold_has.visible = false;
        this.s11.useDes = ''
        this.s22.useDes = ''
        if (__data.chuanqi.isRedPoint) {
            this.btn_silver.gray = true
            this.btn_gold.gray = true
            this.btn_silver.visible = true
            this.btn_gold.visible = true
            if (__data.myCityId == __data.chuanqi.player.cityId) {
                this.btn_gold.gray = false;
                this.s11.useDes = `当前“我的玩法”不符合开启条件`
            } else {
                this.btn_silver.gray = false;
                this.s22.useDes = `当前“我的玩法”不符合开启条件`
            }
        }
        if (__data.chuanqi.reward.receiveStatus == 3) {
            this.btn_silver_has.visible = true
            this.btn_gold_has.visible = true
        }
    }
    clickMask() {
        game.scene.remove(this)
        hallTestShowPanel()
    }
}
class S_chuanqia_close123 extends Laya.Script {
    onClick(e) {
        hallTestShowPanel()
    }
}
class S_chuanqi_share_silver extends Laya.Script {
    onClick() {
        if (this.owner.gray) return
        game.server.send(16014)
        miniApi.share({
            titleId: 12,
            imgId: 'boxSilver',
            shareVerifyOnShowFnTime: __data.shareVideoRule.isVerifyShareOnShowTime,
            params: `uid=${__data.uid}&myCityId=${__data.myCityId}&shareRewardType=chuanqiSilver`,
            shareGroupClickCallback: () => {
                game.server.send(16010)
                game.scene.remove(GameMainRedPacket_2)
            },
            shareOnShowCallback: () => {
                game.scene.add(GameMainRedPacket_2)
            }
        })
    }
}
