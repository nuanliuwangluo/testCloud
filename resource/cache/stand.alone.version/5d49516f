/**
 * 被代理的类必须要实现  除 destroy proxy 以外的所有方法
 */
class LookVideoProxy {

    /**
     * 销毁代理类
     */
    static destroy() {
        this._class = null;
        this._active = false;
    }

    /**
     * 要代理的类
     */
    static proxy(_class) {
        this._class = _class;
        this.sceneHandle();
    }

    static get classIsExist() {
        if (this._class) {
            return true;
        } else {
            return false;
        }
    }

    static get active() { return this._active; }
    static set active(value) {
        this._active = value;
        this.sceneHandle();
    }

    static sceneHandle() {
        if (this.canBeShow) {
            if (LookVideoProxy.type == LookVideoProxy.TYPE_WIN)
                __showScene.show_gameMain_lookVideo_win();
            else if (LookVideoProxy.type == LookVideoProxy.TYPE_LOSE)
                __showScene.show_gameMain_lookVideo_lose();
        }
    }
    static get canBeShow() {
        return this.classIsExist && this.active;
    }

    static set type(value) { this._type = value; }
    static get type() { return this._type; }

    static get TYPE_WIN() { return "win"; }
    static get TYPE_LOSE() { return "lose"; }

    // 上面的方法不需要被代理的类实现  
    //----------------------------------------------------------------
    // 下面的方法必须被代理的类实现

    static get time() {
        return this._class.time;
    }

    static get gold() {
        return this._class.gold;
    }

    static get nextDoubleGold() { return 2300; }

    static get doubleGold() {
        return this._class.doubleGold;
    }

    /**
     * 视频成功调用
     */
    static lookVideoSuccess() {
        if (this.type == this.TYPE_WIN)
            game.server.send(3331, 1);
        else if (this.type == this.TYPE_LOSE)
            game.server.send(3333, 1);
    }

    /**
     * 视频失败调用
     */
    static lookVideoFail() { }
}