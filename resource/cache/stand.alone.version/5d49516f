class GiveupWarnPanel extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_game/result/GiveupWarnPanel',
            layer: 'panel'
        })
        this.mouseThrough = true;
        this.btn_done.on(Laya.Event.CLICK, this, this._onDone);
        this.btn_giveup.on(Laya.Event.CLICK, this, this._onGiveup);
    }

    added(done, giveup) {
        this.done = done;
        this.giveup = giveup;
        this.btn_remember.selected = false;
        HtmlTextUtils.text(
            this.txt, { align: 'center', valign: 'top', fontSize: 40, bold: false, leading: 25, width: this.width, color: '#000000' },
            '真的要放弃&nbsp;', {},
            LookVideoProxy.gold, { color: '#ff2521' },
            '&nbsp;金币吗？/br放弃特权后今日激励金将减半！', {}
        )
        Laya.timer.callLater(this, this._relocationHtml);
    }

    _relocationHtml() {
        this.txt.x = this.width - this.txt.displayWidth >> 1;
    }

    _onDone() {
        this.done && this.done();
        if (this.btn_remember.selected) { LocalUtils.saveByToday('TODAY_GIVEUP_RECORD', 'TRUE'); }
        // this.remove();
    }

    _onGiveup() {
        this.giveup && this.giveup();
        LocalUtils.saveByToday('TODAY_GIVEUP_RECORD', 'TRUE');
        // this.remove();
    }

    remove() {
        game.scene.remove(this);
    }

    clickMask() { }
}


