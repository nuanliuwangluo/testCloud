        game.utils.remove(this.play_c);

        this.__data = __data.deskData.roomVo.allRoundResult;

        this.list.array = this.__data.playerArray;
        //日期
        this.txtDate.text = game.utils.timeToString(this.__data.time || new Date(), ' ');
        //房间号
        this.txtRoomInfo.text = "房间号：" + this.__data.roomPwd;
        //房间信息
        this.txtPlay.text = this.getExplain();

        Laya.timer.callLater(this, this.adapterPlayer);
        // Laya.timer.once(1000, this, this.showFriendRed);
        // this.showFriendRed();
    }

    showFriendRed() {
        let ids = __data.deskData.roomVo.getPlayerIds();
        for (let i = 0; i < ids.length; i++) {
            let status = __data.friendRoom.red.getRedStatus_room(ids[i]);
            if (status == 1 || status == 2) {
                if (ids[i] == __data.uid) {
                    game.server.send(18020)
                } else {
                    __showScene.show_friendRoom_redSuccess(ids[i]);
                }
            }
        }
    }

    added(isLook) {
        this.btn_play.visible = isLook;
        this.btn_c.visible = !isLook;
        this.btn_play.on(Laya.Event.CLICK, this, this._toHall);
        this.btn_rp.on(Laya.Event.CLICK, this, this._onShowPlays);
    }

    _toHall() {
        __showScene.show_hall();
    }

    _onShowPlays(e) {
        e && e.stopPropagation();
        this.addChild(this.play_c);
    }

    getExplain() {
        // ${MahjongNameUtils.getPrefix(__data.deskData.roomVo.allRoundResult.curRuleId)} 删除无用的前缀代码
        let name = `【${MahjongConfig.getName(__data.deskData.roomVo.allRoundResult.lastCityId, __data.deskData.roomVo.allRoundResult.curRuleId)}】`;
        let player = `${__data.deskData.roomVo.allRoundResult.playerArray.length}人`;
        let round = `${__data.deskData.roomVo.allRoundResult.roundCount}局`;
        let plays = FriendRoomPlays.getPlaysInfo(__data.deskData.roomVo.allRoundResult.curRuleId, __data.deskData.roomVo.allRoundResult.roomPlay);
        return name + [player, round, plays].join(',');
    }

    onDisable() { __data.deskData.roomVo.allRoundResult = null }
}
