        this.play_c.height = this.txtPlay.height + this.txtPlay.y * 2;
        this.sign.y = this.play_c.height - 8;
        this.play_c.pivot(this.sign.x + this.sign.width / 2, this.sign.y + this.sign.height);
        this.play_c.pos(this.btn_rp.x, this.btn_rp.y - this.btn_rp.height / 2);
