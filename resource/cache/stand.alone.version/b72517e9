        Laya.timer.callLater(this, this.adapterPlayer);
        Laya.timer.callLater(this, this.showIcons);
    }

    showIcons() {
        if (__data.deskData.roomVo.isRecordPlaying) {
            this.btn_pray.visible = false;
            game.utils.remove(this.quickPray);
            return
        }

        this.btn_pray.visible = true;

        let safe_area = miniApi.statusBarRatio() * game.width;
        let icon_space = 20;
        this.btn_pray.x = -this.x + 30 + safe_area;

        this.friendRed.x = this.btn_pray.x + this.btn_pray.width * this.btn_pray.scaleX + icon_space;
        if (this.__data.isOver) {
            let ids = __data.deskData.roomVo.getPlayerIds();
            for (let i = 0; i < ids.length; i++) {
                let status = __data.friendRoom.red.getRedStatus_room(ids[i]);
                if (status == 1 || status == 2) {
                    if (ids[i] == __data.uid) {
                        game.server.send(18020)
                    } else {
                        __showScene.show_friendRoom_redSuccess(ids[i]);
                    }
                    break;
                }
            }
        }
        let info = PrayStatistics.instance.checkResultTrigger();
        if (info) { this.quickPray.source(info, '结算'); this.addChild(this.quickPray); }
        else { game.utils.remove(this.quickPray); }
    }

    baoHandle() {
        let list = typeof this.baoCode == 'number' ? [this.baoCode] : typeof this.baoCode == 'string' ? this.baoCode.split(',') : [255];
        this.list_bao.array = list;
        this.list_bao.repeatX = this.list_bao.array.length;

        this.list_m.array = GdHorseInfo.horses.all;
        this.list_m.repeatX = this.list_m.array.length;
        this.mFont.x = this.list_m.x + this.list_m.width + 10;
        this.gdm.width = this.mFont.x + this.mFont.width;
        this.adapterPlayer();
    }

    onDisable() {
        FriendMahjongSmallResult.isShow = false;
        GdHorseInfo.clear();
        game.cb.off('result_item_look_player', this, this.lookPlayer);
        game.cb.off(__eh + 'update_user_info', this, this.updateDataHandler)
    }

    setPlayer() {
        for (let i = 0; i < this.__data.playerArray.length; i++) {
            this.playerlist[i].dataSource = this.__data.playerArray[i];
        }
    }

    startAni() {
        this.leftup.x = this.leftup_originx - 1000;
        this.leftdown.x = this.leftdown_originx - 1000;
        this.rightup.x = this.rightup_originx + 1000;
        this.rightdown.x = this.rightdown_originx + 1000;
        // let scaleTime = 300;
        // this.topcIss.init(1, scaleTime);
        // this.topcIss.start();
        let moveTime = 300;
        let delayTime = 0;
        Laya.Tween.to(this.leftup, { x: this.leftup_originx }, moveTime, Laya.Ease.expoOut, null, 0 * delayTime);
        Laya.Tween.to(this.rightup, { x: this.rightup_originx }, moveTime, Laya.Ease.expoOut, null, 1 * delayTime);
        Laya.Tween.to(this.leftdown, { x: this.leftdown_originx }, moveTime, Laya.Ease.expoOut, null, 2 * delayTime);
        Laya.Tween.to(this.rightdown, { x: this.rightdown_originx }, moveTime, Laya.Ease.expoOut, null, 3 * delayTime);
        Laya.timer.once(3 * delayTime + moveTime, this, this._allAniComplete);

        __sound.gameSound("end");
    }

    _playerAni() {

    }

    _rankAniComplete() {
        game.cb.event('RESULT_ANI_RANK_FLY');
    }

    _allAniComplete() {
        this.showButton();
    }

    hideButton() {
        this.btn_quit.visible = false;
        this.btn_goon.visible = false;
        this.btn_all.visible = false;
    }

    showButton() {
        if (__data.deskData.roomVo.isRecordPlaying) { return; }
        this.btnTween && this.btnTween.clear();
        if (this.__data.isOver) this.btn_all.visible = true;
        else this.btn_goon.visible = true;
        this.c_btn.scale(0, 0);
        this.btnTween = this.btnTween || new Laya.Tween();
        this.btnTween.to(this.c_btn, { scaleX: 1, scaleY: 1 }, 250);
    }

    lookPlayer(object, side, point) {
        let position = object ? object.position : null;
        position = position || this.__data.huPositionArr[0] || this.__data.playerArray[0].position;
        Laya.timer.callLater(this, this.showSign, [position, side, point])
    }
    showSign(position, side, point) {
        // this.winnerUI.visible = true;
        point = this.globalToLocal(point);
        for (let i = 0; i < this.__data.playerArray.length; i++) {
            if (this.__data.playerArray[i].position == position) {
                // this.winnerUI.dataSource = this.__data.playerArray[i];
                // this.winnerUI.side = side;
                game.scene.add(MahjongResultDetails, [{
                    position: this.__data.myPosition,
                    player: this.__data.playerArray[i],
                    playerArray: this.__data.playerArray,
                    winners: this.__data.huPositionArr,
                    details: MahjongResultDetailsData.getDetails()
                }]);
            }
        }
        // this.winnerUI.pos(point.x - this.winnerUI.offx, point.y);
    }

    lookAllResultHandler() {
        game.utils.remove(this);
        // game.scene.add(DeskResultBG);
        // game.scene.add(MahjongAllResult);
    }

    updateDataHandler() { this.setPlayer(); }

    static set isShow(value) { this._isShow = value; }
    static get isShow() { return this._isShow; }
}
