            // if (this.__data.score >= 0) {
            //     this.txtScore.urls__ = this.greenArr;
            //     this.txtScore.text = '+' + this.__data.score
            // } else {
            //     this.txtScore.urls__ = this.redArr;
            //     this.txtScore.text = this.__data.score
            // }
            // this.txtScore.x = this.img_hu.x + this.img_hu.width + 60;
            // this.txtScore.y = this.height - this.txtScore.height - 10;

            // this.addChild(this.txtScore)

            let formatScore = GoldFormatUtils.format(this.__data.score, 2);
