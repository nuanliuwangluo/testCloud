            }
        } else if (__data.gameId.curId == FriendRoomPlays.CITY.TANGYUAN && HallPlay.curRuleId > 0) {
            this.baoCode = this.__data.baoCode;
            SkinUtils.setSkin(this.baoFont, '');
            this.yf.visible = true;
            this.yf.x = this.txt_bottom_score.x + this.txt_bottom_score.width + 30;
            if (this.baoCode == 255 || !__data.deskData.roomVo.getIncludeRule(Play_tangyuan.FISH)) {
                this.txt_fish_score.text = 0;
            } else this.txt_fish_score.text = this.baoCode >= 40 ? 10 : (this.baoCode + 1) % 10;
            this.bg.addChild(this.txt_fish_score).pos(this.yf.x + this.yf.width + 10, this.yf.y + (this.yf.height - this.txt_fish_score.height) / 2);
        } else if (HallPlay.curRuleId == FriendRoomPlays.AREA.FUYUAN) {
            this.baoCode = this.__data.baoCode;
            SkinUtils.setSkin(this.baoFont, 'cdn/mahjong_result/mahjong_result/img_zy.png');
        } else if (HallPlay.curRuleId == FriendRoomPlays.AREA.TONGJIANG) {
            this.baoCode = this.__data.baoCode;
            SkinUtils.setSkin(this.baoFont, 'cdn/mahjong_result/mahjong_result/img_hp.png');
        } else if (HallPlay.curRuleId == FriendRoomPlays.AREA.JIXI) {
            this.baoCode = this.__data.baoCode;
            SkinUtils.setSkin(this.baoFont, 'cdn/mahjong_result/mahjong_result/img_bp.png');
            if (this.__data.mondayPieceCode != 255) {
                this.c_mp.visible = true;
                this.c_mp.getChildByName('list').array = [this.__data.mondayPieceCode];
            }
        } else if (HallPlay.curRuleId == FriendRoomPlays.AREA.GUANGDONG) {
            // this.baoCode = this.__data.baoCode;
            this.baoCode = GdGhost.getGhost(this.__data.baoCode)
            this.gdm.visible = true;
            SkinUtils.setSkin(this.baoFont, 'cdn/mahjong_result/mahjong_result/img_gp.png');
        } else if (HallPlay.curRuleId == FriendRoomPlays.AREA.SHUANGYASHAN) {
            this.baoCode = this.__data.baoCode;
            let isFish = this.__data.wfArray.find((value) => { return value == Play_shuangyashan.SEA });// 是否为对海洋
            if (isFish) {
                SkinUtils.setSkin(this.baoFont, 'cdn/mahjong_result/mahjong_result/hy.png');
            } else {
                SkinUtils.setSkin(this.baoFont, 'cdn/mahjong_result/mahjong_result/zyz.png');
            }
        } else {
            this.baoCode = this.__data.baoCode;
            SkinUtils.setSkin(this.baoFont, 'cdn/mahjong_result/mahjong_result/img_bp.png');
        }

        // if (__data.domain == 13) {
        //     baoCode = this.__data.mixed;
        //     SkinUtils.setSkin(this.baoFont, 'cdn/mahjong_result/mahjong_result/img_hp.png');
        // } else {
        //     baoCode = this.__data.baoCode;
        //     SkinUtils.setSkin(this.baoFont, 'cdn/mahjong_result/mahjong_result/img_bp.png');
        // }

        SkinUtils.setSkin(this.result, this.__data.myResult ? 'cdn/mahjong_br/mahjong_br/bg_js1ah.png' : 'cdn/mahjong_br/mahjong_br/bg_js2ah.png');

        this.baoHandle();
