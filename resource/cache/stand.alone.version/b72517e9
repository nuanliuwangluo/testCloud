class FriendRoomTrackEvent {
    static trackEvent() {
        try {
            if (__data.deskData.roomVo.roomModel != __data.deskData.roomVo.FRIEND) { return; }
            let umEventName = excelUtils.getUmEventName(HallPlay.lastCityId)
            let countyName = umEventName;// 地区
            let round = String(__data.deskData.roomVo.allGame);// 总局数
            let result = __data.deskData.roomVo.smallResultData.myResult ? '胜利' : '失败'; // 胜利 失败
            let uid = __data.uid.toString();// 用户id
            let gameMethod = excelUtils.getPlayIdName(__data.deskData.roomVo.modelId);// 玩法名称
            let coins = parseInt(__data.deskData.roomVo.smallResultData.myScore);// 结算分数
            let victoryMethod = '未知';// 胡牌方式
            let vip = __data.vip.isVip ? '是' : '否'; // vip
            let surplus = __data.deskData.roomVo.smallResultData.surplus; // 剩余牌数
            let specialCard = 0;// 特殊牌型
            let lastGame = __data.deskData.roomVo.smallResultData.isOver ? '是' : '否';// 是否为最后一局

            let vms = ['接炮', '自摸', '摸宝', '漏宝', '射宝', '对宝', '大风', '红中', '天胡'];
            for (let i = 0; i < __data.deskData.roomVo.smallResultData.playerArray.length; i++) {
                let player = __data.deskData.roomVo.smallResultData.playerArray[i];
                let winner = player.winPosition.indexOf(player.position) != -1;
                if (winner) {
                    let explains = player.scoreInfo.split(' ');
                    for (let j = 0; explains && j < explains.length; j++) {
                        if (victoryMethod != '未知') continue;
                        let explain = explains[j];
                        for (let z = 0; z < vms.length; z++) {
                            if (victoryMethod != '未知') continue;
                            // 找到这个描述文字了
                            if (explain.indexOf(vms[z]) != -1) {
                                victoryMethod = vms[z];
                                break;
                            }
                        }
                    }
                }
                // 方正
                if (player.id == __data.uid && (HallPlay.lastCityId == 8 || HallPlay.lastCityId == 10)) {
                    for (let s = 0; s < player.tileGroupArray.length; s++) {
                        let group = player.tileGroupArray[s];
                        let isXi = group.startsWith('82');
                        isXi && specialCard++;
                    }
                }
                // 富锦
                if (player.id == __data.uid && HallPlay.lastCityId == 13) {
                    let hands = [].concat(player.handTileArray);
                    let picks = __compUtils.pickup(hands, __data.deskData.roomVo.mixedArr);
                    specialCard = picks.pickups ? picks.pickups.length : 0;
                }
                // 泰来
                if (player.id == __data.uid && HallPlay.lastCityId == 111) {
                    for (let s = 0; s < player.tileGroupArray.length; s++) {
                        let group = player.tileGroupArray[s];
                        let isXi = group.startsWith('82');
                        isXi && specialCard++;
                    }
                }
                // 汤原 经典黑龙江
                if (player.id == __data.uid && (HallPlay.lastCityId == 21 || HallPlay.curRuleId == -1)) {
                    for (let s = 0; s < player.tileGroupArray.length; s++) {
                        let group = player.tileGroupArray[s];
                        let isGang = group.startsWith('5');
                        isGang && specialCard++;
                    }
                }
            }

            // 我赢了 需要Mj_VictoryMethod字段
            if (__data.deskData.roomVo.smallResultData.myResult) {

                // 赢家找到的 是未知
                if (victoryMethod == '未知') {
                    for (let i = 0; i < __data.deskData.roomVo.smallResultData.playerArray.length; i++) {
                        let player = __data.deskData.roomVo.smallResultData.playerArray[i];
                        let loser = player.winPosition.indexOf(player.position) == -1;
                        if (loser) {
                            let explains = player.scoreInfo.indexOf('炮');
                            if (explains != -1) { // 输家的描述中找到了 炮字
                                victoryMethod = '接炮';
                                break;
                            }
                        }
                    }
                }

                miniApi.trackEvent('Mj_FriendGame', {
                    'Mj_County': countyName,
                    'Mj_GameNumber': round,
                    'Mj_Results': result,
                    'Mj_UserID': uid,
                    'Mj_GameMethod': gameMethod,
                    'Mj_Score': coins,
                    'Mj_VictoryMethod': victoryMethod,
                    'Mj_VIP': vip,
                    'Mj_Remainder': surplus,
                    'Mj_SpecialCard': specialCard,
                    'Mj_LastGame': lastGame
                });
            }
            // 我输了   不要Mj_VictoryMethod 这个字段
            else {
                miniApi.trackEvent('Mj_FriendGame', {
                    'Mj_County': countyName,
                    'Mj_GameNumber': round,
                    'Mj_Results': result,
                    'Mj_UserID': uid,
                    'Mj_GameMethod': gameMethod,
                    'Mj_Score': coins,
                    'Mj_VIP': vip,
                    'Mj_Remainder': surplus,
                    'Mj_SpecialCard': specialCard,
                    'Mj_LastGame': lastGame
                });
            }
        } catch (e) {

        }
    }
}
