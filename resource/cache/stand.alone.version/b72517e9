        this.redArr['-'] = 'local/desk_common_num/1/img_red_reduce.png'
    }

    onAwake() { }

    onEnable() {
        game.utils.remove(this.ownerImg)
        game.cb.on(__eh + 'update_user_info', this, this.updateDataHandler)
    }

    onDisable() {
        game.cb.off(__eh + 'update_user_info', this, this.updateDataHandler)
    }

    updateDataHandler() {
        if (this.__data) {
            this.txt_name.text = this.__data.name
            this.txt_id.text = 'ID：' + this.__data.id;
            trace('结算用户信息：', this.__data);
            if (__data.othersVO[this.__data.id]) SkinUtils.setSkin(this.head.getChildByName('head'), __data.othersVO[this.__data.id].headUrl);
            else if (this.__data.url) SkinUtils.setSkin(this.head.getChildByName('head'), this.__data.url);
            else SkinUtils.setSkin(this.head.getChildByName('head'), '');

            if (__data.othersVO[this.__data.id]) SkinUtils.setSkin(this.head.getChildByName('frame'), PropIcon.icon[__data.othersVO[this.__data.id].headFrameId || 301].skin);
            if (this.__data.headFrameId) SkinUtils.setSkin(this.head.getChildByName('frame'), PropIcon.icon[this.__data.headFrameId || 301].skin);
            else SkinUtils.setSkin(this.head.getChildByName('frame'), PropIcon.icon[301].skin);
        }
    }

    set dataSource(value) {
        if (!value) { return }
        this.__data = value;
        this.updateDataHandler();
        // if (__data.othersVO[value.id]) {
        //     this.updateDataHandler();
        // } else { game.server.send(2005, value.id) }

        this.relocationTxt();

        if (__data.deskData.roomVo.roomOwner == this.__data.id) { this.addChild(this.ownerImg) }

        if (this.__data.id == __data.uid) SkinUtils.setSkin(this.bg, 'cdn/mahjong_br/mahjong_br/img_playerb.png');
        else SkinUtils.setSkin(this.bg, 'cdn/mahjong_br/mahjong_br/img_playera.png');

        // if('a' == '交分'){ SkinUtils.setSkin(this.gold, 'cdn/mahjong_result/mahjong_result/img_jiaof.png'); }
        // else { SkinUtils.setSkin(this.gold, 'cdn/mahjong_result/mahjong_result/img_jf.png'); }
    }

    relocationTxt() {
        let formatScore = GoldFormatUtils.format(this.__data.score, 2);
        if (this.__data.score == 0) {
            this.txt_score.text = '-0';
        } else if (this.__data.score > 0) {
            this.txt_score.text = '+' + formatScore;
        } else if (this.__data.score < 0) {
            this.txt_score.text = formatScore;
        }
        let space = 10;
        let width = this.txt_score.width + this.gold.width + space;
        let startx = (this.width - width) / 2;
        this.gold.x = startx;
        this.txt_score.x = this.gold.x + this.gold.width + space;
        this.txt_score.color = this._scoreColor(this.__data.score);
    }

    /**
     * 输赢分数的颜色
     * @param {int} score 
     * @returns 
     */
    _scoreColor(score) {
        if (score > 0)
            return '#6caa01';
        else
            return '#ea7779';
    }

    get dataSource() {
        return this.value
    }
}

