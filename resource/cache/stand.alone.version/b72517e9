            } else if (this.__data.score < 0) {
                this.txt_score.text = formatScore;
            }
            this.txt_score.color = this._scoreColor(this.__data.score);
        } else {
            if (__data.deskData.roomVo.roomPlay.split(",").indexOf("13") > -1) { this.__data.winnerMixedNumber = 0; }

            let __hunScore = 0;
            let __fanScore = 0;
            let __baseScore = 0;

            __baseScore = (__data.deskData.roomVo.roomPlay.split(",").indexOf("9") > -1) ? -1 : (__data.deskData.roomVo.roomPlay.split(",").indexOf("10") > -1) ? -2 : (__data.deskData.roomVo.roomPlay.split(",").indexOf("11") > -1) ? -3 : (__data.deskData.roomVo.roomPlay.split(",").indexOf("14") > -1) ? -5 : (__data.deskData.roomVo.roomPlay.split(",").indexOf("15") > -1) ? -10 : 0

            if (this.__data.huPosition.length > 0) {
                if (this.__data.winPosition.indexOf(this.__data.position) > -1) {
                    __hunScore = this.__data.winnerMixedNumber * (__data.deskData.roomVo.roomPlayer - 1) * Math.abs(__baseScore)
                    __fanScore = this.__data.score - __hunScore
                } else {
                    __hunScore = this.__data.winnerMixedNumber * __baseScore
                    __fanScore = this.__data.score - __hunScore
                }
            }

            // this.txtScore = this.txtScore || new game.NumText(this.greenArr)
            // if (this.__data.score >= 0) {
            //     this.txtScore.urls__ = this.greenArr;
            //     this.txtScore.text = '+' + this.__data.score.toString()
            // } else {
            //     this.txtScore.urls__ = this.redArr;
            //     this.txtScore.text = this.__data.score.toString()
            // }
            // this.txtScore.x = this.img_hu.x + this.img_hu.width + 55;
            // this.txtScore.y = 40

            // this.addChild(this.txtScore)

            if (__data.deskData.roomVo.smallResultData.isJiao) {
                SkinUtils.setSkin(this.gold, 'cdn/mahjong_result/mahjong_result/img_jiaof.png');
                let formatScore = GoldFormatUtils.format(this.__data.score, 2);
                if (this.__data.score == 0) {
                    this.txt_score.text = '-0';
                } else if (this.__data.score > 0) {
                    this.txt_score.text = '+' + formatScore;
                } else if (this.__data.score < 0) {
                    this.txt_score.text = formatScore;
                }
                this.txt_score.color = this._scoreColor(this.__data.score);
            }
            else {
                SkinUtils.setSkin(this.gold, 'cdn/mahjong_result/mahjong_result/img_jf.png');
                let formatScore = GoldFormatUtils.format(this.__data.score, 2);
                if (this.__data.score == 0) {
                    this.txt_score.text = '-0';
                } else if (this.__data.score > 0) {
                    this.txt_score.text = '+' + formatScore;
                } else if (this.__data.score < 0) {
                    this.txt_score.text = formatScore;
                }
                this.txt_score.color = this._scoreColor(this.__data.score);
            }
        }



        let __hunInfo = '';
        __data.deskData.roomVo.playArea = (__data.deskData.roomVo.roomPlay.indexOf('99') != -1) ? 99 : 98
        if (__data.gameId.curId == 13 && HallPlay.curRuleId > 0) {
            if (__data.deskData.roomVo.playArea == 98) {
                __hunInfo = (this.__data.winnerMixedNumber > 0) ? '混×' + this.__data.winnerMixedNumber : '';
            }
        }


        var infoStr = '';
        //胡的说明  具体为后端 提供
        if (this.__data.scoreInfo) {
            if (this.__data.winPosition.indexOf(this.__data.position) != -1) {
                infoStr = this.__data.scoreInfo.endsWith(' ') ? this.__data.scoreInfo + __hunInfo : this.__data.scoreInfo + ' ' + __hunInfo;
            } else {
                infoStr = this.__data.scoreInfo;
            }
        } else {
            infoStr = '';
        }
        // this.txt_info.overflow = 'visible';
        this.txt_info.fontSize = 32;
        this.txt_info.text = this.autoInfoText(infoStr);

        // this.container.width = this.txt_score.x + this.txt_score.width;
        // this.container.x = this.width - this.container.width >> 1;

        let url = this.bgSkin;
        let result = __data.deskData.roomVo.smallResultData.myResult;
        if (this.__data.id == __data.uid) {
            url = url.replace('player1', 'playerme');
        } else if (!result) {
            url = url.replace('player1', 'player2');
        }
        SkinUtils.setSkin(this.bg, url);

        //获取当前用户vo
        let __vo = __data.deskData.roomVo.getPlayer(this.__data.id);
        //当前用户和庄的位置一致 与不一致 的显示与移除
        if (__vo && __vo.position == __data.deskData.roomVo.bankerPosition) this.addChild(this.branker)
        else game.utils.remove(this.branker)

        //胡的位置 显示胡的标志
        if (this.__data.winPosition.indexOf(this.__data.position) != -1) {
            this.__data.winner = true;
            this.addChild(this.img_hu)
        } else {
            this.__data.winner = false;
            game.utils.remove(this.img_hu);
        }

        if (this.__data.winner) {
            SkinUtils.setSkin(this.btn_look, 'cdn/mahjong_result/mahjong_result/bt_ck2.png');
        } else {
            SkinUtils.setSkin(this.btn_look, 'cdn/mahjong_result/mahjong_result/bt_ck.png');
        }

        // 头像地址
        if (__vo) {
            SkinUtils.setSkin(this.head.getChildByName('frame'), __vo.frameUrl);
            if (__vo.url) {
                SkinUtils.setSkin(this.head.getChildByName('head'), __vo.url);
            } else {
                SkinUtils.setSkin(this.head.getChildByName('head'), '');
            }
        }

        this.relocationUI();
    }


    autoInfoText(str) {
        var list = str.split(' ');
        let returnStr = '';
        let temp_list = [];
        for (let i = 0; i < list.length; i++) {
            temp_list.push(list[i]);
            if (temp_list.join(' ').length > 13) {
                temp_list.pop();
                returnStr += temp_list.join(' ') + '\n';
                temp_list = [];
                i--;
            }
        }
        returnStr += temp_list.join(' ');
        return returnStr;
    }


    relocationUI() {
        if (this.side == 'left') {
            this.c_img.x = this.txt_score.x + this.txt_score.textField.textWidth + 30;
            this.c_img.y = this.txt_score.y + (this.txt_score.height - this.c_img.height) / 2;
        } else if (this.side == 'right') {
            this.container.x = this.txt_score.x + this.txt_score.width - this.txt_score.textField.textWidth - this.gold.width - 30;
            this.c_img.x = this.container.x - 30;
            this.c_img.y = this.txt_score.y + (this.txt_score.height - this.c_img.height) / 2;
        }
    }

    showPropertys() {
        let imgs = [];
        //  -1  破产   
        if (this.__data.propertyState == -1 && __data.deskData.roomVo.roomModel != __data.deskData.roomVo.FRIEND) {
            let img = Laya.Pool.getItemByClass('RESULT_PROPERTYS', Laya.Image);
            SkinUtils.setSkin(img, 'local/game_common/1/ic_pc.png');
            imgs.push(img);
        }
        //  1 上限
        if (this.__data.propertyState == 1) {
            let img = Laya.Pool.getItemByClass('RESULT_PROPERTYS', Laya.Image);
            SkinUtils.setSkin(img, 'local/game_common/1/ic_sx.png');
            imgs.push(img);
        }
        //  2 封顶
        if (this.__data.propertyState == -2) {
            let img = Laya.Pool.getItemByClass('RESULT_PROPERTYS', Laya.Image);
            SkinUtils.setSkin(img, 'local/game_common/1/img_fd.png');
            imgs.push(img);
        }

        while (this.c_img.numChildren) {
            let node = this.c_img.removeChildAt(0);
            node.off(Laya.Event.CLICK, this, this._lookBzexplain);
            Laya.Pool.recover('RESULT_PROPERTYS', node);
        }

        this.c_img.height = 0;
        for (let i = 0; i < imgs.length; i++) {
            this.c_img.addChild(imgs[i]);
            imgs[i].x = this.side == 'left' ? 0 : -imgs[i].width; // this.c_img.width == 0 ? this.c_img.width : this.c_img.width + 10;
            imgs[i].y = this.c_img.height == 0 ? 0 : this.c_img.height + 5; // this.c_img.height - imgs[i].height >> 1;
            this.c_img.height = imgs[i].y + imgs[i].height;
        }
    }

    showSign(position) {
        if (this.__data.position == position) {
            game.cb.event('result_player_card', [this.__data]);
        }
    }

    _lookPlayer(e) {
        e && e.stopPropagation();
        game.cb.event('result_item_look_player', [this.__data, this.side, this.localToGlobal(new Laya.Point(this.btn_look.x, this.btn_look.y + this.btn_look.height / 2))]);
    }

    _lookBzexplain(e) {
        // 封顶开始游戏 且 输了的玩家  
        if (parseInt(this.__data.isMaxMatch) && this.__data.winPosition.indexOf(this.__data.position) == -1) {
            miniApi.trackEvent('Mj_UIClick', { 'Mj_ClickScene': '封顶开始说明' });
            let point = this.localToGlobal(new Laya.Point(this.c_img.x + e.currentTarget.x + e.currentTarget.width / 2, this.c_img.y + e.currentTarget.y + e.currentTarget.height));
            BagInfoUtils.init('prefab/ResultExplainTips.json', true);
            BagInfoUtils.show('此玩家已激活封顶开始，损失金币以赢家拥有金币为封顶上限', point, game.scene.layer['panel'].c);
        }

        // 胡的位置  且是 vip 用户 
        if (this.__data.winPosition.indexOf(this.__data.position) != -1 && this.__data.isVip) {
            // 触发了 全额保障
            if (ResultPanelManager.compensateGold()) {
                miniApi.trackEvent('Mj_UIClick', { 'Mj_ClickScene': '全额保障说明' });
                game.scene.add(MahjongResultCompensateExplain, [this.triggerCompensateGroups()])
            }
        }
    }

    /**
     * 输赢分数的颜色
     * @param {int} score 
     * @returns 
     */
    _scoreColor(score) {
        if (score > 0)
            return '#6caa01';
        else
            return '#ea7779';
    }
}


