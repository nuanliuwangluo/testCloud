class MahjongSmallResultInfoScript extends Laya.Script {

    bind(container) {
        this.container = container;
    }

    onEnable() {
        this.showInfo();
        this.owner.getChildByName('btn_play').on(Laya.Event.CLICK, this, this._showPlayContiner);
    }

    onDisable() {
        this.owner.getChildByName('btn_play').off(Laya.Event.CLICK, this, this._showPlayContiner);
    }

    showInfo() {
        this.owner.getChildByName('txt_id').text = `房间号:${__data.deskData.roomVo.roomID}`;
        this.owner.getChildByName('txt_round').text = this.getRound();
        if (__data.deskData.roomVo.isRecordPlaying) this.container.visible = true;
        else this.container.visible = false;
    }

    getRound() {
        if (HallPlay.curRuleId == FriendRoomPlays.AREA.WUHU) {
            return `第${__data.deskData.roomVo.curGame - 1}局`;
        } else if (HallPlay.curRuleId == FriendRoomPlays.AREA.TONGJIANG) {
            return `第${__data.deskData.roomVo.curGame - 1}局`;
        } else {
            return `第${Math.min(__data.deskData.roomVo.curGame - 1, __data.deskData.roomVo.allGame)}/${__data.deskData.roomVo.allGame}局`;
        }
    }

    _showPlayContiner(e) {
        e && e.stopPropagation();
        Laya.timer.callLater(this, this.hideOrShow);
    }

    hideOrShow() {
        if (this.container && this.container.visible)
            this.container.visible = false;
        else
            this.container.visible = true;
    }
}

