    lxGuideHandler(){
        return;
        //选择亮喜的组合
        let __groupArr = [];
        for (let i = 0; i < this.list.length; i++) {
            let __lxScript = this.list[i].getComponent(Mahjong_Lx_Script)
            __lxScript && __lxScript.selected && __groupArr.push(parseInt(this.list[i].card))
        }
        __groupArr.sort(function(a, b) { return a - b })

        if(__groupArr.length < 3)game.cb.event('disabled_lx_button')
        else if(__groupArr.length == 3)game.cb.event('allow_lx_button')
        else { game.cb.event('remove_lx_btn_guide');game.cb.event('disabled_lx_button');return; }

        let collections = LxRules.getYj(__groupArr, [40, 41, 42]);
        this.updateLxScriptFilter(collections);


        let cup = __data.hashCityLevelCup[HallPlay.lastCityId].cup;
        let localNumber = LocalUtils.get('liangxi_show_times' + __data.uid) || 1;
        if(__data.deskData.roomVo.roomModel != __data.deskData.roomVo.FRIEND && cup < 260 && localNumber <= 5){ 
            let groups = LxRules.recommend(this.data, __groupArr, [40, 41, 42]);
            if(groups.length){
                this.guideHand = this.guideHand || new GuideHand();

                let isFind = false;
                let view = null;
                for(let i = 0;i < this.list.length;i++){
                    isFind = groups.findIndex((element)=>{ return element == this.list[i].card }) > -1
                    if(isFind){
                        let __lxScript = this.list[i].getComponent(Mahjong_Lx_Script);
                        if(!__lxScript || !__lxScript.selected){
                            isFind = true;
                            view = this.list[i];
                            break;
                        }
                    }
                }
                if(isFind){
                    game.cb.event('remove_lx_btn_guide');
                    if(view)this.addChild(this.guideHand).pos(view.x + (view.width - this.guideHand.width) / 2, view.y + (view.height - this.guideHand.height) / 2);
                    else game.utils.remove(this.guideHand);
                }
                else { 
                    game.utils.remove(this.guideHand); 
                    if(this.checkLxGroup()){ game.cb.event('show_lx_btn_guide'); } 
                }
            }else{
                game.utils.remove(this.guideHand); 
                if(this.checkLxGroup()){ game.cb.event('show_lx_btn_guide'); }
            }
        }
    }

    removelxGuideHandler(){
        game.utils.remove(this.guideHand);
    }

    checkLxGroup(){
        //选择亮喜的组合
        let __groupArr = [];
        for (let i = 0; i < this.list.length; i++) {
            let __lxScript = this.list[i].getComponent(Mahjong_Lx_Script)
            __lxScript && __lxScript.selected && __groupArr.push(parseInt(this.list[i].card))
        }
        __groupArr.sort(function(a, b) { return a - b })
        let r = LxRules.check(__groupArr, [40, 41, 42]);
        return r;
    }


    init3Data() {
            this.initDoor3D = { x: 85, y: 0, z: -82, allWidth: 0, width: 7.4, height: 10.2, offx: 2, scale: 1.2, changeOffx: 0 }

            let __point = this.localToGlobal(new Laya.Point(0, 15))
            let ray = new Laya.Ray(new Laya.Vector3(), new Laya.Vector3())
            let hitResult = new Laya.HitResult();
            let camera = __data.deskData.roomVo.scene.getChildByName('Main Camera');
            camera.viewportPointToRay(__point, ray);
            __data.deskData.roomVo.scene.physicsSimulation.rayCast(ray, hitResult)

            this.initDoor3D.x = hitResult.succeeded ? hitResult.point.x - this.initDoor3D.width : this.initDoor3D.x
            this.initDoor3D.z = hitResult.succeeded ? hitResult.point.z - this.initDoor3D.height : this.initDoor3D.z

            __point = this.localToGlobal(new Laya.Point(100, -10))
            __point.x *= Laya.stage.clientScaleX
            __point.y *= Laya.stage.clientScaleY


            if (!this.tingPoint) {
                ray = new Laya.Ray(new Laya.Vector3(), new Laya.Vector3())
                hitResult = new Laya.HitResult();
                camera.viewportPointToRay(__point, ray);
                __data.deskData.roomVo.scene.physicsSimulation.rayCast(ray, hitResult)
                this.tingPoint = hitResult.succeeded ? new Laya.Vector3(0, 0.3, hitResult.point.z) : new Laya.Vector3(0, 0.3, -60)
            }
        }
        //自己的比较特殊  需要比对
    endPoint(value) {
        let __end = this.list.filter(function(single) { return parseInt(single.card) == parseInt(value) })
        __end = __end && __end.length > 0 ? __end[0] : null
        if (__end) { return this.localToGlobal(new Laya.Point(__end.x, __end.y)) } else {
            let __start = this.list.length > 0 ? this.list[0] : null
            __end = this.list.length > 0 ? this.list[this.list.length - 1] : null
                //抓的牌为最小的牌
            if (__start && parseInt(__start.card) > parseInt(value)) {
                if (__end) { return this.localToGlobal(new Laya.Point(__end.x, __end.y)) } else { return this.localToGlobal(new Laya.Point(__start.x, __start.y)) }
            }
            //最不济用0,0点为初始点
            else { return this.localToGlobal(new Laya.Point(0, 0)) }
        }
        // return this.list[this.list.length-1].transform;
    }

    //显示列表啊
    set createList(value) {
        let __vo = __data.deskData.roomVo.getPlayer('down')
        while (this.list.length) { game.utils.remove(this.list.shift()) }


        value = value ? value.split(',') : this.data

        value = __compUtils.sort(value, __data.deskData.roomVo.mixedArr)

        if (typeof value == 'string') { this.data = value ? value.split(',') : this.data } else { this.data = value ? value : this.data }


        if (this.ele3DArr.length) {
            this.camera = __data.deskData.roomVo.scene.getChildByName('Main Camera');
            this.outPos = new Laya.Vector3()
            this.endPos = this.prePos.clone();
            this.endPos.x -= this.initDoor3D.width
                //转换坐标
            this.camera.viewport.project(this.endPos, this.camera.projectionViewMatrix, this.outPos);
            let a = this.globalToLocal(new Laya.Point(this.outPos.x / Laya.stage.clientScaleX, this.outPos.y / Laya.stage.clientScaleY))
            this.outPos.x = a.x
        } else { this.outPos = new Laya.Vector3() }
        if (this.data.length > 14) { miniApi.trackEvent('Mj_Error', { 'Mj_ErrorType': '手牌多于14-1' }); }
        this.__width = this.outPos.x
        for (let i = 0; i < this.data.length; i++) {
            let __v = Laya.Pool.getItemByClass(__cName.d, TlmjMahjongDownHand3D)
            __v.skin = this.data[i];
            __v.x = this.__width + __v.width * i
            this.addChild(__v)
            this.list.push(__v)
        }
    }

