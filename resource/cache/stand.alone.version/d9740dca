class TlmjMahjongDownDoor3D extends Laya.Scene {
    constructor() {
        super()
        this.createView(game.uiMap['scene_game/mahjong/MahjongDownDoor']);
    }

    set group(value) {
        value = value.split(',');
        this.__value = value.shift(); //提取数组中的第一个元素  判断吃碰杠啥的
        this.__group = []; //门前牌集合
        this.__position = 0;
        switch (parseInt(this.__value)) {
            case 2: //吃  例如 2,21,22,2   2 value 21 打头的牌  22  吃的牌    2  吃的谁的牌
                //如果头牌和吃的一样后一位在前
                if (value[0] == value[1]) {
                    this.__group.push(parseInt(value[0]) + 1);
                    this.__group.push(parseInt(value[0]));
                    this.__group.push(parseInt(value[0]) + 2);
                    this.__position = value[2] //吃牌来源的位置
                }
                //如果头牌和吃的少一位  顺子形式 
                else if (parseInt(value[0]) + 1 == parseInt(value[1])) {
                    this.__group.push(parseInt(value[0]));
                    this.__group.push(parseInt(value[0]) + 1);
                    this.__group.push(parseInt(value[0]) + 2);
                    this.__position = value[2] //吃牌来源的位置
                }
                //如果头牌和吃的一样后一位在前
                else if (parseInt(value[0]) + 2 == parseInt(value[1])) {
                    this.__group.push(parseInt(value[0]));
                    this.__group.push(parseInt(value[0]) + 2);
                    this.__group.push(parseInt(value[0]) + 1);
                    this.__position = value[2] //吃牌来源的位置
                }
                break;
            case 1: //碰  例如  1,6,1    1 value   6 碰的牌    1  碰的谁的牌
                this.__group.push(parseInt(value[0]));
                this.__group.push(parseInt(value[0]));
                this.__group.push(parseInt(value[0]));
                this.__position = value[1] //吃牌来源的位置
                break;
            case 3: //粘   例如  1,6,1    1 value   6 粘的牌    1  粘的谁的牌
                this.__group.push(parseInt(value[0]));
                this.__group.push(parseInt(value[0]));
                this.__position = value[1] //吃牌来源的位置
                break;
            case 5: //杠   例如  5,0,5  5,1,2    5 value   0 杠的牌    5  杠的谁的牌  5 为自己   即为暗杠
                this.__group.push(parseInt(value[0]));
                this.__group.push(parseInt(value[0]));
                this.__group.push(parseInt(value[0]));
                this.__group.push(parseInt(value[0]));
                this.__position = value[1] //吃牌来源的位置
                break;
            case 81: //亮掌   例如  1,6,1    1 value   6 亮掌的牌    1  粘的谁的牌
                this.__group.push(parseInt(value[0]));
                this.__group.push(parseInt(value[0]));
                break;
            case 82: //亮喜   例如  82,40,40,40
                this.__group.push(parseInt(value[0]));
                this.__group.push(parseInt(value[1]));
                this.__group.push(parseInt(value[2]));
                break;
        }
        this.showView();
    }


    showView() {
        let __width = this.__group.length == 2 ? 175 : 250
        this.size(__width, this.height)
            //全部移除掉
        game.utils.remove(this.door_1, this.door_2, this.door_3, this.door_4)
        let __len = 4
        for (let i = 0; i < __len; i++) {
            if (this.__group[i] >= 0) {
                //把应该显示的显示出来
                this.addChild(this['door_' + (i + 1)])

                //暗杠特殊处理一下
                if (this.__position == 5 && i != 3) { this['door_' + (i + 1)].texture = 'local/mahjong_common/1/' + __data.mahjong_set.cardIndex % 2 + '_ag.png' } else {
                    this['door_' + (i + 1)].texture = 'mahjong_' + (__data.mahjong_set.modelIndex + 2) + 'D_' + (__data.mahjong_set.cardIndex + 2).toString() + '_card/own_' + __data.deskData.roomVo.numberToCard(this.__group[i]) + '.png'
                }

                //指向标志 改变方向
                let __vo = __data.deskData.roomVo.getPlayer(this.__position)
                if (__vo) {
                    this.dir.visible = true
                    if (__vo.seat_tag == 'down') { this.dir.rotation = 180 } else if (__vo.seat_tag == 'left') { this.dir.rotation = 270 } else if (__vo.seat_tag == 'up') { this.dir.rotation = 0 } else if (__vo.seat_tag == 'right') { this.dir.rotation = 90 }
                }

                if (parseInt(this.__value) == 81 || parseInt(this.__value) == 82 || (parseInt(this.__value) == 5 && this.__position == 5) || __data.deskData.roomVo.phase == 'result') { this.dir.visible = false }
                //指向标志 改变位置
                this.dir.y = parseInt(this.__value) == 5 ? this.door_4.y - this.dir.height / 2 : this.door_2.y - this.dir.height / 2
                    //如果是暗杠  或者 亮掌啥的  跟别人没关系 不显示这个
                if (this.__position == 5) game.utils.remove(this.dir)
                else { this.addChild(this.dir) }
            }
        }
    }

    onEnable() {}

    onDisable() {}
}
