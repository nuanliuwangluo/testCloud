        for (let i = 0; i < this.doordata.length; i++) {
            let data = __compUtils.getAnalysis(this.doordata[i]);
            if (data.group.length >= 4) { // 杠什么的
                clen += 3;
            } else {
                clen += data.group.length;
            }
        }
        // 有手牌
        if (player && player.handValue) {
            let values = player.handValue.split(',');
            clen += values.length;
            if (clen > 14) {
                miniApi.trackEvent('Mj_Error', { 'Mj_ErrorType': '门前牌多于14', 'Mj_ErrorInfo': 'self->' + player.handValue + '<--->' + JSON.stringify(this.doordata) });
            }
        } else if (player && player.handNumber > 0) {
            clen += player.handNumber;
            if (clen > 14) {
                miniApi.trackEvent('Mj_Error', { 'Mj_ErrorType': '门前牌多于14', 'Mj_ErrorInfo': 'others->' + player.handNumber + '<--->' + JSON.stringify(this.doordata) });
            }
        }
    }

    //添加一个门前牌列表
    set addDoor(value) {
        let __valueArr = value.split(',')
        if (__valueArr[0] == 88) {
            for (let i = 0; i < this.doordata.length; i++) {
                let singleArr = this.doordata[i].split(',');
                if (singleArr[1] == __valueArr[1]) { singleArr[0] = 5 }
                this.doordata[i] = singleArr.toString()
            }
            this.createDoorList = null
            return
        } else if (__valueArr[0] == 89) {
            for (let i = 0; i < this.doordata.length; i++) {
                let singleArr = this.doordata[i].split(',');
                if (singleArr[1] == __valueArr[1]) { singleArr[0] = 1 }
                this.doordata[i] = singleArr.toString()
            }
            this.createDoorList = null
            return
        }
        this.doordata.push(value)
        this.createDoorList = null;
        this.createList = null;
    }

    huCardSurps(value) {
        for (var k = 0; k < value.length; k++) {
            //检测手牌是否有胡牌相同的
            // for(var i = 0;i < this.list.length;i++){ if(this.list[i].card == value[k].view){ value[k].num ++ } }
            let open = __data.deskData.roomVo.openDoor(this.doordata);
            //检测门前牌
            for (var a = 0; a < this.doordata.length; a++) {
                let __singleArr = this.doordata[a].split(",")
                    //碰
                if (__singleArr[0] == 1 && __singleArr[1] == value[k].view) { value[k].num += 3 }
                //吃
                else if (__singleArr[0] == 2 && (value[k].view >= parseInt(__singleArr[1]) && value[k].view <= parseInt(__singleArr[1]) + 2)) { value[k].num++ }

                //粘
                else if (__singleArr[0] == 3 && __singleArr[1] == value[k].view) { value[k].num += 2 }

                //亮掌
                else if (__singleArr[0] == 81 && __singleArr[1] == value[k].view) { value[k].num += 2 }
                //亮喜
                else if (__singleArr[0] == 82) {
                    if (__singleArr[1] == value[k].view) value[k].num++
                        if (__singleArr[2] == value[k].view) value[k].num++
                            if (__singleArr[3] == value[k].view) value[k].num++
                }
                //杠
                else if (open && __singleArr[0] == 5 && __singleArr[1] == value[k].view) value[k].num += 4
            }
        }
    }

    syncData(syncView) {
        let __vo = __data.deskData.roomVo.getPlayer('right');
        this.data = __vo && __vo.handNumber ? new Array(__vo.handNumber) : ''
        if (syncView) this.createList = null
    }


    clear() {
        while (this.numChildren) this.removeChildAt(0)

        this.__height = 0;
        //手牌列表
        this.data = [];

        for (let i = 0; i < this.list.length; i++) {
            this.list[i].removeSelf();
            this.list[i].active = false;
        }
        //手牌列表
        this.list = [];

        this.doordata = [];
        //门前牌列表
        this.doorlist = [];
        // 听牌
        this.__ting = false;
    }

    set ting(value) {
        this.__ting = value;
    }
}






























































