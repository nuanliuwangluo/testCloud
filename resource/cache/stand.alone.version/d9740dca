class TlmjMahjongHuCard3D extends Laya.Scene {
    constructor() {
        super()
        this.createView(game.uiMap['scene_game/mahjong/MahjongHuCard']);

        // this.scale(game.scale, game.scale)

        this.__offx = 300 * game.scale;
        this.__offy = 270 * game.scale;
    }

    create(value, seat) {
        this.seat = seat;
        if ('texture' in this.view) this.view.texture = Mahjong2DRes.getRes('own', value)
        else if ('skin' in this.view) this.view.skin = Mahjong2DRes.getRes('own', value)

        if (seat == 'down') {
            this.x = config.gameW - this.width * game.scale >> 1
            this.y = __compUtils.getDeskDy() - 220 - 50 - this.height; //config.gameH - this.height * game.scale - this.__offy
        } else if (seat == 'up') {
            this.x = config.gameW - this.width * game.scale >> 1
            this.y = __compUtils.getDeskUy() + 220 + 50; // this.__offy
        } else if (seat == 'left') {
            this.x = __compUtils.getDeskLx() + 150;
            this.y = (config.gameH - this.height) / 2 - this.height / 1.4 // config.gameH - this.height * game.scale >> 1
        } else if (seat == 'right') {
            this.x = __compUtils.getDeskRx() - 150; // config.gameW - this.width * game.scale - this.__offx
            this.y = (config.gameH - this.height) / 2 - this.height / 1.4 // config.gameH - this.height * game.scale >> 1
        }
        if (seat != 'up') ELD.push(this);
    }


    onEnable() {}

    onDisable() { ELD.remove(this); }
}