        // Laya.Tween.to(__v, {y:__end.y}, 50, null, new Laya.Handler(this, function(){ game.utils.remove(__v);this.addChild(__v) } ))
    }


    //显示门前牌列表
    set createDoorList(value) {
        this.init3Data()

        while (this.doorlist.length) { game.utils.remove(this.doorlist.shift()) }

        for (let i = 0; i < this.ele3DArr.length; i++) {
            this.ele3DArr[i].active = false;
            this.ele3DArr[i].destroy();
        }
        for (let i = 0; i < this.arrowArr.length; i++) {
            this.arrowArr[i].active = false;
            this.arrowArr[i].destroy();
        }
        this.ele3DArr = [];
        this.arrowArr = [];

        if (typeof value == 'string') { this.doordata = value ? value.split(';') : this.doordata } else { this.doordata = value ? value : this.doordata }

        this.__width = 0
        this.initDoor3D.allWidth = 0
        for (let i = 0; i < this.doordata.length; i++) {
            // let __v = Laya.Pool.getItemByClass(__cName.ddoor, TlmjMahjongDownDoor)
            // __v.group = this.doordata[i]

            // __v.x = this.__width
            // __v.y = 10
            // this.__width += __v.width
            // this.addChildAt(__v, 0)
            // this.doorlist.push(__v)

            let data = __compUtils.getAnalysis(this.doordata[i]);
            for (let k = 0; k < data.group.length; k++) {
                let c1
                if (data.group.length === 4 && data.position < 0 && k != 3)
                    c1 = Laya.Sprite3D.instantiate(__data.deskData.roomVo.scene.getChildByName('tiles').getChildByName('blank'), __data.deskData.roomVo.scene.getChildByName('container'))
                else
                    c1 = Laya.Sprite3D.instantiate(__data.deskData.roomVo.scene.getChildByName('tiles').getChildByName(__data.deskData.roomVo.numberToCard(data.group[k])), __data.deskData.roomVo.scene.getChildByName('container'));
                c1.transform.localPosition = new Laya.Vector3(this.initDoor3D.x - this.initDoor3D.allWidth, this.initDoor3D.y, this.initDoor3D.z)
                c1.transform.localScale = new Laya.Vector3(this.initDoor3D.scale, 1, this.initDoor3D.scale);
                c1.meshRenderer.material = __data.deskData.roomVo.material

                if (k != 3) { this.prePos = c1.transform.position; }

                if (data.type === 5 && k === 3) {
                    c1.transform.localPosition = new Laya.Vector3(this.initDoor3D.x - this.initDoor3D.allWidth + this.initDoor3D.width * this.initDoor3D.scale * 2, this.initDoor3D.y + 5, this.initDoor3D.z)
                } else
                    this.initDoor3D.allWidth += this.initDoor3D.width * this.initDoor3D.scale

                if (data.seat !== 'down' && data.position > 0 && ((data.group.length <= 3 && k == 1) || (data.group.length == 4 && k == 3))) {
                    let arrow = Laya.Sprite3D.instantiate(__data.deskData.roomVo.scene.getChildByName('arrow'), __data.deskData.roomVo.scene.getChildByName('container'));
                    arrow.transform.localPosition = c1.transform.position;
                    arrow.transform.localPositionX = c1.transform.localPositionX
                    arrow.transform.localPositionZ = c1.transform.localPositionZ + 10
                    arrow.transform.localRotationEuler = new Laya.Vector3(0, data.seat == 'up' ? 180 : data.seat == 'left' ? -90 : data.seat == 'right' ? 90 : 0, 0);
                    arrow.active = true;
                    this.arrowArr.push(arrow)
                }

                this.ele3DArr.push(c1)
            }

            this.initDoor3D.allWidth += this.initDoor3D.offx;
        }



        this.createList = null

        this.listenBug();
    }

    listenBug() {
        let player = __data.deskData.roomVo.getPlayer('down');
        let clen = 0;
        for (let i = 0; i < this.doordata.length; i++) {
            let data = __compUtils.getAnalysis(this.doordata[i]);
            if (data.group.length >= 4) { // 杠什么的
                clen += 3;
            } else {
                clen += data.group.length;
            }
        }
        // 有手牌
        if (player && player.handValue) {
            let values = player.handValue.split(',');
            clen += values.length;
            if (clen > 14) {
                miniApi.trackEvent('Mj_Error', { 'Mj_ErrorType': '门前牌多于14', 'Mj_ErrorInfo': 'self->' + player.handValue + '<--->' + JSON.stringify(this.doordata) });
            }
        } else if (player && player.handNumber > 0) {
            clen += player.handNumber;
            if (clen > 14) {
                miniApi.trackEvent('Mj_Error', { 'Mj_ErrorType': '门前牌多于14', 'Mj_ErrorInfo': 'others->' + player.handNumber + '<--->' + JSON.stringify(this.doordata) });
            }
        }
    }

    //添加一个门前牌列表
    set addDoor(value) {

        let __valueArr = value.split(',')
        if (__valueArr[0] == 88) {
            for (let i = 0; i < this.doordata.length; i++) {
                let singleArr = this.doordata[i].split(',');
                if (singleArr[1] == __valueArr[1]) { singleArr[0] = 5 }
                this.doordata[i] = singleArr.toString()
            }
            this.createDoorList = null
            return
        } else if (__valueArr[0] == 89) {
            for (let i = 0; i < this.doordata.length; i++) {
                let singleArr = this.doordata[i].split(',');
                if (singleArr[1] == __valueArr[1]) { singleArr[0] = 1 }
                this.doordata[i] = singleArr.toString()
            }
            this.createDoorList = null
            return
        }

        // let __v = Laya.Pool.getItemByClass(__cName.ddoor, TlmjMahjongDownDoor)
        // __v.group = value
        // __v.x = this.__width
        // __v.y = 10
        // this.__width += __v.width
        // this.addChildAt(__v, 0)
        // this.doorlist.push(__v)
        // this.doordata.push(value)
        this.doordata.push(value)

        this.createDoorList = null;

        this.createList = null;
    }


    allowControl(value) {
        //先取消牌的拖拽功能
        this.stopControl();
        if (!value) {
            //如果为可以操作所有的牌  再次添加拖拽组件
            for (let i = 0; i < this.list.length; i++) { this.list[i].addComponent(Hand_Drag_Script).unuse(__data.deskData.roomVo.mixedArr) }
        } else {
            //按可出牌添加拖拽组件
            value = value.split(',');
            for (let i = 0; i < this.list.length; i++) {
                for (let k = 0; k < value.length; k++) {
                    if (value[k] == this.list[i].card) {
                        this.list[i].addComponent(Hand_Drag_Script).unuse(__data.deskData.roomVo.mixedArr);
                        this.list[i].showTingTips()
                    }
                }
            }
        }

    }

    stopControl() {
        for (let i = 0; i < this.list.length; i++) { this.list[i].getComponent(Hand_Drag_Script) && this.list[i].getComponent(Hand_Drag_Script).destroy(); }
    }


    cancelChoiceHandler(value) {
        let __list = this.list.filter(function(a) { return a != value })

        for (let i = 0; i < __list.length; i++) {
            __list[i].getComponent(Hand_Drag_Script) && __list[i].getComponent(Hand_Drag_Script).cancelChoice()
        }
    }

    //自动出牌
    autoPlay(value) {
        //从右开始检测
        for (let i = this.list.length - 1; i > 0; i--) {
            if (parseInt(this.list[i].card) == parseInt(value)) {
                //出牌
                let __point = this.localToGlobal(new Laya.Point(this.list[i].x, this.list[i].y))
