class GameMainSeasonRecord extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_seasonRecord',
            layer: 'panel'
        })
        this.__panel.hScrollBarSkin = ``
        this.__panel.hScrollBar.elasticBackTime = 200
        this.item1Array = [this.__item11, this.__item12]
        this.disx = 0
        this.btn_seasonRule.addComponent(S_season_record_rule)
        // this.btn_introduce.addComponent(S_hall_lvInfo)
        this.btn_introduce.visible = false;
    }
    async onEnable() {
        miniApi.trackEvent('Mj_UIExposure', { 'Mj_ExposureScene': '赛季档案界面' })
        // 设置一个当前已经选择的选项 为了和所有当前item索引不一样
        this.selectIndex = 99999
        this.item1Array[0].visible = false
        this.item1Array[1].visible = false
        let data_x1 = Object.values(__data.seasonRecord)
        if (!data_x1.length) return;
        data_x1.sort((a, b) => {
            return b.startTimeMs - a.startTimeMs
        })
        data_x1[0].isCur = true;
        // 初始化
        let defaultIndex = 0
        this.itemArray = [];
        this.item_container.width = 0
        // data_x1 = data_x1.filter((e) => {
        //     return e.rankData;
        // })
        for (let index = 0, length = data_x1.length; index < length; index++) {
            let e = new GameMainSeasonRecordItem()
            e.curIndex = index;
            e.x = (e.width + this.disx) * index;
            e.y = this.__panel.height / 2 - e.height / 2
            e.dataSource = data_x1[index];
            this.itemArray.push(e)
            this.item_container.addChild(e)
            this.item_container.width = Math.max(this.item_container.width, e.x + e.width)
            if (data_x1[index].isCur) {
                defaultIndex = index;
            }
        };
        this.item_container.width += this.disx + this.item1Array[0].width;
        this.__panel.refresh()
        this.item1Array[0].visible = false;
        this.item1Array[1].visible = false;
        await __tool.await(100, this) // 不延迟 this.__panel.scrollTo 不好用 这逼玩意 有bug
        this.__panel.scrollTo((this.disx + this.itemArray[0].width) * defaultIndex, 0)
        this.select(defaultIndex, data_x1[defaultIndex])
    }
    onDisable() {
        this.itemArray && this.itemArray.forEach(e => {
            game.utils.remove(e)
        });
        this.itemArray = null;
        this.clearAwait && this.clearAwait();

        ResUtils.clearTextureRes(['cdn.seasonRecord'])
    }
    async select(curIndex, selectVO) {
        if (this.tweening) return;
        if (curIndex == this.selectIndex) return;

        game.cb.event('season_record_select', [selectVO])

        let w_info = this.item1Array[0].width;
        let w_item = this.itemArray[0].width;

        this.tweenVo = this.tweenVo || {}
        Laya.Tween.clearAll(this.tweenVo)
        this.tweenVo.v = this.__panel.hScrollBar.value
        let t = Laya.Tween.to(this.tweenVo, {
            v: (this.disx + w_item) * curIndex - 100
        }, GameMainSeasonRecord.tweenTime)
        __tool.tweenUpdate(t, () => {
            this.__panel.hScrollBar.value = this.tweenVo.v
        }, this)

        for (let index = 0, length = this.itemArray.length; index < length; index++) {
            let e = this.itemArray[index]
            let tox = (e.width + this.disx) * index;
            if (index > curIndex) {
                tox += w_info
            }
            Laya.Tween.to(e, {
                x: tox
            }, GameMainSeasonRecord.tweenTime)
        };

        if (curIndex < this.selectIndex) {
            let e = this.item1Array[0];
            e.tweenRemove()
            this.item1Array.push(this.item1Array.shift())
            let e1 = this.item1Array[0];
            e1.visible = true;
            e1.x = (w_item + this.disx) * (curIndex + 1)
            e1.tweenAdd(selectVO);
        } else {
            let e = this.item1Array[0];
            e.tweenRemove_retreat()
            this.item1Array.push(this.item1Array.shift())
            let e1 = this.item1Array[0];
            e1.visible = true;
            e1.x = (w_item + this.disx) * (curIndex + 1)
            e1.tweenAdd_retreat(selectVO);
        }
        this.selectIndex = curIndex;
        this.tweening = true
        await __tool.await(GameMainSeasonRecord.tweenTime, this)
        this.tweening = false
    }
}
