class GameMainSeasonRecordItem3 extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_seasonRecordItem3',
            module: false
        })
        this.vo = null
        this.img_head.skin = ''
        this.txt_name.text = ''
    }
    onEnable() {

    }
    onDisable() {
        game.cb.off('update_headFrame', this, this.update_headFrame)
    }
    set dataSource(vo) {
        if (!vo) return;
        this.vo = vo;

        this.txt_name.visible = vo.uid != 0
        this.img_head.visible = vo.uid != 0
        this.txt_mjName.visible = vo.uid != 0
        this.img_rank_bg.visible = vo.uid != 0
        this.img_me.visible = vo.uid != 0
        this.img_lv.visible = vo.uid != 0
        this.img_lv1.visible = vo.uid != 0
        this.txt_noRank.visible = vo.uid != 0

        if (vo.uid == 0) {
            return
        }
        vo.uid && game.server.send(2005, vo.uid);
        game.cb.on('update_headFrame', this, this.update_headFrame)
        // this.update_headFrame()
        // this.txt_score.text = bigNumberToCH(vo.score, 2);
        // this.txt_score.text = vo.score;

        let rd = RankUtils.getRankLvDataByScore(vo.score)
        if (this.isIng) {

            if (vo.uid == __data.uid) {
                if (vo.score < 60) {
                    vo.rank = -1
                }
            }
        }

        this.img_lv.visible = false
        this.img_lv1.visible = false
        if (rd.toNextLevelNeedCup == 0) {
            this.img_lv1.visible = true
            if (this.isIng) {
                if (vo.uid == __data.chuanqi.player.uid && vo.cityId == __data.chuanqi.player.cityId) {
                    rd = __data.rank.chuanqiQueshen;
                }
            } else {
                if (vo.rank == 1 && vo.uid == this.chuanqiId) {
                    rd = __data.rank.chuanqiQueshen;
                }
            }
            this.img_lv1.skin = `local/lvNameBg/1/img_dwx${rd.iconIndex}1.png`
            this.txt_lv1.text = rd.name;
            this.txt_score.text = vo.score - rd.minCup//bigNumberToCH(vo.score, 2);
        } else {
            this.img_lv.visible = true
            this.txt_lv.text = rd.name;
            this.txt_lv_num.text = rd.level;
            this.img_lv.skin = `local/lvNameBg/1/img_dwx${rd.iconIndex}.png`;
        }

        // this.txt_lvName.text = rd.name;
        // this.img_lv.skin = `local/lvNameBg/1/rank_${rd.iconIndex}.png`;

        this.txt_mjName.text = excelUtils.getCityName_mj(vo.cityId) || '';
        this.img_me.visible = vo.isMe ? true : false;
        this.txt_rank.text = vo.rank >= 1000 ? '999+' : vo.rank;
        this.img_rank_bg.skin = vo.rank == -1 ? '' : `cdn/seasonRecord/img_mcbox${vo.rank > 3 ? 4 : vo.rank}.png`
        this.txt_noRank.visible = false;
        this.img_rank_bg.visible = true;
        // this.img_lv.visible = true
        // this.txt_lvName.visible = true
        if (vo.rank == -1) {
            this.img_rank_bg.visible = false
            this.txt_noRank.visible = true;
            this.img_lv.visible = false
            this.img_lv1.visible = false
            // this.txt_lvName.visible = false
        } else if (vo.rank == 1) {
            this.txt_rank.strokeColor = '#c97f00'
        } else if (vo.rank == 2) {
            this.txt_rank.strokeColor = '#627da7'
        } else if (vo.rank == 3) {
            this.txt_rank.strokeColor = '#936f41'
        } else {
            this.txt_rank.strokeColor = '#656565'
        }
    }
    update_headFrame() {
        let curData = __data.othersVO[this.vo.uid]
        if (!curData) {
            return;
        }

        // this.txt_name.text = curData.name;
        LabelHiddenUtils.getAdapterContent(this.txt_name, curData.name)
        let nk = curData.headUrl.split('?')
        if (nk[0]) {
            this.img_head.skin = __data.getHeadTestDefault(curData.headUrl);
        } else {
            this.img_head.skin = ''
        }
    }
}
