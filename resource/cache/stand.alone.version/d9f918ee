class GameMainSeasonRecordItem extends game.ModuleBase {
    static getTime(startTime, endTime) {
        let s = new Date(startTime)
        let e = new Date(endTime)
        let ms = s.getMonth() + 1;
        let es = e.getMonth() + 1;
        let md = s.getDate();
        let ed = e.getDate();
        return ms + '月' + md + '日-' + es + '月' + ed + '日';
    }
    constructor() {
        super({
            map: 'scene_hall/gameMain_seasonRecordItem',
            module: false
        })
        this.vo = null
        this.addComponent(S_click_seasonRecord_item)
    }
    onEnable() {
        game.cb.on('season_record_select', this, this.season_record_select)
    }
    onDisable() {
        game.cb.off('season_record_select', this, this.season_record_select)
    }
    season_record_select(vo) {
        if (vo == this.vo)
            this.img_select.visible = true;
        else this.img_select.visible = false;
    }
    set dataSource(vo) {
        if (!vo) return;
        this.vo = vo

        let isIng = vo.isIng ? true : false;
        this.img_ing.visible = isIng;
        this.img_end.visible = !isIng;
        this.img_bg.skin = isIng ? 'cdn/seasonRecord/img_sjbox1.png' : 'cdn/seasonRecord/img_sjbox2.png';
        this.txt_time.text = GameMainSeasonRecordItem.getTime(vo.startTimeMs, vo.endTimeMs)
        this.img_season.skin = `cdn/seasonRecord/img_season${vo.season}${isIng ? 1 : 2}.png`
        this.img_year.skin = `cdn/seasonRecord/img_${vo.year <= 2023 ? 2024 : vo.year}_${isIng ? 1 : 2}.png`
    }
}
Laya.ClassUtils.regClass('ui.scene_hall.gameMain_seasonRecordItemUI', GameMainSeasonRecordItem);

