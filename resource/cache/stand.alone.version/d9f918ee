class GameMainSeasonRecordRule extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_seasonRecord_Rule',
            layer: 'panel'
        })
        for (let index = 0, length = this.img_reward.numChildren; index < length; index++) {
            let c = this.img_reward.getChildAt(index);
            if (PropIcon.icon[c.name] && PropIcon.icon[c.name].des1) {
                c.vo = PropIcon.icon[c.name]
                c.alpha = 0;
                c.addComponent(S_prop_show_des_seasonRule)
            }
        };
        this.__tab.selectHandler = new Laya.Handler(this, this.onSelect);
        this.__panel.vScrollBarSkin = '';
    }
    onEnable() {
        this.nop = true
        this.__tab.selectedIndex = -1;
        this.__tab.selectedIndex = 0;
        this.nop = 0;
        miniApi.trackEvent('Mj_UIExposure', { 'Mj_ExposureScene': '赛季规则界面' })
    }
    onDisable() {
        ResUtils.clearTextureRes(['cdn.seasonRecord'])
    }
    onSelect(index) {
        !this.nop && __sound.playGameYx('button')
        this.onS(index)
    }
    async onS(index) {
        let bs = this.__tab.items
        this.origin_tab_labelColors = this.origin_tab_labelColors || this.__tab.labelColors;
        for (let index = 0, length = bs.length; index < length; index++) {
            const e = bs[index];
            e.labelColors = this.origin_tab_labelColors;
            e.labelStroke = 0;
        };
        await __tool.await(50)
        if (bs[index]) {
            bs[index].labelStroke = 4;
            bs[index].labelColors = '#fff,#fff,#fff';
        }

        this.img_reward.visible = false;
        this.__panel.visible = false;
        if (index == 0) {
            this.__panel.visible = true;
        }
        else if (index == 1) {
            this.img_reward.visible = true;
        }
    }
}