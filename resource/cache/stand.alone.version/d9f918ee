class GameMainSeasonRecordItem1 extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_seasonRecordItem1',
            module: false
        })
        this.rect = new Laya.Rectangle()
        this.rect.width = this.width;
        this.rect.height = this.height;
        this.scrollRect = this.rect;
        // 里面只放入前三  自己的item 没有放入
        ['person', 'local'].forEach((e) => {
            this['items_' + e] = [
                this[`${e}_scene_1`],
                this[`${e}_scene_2`],
                this[`${e}_scene_3`],
            ]
        });
    }
    onEnable() {
        game.cb.on('update_season_record_item_data_by_id', this, this.updateData)
    }
    onDisable() {
        game.cb.off('update_season_record_item_data_by_id', this, this.updateData)
    }
    set dataSource(vo) {
        if (!vo) return;
        this.vo = vo
    }
    tweenAdd(selectVO) {
        this.seasonId = selectVO.id
        !selectVO.isIng && game.server.send(2251, this.seasonId, HallPlay.lastCityId)
        this.rect.x = 0;
        this.rect.width = 0;
        Laya.Tween.to(this.rect, {
            width: this.width
        }, GameMainSeasonRecord.tweenTime)
        this.showInfo(selectVO)
    }
    tweenRemove() {
        this.rect.width = this.width;
        this.rect.x = 0
        Laya.Tween.to(this.rect, {
            x: -this.width - 1
        }, GameMainSeasonRecord.tweenTime)
    }
    tweenAdd_retreat(selectVO) {
        this.seasonId = selectVO.id
        !selectVO.isIng && game.server.send(2251, this.seasonId, HallPlay.lastCityId)
        this.rect.width = this.width;
        this.rect.x = -this.width
        Laya.Tween.to(this.rect, {
            x: 0
        }, GameMainSeasonRecord.tweenTime)
        this.showInfo(selectVO)
    }
    tweenRemove_retreat() {
        this.rect.x = 0
        this.rect.width = this.width
        Laya.Tween.to(this.rect, {
            width: 0
        }, GameMainSeasonRecord.tweenTime)
    }
    updateData(seasonId) {
        if (this.seasonId == seasonId) {
            this.showInfo(__data.seasonRecord[seasonId])
        }
    }
    showInfo(selectVO) {
        if (selectVO.isIng) {
            let e = selectVO;
            // 进行中赛季重新生成
            trace('录入进行中赛季排名')
            // 1 个人榜；2 城市榜；
            let person_datas111 = __data[`rank_list${1}`]
            let local_datas111 = __data[`rankCity${HallPlay.lastCityId}`]

            let getCityIdByMjName = excelUtils.getCityIdByMjName_mj
            let getKey11 = (data0, index1, index2, key, defaultValue) => {
                try {
                    return data0[index1][index2][key] || defaultValue
                } catch (error) {
                    return defaultValue
                }
            }
            let person_datas = [
                { rank: 1, uid: getKey11(person_datas111, 1, 0, 'uid', 0), score: getKey11(person_datas111, 1, 0, 'score', 0), cityId: getCityIdByMjName(getKey11(person_datas111, 1, 0, 'city', '')) },
                { rank: 2, uid: getKey11(person_datas111, 1, 1, 'uid', 0), score: getKey11(person_datas111, 1, 1, 'score', 0), cityId: getCityIdByMjName(getKey11(person_datas111, 1, 1, 'city', '')) },
                { rank: 3, uid: getKey11(person_datas111, 1, 2, 'uid', 0), score: getKey11(person_datas111, 1, 2, 'score', 0), cityId: getCityIdByMjName(getKey11(person_datas111, 1, 2, 'city', '')) },
            ];
            let local_datas = [
                { rank: 1, uid: getKey11(local_datas111, 1, 0, 'uid', 0), score: getKey11(local_datas111, 1, 0, 'score', 0), cityId: HallPlay.lastCityId },
                { rank: 2, uid: getKey11(local_datas111, 1, 1, 'uid', 0), score: getKey11(local_datas111, 1, 1, 'score', 0), cityId: HallPlay.lastCityId },
                { rank: 3, uid: getKey11(local_datas111, 1, 2, 'uid', 0), score: getKey11(local_datas111, 1, 2, 'score', 0), cityId: HallPlay.lastCityId },
            ];
            let myCityId = __data.myCityId
            let person_data_me = { rank: person_datas111['my'].rank, uid: __data.uid, cityId: getCityIdByMjName(person_datas111['my'].city), score: person_datas111['my'].score, isMe: true }
            let local_data_me = { rank: local_datas111['my'].rank, uid: __data.uid, cityId: HallPlay.lastCityId, score: local_datas111['my'].score, isMe: true }

            __data.seasonRecord[e.id].rankData = {
                person_datas,
                person_data_me,
                local_datas,
                local_data_me,
            };
        }
        if (selectVO.rankData) {
            ['person', 'local'].forEach((e) => {
                let arr = this['items_' + e]
                arr.forEach((e_item, index) => {
                    e_item.isIng = selectVO.isIng;
                    e_item.chuanqiId = selectVO.rankData.legendId;
                    let data001 = selectVO.rankData[e + '_datas'][index]
                    if (data001) {
                        e_item.dataSource = data001
                        e_item.visible = true;
                    } else {
                        e_item.visible = false;
                    }
                });
                this[e + '_scene_me'].isIng = selectVO.isIng;
                this[e + '_scene_me'].chuanqiId = selectVO.rankData.legendId
                let data002 = selectVO.rankData[e + '_data_me'];
                if (data002) {
                    this[e + '_scene_me'].dataSource = data002;
                    this[e + '_scene_me'].visible = true;
                } else {
                    this[e + '_scene_me'].visible = false;
                }
            });
        } else {
            ['person', 'local'].forEach((e) => {
                let arr = this['items_' + e]
                arr.forEach((e_item, index) => {
                    e_item.visible = false;
                });
                this[e + '_scene_me'].visible = false;
            });
        }
    }
}
