class GameMainAdReward extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_ad_reward',
            layer: 'panel'
        })
    }

    onEnable() {
        this.startLightAni();
        this.startShowAni();
    }

    onDisable() {
        Laya.timer.clearAll(this);

        this.lightAni.stop();
        this.showAni.stop();
        this.closeAni.stop();

        this.showAni.off('complete', this, this.showComplete);
        this.closeAni.off('complete', this, this.closeComplete);
    }

    /**
     * 
     * @param {*} type 得到的奖励id
     * @param {int} number 得到的奖励数量
     */
    added(type, number) {
        this._number = number;
        let icon = PropIcon.icon[type] && PropIcon.icon[type].skin || '';
        SkinUtils.setSkin(this.icon, icon);
        this._setText('');
    }

    startLightAni() {
        this.lightAni.play(0, true);
    }

    startShowAni() {
        this.showAni.on('complete', this, this.showComplete);
        this.showAni.play(0, false);
    }

    startCloseAni() {
        this._setText('');
        this.closeAni.on('complete', this, this.closeComplete);
        this.closeAni.play(0, false);
    }

    showComplete() {
        this._setText(this._number);
        Laya.timer.once(1200, this, this.startCloseAni);
    }

    closeComplete() {
        game.scene.remove(this);
    }


    _setText(value) {
        this.txt_number.text = value;
    }
}




class PieCd extends Laya.Script {

    onEnable() {
        this.backups();
    }

    // 备份需要还原的数据
    backups() {
        this._mouseEnabled = this.owner.mouseEnabled;
    }

    //  还原数据
    restore() {
        this.owner.visible = true;
    }

    temp() {
        this.owner.visible = false;
    }

    /**
     * 
     * @param {number} time 时间 单位毫秒
     */
    start(time) {
        this.reset();
        this.temp();

        this.gray = this.createTexture(true);
        this.common = this.createTexture();

        this.gray.pivotX = this.common.pivotX = this.owner.pivotX;
        this.gray.pivotY = this.common.pivotY = this.owner.pivotY;
        this.gray.centerX = this.common.centerX = this.owner.centerX;
        this.gray.centerY = this.common.centerY = this.owner.centerY;

        this.owner.parent.addChild(this.common).pos(this.owner.x, this.owner.y);
        this.owner.parent.addChild(this.gray).pos(this.owner.x, this.owner.y);

        this.rect = new Laya.Sprite();
        this.gray.mask = this.rect;

        this.radius = this.getRect();
        if (!time) { throw new Error('please set time in PieCd.') }

        this.end_w = 0;
        this.tween = new Laya.Tween().to(this, { end_w: this.common.width }, time, null, Laya.Handler.create(this, this.destroySelf));
        this.tween.update = Laya.Handler.create(this, this._updatePie, null, false);

        this.rect.graphics.drawRect(0, 0, this.common.width, this.common.height, '#ff0000');
    }

    _updatePie() {
        this.rect.x = this.end_w;
    }

    getRect() {
        let center = this.getCenterPoint(this.owner);
        let width = this.owner.width / 2;
        let height = this.owner.height / 2;
        // 半径
        return this.distance(center, new Laya.Point(center.x + width, center.y + height));
    }

    createTexture(gray) {
        let _sprite = new Laya.Sprite();
        let center = this.getCenterPoint(this.owner);
        _sprite.texture = this.owner.drawToTexture(this.owner.width, this.owner.height, center.x + Math.ceil(this.owner.width / 2), center.y + Math.ceil(this.owner.height / 2));
        gray && SkinUtils.gray(_sprite);
        return _sprite;
    }

    reset() {
        this.restore();
        this.tween && this.tween.clear();
        game.utils.remove(this.gray, this.common);
        if (this.gray) {
            this.gray.destroy();
            this.gray = null;
        }
        if (this.common) {
            this.common.destroy();
            this.common = null;
        }
        if (this.circle) {
            this.circle.destroy();
            this.circle = null;
        }
        this.initAngle = null;
        this.angle = null;
        this.radius = null;
    }

    destroySelf() {
        this.reset();
        this.destroy();
    }


    /**
     * 获取对象的中心点的真实坐标(切记对象需要能回去到宽高，已经设定锚点的对象会设置宽高，没有的sprite对象可能存在宽高为0的情况)
     * @param {Laya.Image} icon 
     */
    getCenterPoint(view) {
        let point = this.getAnchorPoint(view);
        // 没有设定锚点返回view 的中心点
        return new Laya.Point(view.x + view.width / 2 - point.x, view.y + view.height / 2 - point.y);
    }

    /**
     * 获取对象的锚点距离
     * @param {Laya.Image} view 
     */
    getAnchorPoint(view) {
        // 便宜位置  默认0
        let anchor = new Laya.Point(0, 0);
        // 已经设定锚点了
        if (view.pivotX != 0 || view.pivotY != 0) {
            anchor.x = view.pivotX || 0;
            anchor.y = view.pivotY || 0;
        }
        // 已经设定锚点了
        else if (!isNaN(view.anchorX) && !isNaN(view.anchorY)) {
            anchor.x = view.anchorX * view.width;
            anchor.y = view.anchorY * view.height;
        }
        return anchor;
    }

    /**
     * a，b两点之间的距离
     * @param {Laya.Point} a 
     * @param {Laya.Point} b 
     */
    distance(a, b) {
        let dis = Math.sqrt(Math.pow(Math.abs(a.x - b.x), 2) + Math.pow(Math.abs(a.y - b.y), 2));
        return dis;
    }
}