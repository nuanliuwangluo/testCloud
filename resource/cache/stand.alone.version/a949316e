class GameMainAd extends game.ModuleBase {
    static get clearRes() {
        this._clearRes = this._clearRes ||
            ['cdn.ad'];
        return this._clearRes
    }
    constructor() {
        super({
            map: 'scene_hall/gameMain_ad',
            layer: 'panel'
        })
    }
    onAwake() {
        this.addComponent(GameMainADScript);
        this.btn_probability.addComponent(ProbabilityScript).tips(this.showTips.bind(this));
        this.addComponent(AdTimeDownToClose);
    }

    added(videoR) {
        this.videoR = videoR;
        game.cb.on('ad_get_cd', this, this._success);
        // miniApi.showCustomAd_leftRight('left')
        this.updateCountdown();
        Laya.timer.loop(1000, this, this.updateCountdown)
    }

    onDisable() {
        game.cb.off('ad_get_cd', this, this._success);
        miniApi.hideCustomAd_leftRight('left')
        miniApi.hideCustomAd_leftRight('right')
        this.clearAwait && this.clearAwait()
        hallTestShowPanel()
        ResUtils.clearTextureRes(GameMainAd.clearRes)
        Laya.timer.clearAll(this)
    }

    updateCountdown() {
        let ssm = new Date().setHours(0, 0, 0, 0) - Date.now() + 24 * 3600 * 1000
        var hour = Math.floor(ssm / 3600 / 1000);
        var minute = Math.floor(ssm / 60 / 1000) % 60;
        var miao = Math.floor(ssm / 1000) % 60;
        let timeStr = (hour > 10 ? hour : '0' + hour) + ':'
        timeStr += (minute > 10 ? minute : '0' + minute) + ':'
        timeStr += miao > 10 ? miao : '0' + miao
        this.txt_countdown.text = timeStr
        if (ssm <= 0) {
            game.scene.remove(GameMainAd)
            game.cb.event('update_ad')
        }
    }

    clickMask() { }

    async _success() {
        if (__data.vip.isVip) {

        } else {
            // this.btn_get.addComponent(PieCd).start(10 * 1000);
        }

    }

    /**
     * 显示概率提示信息
     */
    showTips() {
        this.tips.visible = true;
    }

    closeTips() {
        this.tips.visible = false;
    }
}
class GameMainADScript extends Laya.Script {
    onEnable() {
        miniApi.setItem(__data.uid + ':' + new Date().toDateString() + ':show_panel_adTime', 1)
        this.setText('');
        this.queryInfo();
        game.cb.on('update_ad', this, this.update);
        this.owner.btn_get.on('click', this, this.getAdHandler);
    }

    onDisable() {
        game.cb.off('update_ad', this, this.update);
        this.owner.btn_get.off('click', this, this.getAdHandler);
        hallTestShowPanel()
    }

    queryInfo() {
        AdData.send()
    }

    // 初始化按钮状态
    init() {
        // 领取次数已经没有了
        if (AdData.time == 0) {
            SkinUtils.gray(this.owner.btn_get, true, false);
        }
        // 还有领取次数
        else {
            SkinUtils.gray(this.owner.btn_get, false, true);
        }
        this.owner.tips.visible = false;

        this.setText();
    }

    /**
     * 领取奖励
     */
    async getAdHandler() {
        game.cb.event('ad_get_cd');
        // 视频领取
        await miniApi.video_ready('adunit-24f34675f1830a6c')
        miniApi.video_show('adunit-24f34675f1830a6c', () => {
            game.server.send(2214);
        }, () => {
            __tips('暂无广告，请稍后再试或开通VIP')
        }, 0)
        let n = __data.vip.isVip ? 'VIP领取' : '参与广告'
        miniApi.trackEvent('Mj_ADClick', { Mj_ADPreference: miniApi.adUserValueLevel, 'Mj_ADScene': '广告时间', 'Mj_Participation': n })
    }
    /**
     * 刷新概率说明
     */
    update() {
        // AdData.list.sort((a, b) => { return a.odds - b.odds; });
        this.owner.list.array = AdData.list;
        this.init();
    }

    /**
     * 剩余次数
     */
    setText() {
        // this.owner.label_c.visible = false;
        // this.owner.txt_min_num.text = '×' + this.getNumber(1, 'min');
        // this.owner.txt_max_num.text = '×' + this.getNumber(1, 'max');
        // this.owner.txt_msk_num.text = '×' + this.getNumber(3);
        // // this.owner.txt_sd_num.text = '×' + this.getNumber(8004);
        this.owner.txt_time.text = '今日剩余' + AdData.time + '次';
    }

    getNumber(type, st) {
        let _number = '';
        for (let i = 0; i < AdData.list.length; i++) {
            if (AdData.list[i].type == type) {
                if (!_number) {
                    _number = AdData.list[i].number;
                } else if (st == 'min') {
                    _number = Math.min(_number, AdData.list[i].number);
                } else if (st == 'max') {
                    _number = Math.max(_number, AdData.list[i].number);
                } else {
                    _number = AdData.list[i].number;
                }
            }
        }
        return _number;
    }
}


