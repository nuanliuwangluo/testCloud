    //打牌
    addOutHandler(position, value, isDele) {
        let __vo = __data.deskData.roomVo.getPlayer(position)

        if (__vo) {
            this.downoutlist.sign = false
            this.upoutlist.sign = false
            this.leftoutlist.sign = false
            this.rightoutlist.sign = false

            if (__vo.seat_tag != 'down') __sound.gameSound(MahjongConfig.getMusicPath(HallPlay.curRuleId) + __vo.sex + "/pai_" + value)

            if (__vo.seat_tag == 'down') {
                this.downoutlist.sign = true
                __data.deskData.isCanPlay = false;

                if (__data.deskData.roomVo.isRecordPlaying) {
                    //自动出牌
                    let __endPoint = this.downlist.endPoint(value);
                    this.downoutlist.addOut = [value, __endPoint]
                    this.downlist.syncData(true)
                    __sound.gameSound(MahjongConfig.getMusicPath(HallPlay.curRuleId) + __vo.sex + "/pai_" + value)
                } else {

                    //托管的状态
                    if (__vo.autoState == 1) {
                        __sound.gameSound(MahjongConfig.getMusicPath(HallPlay.curRuleId) + __vo.sex + "/pai_" + value)

                        //自动出牌
                        let __endPoint = this.downlist.endPoint(value);
                        this.downoutlist.addOut = [value, __endPoint]
                        this.downlist.syncData(true)
                    }
                    //听牌状态
                    else if (__vo.tingState >= 1) {
                        if (__data.deskData.isActiveToOut) {
                            __data.deskData.isActiveToOut = false;
                            this.downlist.syncData(true)
                        } else {
                            this.downlist.autoPlay(value)
                            this.downlist.syncData(true)
                        }
                    }
                    //听牌状态/
                    else if (__vo.hupai && __vo.hupai.length > 0) {
                        if (__data.deskData.isActiveToOut) {
                            __data.deskData.isActiveToOut = false;
                            this.downlist.syncData(true)
                        } else {
                            this.downlist.autoPlay(value)
                            this.downlist.syncData(true)
                        }
                    }
                    //早已记不得这个是处理什么的了  现在全当 上听后第一次打牌
                    else if (isDele) {
                        this.downlist.syncData(true)
                    }
                    //听牌状态
                    // else if (__vo.tingState >= 1) {
                    //     this.downlist.autoPlay(value)
                    //     this.downlist.syncData(true)
                    // }
                }
            } else if (__vo.seat_tag == 'left') {
                this.leftoutlist.addOut = [value, this.leftlist.endPoint]
                this.leftoutlist.sign = true
                this.leftlist.syncData(true)
            } else if (__vo.seat_tag == 'right') {
                this.rightoutlist.addOut = [value, this.rightlist.endPoint]
                this.rightoutlist.sign = true
                this.rightlist.syncData(true)
            } else if (__vo.seat_tag == 'up') {
                this.upoutlist.addOut = [value, this.uplist.endPoint]
                this.upoutlist.sign = true
                this.uplist.syncData(true)
            }
        }

        this.huTipsHandler();
        this.signOutHandler(position);
    }

