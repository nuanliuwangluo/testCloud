        } else if (__data.deskData.roomVo.phase == "result") {
            this.clearGame();
            this.clearList();
            if (__data.deskData.roomVo.roomModel == __data.deskData.roomVo.FRIEND) this.sceneInit();
            this.setChangeHandler();
        }
    }


