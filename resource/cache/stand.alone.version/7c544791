    updateWallSurps() {
        let __out = 112 - 13 * __data.deskData.roomVo.roomPlayer - __data.deskData.roomVo.surplus;
        for (let i = 0; i < __out; i++)
            this.wallArr[13 * __data.deskData.roomVo.roomPlayer + i] && (this.wallArr[13 * __data.deskData.roomVo.roomPlayer + i].active = false);
    }

    resetWall() {
        for (let i = 0; i < this.wallArr.length; i++) { this.wallArr[i].active = true; }
    }

    hideWall() {
        for (let i = 0; i < this.wallArr.length; i++) { this.wallArr[i].active = false; }
    }


    dispatchHandler() {
        for (let i = 0; i < this.wallArr.length; i++) { this.wallArr[i].active = true; }

        let randomBegin = Math.floor(Math.random() * this.wallArr.length)
        //如果随机到下面的那个牌  没有从那抓的  所以减去1个  让用户从上面开始抓
        randomBegin = (randomBegin % 2 != 0) ? randomBegin - 1 : randomBegin;

        this.wallArr = this.wallArr.concat(this.wallArr.splice(0, randomBegin));
        for (let i = 0; i < 13 * __data.deskData.roomVo.roomPlayer; i++) { this.wallArr[i].active = false; }

    }

    onEnable() {
        __sound.playGameMusic('bgm_room');
        this.cleanPlayerHead();
        this.init();
        this.sceneInit();
        this.registerEvent();

        this.initReadyCommon();
        DeskDissolveCheck.check();
        MahjongDeskShareUtils.enter();
        Laya.timer.callLater(this, this.adapterPlayer);
        Laya.timer.callLater(this, this.sceneInit);
    }
    onDisable() {
        this.destroyEvent();

        this.clearGame();

        this.clearList();

        this.clearCountDownPlane();
        this.stopCompassTimer();
        MahjongDeskShareUtils.leave();
        miniApi.hideCustomAd_leftRight('down');
    }

    adapterPlayer() {
        let safe_area = miniApi.statusBarRatio() * game.width;

        this.mouseThrough = true;
        let up = this.game.getChildByName('player_up');
        let down = this.game.getChildByName('player_down');
        let left = this.game.getChildByName('player_left');
        let right = this.game.getChildByName('player_right');

        let auto = this.game.getChildByName('auto_box');
        this.downlist.y = this.height + this.y - 180 - 15;
        down.y = this.downlist.y - 300;
        auto.y = this.height + this.y - this.height;

        left.x = -this.x + 30 + safe_area;
        left.y = right.y;
        down.x = -this.x + 30 + safe_area;
        right.x = this.width + this.x - safe_area - right.width - 30;
        up.y = -this.y;

        this.upRateTips.pos(up.x + up.width + 0, up.y + (up.height - this.upRateTips.height) / 2);
        this.downRateTips.pos(down.x + down.width + 15, this.downlist.y - this.downRateTips.height - 15);
        this.leftRateTips.pos(left.x + left.width + 0, left.y + (left.height - this.leftRateTips.height) / 2);
        this.rightRateTips.pos(right.x - this.rightRateTips.width - 0, right.y + (right.height - this.rightRateTips.height) / 2);

        let pop_down = this.game.getChildByName('popContainer').getChildByName('pop_down');
        let pop_right = this.game.getChildByName('popContainer').getChildByName('pop_right');
        let pop_up = this.game.getChildByName('popContainer').getChildByName('pop_up');
        let pop_left = this.game.getChildByName('popContainer').getChildByName('pop_left');
        pop_down.pos(down.x + down.width / 2, down.y + down.height / 2);
        pop_right.pos(right.x + right.width / 2, right.y + right.height / 2);
        pop_up.pos(up.x + up.width / 2, up.y + up.height / 2);
        pop_left.pos(left.x + left.width / 2, left.y + left.height / 2);

        let ready_up = this.ready.getChildByName('player_up');
        let ready_down = this.ready.getChildByName('player_down');
        let ready_left = this.ready.getChildByName('player_left');
        let ready_right = this.ready.getChildByName('player_right');
        ready_up.pos(up.x, up.y);
        ready_down.pos(down.x, down.y);
        ready_left.pos(left.x, left.y);
        ready_right.pos(right.x, right.y);

        pop_down = this.ready.getChildByName('popContainer').getChildByName('pop_down');
        pop_right = this.ready.getChildByName('popContainer').getChildByName('pop_right');
        pop_up = this.ready.getChildByName('popContainer').getChildByName('pop_up');
        pop_left = this.ready.getChildByName('popContainer').getChildByName('pop_left');
        pop_down.pos(ready_down.x + ready_down.width / 2, ready_down.y + ready_down.height / 2);
        pop_right.pos(ready_right.x + ready_right.width / 2, ready_right.y + ready_right.height / 2);
        pop_up.pos(ready_up.x + ready_up.width / 2, ready_up.y + ready_up.height / 2);
        pop_left.pos(ready_left.x + ready_left.width / 2, ready_left.y + ready_left.height / 2);

        let ready_empty_up = this.ready.getChildByName('empty_up');
        let ready_empty_down = this.ready.getChildByName('empty_down');
        let ready_empty_left = this.ready.getChildByName('empty_left');
        let ready_empty_right = this.ready.getChildByName('empty_right');
        ready_empty_up.pos(ready_up.x + (ready_up.width - ready_empty_up.width) / 2, ready_up.y + (ready_up.height - ready_empty_up.height) / 2);
        ready_empty_down.pos(ready_down.x + (ready_down.width - ready_empty_down.width) / 2, ready_down.y + (ready_down.height - ready_empty_down.height) / 2);
        ready_empty_left.pos(ready_left.x + (ready_left.width - ready_empty_left.width) / 2, ready_left.y + (ready_left.height - ready_empty_left.height) / 2);
        ready_empty_right.pos(ready_right.x + (ready_right.width - ready_empty_right.width) / 2, ready_right.y + (ready_right.height - ready_empty_right.height) / 2);

        this.ready.getChildByName('desk').x = this.width + this.x - safe_area - this.ready.getChildByName('desk').width - 30;
        this.updateIcon();
    }

