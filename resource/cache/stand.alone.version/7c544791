    updateLimitKick() {
        //不是准备阶段  直接跳过
        if (__data.deskData.roomVo.phase != 'ready') { return }
        //不为体验馆模式 跳过
        // if(__data.deskData.roomVo.roomModel != 5){ return }
        //1 为麻将
        let have = __compUtils.autoKick(1);
        //当前大区没有踢人功能  跳过
        if (!have) { return }
        //
        let __time = __data.deskData.roomVo.limitKickTime();

        for (let i = 1; i <= 4; i++) {
            let __vo = __data.deskData.roomVo.getPlayer(i)
            //房主忽略掉（亮哥特意要求更改的）
            if (__vo && __vo.id == __data.deskData.roomVo.roomOwner) { continue }
            //离线
            if (__vo && __vo.onlineState != 1) {
                //如果当前离线用户已经开始计时  跳过当前用户
                if (this.ready.getChildByName('player_' + __vo.seat_tag).getComponent(Mahjong_Limit_Time_Script)) { continue; }
                this.ready.getChildByName('player_' + __vo.seat_tag).addComponent(Mahjong_Limit_Time_Script).start(__time, true, function () {
                    if (__data.deskData.roomVo.roomModel == 6 || __data.deskData.roomVo.roomModel == 7)
                        __data.deskData.roomVo.friendId && game.server.send(9205, __vo.id, __data.deskData.roomVo.friendId)
                    else
                        game.server.send(8023, __vo.id)
                })
            } else if (__vo && __vo.onlineState == 1) {
                let __script = this.ready.getChildByName('player_' + __vo.seat_tag) ? this.ready.getChildByName('player_' + __vo.seat_tag).getComponent(Mahjong_Limit_Time_Script) : null;
                __script && __script.destroy();
            }
        }
    }

