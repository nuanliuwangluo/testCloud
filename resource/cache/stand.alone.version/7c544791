    countdownloop() {
        if (!__data.deskData.roomVo.scene || this.change_time < 0) { return }
        this.clearCountDownPlane();
        let plane = this.create3dText({ value: this.change_time, color: '#ffffff', font: "bold 50px 黑体" }, 'compass_3d_text');
        this.cd_plane = Laya.Sprite3D.instantiate(plane, __data.deskData.roomVo.scene.getChildByName('container'));
        this.cd_plane.transform.localPosition = new Laya.Vector3(0, 0.35, -2);
        this.cd_plane.transform.localScale = new Laya.Vector3(0.25, 0.25, 0.25);
        this.change_time--;
        if (this.change_time < 0) { this.stopCompassTimer(); }
    }

