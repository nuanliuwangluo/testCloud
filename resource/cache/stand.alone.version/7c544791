    /**
     * 解散房间
     * [dissolveRoomHandler description]
     * @return {[type]} [description]
     */
    dissolveRoomHandler() {
        if (__data.deskData.roomVo.phase == 'ready') {
            //准备阶段  房主有权限解散  其他人无法解散该房间
            if (__data.deskData.roomVo.roomOwner == __data.uid) {
                game.scene.add(MultipleBtnPrompt, [__tipsName[7014], function () { game.server.send(3005) }])
            } else { __tips(__tipsName[7033]) }
        } else if (__data.deskData.roomVo.phase == 'game' || __data.deskData.roomVo.phase == 'result') {
            //游戏阶段 或者 结算阶段 都可解散该房间
            game.server.send(3005)
        }
    }

    /**
     * 退出房间
     * [quitRoomHandler description]
     * @return {[type]} [description]
     */
    quitRoomHandler() {
        if (__data.deskData.roomVo.phase == 'ready') {
            //准备阶段  且是体验房间的话  允许房主退出房间   否则  房主只能解散
            if (__data.deskData.roomVo.roomOwner == __data.uid && __data.deskData.roomVo.createModel == 3) { game.server.send(3004) } else if (__data.deskData.roomVo.roomOwner != __data.uid) { game.server.send(3004) } else { __tips(__tipsName[7033]) }
        } else if (__data.deskData.roomVo.phase == 'game' || __data.deskData.roomVo.phase == 'result') {
            //游戏阶段 或者 结算阶段 都不可退出房间
            __tips(__tipsName[7033])
        }
    }


    /**
     * 游戏阶段界面
     * [updatePhaseHandler description]
     * @return {[type]} [description]
     */
    updatePhaseHandler() {
        if (__data.deskData.roomVo.phase == "ready" && __data.deskData.roomVo.roomModel == __data.deskData.roomVo.FRIEND) {
            this.readyGame();
            this.setChangeHandler();
        } //房卡场有准备阶段。 金币场是没有的 
        else if (__data.deskData.roomVo.phase == "game") {
            game.cb.event('AITalking_init');
