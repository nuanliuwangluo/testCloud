class GameMainNewPlayerGift extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_newPlayerGift',
            layer: 'panel'
        })
        this.btn_receive.addComponent(S_newPlayerGift_receive)
        this.btn_select.addComponent(S_click_single_select_box)
        this.btn_close.addComponent(S_newPlayerGift_receive1)
    }
    added(type = 'newPlayer') {
        this.type = type;
        // type = newPlayer or returnPlayer
        if (type == 'newPlayer') {
            this.btn_close.visible = false
            this.btn_select.visible = false;
            this.txt_select.visible = false;
            this.img_title.skin = `cdn/newPlayerGift/img_xsdlb_xr.png`
            miniApi.trackEvent_gameStep('Mj_StepAnalysis', { 'Mj_Steps': '新人大礼包-显示' })

            this.update_newPlayerGift_data()
            game.cb.on('update_newPlayerGift_data', this, this.update_newPlayerGift_data)
            miniApi.setItem(__data.uid + ':' + new Date().toDateString() + ':show_panel_newPlayerGift', 1)
        } else if (type == 'returnPlayer') {
            this.btn_close.visible = true
            this.btn_select.visible = miniApi.clientType != 'app';
            this.txt_select.visible = miniApi.clientType != 'app';
            this.img_title.skin = `cdn/newPlayerGift/img_xsdlb_hg.png`
            miniApi.trackEvent_gameStep('Mj_StepAnalysis', { 'Mj_Steps': '回归大礼包-显示' })

            this.update_returnPlayerGift_data()
            game.cb.on('update_returnPlayerGift_data', this, this.update_returnPlayerGift_data)
            miniApi.setItem(__data.uid + ':' + new Date().toDateString() + ':show_panel_returnPlayerGift', 1)

            if (__data.sub.isSubActivity) {
                this.btn_select.visible = false;
                this.txt_select.visible = false;
                this.btn_select.isSelect = false;
            }
        }
    }
    onDisable() {
        game.cb.off('update_newPlayerGift_data', this, this.update_newPlayerGift_data)
        game.cb.off('update_returnPlayerGift_data', this, this.update_returnPlayerGift_data)
        // game.cb.event('hall_play_show_hand')
        // if (this.type == 'returnPlayer') {
        // hallTestShowPanel()
        // }
    }
    update_newPlayerGift_data() {
        this.scene_prop0.vo = __data.newPlayerGift.reward[0]
        this.scene_prop1.vo = __data.newPlayerGift.reward[1]
        this.scene_prop2.vo = __data.newPlayerGift.reward[2]
    }
    update_returnPlayerGift_data() {
        this.scene_prop0.vo = __data.returnPlayerGift.reward[0]
        this.scene_prop1.vo = __data.returnPlayerGift.reward[1]
        this.scene_prop2.vo = __data.returnPlayerGift.reward[2]
    }
    clickMask() { }
}
class S_newPlayerGift_receive1 extends Laya.Script {
    onClick(e) {
        let receive = () => {
            miniApi.trackEvent_gameStep('Mj_StepAnalysis', { 'Mj_Steps': '回归大礼包-领取' + __data.returnPlayerGift.isReceive })
            game.scene.remove(GameMainNewPlayerGift)
            if (!__data.returnPlayerGift.isHaveGift) return;
            // 发送领取消息
            game.server.send(16004)
        }
        receive()
    }
}
class S_newPlayerGift_receive extends Laya.Script {
    async onClick(e) {
        if (this.owner.parent.type == 'newPlayer') {
            miniApi.trackEvent_gameStep('Mj_StepAnalysis', { 'Mj_Steps': '新人大礼包-领取' + __data.newPlayerGift.isReceive })
            if (__data.newPlayerGift.isReceive) return;

            miniApi.adsdk_track('CREATE_ROLE')

            try {
                let a = miniApi.getItem(__data.uid + ':click_S_newPlayerGift_receive')
                if (a) {
                    game.scene.remove(GameMainNewPlayerGift)
                    game.server.send(2246)
                }
                miniApi.setItem(__data.uid + ':click_S_newPlayerGift_receive', 1)
                // V3.1.9.5
                // 1、点击“立即领取”时弹出授权（信息 + 好友），无论玩家是否授权成功，关闭好友授权界面后正常走领取流程
                await miniApi.getUserProfile()
                // wx.getOpenDataContext().postMessage({ 'type': 'getFriendData' })
            } catch (error) {
            }
            // 发送领取消息
            game.scene.remove(GameMainNewPlayerGift)
            game.server.send(2246)
            // miniApi.setItem(__data.uid + ':offline_action_receive_newPlayer_gift', 1)
        } else {
            let receive = () => {
                miniApi.trackEvent_gameStep('Mj_StepAnalysis', { 'Mj_Steps': '回归大礼包-领取' + __data.returnPlayerGift.isReceive })
                game.scene.remove(GameMainNewPlayerGift)
                if (!__data.returnPlayerGift.isHaveGift) return;
                // 发送领取消息
                game.server.send(16004)
            }
            if (!this.owner.parent.btn_select.visible || !this.owner.parent.btn_select.isSelect) {
                receive()
            } else {
                if (!__data.sub.isSubActivity) {
                    let a = await miniApi.activitySubscribe()
                    if (a == 1) {
                        receive()
                        game.server.send(16006, 1)
                    }
                }
            }
        }
    }
}