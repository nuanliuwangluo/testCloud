class FriendRoomRedPanel extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_friendRoom/friendRoom_redPanel',
            layer: 'panel'
        })
        this.btn_rank.addComponent(S_FriendRoomRedPanel_rank)
        this.btn_rank.alpha = 0;
        this.sbar = this.img_bar.addComponent(S_progress_bar)
        this.btn_robRed.addComponent(S_FriendRoomRedPanel_robRed)
        this.btn_rob2.addComponent(S_FriendRoomRedPanel_rob2)
        this.btn_game2.addComponent(S_FriendRoomRedPanel_game2)
        this.btn_subscribe.addComponent(S_FriendRoomRedPanel_subscribe)
        this.btn_receiveTask.addComponent(S_FriendRoomRedPanel_receiveTask)
        this.btn_reChallenge.addComponent(S_click_friend_reChallenge)
    }
    async added() {
        game.server.send(20002)
        effectUtils.stopBreathe(this.btn_robRed)
        await __tool.await(1)
        this.update_friend_red_data()
        game.cb.on('update_friend_red_data', this, this.update_friend_red_data)
    }
    onDisable() {
        game.cb.off('update_friend_red_data', this, this.update_friend_red_data)
        this.clearAwait && this.clearAwait()
        effectUtils.stopBreathe(this.btn_robRed)
        effectUtils.stopBreathe(this.btn_receiveTask)
    }
    update_friend_red_data() {
        this.sp_pro.visible = false;
        this.sp_end.visible = false;
        this.btn_robRed.visible = false;
        this.btn_rob2.visible = false;
        this.btn_game2.visible = false;
        this.btn_reChallenge.visible = false;
        this.btn_receiveTask.visible = false;
        this.img_receiveTask_tips.visible = false;
        effectUtils.stopBreathe(this.btn_receiveTask);

        let { need, name } = __data.friendRoom.red;
        let redStatus = __data.friendRoom.red.status;
        let redNum = __data.friendRoom.red.surplusRedNum;
        this.txt_task_name.text = name
        this.txt_red_num.text = `剩余${redNum}个`
        this.txt_time.text = `每日${__data.friendRoom.red.timeStart}:00-${__data.friendRoom.red.timeEnd}:00`

        __tool.labelParentCenterAndSetXY(this.sp_des1, 0, 0, 0)
        __tool.labelParentCenterAndSetXY(this.sp_des2, 0, 0, 0)

        if (redNum <= 0) {
            this.sp_end.visible = true;
            this.txt_end.text = '今日好友大擂台红包已抢光，更多红包活动即将开启，敬请期待！'
        }
        else if (__data.friendRoom.red.isTimeEnd()) {
            this.sp_end.visible = true;
            this.txt_end.text = '今日好友大擂台红包已结束，更多红包活动即将开启，敬请期待！'
        }
        else if (redStatus == 2) {
            this.sp_end.visible = true;
            this.txt_end.text = '恭喜获得红包，更多红包活动即将开启，敬请期待！'
        }
        else if (redStatus == 1) {
            this.sp_pro.visible = true;
            this.btn_robRed.visible = true;
            this.txt_pro.text = '挑战成功';
            this.sbar.progress = 1;
            this.img_fail.visible = false;
        }
        else if (redStatus == 0) {
            // 无红包（未领取任务）
            this.sp_pro.visible = true;
            this.btn_receiveTask.visible = true;
            this.img_receiveTask_tips.visible = true;
            this.sbar.progress = 0;
            this.img_fail.visible = false;
            effectUtils.breathe(this.btn_receiveTask, 1, 1.1, 500)
        }
        else if (redStatus == 3) {
            // 任务已领取（未完成）
            this.btn_rob2.visible = true;
            this.btn_rob2.gray = true
            this.btn_game2.visible = true;
            this.sp_pro.visible = true;
            this.txt_pro.text = 0 + ' / ' + need;
            this.sbar.progress = 0 / need;
            this.img_fail.visible = false;
        }
        else if (redStatus == 4) {
            // 任务失败（未完成）
            this.btn_reChallenge.visible = true;
            this.sp_pro.visible = true;
            this.txt_pro.text = 0 + ' / ' + need;
            this.sbar.progress = 0 / need;
            this.img_fail.visible = true;
        }
        else {
            this.btn_rob2.visible = true;
            this.btn_rob2.gray = true
            this.btn_game2.visible = true;

            this.sp_pro.visible = true;
            this.txt_pro.text = 0 + ' / ' + need;
            this.sbar.progress = 0 / need;
            this.img_fail.visible = false;
        }
    }
}
class S_FriendRoomRedPanel_rank extends Laya.Script {
    onClick(e) {
        // 全民红包排行榜
        game.server.send(18006, 7)
        game.scene.add(FriendRoomRedRank)
    }
}
class S_FriendRoomRedPanel_robRed extends Laya.Script {
    onClick(e) {
        let s = __data.friendRoom.red.status;
        if (s == 1) {
            game.server.send(18020)
        }
    }
}
class S_FriendRoomRedPanel_rob2 extends Laya.Script {
    onRightClick() {
        if (miniApi.clientType === 'web') {
            game.server.send(18021, HallPlay.curRuleId, __data.uid, __data.uid)
        }
    }
    onClick(e) {
        __tips('尚未达到领取条件')
    }
}
class S_FriendRoomRedPanel_game2 extends Laya.Script {
    onClick(e) {
        game.scene.remove(FriendRoomRedPanel)
    }

}
class S_FriendRoomRedPanel_subscribe extends Laya.Script {
    async onClick(e) {
        if (!__data.allPlayerRed.isSub) {
            let a = await miniApi.activitySubscribe()
            if (a == 1) {
                game.server.send(18005)
                game.scene.remove(FriendRoomRedPanel)
            }
        } else {
            __tips('订阅成功')
            game.scene.remove(FriendRoomRedPanel)
        }
    }
}
class S_FriendRoomRedPanel_receiveTask extends Laya.Script {
    onClick(e) {
        if (__showScene.sceneType == 'hallPlay') {
            game.server.send(18022)
        } else {
            if (__data.deskData.roomVo.curGame > 5) {
                __tips('不符合接任务条件：本场对局已超过5局')
            } else {
                game.server.send(18022)
            }
        }
    }
}