// 发财树奖励道具
class PropItem2 extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/propItem2',
            module: false
        })
        this.__vo;
        this.addComponent(S_prop_show_des)

        this.url = [];
        for (let index = 0, length = 39; index < length; index++) {
            this.url.push('cdn/dailyLogin_effect/' + (index + 1) + '.png')
        };
        this.img_effect.visible = false
        this.arr = [];
    }
    onEnable() {
        game.cb.on('tree_reward_prop_item_effect', this, this.tree_reward_prop_item_effect)
    }
    onDisable() {
        game.cb.on('tree_reward_prop_item_effect', this, this.tree_reward_prop_item_effect)
        this.clearAwait && this.clearAwait()
        while (this.arr.length) {
            let a = this.arr.shift();
            a.stop();
            game.utils.remove(a)
        }
        this.arr = [];
    }
    async tree_reward_prop_item_effect() {
        let img = game.Clip(null, this.url, 45, false, () => {
            img.stop()
            img.visible = false
            game.utils.remove(img)
        })
        img.width = this.img_effect.width
        img.height = this.img_effect.height
        img.skin = this.url[0]
        img.x = this.img_effect.x
        img.y = this.img_effect.y
        this.addChild(img)
        img.play(0)
        this.arr.push(img)
    }
    set vo(vo) {
        if (!vo) return;
        this.__vo = vo;
        this.txt_num.text = bigNumberToCH(vo.num);
        this.img_prop.skin = PropIcon.icon[vo.propId].skin

        let a = this.width / gtool.fileWH.getWHById(vo.propId).w
        let b = this.height / gtool.fileWH.getWHById(vo.propId).h
        this.img_prop.scaleX = Math.min(a, b)
        this.img_prop.scaleY = Math.min(a, b)
    }
    get vo() {
        return this.__vo;
    }
}
Laya.ClassUtils.regClass('ui.scene_hall.propItem2UI', PropItem2);
