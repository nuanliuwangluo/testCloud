// 重回房间逻辑
let __reBack_info = {
    mahjong: {
        code: -1,
        roomId: 0,
        roomType: 1,
        isRead: false
    },
    call: null,
    // 退出房间的时候是否回到主界面
    backMain: false,
    read(_call) {
        this.call = _call;
        this.mahjong.isRead = false;
        game.server.send(3001);
        // game.server.send(13001);
    },
    async back() {
        // 消息读取完毕
        if (this.mahjong.isRead) {
            // 在麻将房间里
            if (this.mahjong.code == 1) {
                __data.firstPay.send() // 首充礼包 影响布局 这里不干掉 因为返回房间 继续匹配可能会用
                game.server.send(2405) // 商城信息 里面有支付显示 必须发送
                game.server.send(2211) // 救济金
                this.in(__data.gameId.curId, this.mahjong.roomId);
            }
            // 都没有在2种房间内
            else {
                let r = false;
                try {
                    r = __data.analysisParams(wx.onshow_res.query);
                } catch (e) {
                    r = __showScene.handleRoomParams();
                    __data.deleteParams();
                }
                if (!r && this.call instanceof Function) {
                    this.call();
                    this.call = null;
                }
            }
        }
    },
    // 加入房间
    async in(gameId, roomId) {
        game.server.send(16022);
        if (this.mahjong.roomType == 2) {
            game.server.send(14016);
        } else if (__data.gameId.isMahjong(gameId)) {
            await __showScene.load_game_mahjong()
            __showScene.show_game_mahjong(true);
            game.server.send(3000, roomId);
            game.server.send(3002, roomId);
        }
        this.mahjong.code = 0;
        this.mahjong.roomId = 0;
        this.mahjong.roomType = 1;
    }
};