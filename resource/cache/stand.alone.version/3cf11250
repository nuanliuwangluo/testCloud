                    )
                }
                if (__tool.getDeepProperty(data, 'playerTop3s.top3Id')) {
                    person_datas.push(
                        { rank: 3, uid: data.playerTop3s.top3Id, score: data.playerTop3s.top3Score, cityId: data.playerTop3s.playerTop2city }
                    )
                }
                data.legendId = -1;
                if (person_datas[0] && person_datas[0].uid) {
                    let rd = RankUtils.getRankLvDataByScore(person_datas[0].score);
                    if (rd.toNextLevelNeedCup == 0 && person_datas[0].score - rd.minCup >= __data.rank.rank_exceed_queshen_score) {
                        data.legendId = person_datas[0].uid;
                    }
                }

                let local_datas = [];
                if (__tool.getDeepProperty(data, 'myCityData.top3s.top1Id')) {
                    local_datas.push(
                        { rank: 1, uid: data.myCityData.top3s.top1Id, score: data.myCityData.top3s.top1Score, cityId: data.myCityData.c }
                    )
                }
                if (__tool.getDeepProperty(data, 'myCityData.top3s.top2Id')) {
                    local_datas.push(
                        { rank: 2, uid: data.myCityData.top3s.top2Id, score: data.myCityData.top3s.top2Score, cityId: data.myCityData.c }
                    )
                }
                if (__tool.getDeepProperty(data, 'myCityData.top3s.top3Id')) {
                    local_datas.push(
                        { rank: 3, uid: data.myCityData.top3s.top3Id, score: data.myCityData.top3s.top3Score, cityId: data.myCityData.c }
                    )
                }

                let person_data_me = null;
                if ('myIndex' in data) {
                    person_data_me = { rank: data.myIndex, uid: __data.uid, cityId: data.myCity, score: data.myScore, isMe: true }
                }

                let local_data_me = null;
                let rn1 = __tool.getDeepProperty(data, 'myCityPlayerData')
                if (rn1 != undefined) {
                    local_data_me = { rank: data.myCityPlayerData.i, uid: __data.uid, cityId: data.myCityPlayerData.c, score: data.myCityPlayerData.s, isMe: true }
                }

                __data.seasonRecord[data.id].rankData = {
                    legendId: data.legendId || 0,
                    person_datas,
                    person_data_me,
                    local_datas,
                    local_data_me,
                };

                game.cb.event('update_season_record_item_data_by_id', [data.id])
            }
        } catch (error) {
            miniApi.uploadError(__data.uid + ' - 2251 - ' + JSON.stringify(error))
            console.error(error);
        }
