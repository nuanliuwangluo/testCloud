class GameMainRelief extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_relief',
            layer: 'panel'
        })
        this.btn_video.addComponent(S_relief_video)
        this.btn_share.addComponent(S_relief_video)
        this.videoR;
        // this.btn_close.visible = false;
        this.sp_of1.visible = false;
        this.btn_giveup.addComponent(S_relief_close)
    }
    added() {
        miniApi.setItem(__data.uid + ':' + new Date().toDateString() + ':show_panel_helpGold', 1)
        // this.txt_content.text = `您可领取${__data.helpGold_num}金币，今天还能领取${__data.helpGold_count}次。`
        this.update_relife_mul(0, 2)

        let isVideoSuccess = __data.shareVideoRule.ifVideoSuccessUseRule('adunit-1f51e678c42934e3')
        this.update_video_ready({ adUnitId: 'adunit-1f51e678c42934e3', isSuccess: isVideoSuccess })
    }
    onDisable() {
        hallTestShowPanel()
    }
    update_video_ready(r) {
        this.videoR = r;
        this.btn_video.visible = false
        this.btn_share.visible = false
        if (r.isSuccess) {
            this.btn_video.visible = true
        } else {
            this.btn_share.visible = true
            // __data.shareVideoRule.total_shareShowCount(this.btn_share.parent)
        }
    }
    clickMask() { }
    async update_relife_mul(isTween, mul) {
        this.sp_btn.visible = true;
        this.txt_gold.text = __data.helpGold_num;
        this.txt_count.text = `（今日剩余${__data.helpGold_count}次）`
        __tool.labelParentCenterAndSetXY(this.sp_txt, this.sp_of1.x, 5)
    }
}

class S_relief_close extends Laya.Script {
    onClick(e) {
        new S_relief_receive().onClick()
    }
}
class S_relief_receive extends Laya.Script {
    onClick(e) {
        let gr = game.scene.get(GameMainRelief)
        game.server.send(2215)
        S_relief_receive.type = 0
        S_relief_receive.videoR = gr.videoR
        // 增加一个消息 让2212可以生效 否则后台拦截
        game.scene.remove(GameMainRelief)
    }
}
S_relief_receive.type = 0
window.S_relief_receive = S_relief_receive;
class S_relief_video extends Laya.Script {
    async onClick(e) {
        let gr = game.scene.get(GameMainRelief)
        game.server.send(2215)
        S_relief_receive.type = 1
        S_relief_receive.videoR = gr.videoR
        // 增加一个消息 让2212可以生效 否则后台拦截
    }
}