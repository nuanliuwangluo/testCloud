/**
 * 血战麻将下雨刮风特效
 * @author sweets
 */
class MahjongXuezhanEffect extends Laya.Script{

    onAwake(){
        this.rain = new Laya.Image();
        this.wind = new Laya.Image();
        this.rain.anchorX = this.rain.anchorY = 0.5;
        this.wind.anchorX = this.wind.anchorY = 0.5;
    }
    onEnable(){
        game.cb.on('xuezhan_effect_rain', this, this.effectRain);
        game.cb.on('xuezhan_effect_wind', this, this.effectWind);
    }
    onDisable(){
        game.cb.off('xuezhan_effect_rain', this, this.effectRain);
        game.cb.off('xuezhan_effect_wind', this, this.effectWind);
    }

    effectRain(){
        __sound.gameSound("xuezhan_rain");
        this.container && this.container.addChild(this.rain).pos(this.container.width / 2, this.container.height / 2);
        // 下雨效果
        this.rain.addComponent(PlayComponent).start({ startIndex:1, endIndex:11, frame:2, prefix:'cdn/mahjong_xuezhan/rain_', tail:'png', complete:()=>{
            game.utils.remove(this.rain);
        }});
    }
    effectWind(){
        __sound.gameSound("xuezhan_wind");
        this.container && this.container.addChild(this.wind).pos(this.container.width / 2, this.container.height / 2);
        // 吹风效果
        this.wind.addComponent(PlayComponent).start({ startIndex:1, endIndex:11, frame:2, prefix:'cdn/mahjong_xuezhan/wind_', tail:'png', complete:()=>{
            game.utils.remove(this.wind);
        }});
    }

    get container(){
        return this.owner ? this.owner.game.getChildByName('desk') : null;
    }
}