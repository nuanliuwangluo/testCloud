class GameMainWinLoseGuide extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_winLoseGuide',
            layer: 'panel'
        })
        // show_gameMain_winLoseGuide
        this.btn_go.addComponent(S_winloseguide_go)
        this.btn_close.addComponent(S_winloseguide_close)
    }
    async added() {
        miniApi.setItem(__data.uid + ':' + new Date().toDateString() + ':show_panel_winLoseGuideType', GameMainWinLoseGuide.showType)
        this.img_win.visible = GameMainWinLoseGuide.showType == 'win';
        this.img_lose.visible = !this.img_win.visible;
        GameMainWinLoseGuide.showType = null;
    }

    onDisable() { }
    clickMask() {
        hallTestShowPanel()
    }
}
GameMainWinLoseGuide.showType = null; // win lose

class S_winloseguide_go extends Laya.Script {
    onClick(e) {
        miniApi.setItem(__data.uid + ':' + new Date().toDateString() + ':show_panel_winLoseGuide_go', 1)
        if (HallPlay.lastCityId) {
            __data.lastSceneQueue.push(__showScene.show_hall)
            __showScene.show_hall_play(HallPlay.lastCityId);
        } else {
            __data.lastSceneQueue.push(__showScene.show_hall)
            __showScene.show_hall_play(__data.myCityId);
        }
    }
}

class S_winloseguide_close extends Laya.Script {
    onClick(e) {
        hallTestShowPanel()
    }
}