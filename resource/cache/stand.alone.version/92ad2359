class GardenTask extends game.ModuleBase {
    constructor() {
        super({
            map: 'garden/Garden_task',
            layer: 'panel'
        })
        this.btn_close.addComponent(S_click_GardenTask_close)
        this.s_bar = this.img_bar.addComponent(S_progress_bar)
        this.btn_show_reward.addComponent(S_clickBtnShow_clickOtherRemove).init(this.img_reward)
        this.btn_exe.addComponent(S_garden_task_exe)
        this.btn_open.addComponent(S_garden_task_open)
        this.txt_needStar = new game.NumText(GardenTask.numURL)
        this.img_star1_off.parent.addChild(this.txt_needStar)
        this.txt_needStar.x = this.img_star1_off.x
        this.txt_needStar.y = this.img_star1_off.y
        game.utils.remove(this.img_star1_off)

        this.txt_buildValue = new game.NumText(GardenTask.numURL)
        this.txt_buildValue.align = 'center'
        this.txt_buildValue_off.parent.addChild(this.txt_buildValue)
        this.txt_buildValue.x = this.txt_buildValue_off.x
        this.txt_buildValue.y = this.txt_buildValue_off.y
        game.utils.remove(this.txt_buildValue_off)

        this.txt_reward_box = new game.NumText(GardenTask.numURL)
        this.txt_reward_box.align = 'center'
        this.txt_box_off.parent.addChild(this.txt_reward_box)
        this.txt_reward_box.x = this.txt_box_off.x
        this.txt_reward_box.y = this.txt_box_off.y
        game.utils.remove(this.txt_box_off)

        this.txt_r_box = new game.NumText(GardenTask.numURL)
        this.txt_r_box.align = 'center'
        this.txt_r_off.parent.addChild(this.txt_r_box)
        this.txt_r_box.x = this.txt_r_off.x
        this.txt_r_box.y = this.txt_r_off.y
        game.utils.remove(this.txt_r_off)
        this.txt_r_box.scaleX = this.txt_r_box.scaleY = 0.7

        this.txt_r_box.text = '10万'
        this.txt_r_box.scaleX = 1.2
        this.txt_r_box.scaleY = 1.2
        this.txt_reward_box.text = '10万'

        this.img_hand.visible = false;
    }
    added() {
        game.cb.on('update_garden_task_data', this, this.update_garden_task_data)
        this.update_garden_task_data()

        this.task_hand_add()
        game.cb.event('garden_build_remove_hand')
        game.cb.event('garden_main_ui_res_updateLayer')
    }
    onDisable() {
        game.cb.off('update_garden_task_data', this, this.update_garden_task_data)
        this.task_hand_remove()
    }
    task_hand_add() {
        if (__data.garden.task.isShowHandGuide) {
            this.img_hand.visible = true;
            this.img_hand.clipPlay(0)
        }
    }
    task_hand_remove() {
        this.img_hand.visible = false;
        this.img_hand.clipStop()
    }
    update_garden_task_data() {
        let reward = __data.garden.task.getChapterReward()
        this.item_reward1.visible = false
        this.item_reward2.visible = false
        this.item_reward3.visible = false;
        for (let index = 0, length = reward.length; index < length; index++) {
            const e = reward[index];
            this[`item_reward${index + 1}`].visible = true;
            this[`item_reward${index + 1}`].dataSource = e;
            this.img_reward.width = this[`item_reward${index + 1}`].x + this[`item_reward${index + 1}`].width + this[`item_reward${1}`].x;
        };
        this.txt_progress.text = Math.floor(__data.garden.task.progress * 100) + '%';
        this.s_bar.progress = __data.garden.task.progress
        this.txt_title.text = __data.garden.task.getTitle();

        this.img_buildValue.visible = false
        this.img_box.visible = false
        this.btn_exe.visible = false
        this.btn_open.visible = false
        if (__data.garden.task.rewardType_chapter == 1) {
            this.btn_open.visible = true
            this.img_box.visible = true
            this.txt_taskName.text = '奖励时刻';
            this.txt_progress.text = Math.floor(1 * 100) + '%';
            this.s_bar.progress = 1
        } else if (__data.garden.task.rewardType_chapter == 0) {
            this.btn_exe.visible = true
            this.img_buildValue.visible = true
            this.txt_taskName.text = __data.garden.task.branchTaskName;
            this.txt_buildValue.text = __data.garden.task.buildValue;
            this.txt_needStar.text = __data.garden.task.needStar
        }
    }
    clickMask() {
        game.scene.remove(this)
        game.cb.event('garden_build_add_hand')
        game.cb.event('garden_main_ui_res_updateLayer')
    }
}
GardenTask.numURL = {};
for (let index = 0, length = 10; index < length; index++) {
    GardenTask.numURL[index] = `cdn/garden_ui/${index}.png`
};
GardenTask.numURL['~'] = `cdn/garden_ui/img_blx.png`
GardenTask.numURL['万'] = `cdn/garden_ui/img_wjb.png`

// 赛季结束奖励道具
class GardenTaskRewardItem extends game.ModuleBase {
    constructor() {
        super({
            map: 'garden/Garden_task_reward_item',
            module: false
        })
        this.__vo;
        // this.addComponent(S_prop_show_des)
    }
    onEnable() { }
    onDisable() { }
    set dataSource(vo) {
        if (!vo) return;
        this.__vo = vo;
        // this.txt_num.text = '×' + vo.num;
        this.txt_num.text = vo.num;
        this.img_prop.skin = PropIcon.icon[vo.propId].skin

        let a = this.width / gtool.fileWH.getWHById(vo.propId).w;
        let b = this.height / gtool.fileWH.getWHById(vo.propId).h;
        this.img_prop.scaleX = Math.min(a, b)
        this.img_prop.scaleY = Math.min(a, b)
    }
    get vo() {
        return this.__vo;
    }
}
Laya.ClassUtils.regClass('ui.garden.Garden_task_reward_itemUI', GardenTaskRewardItem);

class S_click_GardenTask_close extends Laya.Script {
    onClick() {
        game.scene.remove(GardenTask)
        game.cb.event('garden_build_add_hand')
        game.cb.event('garden_main_ui_res_updateLayer')
    }
}
class S_garden_task_exe extends Laya.Script {
    onEnable() {
        this.isAni = false;
    }
    async onClick() {
        if (window.TestPanel && window.TestPanel.garden_build_skip_star_test) {

        } else if (__data.garden.star < __data.garden.task.needStar) {
            return __showScene.show_garden_starNoEnough()
        }
        if (this.isAni) return;
        this.isAni = true;
        __sound.playGameYx("usestar");
        __data.addMoney(5, -__data.garden.task.needStar)
        S_garden_task_exe.needStar = __data.garden.task.needStar
        await gardenEffect.taskStar()
        await __tool.await(50)
        Laya.Tween.to(this.owner.parent, { scaleX: 0, scaleY: 0 }, 200)
        await __tool.await(100)
        this.isAni = false;
        // return;
        game.cb.event('garden_remove_main_ui')
        game.scene.remove(GardenTask)
        let a = __data.garden.task.dressSelect(__data.garden.task.branchTaskId);
        if (a.length > 1) {
            game.scene.add(GardenBuildMask);
            game.scene.add(GardenBuild)
        }

        // 移动窗口
        let data = __data.excelConfig.hashGardenPositionArea[__data.garden.task.branchTaskId]
        game.cb.event('garden_groud_scale', ['min', true])
        let g = game.scene.get(Garden_groud)
        await g.moveTo(...data.centerXY.toArray('_'), true)

        if (a.length > 1) {
            game.cb.event('garden_groud_add_filter_ani', [__data.garden.task.branchTaskId])
        } else {
            // 1个选项 没有取消 所以 需要星星 不存
            S_garden_task_exe.needStar = 0;
            game.server.send(15005, __data.garden.task.branchTaskId, a[0].id)
        }
    }
}
class S_garden_task_open extends Laya.Script {
    onClick() {
        game.scene.remove(GardenTask)
        game.server.send(15010)
    }
}