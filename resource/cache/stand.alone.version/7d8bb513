class S_mm_pause_zhendong extends Laya.Script {
    onClick(e) {
        let a = miniApi.getItem(__data.uid + '-vibrate')
        if (a == '0') {
            miniApi.setItem(__data.uid + '-vibrate', 1)
        } else {
            miniApi.setItem(__data.uid + '-vibrate', 0)
        }
        this.owner.parent.updateOnoff()
    }
}
class S_mm_pause_allMusic extends Laya.Script {
    onClick(e) {
        if (LocalUtils.music.value == 0 || LocalUtils.sound.value == 0) {
            LocalUtils.music.value = 1
            LocalUtils.sound.value = 1
            config.isMusic = false
            config.isSound = false
            miniApi.setItem('music', 'false')
            miniApi.setItem('sound', 'false')
            __sound.stopAllMusic()
        } else {
            LocalUtils.music.value = 0
            LocalUtils.sound.value = 0
            config.isMusic = true
            config.isSound = true
            miniApi.setItem('music', 'true')
            miniApi.setItem('sound', 'true')
            __sound.playAllMusic()
        }
        LocalUtils.save(LocalUtils.music.key, LocalUtils.music.value)
        LocalUtils.save(LocalUtils.sound.key, LocalUtils.sound.value)
        this.owner.parent.updateOnoff()
    }
}