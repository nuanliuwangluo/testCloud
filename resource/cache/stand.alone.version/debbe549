class QuickBuyGift {

    static to(uid, giftId, done) {
        this._quick = true;
        this._uid = uid;
        this._giftId = giftId;
        this._done = done;
        game.server.send(2404, this._giftId, 1, 0);
    }

    static do() {
        this._done && this._done(this._uid, this._giftId);
        this.clear();
    }

    static clear() {
        this._quick = null;
        this._uid = null;
        this._giftId = null;
        this._done = null;
    }

    static isQuick(id) {
        let isGift = BagData.gifts.find((e) => {
            return e == id;
        })
        return isGift && this._quick;
    }
}