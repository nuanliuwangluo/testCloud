class GameMainPlayerInfoItem2 extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_playerInfoItem2',
            module: false
        })
        this.__vo;
        // this.addComponent(S_click_playerInfoItem2)
        // this.addComponent(S_prop_show_des__123)
        // this.btn_use.addComponent(S_click_playerInfoItem2_btn_use)

        this.img_prop.on(Laya.Event.CLICK, this, this._useProp);

    }
    onEnable() {
        // game.cb.on('S_click_playerInfoItem2', this, this.S_click_playerInfoItem2)
    }
    onDisable() {
        // game.cb.off('S_click_playerInfoItem2', this, this.S_click_playerInfoItem2)
    }

    _useProp() {
        let targetUid = game.scene.get(GameMainPlayerInfo).curUid;
        if (!targetUid || targetUid == __data.uid) { return }

        let data = PropIcon.icon[this.__vo.id];
        let cross = false;
        // 免费道具
        if (data.buyType == 'free') {
            cross = true;
        } else {
            // 收费道具  数量超过 0个
            if (this.__vo.num > 0 || BagData.getPropNumber(601) > 0) {
                cross = true;
            } else {
                // console.log('弹出购买界面!');
                __showScene.show_shop_601();
                // QuickBuyGift.to(targetUid, this.__vo.id, this.sendGiftAndThenCd.bind(this));
            }
        }
        // 验证通过  可以发送道具
        if (cross) {
            this.sendGiftAndThenCd(targetUid, this.__vo.id);
        }
    }

    sendGiftAndThenCd(uid, giftId) {
        if (DeskCommonUI.scene == 1) //麻将 信息
            game.server.send(5003, uid, giftId);
        else if (DeskCommonUI.scene == 2) //斗地主信息
            game.server.send(15003, uid, giftId);
        this.pieCd = this.img_prop.addComponent(PieCd);
        this.pieCd.start(3000);
        game.scene.remove(GameMainPlayerInfo);
    }

    S_click_playerInfoItem2() {
        // 使用头像框成功后需要执行此事件
        // game.cb.event('update_head_frame');
        // this.btn_use.visible = false;
    }
    set dataSource(vo) {
        if (!vo) return;
        this.__vo = vo;

        this.sp_stone.visible = false
        this.txt_free.visible = false
        this.txt_num.visible = false
        let p = PropIcon.icon[vo.id];
        if (p.buyType == 'free') {
            this.txt_free.visible = true
        } else if (p.buyType == 'stone' && vo.num <= 0) {
            this.sp_stone.visible = true
            this.txt_stone.text = p.price;
            __tool.labelParentCenterAndSetXY(this.sp_stone, this.width / 2, 5)
        } else {
            this.txt_num.visible = true
            this.txt_num.text = vo.num + '次'
        }
        this.img_prop.skin = p.skin;
        // this.txt_name.text = PropIcon.icon[vo.propId].name
        // this.img_useing.visible = vo.isUseing ? true : false;
        // this.img_lock.visible = vo.isLock ? true : false;
        // this.btn_use.visible = false;
    }
    get vo() {
        return this.__vo;
    }
}
