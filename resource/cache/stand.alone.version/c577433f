class S_scelet_play_0_click extends Laya.Script {
    onClick(e) {
        let pp = this.owner.name.slice(1)
        if (pp == 1) {
            // 如果是黑龙江
            miniApi.trackEvent_gameStep('Mj_StepAnalysis', { 'Mj_Steps': '选择玩法-省份黑龙江' })
            game.scene.remove(GameMainSelectPlay0)
            game.scene.remove(GameMainSelectPlay0_return)
            game.scene.remove(GameMainSelectPlay0_otherArea)
            game.scene.add(GameMainSelectPlay1)
            game.scene.add(GameMainSelectPlay1_return)
            game.scene.add(GameMainSelectPlay1_otherArea)
        } else if (pp == 25 || pp == 26 || pp == 27 || pp == 28) {
            // 点击北京、上海、天津、重庆的也直接视为选完玩法了
            miniApi.trackEvent_gameStep('Mj_StepAnalysis', { 'Mj_Steps': '选择玩法-省份其他' })
            for (const key in __data.excelConfig.hashCityIdVO) {
                let e = __data.excelConfig.hashCityIdVO[key]
                if (e.provinceId == pp) {
                    hall_modifyMyCityId(e.cityId) // 位置玩法
                    break
                }
            }
        } else {
            miniApi.trackEvent_gameStep('Mj_StepAnalysis', { 'Mj_Steps': '选择玩法-省份其他' })
            game.scene.add(GameMainSelectPlay2, [pp, 1])
        }
    }
}