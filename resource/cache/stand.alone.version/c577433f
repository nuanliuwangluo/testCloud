class GameMainSelectPlay2 extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_selectPlay2',
            layer: 'panel'
        })
        this.__list.vScrollBarSkin = '';
        this.btn_other.addComponent(S_click_close_remove_parent)
        // this.btn_more.addComponent(S_selectPlay_more)
        // this.btn_close.visible = false;
    }
    async added(bigCityId, is_province) {
        // 检测是不是黑龙江地区
        let a1 = game.scene.get(GameMainSelectPlay1)
        let isHeilongjiang = a1 && a1.parent;
        this.btn_other.visible = !isHeilongjiang;
        this.img_bg_province.visible = !isHeilongjiang;

        // is_province 1 bigCityId是省份
        // is_province 0 bigCityId不是省份
        this.__list.array = []

        // GameMainSelectPlay.defaultIndex = GameMainSelectPlay.defaultIndex || 0
        // 这里需要延迟 不延迟 onSelect 里面设置颜色不好使 laya bug
        if (!is_province)
            this.showSmallCityList(bigCityId);
        else this.showSmallCityListByProvince(bigCityId)

        this.txt_title.text = '请选择玩法'

        if (!isHeilongjiang) this.tween1()
    }
    onDisable() {
        this.clearAwait && this.clearAwait()
        Laya.Tween.clearAll(this.btn_other)
    }
    showSmallCityList(bigCityId) {
        let bigCityName = excelUtils.getBigCityName(bigCityId);
        let a = excelUtils.getSmallCityListByBigCity(bigCityName)
        this.show_list(a)
    }
    showSmallCityListByProvince(provinceId) {
        this.img_province.skin = `local/a_selectPlay/1/img_sheng${provinceId}.png`;

        let v = [];
        for (const key in __data.excelConfig.hashCityIdVO) {
            let e = __data.excelConfig.hashCityIdVO[key];
            if (e.provinceId == provinceId) {
                v.push({
                    cityName: e.cityName,
                    cityId: e.cityId,
                })
            }
        }
        this.show_list(v)
    }
    show_list(a) {
        a.sort((a1, a2) => {
            let s1 = excelUtils.getPlayOnOff(a1.cityId)
            let defaultPlayId = s1 && s1.defaultPlayId || -1;
            let hot1 = parseInt(defaultPlayId) != -1;

            let s2 = excelUtils.getPlayOnOff(a2.cityId)
            defaultPlayId = s2 && s2.defaultPlayId || -1;
            let hot2 = parseInt(defaultPlayId) != -1;

            let v1 = 0;
            let v2 = 0;
            if (hot1) v1 = 1000
            if (hot2) v2 = 1000
            return v2 - v1;
        })
        this.__list.array = a
    }
    clickMask() {
        if (GameMainSelectPlayBG.isClose) {
            game.scene.remove(this)
        }
    }
    async tween1() {
        await __tool.tweenp(this.btn_other, {
            scaleX: 1.1,
            scaleY: 1.1,
        }, 500)
        await __tool.tweenp(this.btn_other, {
            scaleX: 0.9,
            scaleY: 0.9,
        }, 500)
        this.tween1()
    }
}

class GameMainSelectPlayItem extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_selectPlayItem',
            module: false
        })
        this.__vo;
        this.addComponent(S_click_selectPlayItem)
    }
    onEnable() {
        this.img_effect.visible = false;
    }
    onDisable() {
        this.clearAwait && this.clearAwait()
    }
    set dataSource(vo) {
        if (!vo) return;
        this.__vo = vo;
        let a2 = excelUtils.getPlayOnOff(vo.cityId)
        let defaultPlayId = a2 && a2.defaultPlayId || -1
        this.txt_name.text = vo.cityName + '麻将';
        this.txt_name.color = '#505374'
        this.img_sign.visible = false;
        this.img_bg.skin = 'local/a_selectPlay/1/bt_unchooce.png'
        if (GameMainSelectPlayBG.isCur) {
            this.img_sign.skin = 'local/a_selectPlay/1/img_dq.png'
            if (vo.cityId == __data.myCityId) {
                this.img_sign.visible = true;
                this.img_bg.skin = 'local/a_selectPlay/1/bt_chooce.png'
                this.txt_name.color = '#5aa73c'
            }
        } else {
            this.img_sign.skin = 'local/a_selectPlay/1/img_zj.png'
            let nearCityId = miniApi.getItem(__data.uid + '_near_play')
            if (vo.cityId == nearCityId) {
                this.img_sign.visible = true;
                this.img_bg.skin = 'local/a_selectPlay/1/bt_chooce.png'
                this.txt_name.color = '#5aa73c'
            }
        }
        this.img_hot.visible = parseInt(defaultPlayId) > 0;
        if (miniApi.clientType == 'app') {
            this.img_hot.visible = false;
        }

        if (!__data.myCityId) {
            this.playEffect()
        }
    }
    async playEffect() {
        this.clearAwait && this.clearAwait()
        this.img_effect.visible = true
        Laya.Tween.clearAll(this.img_effect)
        this.img_effect.alpha = 1;
        await __tool.tweenp(this.img_effect, {
            alpha: 0,
        }, 500)
        await __tool.tweenp(this.img_effect, {
            alpha: 1,
        }, 500)
        this.playEffect()
    }
}
Laya.ClassUtils.regClass('ui.scene_hall.gameMain_selectPlayItemUI', GameMainSelectPlayItem);

class S_click_selectPlayItem extends Laya.Script {
    onClick(e) {
        miniApi.trackEvent_gameStep('Mj_StepAnalysis', { 'Mj_Steps': '选择玩法-2级玩法' })
        let cityId = this.owner.__vo.cityId;
        if (GameMainSelectPlayBG.isCur) {
            hall_modifyMyCityId(cityId)
            if (!GameMainSelectPlayBG.isClose) {
                miniApi.trackEvent('Mj_Login', { Mj_ADPreference: miniApi.adUserValueLevel, 'Mj_LoginType': '完成选区', 'Mj_LoginDate': __data.Mj_LoginDate })
            }
        } else {
            game.server.send(11004, cityId)
            let a = __data.lastSceneQueue.pop();
            a && a(cityId)
        }
    }
}

let hall_modifyMyCityId = window.hall_modifyMyCityId = (myCityId) => {
    miniApi.setItem(__data.uid + ':offline_action_change_city', 1)
    if (!__data.myCityId) {
        miniApi.adsdk_track('REGISTER')
        let a = __data.excelConfig.hashCityIdVO[myCityId]
        let Mj_SetProvince = a && a.province || '其他'
        let Mj_SetCounty = a && a.cityName || '其他'
        let Mj_Results = ''
        if (__data.province) {
            if (__data.province.includes(Mj_SetProvince)) {
                Mj_Results = '正确'
            } else {
                Mj_Results = '错误'
            }
        } else {
            Mj_Results = '未知'
        }

        miniApi.trackEvent('Mj_IPAnalysis', {
            Mj_APIProvince: __data.province || '未知',
            Mj_SetProvince,
            Mj_SetCounty,
            Mj_Results,
        })

    }



    __data.myCityId = myCityId;
    game.server.send(2216, myCityId)

    let a = __data.lastSceneQueue.pop();
    a && a(myCityId)
}

