class FriendRoom_info_main extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_friendRoom/friendRoom_info_main',
            layer: 'panel'
        })
        this.__tab.selectHandler = new Laya.Handler(this, this.onSelect);
        this.__list.vScrollBarSkin = ''
        this.btn_return.addComponent(S_fr_info_main_return)
    }
    added(vo) {
        this.vo = vo;
        this.cityId = vo.cityId;
        this.ruleId = vo.ruleId;
        this.rule = vo.rule;

        [1, 2, 3, 4].forEach((e, index) => {
            try {
                let pl = this['player' + e];
                pl.skin = vo.playerHeadUrls[index];
                pl.getChildByName('img_frame').skin = PropIcon.icon[vo.playerHeadBorders[index] || 301].skin;
                LabelHiddenUtils.getAdapterContent(pl.getChildByName('txt_name'), vo.playerNames[index])
            } catch (error) {
                console.error('FriendRoom_info_main added', error)
            }
        })

        this.__tab.selectedIndex = 0;
        this.onSelect(0)
        game.cb.on('update_friendRoom_info_main_data', this, this.update_friendRoom_info_main_data)
        if (FriendRoom_record_main_gameRecord.save) {
            this.update_friendRoom_info_main_data(FriendRoom_record_main_gameRecord.friend_room_info_vo1)
        }
    }
    onDisable() {
        game.cb.off('update_friendRoom_info_main_data', this, this.update_friendRoom_info_main_data)
    }
    async onSelect(index) {
        let bs = this.__tab.items
        this.origin_tab_labelColors = this.origin_tab_labelColors || this.__tab.labelColors;
        for (let index = 0, length = bs.length; index < length; index++) {
            const e = bs[index];
            e.labelColors = this.origin_tab_labelColors;
            e.labelStroke = 0;
        };
        this.onSelectTag(index)
        await __tool.await(10)
        bs[index].labelStroke = 4;
        bs[index].labelColors = '#fff,#fff,#fff';
    }
    onSelectTag(index) {
        this.scene_0.visible = false;
        this.scene_1.visible = false;
        if (index == 0) {
            this.scene_0.visible = true
            let a = this.useData && this.useData.data || [];
            this.__list.array = a;
            if (FriendRoom_record_main_gameRecord.save) {
                this.__list.scrollTo(FriendRoom_record_main_gameRecord.list_index001 || 0)
            }
        } else {
            this.scene_1.visible = true;
            this.scene_1.set_play(this.cityId, this.ruleId, this.vo.playerNames.length, this.vo.roundCount, this.rule);
        }
    }
    update_friendRoom_info_main_data(data) {
        FriendRoom_record_main_gameRecord.friend_room_info_vo1 = data;
        if (data.rid == this.vo.roomId) {
            this.useData = data;
        } else this.useData = null;
        this.onSelectTag(this.__tab.selectedIndex)
    }
}

class S_fr_info_main_return extends Laya.Script {
    onClick(e) {
        game.scene.remove(FriendRoom_info_main)
    }
}

