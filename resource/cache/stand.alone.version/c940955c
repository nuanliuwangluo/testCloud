    set dataSource(vo) {
        this.vo = vo;
        if (!vo) return;
        this.txt_index.text = vo.round;
        [1, 2, 3, 4].forEach((e, index) => {
            try {
                // let pl =  ;
                // pl.skin = v['player' + e].head;
                // pl.getChildByName('img_frame').skin = PropIcon.icon[v['player' + e].headFrameId].skin;
                // LabelHiddenUtils.getAdapterContent(pl.getChildByName('txt_name'), v['player' + e].name)
