class S_FR_info_main_item_replay extends Laya.Script {
    onClick(e) {
        FriendRoom_record_main_gameRecord.info_main_index;

        let ud = FriendRoom_record_main_gameRecord.friend_room_info_vo1
        let a = ud && ud.data || [];
        let index = a.findIndex((e) => {
            return e.roundId == this.owner.parent.vo.roundId
        })
        FriendRoom_record_main_gameRecord.list_index001 = index;

        if (!__data.vip.isVip) {
            __showScene.show_friendRoom_vipSale(FriendRoom_vipSale.replay)
        } else {
            DeskReplayUtils.hallCityId = HallPlay.lastCityId;
            DeskReplayUtils.lookOthers = false;
            let rid = this.owner.parent.vo.roundId;
            __showScene.wait();
            game.server.send(14015, rid);
        }
    }
}

