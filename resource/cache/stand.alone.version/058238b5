/**
 * 获取对象的中心点的真实坐标(切记对象需要能回去到宽高，已经设定锚点的对象会设置宽高，没有的sprite对象可能存在宽高为0的情况)
 * @param {Laya.Image} icon 
 */
__compUtils.getCenterPoint = function (view) {
    let point = this.getAnchorPoint(view);
    // 没有设定锚点返回view 的中心点
    return new Laya.Point(view.x + view.width / 2 - point.x, view.y + view.height / 2 - point.y);
}

/**
 * 获取对象的锚点距离
 * @param {Laya.Image} view 
 */
__compUtils.getAnchorPoint = function (view) {
    // 便宜位置  默认0
    let anchor = new Laya.Point(0, 0);
    // 已经设定锚点了
    if (view.pivotX != 0 || view.pivotY != 0) {
        anchor.x = view.pivotX || 0;
        anchor.y = view.pivotY || 0;
    }
    // 已经设定锚点了
    else if (!isNaN(view.anchorX) && !isNaN(view.anchorY)) {
        anchor.x = view.anchorX * view.width;
        anchor.y = view.anchorY * view.height;
    }
    return anchor;
}

/**
 * 通过房间id  辨别消息号
 * [idToServerNumber description]
 * @param  {[type]} value  [description]        房间id
 * @param  {[type]} server [description]        服务id
 * @return {[type]}        [description]
 */
__compUtils.idToServerNumber = function (value, server) {

    if (value >= 100000 && value < 400000) {
        return server //麻将
    } else if (value >= 400000 && value < 500000) {
        return server + 10000 //斗地主
    } else if (value >= 500000 && value < 600000) {
        return server + 20000 //跑得快
    }
    return server
}

