class LxRules {

    static check(group, specials) {
        return this._checkType(group, specials);
    }

    static _checkType(values, specials) {
        let lastType = '';
        for (let i = 0; i < values.length; i++) {
            let value = values[i].toString();// 选中的牌
            let isSpecial = specials.find((element) => element.toString() == value); // 这张牌是否为万能牌
            if (isSpecial) continue;// 这张牌是混
            let type = this._getType(values[i]);
            if (type == this.NONE) { return ''; }// 不符合规则 非幺九
            // 如果没记录过  记录一下类型
            if (!lastType) { lastType = type; }
            else if (lastType == type) { return ''; }// 如果记录过类型 且类型不同  也不符合规则
            else if (lastType != type) {
                let sw1 = lastType.split(this.KEY)[0];
                let sw2 = type.split(this.KEY)[0];
                if (sw1 != sw2) return '';
            }// 如果记录过类型 且类型不同  也不符合规则
        }
        if (lastType == '' && values.length)// 最后未检测到类型 但是数据存在  那肯定都是混
            return this.HUN;
        return lastType;
    }

    /**
     * 推荐
     * @param {Array} list 手牌集合
     * @param {Array} group 已经选择的组合
     * @param {Array} specials 混集合
     * @returns 
     */
    static recommend(list, group, specials) {
        // 有选择的亮喜
        if (group.length) {
            // 看选择的亮喜牌是否符合规则， 如果不符合规则 结束亮喜
            let list = this.lackCheck(group, specials);
            return list;
        } else {
            let list = [];
            for (let i = 0; i < __data.deskData.roomVo.lxData.length; i++) {
                //将后端给的组合再次拆分一下
                let arrays = __data.deskData.roomVo.lxData[i].split('_')
                //比对数组
                list = list.concat(arrays);
                //再次进行排序
                list.sort(function (a, b) { return a - b })
            }
            return list;
        }
    }

    /**
     * 缺失检测
     * @param {Array} group 
     * @param {Array} specials 
     * @returns 
     */
    static lackCheck(group, specials) {
        let t = this._checkType(group, specials);
        // 合规 
        if (t) {
            // 已经选完整了
            if (group.length == 3) { return []; }
            else {
                let list = this.getListByType(t);// 获取亮喜的同类型其他牌
                for (let i = 0; i < group.length; i++) {
                    let index = list.findIndex((e) => e == group[i]);// 找到已经选择的牌
                    if (index >= 0) { list.splice(index, 1); }// 删除掉（同一张牌不可以在一个组合内重复出现）
                }
                return [].concat(list).concat(specials);
            }
        } else {// 不合规
            return [];
        }
    }

    static _getType(value) {
        if (value == 0)
            return this.YAO_W;
        else if (value == 10)
            return this.YAO_B;
        else if (value == 20)
            return this.YAO_T;
        else if (value == 8)
            return this.JIU_W;
        else if (value == 18)
            return this.JIU_B;
        else if (value == 28)
            return this.JIU_T;
        else
            return this.NONE;
    }

    static getYj(list, specials) {
        for (let i = 0; i < list.length; i++) {
            if (parseInt(list[i]) == 0 || parseInt(list[i]) == 10 || parseInt(list[i]) == 20) {
                // 使用 Set 去重
                let uniques = [0, 10, 20].filter(item => !list.includes(item));
                return specials.concat(uniques);
            }
            else if (parseInt(list[i]) == 8 || parseInt(list[i]) == 18 || parseInt(list[i]) == 28) {
                // 使用 Set 去重
                let uniques = [8, 18, 28].filter(item => !list.includes(item));
                return specials.concat(uniques);
            }
        }
        return null;
    }

    static getListByType(type) {
        if (type == this.YAO_W || type == this.YAO_B || type == this.YAO_T) {
            return [0, 10, 20]
        } else if (type == this.JIU_W || type == this.JIU_B || type == this.JIU_T) {
            return [8, 18, 28]
        } else if (type == this.HUN) {
            return [0, 10, 20, 8, 18, 28]
        } else {
            return [];
        }
    }

    static get NONE() { return 'N'; }
    static get YAO_W() { return `Y${this.KEY}W`; }
    static get YAO_B() { return `Y${this.KEY}B`; }
    static get YAO_T() { return `Y${this.KEY}T`; }
    static get JIU_W() { return `J${this.KEY}W`; }
    static get JIU_B() { return `J${this.KEY}B`; }
    static get JIU_T() { return `J${this.KEY}T`; }
    static get HUN() { return 'H'; }
    static get KEY() { return '_'; }
}



class MahjongCollectUtils {
    static getStrategy(){
        try{
            let all = MahjongCollectUtils.getAll();
            let uniqueId = MahjongConfig.getUniqueId(__data.gameId.lastId, __data.gameId.lastRuleId);
            let desk = game.scene.get(window['MahjongDesk' + uniqueId + '3D']);
            for (const key in all) {
                MahjongCollectUtils.getNumber(MahjongCollectUtils.getMap(key), [
                    desk.downlist.huCardSurps.bind(desk.downlist),
                    desk.uplist.huCardSurps.bind(desk.uplist),
                    desk.leftlist.huCardSurps.bind(desk.leftlist),
                    desk.rightlist.huCardSurps.bind(desk.rightlist),
                    desk.downoutlist.huCardSurps.bind(desk.downoutlist),
                    desk.upoutlist.huCardSurps.bind(desk.upoutlist),
                    desk.leftoutlist.huCardSurps.bind(desk.leftoutlist),
                    desk.rightoutlist.huCardSurps.bind(desk.rightoutlist)
                ])
            }
            let strategy = MahjongCollectUtils.analyzeArrayKeys();
            return strategy;
        }catch(e){
            trace('%c出牌策略异常：' + JSON.stringify(e), 'color:#ff7575');
        }
    }

    static getNumber(list, functions) {
        for (let i = 0; list && i < list.length; i++) {
            list[i].num = 0;
        }
        for (let i = 0; functions && i < functions.length; i++) {
            functions[i](list);
        }
    }

    static analyzeArrayKeys() {
        const data = this._map;
        const maxRateKeys = [];
        const maxNumSumKeys = [];
        
        if (!data || typeof data !== 'object') {
            return {
                maxRateKeys: maxRateKeys,
                maxNumSumKeys: maxNumSumKeys,
                commonKeys: []
            };
        }
        
        let maxRate = -Infinity;
        let maxNumSum = -Infinity;
        
        for (const key in data) {
            if (!data.hasOwnProperty(key)) continue;
            
            const arr = data[key];
            if (!Array.isArray(arr)) continue;
            
            const keyNum = Number(key);
            let localMaxRate = -Infinity;
            let localNumSum = 0;
            
            for (let i = 0; i < arr.length; i++) {
                const item = arr[i];
                if (!item) continue;
                
                if (typeof item.rate === 'number' && item.rate > localMaxRate) {
                    localMaxRate = item.rate;
                }
                
                if (typeof item.num === 'number') {
                    localNumSum += (4 - item.num);
                }
            }
            
            // 处理最大rate
            if (localMaxRate > maxRate) {
                maxRate = localMaxRate;
                maxRateKeys.length = 0;
                maxRateKeys.push(keyNum);
            } else if (localMaxRate === maxRate) {
                maxRateKeys.push(keyNum);
            }
            
            // 处理最大num总和
            if (localNumSum > maxNumSum) {
                maxNumSum = localNumSum;
                maxNumSumKeys.length = 0;
                maxNumSumKeys.push(keyNum);
            } else if (localNumSum === maxNumSum) {
                maxNumSumKeys.push(keyNum);
            }
        }
        
        // 找出重合的keys
        const commonKeys = [];
        for (let i = 0; i < maxRateKeys.length; i++) {
            for (let j = 0; j < maxNumSumKeys.length; j++) {
                if (maxRateKeys[i] === maxNumSumKeys[j]) {
                    commonKeys.push(maxRateKeys[i]);
                    break;
                }
            }
        }
        
        return {
            maxRate,
            maxNumSum,
            maxRateKeys: maxRateKeys,
            maxNumSumKeys: maxNumSumKeys,
            commonKeys: commonKeys
        };
    }

    static resetMap() {
        this._map = {};
    }

    static setMap(code, list) {
        if (!this._map) { this._map = {}; }
        this._map[code] = list;
    }

    static getMap(code) {
        if (!this._map) { return []; }
        return this._map[code]
    }

    static getAll(){ return this._map; }

    static rate(vo) {
        let initRate = 1;
        let rates = [];
        if (vo) {
            if (vo.position == __data.deskData.roomVo.bankerPosition) {
                trace(`[ID:${vo.id} name:${vo.name}]` + '庄家2翻.');
                rates.push(2);
            }
            let doors = vo.doorValue ? vo.doorValue.split(';') : [];
            let xnumbers = 0;// 万组合个数
            let ynumbers = 0;// 饼组合个数
            let znumbers = 0;// 条组合个数
            for (let i = 0; i < doors.length; i++) {
                let data = __compUtils.getAnalysis(doors[i]);
                if (data.type == 82) {// 亮喜
                    trace(`[ID:${vo.id} name:${vo.name}]` + '亮喜2翻.');
                    rates.push(2);
                }
                if (data.type == 5) {// 杠牌
                    if (data.position < 0) { // 暗杠
                        trace(`[ID:${vo.id} name:${vo.name}]` + '暗杠4翻.');
                        rates.push(4);
                    } else {// 明杠
                        trace(`[ID:${vo.id} name:${vo.name}]` + '暗杠2翻.');
                        rates.push(2);
                    }
                }
                if (data.type == 88) {// 杠门前牌
                    trace(`[ID:${vo.id} name:${vo.name}]` + '杠门前2翻.');
                    rates.push(2);
                }
                if (data.design == 'X') xnumbers++;
                else if (data.design == 'Y') ynumbers++;
                else if (data.design == 'Z') znumbers++;
            }
            if (xnumbers == 3) { trace(`[ID:${vo.id} name:${vo.name}]` + '3同花2翻.'); rates.push(2); }
            else if (xnumbers == 4) { trace(`[ID:${vo.id} name:${vo.name}]` + '4同花4翻.'); rates.push(4); }
            else if (xnumbers == 5) { trace(`[ID:${vo.id} name:${vo.name}]` + '5同花8翻.'); rates.push(8); }
            if (ynumbers == 3) { trace(`[ID:${vo.id} name:${vo.name}]` + '3同花2翻.'); rates.push(2); }
            else if (ynumbers == 4) { trace(`[ID:${vo.id} name:${vo.name}]` + '4同花4翻.'); rates.push(4); }
            else if (ynumbers == 5) { trace(`[ID:${vo.id} name:${vo.name}]` + '5同花8翻.'); rates.push(8); }
            if (znumbers == 3) { trace(`[ID:${vo.id} name:${vo.name}]` + '3同花2翻.'); rates.push(2); }
            else if (znumbers == 4) { trace(`[ID:${vo.id} name:${vo.name}]` + '4同花4翻.'); rates.push(4); }
            else if (znumbers == 5) { trace(`[ID:${vo.id} name:${vo.name}]` + '5同花8翻.'); rates.push(8); }

            trace(`[ID:${vo.id} name:${vo.name}]` + '翻数集合：', rates);
        }
        for (let i = 0; i < rates.length; i++) {
            initRate *= rates[i];
        }
        return initRate;
    }
