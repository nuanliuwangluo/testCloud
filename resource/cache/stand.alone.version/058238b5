/**
 * 时间戳 转换为 年月日  时分秒
 * [timeToString description]
 * @param  {[type]} time [description]  时间戳
 * @param  {[type]} sign [description]  年月日与时分秒之间的间隔  一般多为  空格或者换行  默认换行
 * @return {[type]}      [description]
 */
__compUtils.timeToString = function (time, sign) {
    if (!time) return ''
    sign = sign ? sign : '\n'
    var d = new Date(time)
    var year = d.getFullYear()
    var month = (d.getMonth() + 1)
    month = month < 10 ? '0' + month : month
    var date = d.getDate()
    date = date < 10 ? '0' + date : date
    var hour = d.getHours()
    hour = hour < 10 ? '0' + hour : hour
    var minute = d.getMinutes()
    minute = minute < 10 ? '0' + minute : minute
    var second = d.getSeconds()
    second = second < 10 ? '0' + second : second
    return year + '-' + month + '-' + date + sign + hour + ':' + minute + ':' + second
}
__compUtils.timeToShotString = function (time, sign) {
    if (!time) return ''
    sign = sign ? sign : '\n'
    var d = new Date(time)
    var year = d.getFullYear()
    var month = (d.getMonth() + 1)
    month = month < 10 ? '0' + month : month
    var date = d.getDate()
    date = date < 10 ? '0' + date : date
    return year + '-' + month + '-' + date;
}

/**
 * [sort description]
 * @param  {[type]} value     [description]     要排序的数组  根据大小排
 * @param  {[type]} pre_value [description]     要提前处理的数组
 * @param  {[type]} end_value [description]     要靠后处理的数组
 * @return {[type]}           [description]
 */
__compUtils.sort = function (value, pre_value, end_value) {
    let __reArr = []
    let valArr = []
    if (typeof value == 'string') {
        valArr = [].concat(value.split(','))
    } else valArr = [].concat(value);

    let picks = __compUtils.pickup(valArr, pre_value);
    //将排提前显示
    let preArr = picks.pickups || [];
    valArr = picks.origins;

    picks = __compUtils.pickup(valArr, end_value);
    //将排靠后显示
    let endArr = picks.pickups || [];
    valArr = picks.origins;

    valArr.sort(function (a, b) { return a - b })

    preArr.sort(function (a, b) { return a - b })

    endArr.sort(function (a, b) { return a - b })

    __reArr = __reArr.concat(preArr)
    __reArr = __reArr.concat(valArr)
    __reArr = __reArr.concat(endArr)
    
    
    return __reArr
}

__compUtils.pickup = function (value, rules) {
    let origins = value;
    let pickups = [];

    if (rules && rules.length > 0) {
        for (let i = 0; i < origins.length; i++) {
            let index = rules.some(function (value) { return value.toString() == origins[i].toString() })
            if (index) {
                pickups = pickups.concat(origins.splice(i, 1));
                i -= 1;
            }
        }
    }
    return { origins, pickups }
}


