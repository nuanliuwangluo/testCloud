class WuhuMahjongAlarmTest{
    static test(list, seat){
        let player = __data.deskData.roomVo.getPlayer(seat);
        let r = false;
        r = this.firstAlarm(list);
        if(r && player){ trace('A警报.');game.cb.event('alarm_event', [player.position]); }
        r = this.secondAlarm(list);
        if(r && player){ trace('B警报.');game.cb.event('alarm_event', [player.position]); }
        r = this.thirdAlarm(list);
        if(r && player){ trace('C警报.');game.cb.event('alarm_event', [player.position]); }
    }

    /**
     * 门前三个同色或有红中的刻子 警告的是 清一色 混一色
     * @param {*} object 
     * @returns 
     */
    static firstAlarm(list){
        let chains = [];
        for (let i = 0; i < list.length; i++) {
            let data = __compUtils.getAnalysis(list[i]);
            // 碰 或者 杠
            if(data.type == 1 || data.type == 5){
                // 根据花色计算数量
                if(data.design){
                    chains.push({ design:data.design, type:data.type });
                }
            }
        }
        let index = 0;
        let next = '';
        let result = chains.length >= 3 ? this.YES : this.NO;
        while(index < chains.length && chains.length >= 3){
            // 花色 不符合
            if(chains[index].design != 'H' && chains[index].design != next && next && index < 3){
                index = chains.length;
                result = this.NO;
            }
            if(chains[index] && chains[index].design != 'H' && !next){
                next = chains[index].design;
            }
            index++;
        }
        if(result == this.YES)
            return true;
        else if(result == this.NO)
            return false;
    }

    /**
     * 门前同色两杠加另一色刻子   警告的双八支
     * @param {*} object 
     * @returns 
     */
    static secondAlarm(list){
        let chains = [];
        let designs = [];
        let objects = {};
        for (let i = 0; i < list.length; i++) {
            let data = __compUtils.getAnalysis(list[i]);
            // 碰 或者 杠
            if(data.type == 1 || data.type == 5){
                // 根据花色计算数量
                if(data.design){
                    objects[`${data.design}_${data.type}`] = objects[`${data.design}_${data.type}`] || 0;
                    objects[`${data.design}_${data.type}`] ++;

                    chains.push({ design:data.design, type:data.type });

                    let isIn = designs.indexOf(data.design) > -1;
                    if(!isIn)designs.push(data.design);
                }
            }
        }

        let result = this.NO;
        if(objects[`X_5`] >= 2){
            if(objects[`Y_5`] >= 1 || objects[`Y_1`] >= 1){
                result = this.YES;
            }else if(objects[`Z_5`] >= 1 || objects[`Z_1`] >= 1){
                result = this.YES;
            }
        }else if(objects[`Y_5`] >= 2){
            if(objects[`X_5`] >= 1 || objects[`X_1`] >= 1){
                result = this.YES;
            }else if(objects[`Z_5`] >= 1 || objects[`Z_1`] >= 1){
                result = this.YES;
            }
        }else if(objects[`Z_5`] >= 2){
            if(objects[`X_5`] >= 1 || objects[`X_1`] >= 1){
                result = this.YES;
            }else if(objects[`Y_5`] >= 1 || objects[`Y_1`] >= 1){
                result = this.YES;
            }
        }

        if(objects[`H_5`] >= 1 || objects[`H_1`] >= 1)result = this.NO;
        if(designs.length > 2)result = this.NO;

        if(result == this.YES)
            return true;
        else if(result == this.NO)
            return false;
    }

    /**
     * 门前两个同色刻子                警告的胡双四核  
     * @param {*} object 
     * @returns 
     */
     static thirdAlarm(list){
        let chains = [];
        let designs = [];
        let objects = {};
        let len = list.length > 3 ? 3:list.length;
        for (let i = 0; i < len; i++) {
            let data = __compUtils.getAnalysis(list[i]);
            // 碰 或者 杠
            if(data.type == 1 || data.type == 5){
                // 根据花色计算数量
                if(data.design){
                    objects[`${data.design}_${data.type}`] = objects[`${data.design}_${data.type}`] || 0;
                    objects[`${data.design}_${data.type}`] ++;

                    chains.push({ design:data.design, type:data.type });

                    let isIn = designs.indexOf(data.design) > -1;
                    if(!isIn)designs.push(data.design);
                }
            }
        }

        let result = this.NO;
        if(objects['X_1'] >= 2 || objects['Y_1'] >= 2 || objects['Z_1'] >= 2){ result = this.YES }

        if(result == this.YES)
            return true;
        else if(result == this.NO)
            return false;
    }


    static get NO(){ return 'no'; }
    static get YES(){ return 'yes'; }
}


class MahjongBackPickError{

    static listen(code, position, type){
        try{
            // 好友房不增加此检测
            if(__data.deskData.roomVo.roomModel == __data.deskData.roomVo.FRIEND){ return; }
            if(__data.deskData.roomVo.phase == "result"){ return; }
            // 最后检测 吃碰的牌 是否为 最后打出的牌
            let uniqueId = MahjongConfig.getUniqueId(__data.gameId.lastId, __data.gameId.lastRuleId);
            let desk = game.scene.get(window['MahjongDesk' + uniqueId + '3D']);
            var seat = __data.deskData.roomVo.getPlayer(position).seat_tag;
            if(desk[`${seat}outlist`].data.length > 0){
                // 最后一次出的牌
                let value = desk[`${seat}outlist`].data[desk[`${seat}outlist`].data.length - 1];
                let reporter = MahjongBackPickError.getReporter();// 获取上报人
                if(value == code && reporter == __data.uid){
                    console.log("%c触发Mj_Error：" + type + '<--->' + code + '<--->' + position + '<--->' + seat, "color:#ff5500");
                    miniApi.trackEvent('Mj_Error', { 'Mj_ErrorType': `碰回手牌`, 'Mj_ErrorInfo': type });
                }
            }
        }catch(e){
            console.log('碰回手牌事件检测异常');
        }
    }

    // 获取一个上报人
    static getReporter(){
        let reporter = 0;
        let ids = __data.deskData.roomVo.getPlayerIds();
        for(let i = 0;i < ids.length;i++){
            // 如果没有上报人， 先确定一个上报人
            if(!reporter){ reporter = ids[i]; }
            // 然后取一个Id最小的人确定为上报人
            else{ reporter = Math.min(reporter, ids[i]); }
        }
        return reporter;
    }
}




class GdGhost{
    static getGhost(code){
        let ghost = -1;
        for (const key in this.rule) {
            const index = this.rule[key].indexOf(parseInt(code));
            if(index != -1){
                ghost = this.rule[key][(index + 1) % this.rule[key].length];
                break;
            }
        }
        return ghost;
    }

    static getOrigin(code){
        let ghost = code;
        for (const key in this.rule) {
            const index = this.rule[key].indexOf(parseInt(code));
            if(index != -1){
                ghost = this.rule[key][(index - 1 + this.rule[key].length) % this.rule[key].length];
                break;
            }
        }
        return ghost;
    }

    static get rule(){
        if(!this._rule){
            this._rule = {
                "万":[0,1,2,3,4,5,6,7,8],
                "筒":[10,11,12,13,14,15,16,17,18],
                "条":[20,21,22,23,24,25,26,27,28],
                "花":[30,31,32,33,40,41,42]
            }
        }
        return this._rule;
    }
}