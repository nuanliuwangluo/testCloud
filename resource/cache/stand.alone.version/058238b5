class ComponentUtils{
    /**
     * 清理组件
     * @param {Array|Object} view 
     * @param {Class} scriptName 
     * @returns 
     */
    static clearScript(view, scriptName) {
        if (view instanceof Array) {
            for (let i = 0; i < view.length; i++) {
                //如果对象没有getComponents方法  直接跳过
                if (!this._getComponentProperty(view[i])) { continue; }
                //否知执行清理组件
                else this._clearScript(view[i], scriptName);
            }

        } else if (view instanceof Object) {
            //如果对象没有getComponents方法  直接跳过
            if (!this._getComponentProperty(view)) { return; }
            //否知执行清理组件
            this._clearScript(view, scriptName);
        }
    }
    static _getComponentProperty(view) {
        return (typeof(view.getComponents) == 'function');
    }
    static _clearScript(view, scriptName) {
        let scriptArr = view.getComponents(scriptName);
        if (!scriptArr || scriptArr.length == 0) { return };
        while (scriptArr.length) {
            scriptArr[0].destroy();
            scriptArr.splice(0, 1);
        }
    }
}


