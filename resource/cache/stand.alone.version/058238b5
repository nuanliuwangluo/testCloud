class ReadyManager {
    static getStatus(vo) {
        let friendSmallResult = game.scene.get(FriendMahjongSmallResult);
        let friendAllResult = game.scene.get(FriendMahjongAllResult);
        // 已经准备了 不显示按钮
        if (vo && vo.readyState > 0) return false;
        // 不是好友房  不显示按钮
        if (__data.deskData.roomVo.roomModel != __data.deskData.roomVo.FRIEND) return false;
        // 等待结算不显示按钮
        if (__data.deskData.roomVo.waiting_result) return false;
        // 小结算正在显示 不显示按钮
        if (friendSmallResult && friendSmallResult.parent) return false;
        // 大结算正在显示 不显示按钮
        if (friendAllResult && friendAllResult.parent) return false;

        return true;
    }

    //获取授权记录
    static getAuthed() {
        return new Promise((res, rej) => {
            try {
                // 微信环境获取对应结果
                if (window.wx && typeof window.wx === 'object') {
                    wx.getSetting({
                        async success(res1) {
                            if ('scope.userInfo' in res1.authSetting) {
                                if (res1.authSetting['scope.userInfo']) {
                                    res(1)
                                } else {
                                    res(0)
                                }
                            } else {
                                res(0);
                            }
                        }
                    })
                } else { //非微信环境  直接返回同意授权结果
                    res(1);
                }
            } catch (e) {
                res(0);
            }
        })
    }

    static async auth() {
        let r = await this.getAuthed();
        // 没有同意过授权，弹出授权提示
        if (r == 0) r = await miniApi.getUserProfile();
        return r;
    }
}


