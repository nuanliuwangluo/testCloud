        // if (__data.resultData && hall && hall.parent) {
        if (__data.resultData) {
            if (__reBack_info.mahjong.isRead && !__reBack_info.mahjong.code && !__data.deskData.roomVo.roomID) {
                trace('显示分享结算.')
                __data.deskData.roomVo.allRoundResult = JSON.parse(__data.resultData);
                await __showScene.load_game_result();
                game.scene.add(FriendMahjongAllResult, [true]);
                __data.resultData = null;
            } else {
                __data.resultData = null;
            }
        }
