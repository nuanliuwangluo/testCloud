    // 处理onShow 附带参数
    handleRoomParams() {
        trace('处理快速进入房间流程.', __reBack_info.mahjong, __data.deskData.roomVo.roomID, __data.roCityId, __data.room_pwd);
        if (__reBack_info.mahjong.isRead && !__reBack_info.mahjong.code && !__data.deskData.roomVo.roomID) {
            // 没有选区  却需要自动进入房间，  默认设置玩法
            if (!__data.myCityId) {
                if (__data.roCityId) {
                    game.server.send(2216, __data.roCityId) // 我的玩法
                    __data.roCityId = null;
                }
            }
            // 处理邀请信息
            if (__data.room_pwd) {
                let loading = game.scene.get(Loading);
                if (loading && loading.parent) this.removeWait();
                else this.wait();
                __data.autoInRoom = true;
                game.server.send(14006, __data.room_pwd);
                __data.room_pwd = null;
                return true;
            }
        } else {
            __data.roCityId = null;
            __data.room_pwd = null;
        }
        return false;
    },
