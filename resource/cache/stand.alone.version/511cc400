                GameMainSelectPlayBG.isClose = isClose;
                game.scene.add(GameMainSelectPlayBG)
                if (province) {
                    let p1 = province.slice(0, 2)
                    let isfind
                    for (const key in __data.excelConfig.hashCityIdVO) {
                        let a = __data.excelConfig.hashCityIdVO[key];
                        if (province.includes(a.province)) {
                            if (a.province == '黑龙江') {
                                game.scene.add(GameMainSelectPlay1)
                                game.scene.add(GameMainSelectPlay1_return)
                                game.scene.add(GameMainSelectPlay1_otherArea)
                            } else {
                                game.scene.add(GameMainSelectPlay0)
                                game.scene.add(GameMainSelectPlay0_return)
                                game.scene.add(GameMainSelectPlay0_otherArea)
                                let pp = a.provinceId;
                                if (pp == 25 || pp == 26 || pp == 27 || pp == 28) {
                                    // 北京重庆什么的
                                } else {
                                    game.scene.add(GameMainSelectPlay2, [pp, 1])
                                }
                            }
                            isfind = true;
                            break;
                        }
                    }
                    if (!isfind) {
                        game.scene.add(GameMainSelectPlay0)
                        game.scene.add(GameMainSelectPlay0_return)
                        game.scene.add(GameMainSelectPlay0_otherArea)
                    }
                } else {
                    game.scene.add(GameMainSelectPlay0)
                    game.scene.add(GameMainSelectPlay0_return)
                    game.scene.add(GameMainSelectPlay0_otherArea)
                }
                res(1)
            }, function (v) {
