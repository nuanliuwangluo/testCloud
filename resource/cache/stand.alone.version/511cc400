    async show_hall() {
        Laya.stage.frameRate = "slow"
        window.OpenHtml && OpenHtml.takeFront('main');
        __sound.playGameMusic('bgm_hall')

        ResUtils.clearTextureRes(['ab.a_panel_prop_get'])
        ResUtils.clearTextureRes(['bag_icon'])
        ResUtils.clearTextureRes(['ab.bag'])
        ResUtils.clearTextureRes(['ab.hall_area_btn_big'])
        ResUtils.clearTextureRes(['local.a_selectPlay.1'])
        ResUtils.clearAtlas('res/atlas/local/a_selectPlay/1.atlas')
        // 清理loading缓存
        let clearLoadingRes = [
            'local/loading/1/bar_loading.png',
            'local/loading/1/bt_login_we.png',
            'local/loading/1/img_bh.png',
            'local/loading/1/img_slts.png',
            'local/loading/1/loading.png',
            'local/loading/1/logo.png',
            'bigImage/loadingbg.png',
            'bigImage/loadingbg2.png',
            'bigImage/img_qhb.png',
        ]
        for (const iterator of clearLoadingRes) {
            Laya.loader.clearTextureRes(iterator)
        }
        // 清理花园
        clearGradenRes()
        __data.lastSceneQueue = [];
        // 检测是直接显示大厅，还是显示玩法
        if (!__data.myCityId) {
            __data.tryAnalysis();
            let r = this.handleRoomParams();
            if (!r) {// 不需要直接进入好友房  弹出选择界面
                miniApi.trackEvent_gameStep('Mj_StepAnalysis', { 'Mj_Steps': '强制选择玩法' })
                __data.lastSceneQueue.push(__showScene.show_hall)
                await __showScene.show_gameMain_selectPlay(1, 0, __data.province)
            }
        } else {
            // 如果掉线登录 会直接返回大厅 所以兼容一下 直接清理小游戏场景
            let ana = game.scene.get(MjMatch_ui_left)
            ana && ana.removeTimer()
