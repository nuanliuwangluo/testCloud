            game.utils.remove(S_3D_mjMatch.scene)

            __showScene.sceneType = 'hall'
            game.scene.removeAll()
            miniApi.trackEvent_gameStep('Mj_StepAnalysis', { 'Mj_Steps': '显示大厅' })
            game.scene.add(HallBg)
            game.scene.add(Hall)
            game.scene.add(HallLeftUp)
            game.scene.add(HallLeftDown)
            game.scene.add(HallRightDown)
            game.scene.add(Icon_marketActivity)
            // game.scene.registe(Horn)
            // game.cb.event('game_horn');
            __showScene.handleResultParams();
        }
