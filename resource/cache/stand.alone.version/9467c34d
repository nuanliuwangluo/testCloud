class GameMainSeasonEnd extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_seasonEnd',
            layer: 'panel'
        })
        this.btn_sure.addComponent(S_seasonEnd_sure)

        this.txtImg = new game.NumText(GameMainSeasonStart.fontUrl, 'center')
        this.txtImg.x = this.img_bg.x;
        this.txtImg.y = this.img_bg.y;
        this.addChild(this.txtImg)
    }
    added() {
        this.sp_rank.iy = this.sp_rank.iy || this.sp_rank.y;
        this.btn_sure.iy = this.btn_sure.iy || this.btn_sure.y;
        let person_rank = __data.seasonEndData.index;
        let local_rank = __data.seasonEndData.maxIndex;
        let score = __data.seasonEndData.maxScore;
        let year = __data.seasonEndData.year
        let season = GameMainSeasonStart.seasonFontToId[__data.seasonEndData.season.charAt(0)]
        // 个人排名 本地排名 分数 年 季节1-4=春夏秋冬
        this.play_light()
        if (person_rank < 1) {
            this.txt_rank_person.text = '未上榜'
        } else {
            this.txt_rank_person.text = `第${person_rank}名`
        }
        if (local_rank < 1) {
            this.txt_rank_local.text = '未上榜'
        } else {
            this.txt_rank_local.text = `第${local_rank}名`
        }

        this.txt_rank_person.x = this.txt_person.x + this.txt_person.textField.textWidth + 2
        this.txt_local.x = this.txt_rank_person.x + this.txt_rank_person.textField.textWidth + 50
        this.txt_rank_local.x = this.txt_local.x + this.txt_local.textField.textWidth;
        let w = this.txt_rank_local.x + this.txt_rank_local.textField.textWidth
        this.sp_rank.x = this.width / 2 - w / 2;

        let rd = RankUtils.getRankLvDataByScore(score)
        if (rd.toNextLevelNeedCup == 0) {
            this.img_queshen.visible = true;
            this.img_normal.visible = false;
            score -= rd.minCup;

            this.img_score.visible = true
            this.txt_score.text = score;
            let width_score = this.txt_score.x + this.txt_score.textField.textWidth;
            this.sp_score.x = this.sp_score.parent.width / 2 - width_score / 2;

            this.sp_rank.y = this.sp_rank.iy;
            this.btn_sure.y = this.btn_sure.iy;
        } else {
            this.img_queshen.visible = false;
            this.img_normal.visible = true;
            this.img_score.visible = false;

            this.sp_rank.y = this.sp_rank.iy - 110;
            this.btn_sure.y = this.btn_sure.iy - 110;
        }

        if (rd.toNextLevelNeedCup == 0) {
            this.img_queshen1.visible = true
            this.txt_lv_num.visible = false
        } else {
            this.img_queshen1.visible = false
            this.txt_lv_num.visible = true
            this.txt_lv_num.text = rd.level;
        }

        if (rd.toNextLevelNeedCup == 0 && score >= __data.rank.rank_exceed_queshen_score) {
            let rd;
            if (person_rank == 1) rd = __data.rank.chuanqiQueshen;
            else rd = __data.rank.xingyaoQueshen
            this.txt_lv_name.text = rd.name;
            this.img_lv_bg.skin = `local/lvNameBg/1/rank_${rd.iconIndex}.png`;
            this.img_sign.skin = `cdn/rank_sign/img_rank_sign_${rd.iconIndex}.png`;
        } else {
            this.txt_lv_name.text = rd.name;
            this.img_lv_bg.skin = `local/lvNameBg/1/rank_${rd.iconIndex}.png`;
            this.img_sign.skin = `cdn/rank_sign/img_rank_sign_${rd.iconIndex}.png`;
        }


        this.txtImg.text = year + GameMainSeasonStart.seasonIdToText[season] + '季赛结束'
        this.txtImg.y = this.img_bg.y - this.txtImg.height / 2
    }
    onDisable() {
        Laya.Tween.clearAll(this.img_light)
        this.clearAwait && this.clearAwait()
        __showScene.show_seasonReward()
    }
    clickMask() { }
    async play_light() {
        this.img_light.rotation = 0
        let tweenTime = 5000
        await __tool.tweenp(this.img_light, { rotation: 360 }, tweenTime, Laya.Ease.linearNone)
        this.play_light()
    }
}
class S_seasonEnd_sure extends Laya.Script {
    onClick() {
        game.scene.remove(GameMainSeasonEnd)
    }
}