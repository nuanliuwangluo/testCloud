class GameMainVipBombbox extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_vipBombbox',
            layer: 'panel'
        })
        this.sp_vip_buy.addComponent(S_vip_buy_btn)
        this.btn_vip.addComponent(S_vipbombbox_look)
    }
    added(type) {
        this.type = type;
        this.update_vip_data()
        game.cb.on('update_vip_data', this, this.update_vip_data)
    }
    onDisable() {
        game.cb.off('update_vip_data', this, this.update_vip_data)
    }
    update_vip_data() {
        // 1财产保护 2奖杯特权
        // if (this.type == 1) {
        //     this.img_bg.skin = 'cdn/vip_bomb_box/img_ccbhbg.png'
        // } else {
        this.img_bg.skin = 'cdn/vip_bomb_box/img_jbtqbg.png'
        // }
        this.sp_vip_buy.visible = !__data.vip.isVip;
    }
    clickMask() { }
}
class S_vipbombbox_look extends Laya.Script {
    onClick(e) {
        __showScene.show_vip('des')
    }
}