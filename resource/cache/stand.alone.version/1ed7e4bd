        let newGroup = {
            name: 'click-' + vo.positionId,
            name2: vo.groupName,
            layerName: '',
            gridArray: []
        }
        vo.groupName.toArray(',').forEach((e) => {
            let nx1 = mapData.group.find((e1) => {
                return e1.name == e
            })
            if (!nx1) {
                console.error('vo.positionId:' + vo.positionId, 'groupName:' + e);
