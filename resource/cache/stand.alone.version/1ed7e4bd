Garden_groud.get_effective_tile_by_positionId = (positionId) => {
    let g = game.scene.get(Garden_groud)
    let data = __data.excelConfig.hashGardenPositionArea[positionId]
    if (!data) {
        console.error('这个位置没有区域配置', positionId)
        return []
    }
    let tileXYArray = Garden_groud.get_effective_tileXY_by_positionId(positionId)
    let tileArray = [];
    tileXYArray.forEach((e) => {
        let n1 = g.tileMap.getTileByLayerNameAndTileXY(e.layerName, e.x, e.y)
        if (n1) {
            tileArray.push(n1)
        }
    })
    return tileArray
}
Garden_groud.hash_positionId_effective_tileXY = {};
Garden_groud.get_effective_tileXY_by_positionId = (positionId) => {
    let a = Garden_groud.hash_positionId_effective_tileXY[positionId];
    if (a) return a;
    let data = __data.excelConfig.hashGardenPositionArea[positionId]
    if (!data) {
        return console.error('这个位置没有配置区域', positionId)
    }
    let tileXYArray = [];
    if (data.grid) {
        let a1 = data.grid.toArray(',')
        a1.forEach(e => {
            let n = e.toArray('_')
            tileXYArray.push({
                layerName: n[0],
                x: parseInt(n[1]),
                y: parseInt(n[2]),
                textureIdIndex: n[3],
            })
        });
    }
    if (data.gridGroupName) {
        data.gridGroupName.toArray(',').forEach((e01) => {
            let g = game.scene.get(Garden_groud)
            let e02 = e01.toArray('_')
            let nx1 = g.mapData.group.find((e) => {
                return e.name == e02[0]
            })
            if (!nx1) {
                console.error('组不存在', e02[0])
                return []
            }
            nx1.gridArray.forEach(e => {
                let n = e.toArray('-').map(Number)
                tileXYArray.push({
                    layerName: nx1.layerName,
                    x: n[0],
                    y: n[1],
                    textureIdIndex: e02[1],
                })
            });
        })
    }
    // else {
    //     console.error('位置', positionId, '有效区域不存在')
    // }
    Garden_groud.hash_positionId_effective_tileXY[positionId] = tileXYArray;
    return tileXYArray
}
Garden_groud.hash_originTextureId = {};
Garden_groud.get_originTextureId = (mapName) => {
    let a = Garden_groud.hash_originTextureId[mapName];
    let mapData = game.TiledMap.hash_map[mapName]
    if (a) return a;
    a = [];
    for (const position in __data.excelConfig.hashGardenPositionArea) {
        // let d = __data.excelConfig.hashGardenPositionArea[position];
        let b = Garden_groud.get_effective_tileXY_by_positionId(position)

        for (const iterator of b) {
            let d = mapData.layer.find((e) => {
                return e.name == iterator.layerName
            })
            if (d) {
                a.push({
                    layerName: iterator.layerName,
                    x: iterator.x,
                    y: iterator.y,
                    originTextureId: d.data[iterator.y * mapData.widthNum + iterator.x] || 0,
                })
            }
        }
    }
    Garden_groud.hash_originTextureId[mapName] = a;
    return a
}
