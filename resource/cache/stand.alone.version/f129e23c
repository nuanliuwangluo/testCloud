class GardenUpdate_bombbox extends game.ModuleBase {
    constructor() {
        super({
            map: 'garden/Garden_update_bombbox',
            layer: 'panel'
        })
        this.btn_go.addComponent(S_GardenUpdate_bombbox_click_go)
    }
    added(first_show_talk) {
        this.first_show_talk = first_show_talk;
        game.cb.event('garden_build_remove_hand')
    }
    onDisable() {
        this.first_show_talk && __data.garden.task.branchTaskId - 1 == 0 && GTU.show(__data.garden.task.branchTaskId - 1)
    }
}
class S_GardenUpdate_bombbox_click_go extends Laya.Script {
    onClick(e) {
        game.scene.remove(GardenUpdate_bombbox);
    }
}