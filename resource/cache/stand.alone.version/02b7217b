class TestPanelItem extends game.ModuleBase {
    constructor() {
        super({
            map: 'test/TestPanelItem',
            module: false
        })
        this.addComponent(S_TestPanelItem_click)
    }
    getRandomHex() {
        return Math.floor(Math.random() * 16).toString(16).padStart(1, '0');
    }
    onEnable() {
        // 生成红、绿、蓝三个颜色的随机十六进制值
        let red = this.getRandomHex();
        let green = this.getRandomHex();
        let blue = this.getRandomHex();
        this.txt.bgColor = `#${red}${green}${blue}`;
    }

    onDisable() { }

    set dataSource(vo) {
        if (!vo) return;
        this.__vo = vo;

        this.txt.text = vo.name;
    }
}
Laya.ClassUtils.regClass('ui.test.TestPanelItemUI', TestPanelItem);

class S_TestPanelItem_click extends Laya.Script {
    onClick(e) {
        game.scene.remove(TestPanel)
        this.owner.__vo.fn()
    }
}