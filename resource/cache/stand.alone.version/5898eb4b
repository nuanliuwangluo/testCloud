// 金币罐
__data.activity.goldBox = {
    gold: 0,// 储值金额
    level: 0,// 等级
    // 格式化需求金币数量
    formatGold(num) {
        if (num < 10000) {
            return num;
        }
        let wan = num / 10000;
        // 保留两位小数
        let fixed = wan.toFixed(2);
        // 如果最后一位是 0，去掉它
        if (fixed.endsWith('0')) {
            fixed = fixed.slice(0, -1);
        }
        // 如果小数点最后一位还是 0（例如 3.10 -> 3.1），再处理一次
        if (fixed.endsWith('.0')) {
            fixed = fixed.slice(0, -2);
        }
        return fixed + '万';
    },

    get openNeedStone() {
        return 30 * this.level;
    },// 开启需要的钻石数量
    get isOpen() {
        return this.gold >= 30000 * this.level
    },// 是否开启

    get isFull() {
        return this.gold >= this.fullNumber;
    },// 是否满

    get fullNumber() {
        return 30000 * this.level * 1.6;
    },// 已满对应的金额

    get fullStone() {
        return __data.activity.goldBox.fullNumber / 1000;
    }// 已满对应的钻石价值
}

