    ],// 日常奖励
    finnals: [{ id: 1, number: 50000 }, { id: 8005, number: 20 }],// 最终奖励

    get isFinal() { return this.stepGiftProgress == this.rewards.length; },// 是否可以领取最终奖励
    get isEnd() { return this.stepGiftProgress > this.rewards.length; },// 是否全部领取完成

    getRewardByStep(step) {
        let item = this.rewards[step];
        if (item) {
            return [item.reward];
        } else if (step == this.rewards.length) {
            return this.finnals;
        }
    },
    // 获取本周日期范围 (周一 - 周日)
    getWeekRange() {
        const now = new Date();
        const currentDay = now.getDay(); // 0 (周日) - 6 (周六)
        // 计算周一的偏移量：如果今天是周日(0)，则偏移 -6 天；否则偏移 1 - currentDay
        const mondayOffset = currentDay === 0 ? -6 : 1 - currentDay;
        const monday = new Date(now.getFullYear(), now.getMonth(), now.getDate() + mondayOffset);
        const sunday = new Date(monday.getFullYear(), monday.getMonth(), monday.getDate() + 6);
        const pad = (num) => num < 10 ? '0' + num : '' + num;
        const startStr = `${pad(monday.getMonth() + 1)}.${pad(monday.getDate())}`;
        const endStr = `${pad(sunday.getMonth() + 1)}.${pad(sunday.getDate())}`;
        return `${startStr} - ${endStr}`;
    },
    // 格式化需求数量
    formatNumber(num) {
        if (num < 10000) {
            return num;
        }
        let wan = num / 10000;
        // 保留两位小数
        let fixed = wan.toFixed(2);
        // 如果最后一位是 0，去掉它
        if (fixed.endsWith('0')) {
            fixed = fixed.slice(0, -1);
        }
        // 如果小数点最后一位还是 0（例如 3.10 -> 3.1），再处理一次
        if (fixed.endsWith('.0')) {
            fixed = fixed.slice(0, -2);
        }
        return fixed + '万';
    },
}

