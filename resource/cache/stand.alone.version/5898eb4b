__data.activity.todayDiscount = {
    allCount: 2,// 每日购买上限
    dailyDealId: 0,// 礼包id
    purchaseCount: 0, // 已购买次数
    deals: {
        // 原价  新价  金币  富贵竹  折扣
        10032: { old: 10, new: 3, gold: 54000, bamboo: 40, dc: 3 },
        10033: { old: 19, new: 6, gold: 108000, bamboo: 80, dc: 3 },
        10034: { old: 34, new: 12, gold: 216000, bamboo: 120, dc: 3 }
    },// 套餐

    formatGold(gold) {
        if (gold < 10000)
            return gold
        return `${(gold / 10000).toFixed(1)}万`;
    },// 格式化金币

    getRemainingTimeToMidnight() {// 获取至24时剩余时间
        const now = new Date();
        const endOfDay = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1);
        const diff = endOfDay - now;
        const h = Math.floor(diff / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);
        return `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
    },

    get deal() {// 今日随机的套餐
        return this.deals[this.dailyDealId];
    },

    get isAllowBuy() {// 是否允许购买
        return this.purchaseCount < this.allCount;
    }
}

