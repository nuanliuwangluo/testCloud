
class MahjongQuickPrayMenuBase extends game.ModuleBase {
    constructor(name, removeAfterClick) {
        super({
            map: `scene_game/mahjong/${name}`,
            module: false
        })
        this.removeAfterClick = removeAfterClick;
    }
    
    onEnable(){
        this.btn_pray.on(Laya.Event.CLICK, this, this.onPray);
        this.bless = this.getBless();
        this.setBless(this.bless);
        trace("随机祝福：", this.bless);
    }

    onDisable(){
        this.btn_pray.off(Laya.Event.CLICK, this, this.onPray);
    }

    onPray(){
        MahjongBless.data.isQuick = 1;
        MahjongBless.data.quickInfo = this.info;
        this.bless.baseMul = 1;
        bless_buy_logic(this.bless, 2);
        this.removeAfterClick && game.utils.remove(this);
    }

    setBless(bless){
        this.txt_cost.text = bless.baseStoneCost;
        SkinUtils.setSkin(this.icon, `cdn/bless_mj/${bless.quickImg}.png`);
    }

    source(info, type){
        this.info = info;
        this.info.type = type + info.number;
        this.txt.text = info.content;
    }

    // MahjongBless.data 前三个随机
    // d1.firstFree == 1 && firstFree_isBuy == 1 是免费的
    // baseStoneCost 钻石
    getBless(){
        let arrays = [];
        // 如果金蝉不免费，在随机队列中
        if(!(MahjongBless.data.d1.firstFree == 1 && MahjongBless.data.firstFree_isBuy == 1)){
            arrays = [MahjongBless.data.d1, MahjongBless.data.d2, MahjongBless.data.d3];
        }
        // 如果金蝉免费，不在随机队列中
        else{
            arrays = [MahjongBless.data.d2, MahjongBless.data.d3];
        }
        let index = Math.floor(Math.random() * arrays.length);
        return arrays[index];
    }
}
