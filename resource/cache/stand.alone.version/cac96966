            this.checkThrowNoHuTrigger();// 检查是否触发快速祈福
        }else if(self && self.hupai && self.hupai.length){ // 知道可以胡什么牌的情况下抓牌（某些玩法不带听牌）
            this.setCatchNoHuByList(code);
            this.checkThrowNoHuTrigger();// 检查是否触发快速祈福
        }else{// 未听牌的情况下摸牌
            this.setCatchByList(code);
        }
    }
    throw(code){
        if(!this.available){ return; }
        PrayStatistics.log && trace('%c Statistics-->弃牌：' + code, `color: ${this.color}`);
        // TODO: 弃牌
        let self = __data.deskData.roomVo.getPlayerBySeat(0);
        if(this.checkAfterThrowState){
            this.checkTingTrigger();// 检查是否触发快速祈福
