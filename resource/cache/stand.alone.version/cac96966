// 快速祈福组件
class MahjongQuickPrayComponent extends Laya.Script{

    onAwake(){
        this.quickPrayMenu = new MahjongQuickPrayMenu();
        this.quickPrayMenu.bar.getComponent(VideoCountDown).setAfter(this.onOvertime.bind(this));// 倒计时条走完
    }

    onEnable(){
        Laya.timer.callLater(PrayStatistics.instance, PrayStatistics.instance.checkJoinGameTrigger);
        game.cb.on('quick_pray', this, this.onQuickPray);
    }

    onDisable(){
        game.cb.off('quick_pray', this, this.onQuickPray);
    }

    onQuickPray(content, number){
        game.utils.remove(this.quickPrayMenu);
        this.quickPrayMenu.source({ content, number }, '对局');
        this.owner.addChild(this.quickPrayMenu).pos(-this.owner.x - this.quickPrayMenu.width, this.player.y + this.player.height - this.quickPrayMenu.height - 25);
        Laya.Tween.to(this.quickPrayMenu, {x: this.player.x + this.player.width + 15 }, 150, Laya.Ease.QuartOut, Laya.Handler.create(this, this._showComplete));
    }

    // 计时结束
    onOvertime(){
        game.utils.remove(this.quickPrayMenu);
        Laya.Tween.clearAll(this.quickPrayMenu);
    }

    get container(){
        if (this.owner.ready && this.owner.ready.parent) {
            return this.owner.ready;
        } else {
            return this.owner.game;
        }
    }

    get player(){
        if (this.owner.ready && this.owner.ready.parent) {
            return this.owner.ready.getChildByName('player_down');
        } else {
            return this.owner.game.getChildByName('player_down');;
        }
    }
}


