    checkQingyise(){
        // TODO: 检查是否为清一色
        let doorGroups = this.getDoorGroups();
        if(!doorGroups)return false;// 门前牌组就不满足，直接否定清一色
        let self = __data.deskData.roomVo.getPlayerBySeat(0);
        let values = self.handValue.split(',');
        let commons = values.filter(value => value < 40);
        let wans = commons.filter(common => common < 10);
        if(wans.length == commons.length){ return true; }// 万清一色
        let tongs = commons.filter(common => common < 20 && common >= 10);
        if(tongs.length == commons.length){ return true; }// 筒清一色
        let tiaos = commons.filter(common => common < 30 && common >= 20);
        if(tiaos.length == commons.length){ return true; }// 条清一色
        return false;
    }
    // 门前牌组，用来辅助判断是否满足清一色
    getDoorGroups(){
        try {
            // 检查喜或者掌是否满足2个及以上
            let uniqueId = MahjongConfig.getUniqueId(__data.gameId.lastId, __data.gameId.lastRuleId);
            let desk = game.scene.get(window['MahjongDesk' + uniqueId + '3D']);
            let values = desk.downlist.doordata.map(groups => {
                let data = __compUtils.getAnalysis(groups);
                return data.group[0];
            }).filter(value => value < 40);
            let wans = values.filter(value => value < 10);
            if(wans.length == values.length){ return true; }// 门前牌都是万
            let tongs = values.filter(value => value < 20 && value >= 10);
            if(tongs.length == values.length){ return true; }// 门前牌都是筒
            let tiaos = values.filter(value => value < 30 && value >= 20);
            if(tiaos.length == values.length){ return true; }// 门前牌都是条
            return false;
        } catch (error) {
