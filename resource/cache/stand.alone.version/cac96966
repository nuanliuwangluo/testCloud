        else if(!result && PrayStatistics.tingState)this.setLastMiniGameTingResultByList(1);
        PrayStatistics.log && trace('%c Statistics-->小局结束，听牌未胡：' + result + '-->' + PrayStatistics.tingState, `color: ${this.color}`);
    }
