        this.setGameQuickPrayState('');
        this.setResultQuickPrayState('');
    }
    // 新的一场对局，清理数据
    newGame(){ 
        if(!this.available){ return; }
        PrayStatistics.log && trace('%c Statistics-->开始新一局，清理数据.', `color: ${this.color}`);
        PrayStatistics.tingState = false;// 听牌状态重置
        this.clearCatch(); // 清理抓牌的数据
        this.clearThrow(); // 清理弃牌的数据
        this.clearCatchNoHu();// 清理抓牌不胡的数据
        this.setGameQuickPrayState('');
        this.setResultQuickPrayState('');
    }

    get color(){ return '#883399'; }

    // 最近2次大局总分小于0   触发快速祈福 1.1
    checkJoinGameTrigger(){
        if(!this.available){ return; }
        let state = this.getGameQuickPrayState();// 是否已经弹出过该弹窗
        if(state){ return ""; }// 已经展示过 不再进行展示
        // TODO: 保存最后游戏分数
        let values = this.getLastGameScoreList();
        let len = 2;
        if(values.length >= len){
            let lastTwoValues = values.slice(-len);// 取最后存储的len个分数
            let scores = lastTwoValues.filter(value => value < 0);// 这len次分数都是负分，也就是输了
            if(scores.length == len){ this.taskHandle('总输？这次该转运了', 1);return true; }// len局都输算触发
        }
        PrayStatistics.log && trace('%c Statistics-->checkJoinGameTrigger：' + values, `color: ${this.color}`);
        return false;
    }

    // 未上听的情况下，本小局连续3轮抓啥打啥    触发快速祈福 1.2
    checkThrowTrigger(){
        if(!this.available){ return; }
        let state = this.getGameQuickPrayState();// 是否已经弹出过该弹窗
        if(state){ return ""; }// 已经展示过 不再进行展示
        let catches = this.getCatchList();
        let throws = this.getThrowByList();
        PrayStatistics.log && trace('%c Statistics-->checkThrowTrigger：', `color: ${this.color}`);
        PrayStatistics.log && trace('%c Statistics-->抓牌：' + catches, `color: ${this.color}`);
        PrayStatistics.log && trace('%c Statistics-->弃牌：' + throws, `color: ${this.color}`);
        if(catches.length >= 3 && throws.length >= 3){
            // 都取最后3张牌
            catches = catches.slice(-3);
            throws = throws.slice(-3);
            if(JSON.stringify(catches) === JSON.stringify(throws)){// 抓打的完全一样
                this.taskHandle('牌路不顺，破局趁现在', 2);
                return true;
            };
        }
        return false;
    }

    // 已上听的情况下，3轮未胡牌    触发快速祈福 1.3
    checkThrowNoHuTrigger(){
        if(!this.available){ return; }
        let state = this.getGameQuickPrayState();// 是否已经弹出过该弹窗
        if(state){ return ""; }// 已经展示过 不再进行展示
        let catches = this.getCatchNoHuByList();
        PrayStatistics.log && trace('%c Statistics-->checkThrowNoHuTrigger：' + catches, `color: ${this.color}`);
        if(catches.length == 3){
            this.taskHandle('听牌了，求自摸！', 3);
            return true;// 3轮未胡牌算触发
        }
        return false;
    }
    // 已上听的牌型不小  且前两句都没有胡牌    触发快速祈福 1.4
    checkTingTrigger(){
        if(!this.available){ return; }
        let state = this.getGameQuickPrayState();// 是否已经弹出过该弹窗
        if(state){ return ""; }// 已经展示过 不再进行展示
        // TODO: 检查是否触发快速祈福
        let results = this.getLastMiniGameResultByList();
        if(results.length < 2)return false;// 2小局未胡牌条件不满足
        let isAllLose = results.slice(-2).every(result => result == 0);// 前2局都输了
        let result = false;
        if(PrayStatistics.tingState && isAllLose){
            if(this.checkQingyise())// 满足清一色
                result = true;
            else if(this.checkMultiple())// 满足高倍率
                result = true;
            else if(this.checkXiZhang())// 满足亮喜两张组数
                result = true;
            if(result)this.taskHandle('大牌在手，好运速来！', 4);
        }
        PrayStatistics.log && trace('%c Statistics-->checkTingTrigger：' + result, `color: ${this.color}`);
        return result;
    }

    // 处理快速祈福
    taskHandle(content, number){
        if(!this.available){ return; }
        game.cb.event('quick_pray', [content, number]);
        this.setGameQuickPrayState(1);
        miniApi.trackEvent('Mj_Marketing', { 'Mj_MarketingScene': `对局${number}`, 'Mj_MarketingType':'快速祈福', 'Mj_MarketingStatus':'曝光' })
    }

    // 结算
    checkResultTrigger(){
        if(!this.available){ return; }
        let state = this.getResultQuickPrayState();// 是否已经弹出过该弹窗
        PrayStatistics.log && trace('%c Statistics-->快速祈福结算状态：' + state, `color: ${this.color}`);
        if(state){ return ""; }// 已经展示过 不再进行展示
        let content = '';
        let number = 0;
        content = this.checkResultLoseTrigger();// 结算连续3局得分小于0
        PrayStatistics.log && trace('%c Statistics-->结算快速祈福判断[1]：' + content, `color: ${this.color}`);
        if(content){ 
            number = 1;
            miniApi.trackEvent('Mj_Marketing', { 'Mj_MarketingScene': `结算${number}`, 'Mj_MarketingType':'快速祈福', 'Mj_MarketingStatus':'曝光' })
            this.setResultQuickPrayState(1);
            return { content, number }; 
        }
        content = this.checkResultLoseMostTrigger();// 对局超过一半且自己输分超过总输分的75%
        PrayStatistics.log && trace('%c Statistics-->结算快速祈福判断[2]：' + content, `color: ${this.color}`);
        if(content){ 
            number = 2;
            miniApi.trackEvent('Mj_Marketing', { 'Mj_MarketingScene': `结算${number}`, 'Mj_MarketingType':'快速祈福', 'Mj_MarketingStatus':'曝光' })
            this.setResultQuickPrayState(1);
            return { content, number }; 
        }
        content = this.checkResultKeepLoseTrigger();// 连续5小局未胡牌
        PrayStatistics.log && trace('%c Statistics-->结算快速祈福判断[3]：' + content, `color: ${this.color}`);
        if(content){ 
            number = 3;
            miniApi.trackEvent('Mj_Marketing', { 'Mj_MarketingScene': `结算${number}`, 'Mj_MarketingType':'快速祈福', 'Mj_MarketingStatus':'曝光' })
            this.setResultQuickPrayState(1);
            return { content, number }; 
        }
        content = this.checkResultTingAndLoseTrigger();// 上听至少2次且未胡牌
        PrayStatistics.log && trace('%c Statistics-->结算快速祈福判断[4]：' + content, `color: ${this.color}`);
        if(content){ 
            number = 4;
            miniApi.trackEvent('Mj_Marketing', { 'Mj_MarketingScene': `结算${number}`, 'Mj_MarketingType':'快速祈福', 'Mj_MarketingStatus':'曝光' })
            this.setResultQuickPrayState(1);
            return { content, number }; 
        }
        PrayStatistics.log && trace('%c Statistics-->结算快速祈福判断[5]：' + content, `color: ${this.color}`);
        return null;
    }

    // 结算连续3局得分小于0
    checkResultLoseTrigger(){
        if(!this.available){ return; }
        let scores = this.getLastMiniGameScoreByList();
        PrayStatistics.log && trace('%c Statistics-->checkResultLoseTrigger：' + scores, `color: ${this.color}`);
        if(scores.length >= 3){
            let result = scores.slice(-3).every(score => score < 0);
            if(result)return "运气不佳？祈福好运！";
        }
        return "";
    }

    // 对局超过一半且自己输分超过总输分的75%
    checkResultLoseMostTrigger(){
        if(!this.available){ return; }
        if(__data.deskData.roomVo.allGame <= 1)return false;// 这种是对局总数不确定的对局，所以不处理
        if(__data.deskData.roomVo.curGame <= __data.deskData.roomVo.allGame / 2)return false;// 这种是对局数没有超过一半, 所以不处理
        // 自己输分 如果超过100
        let myScore = __data.deskData.roomVo.getPlayer(__data.uid).score;
        PrayStatistics.log && trace('%c Statistics-->checkResultLoseMostTrigger：' + myScore, `color: ${this.color}`);
        if(myScore < -100){ return "绝境深处，祈福翻盘！"; }
        let ids = __data.deskData.roomVo.getPlayerIds();
        let allLoseScore = 0;// 所有输的玩家的总分
        ids.filter(id => __data.deskData.roomVo.getPlayer(id).score < 0).map(id=> allLoseScore += parseInt(__data.deskData.roomVo.getPlayer(id).score));
        PrayStatistics.log && trace('%c Statistics-->checkResultLoseMostTrigger：' + allLoseScore + '-->' + allLoseScore * 0.75, `color: ${this.color}`);
        if(allLoseScore * 0.75 > myScore){ return "绝境深处，祈福翻盘！"; }
        return "";
    }

    // 连续5小局未胡牌
    checkResultKeepLoseTrigger(){
        if(!this.available){ return; }
        let results = this.getLastMiniGameResultByList();
        PrayStatistics.log && trace('%c Statistics-->checkResultKeepLoseTrigger：' + results, `color: ${this.color}`);
        if(results.length >= 5){
            let result = results.slice(-5).every(result => result == 0);
            if(result)return "运气不佳？祈福好运！";
        }
        return "";
    }

    // 上听至少2次且未胡牌
    checkResultTingAndLoseTrigger(){
        if(!this.available){ return; }
        let tingResults = this.getLastMiniGameTingResultByList();
        PrayStatistics.log && trace('%c Statistics-->checkResultTingAndLoseTrigger：' + tingResults, `color: ${this.color}`);
        if(tingResults.length >= 2){
            return "运气不佳？祈福好运！";
        }
        return "";
    }

    static get instance(){
        if(!this._instance){
            this._instance = new PrayStatistics();
        }
        return this._instance;
    }
}