
class GameMainRedChallengeFail extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_allPlayerRed_fail',
            layer: 'panel'
        })
        this.txt_giveup.addComponent(S_red_fail_giveup)
        this.s_all = this.btn_re.addComponent(S_click_allpr_reChallenge)
        this.s_new = this.btn_re.addComponent(S_click_rec_reChallenge)
        this.s_friend = this.btn_re.addComponent(S_click_friend_reChallenge)
        this.img_ad.addComponent(S_allred_to_vip)
    }
    added(type) {
        miniApi.setItem(__data.uid + ':red_fail_bomb_box', '1')
        // 'adunit-21b4a4918cdbf39b': '新人红包复活',
        // 'adunit-14d1ff0df5c09c4c': '全民复活复活',
        this.adid = ''
        this.type = type;
        if (type == 'newPlayer') {
            this.s_all.enabled = false
            this.s_friend.enabled = false
            this.s_new.enabled = true
            this.adid = 'adunit-21b4a4918cdbf39b'
            this.img_newPlayerRed.visible = true
            this.img_redNum.visible = false
            this.img_ad.visible = false;
            this.img_bg.y = 145
            game.utils.remove(this.scene_luck)
        } else if (type == 'allPlayer') {
            this.s_all.enabled = true
            this.s_new.enabled = false
            this.s_friend.enabled = false
            this.adid = 'adunit-14d1ff0df5c09c4c'
            this.img_newPlayerRed.visible = false
            this.img_redNum.visible = true
            this.show_red_num_allPlayerRed()
            game.cb.on('update_allPlayerRed_data', this, this.show_red_num_allPlayerRed)
            if (__data.vip.isVip) {
                this.img_ad.visible = false;
                this.img_bg.y = 145;
            } else {
                this.img_ad.visible = true;
                this.img_bg.y = 20;
            }
            this.addChild(this.scene_luck)
        } else if (type == 'friendRed') {
            this.s_all.enabled = false
            this.s_new.enabled = false
            this.s_friend.enabled = true
            this.adid = 'adunit-friendRed_relife'
            this.img_newPlayerRed.visible = false
            this.img_redNum.visible = true
            this.show_red_num_friendRed()
            game.cb.on('update_friendRed_data', this, this.show_red_num_friendRed)
            if (__data.vip.isVip) {
                this.img_ad.visible = false;
                this.img_bg.y = 145;
            } else {
                this.img_ad.visible = true;
                this.img_bg.y = 20;
            }
            game.utils.remove(this.scene_luck)
        }
    }
    onDisable() {
        game.cb.off('update_allPlayerRed_data', this, this.show_red_num_allPlayerRed)
        game.cb.off('update_friendRed_data', this, this.show_red_num_friendRed)
        ResultPanelManager.show();
    }
    show_red_num_allPlayerRed() {
        let index = __data.allPlayerRed.isTimeIn()
        if (index > 0) {
            this.txt_redNum.text = __data.allPlayerRed.redNum[index - 1]
        } else {
            this.txt_redNum.text = 0;
        }
    }
    show_red_num_friendRed() {
        let index = __data.friendRoom.red.isTimeIn()
        if (index > 0) {
            this.txt_redNum.text = __data.friendRoom.red.surplusRedNum
        } else {
            this.txt_redNum.text = 0;
        }
    }
}
class S_allred_to_vip extends Laya.Script {
    onClick(e) {
        __showScene.show_vip()
    }
}
class S_red_fail_giveup extends Laya.Script {
    onClick(e) {
        let a = game.scene.get(GameMainRedChallengeFail)
        if (a && a.type == 'friendRed') {
            miniApi.setItem(__data.uid + ':friendRed_fail_bomb_box:' + new Date().toDateString(), '1')
        }
        game.scene.remove(GameMainRedChallengeFail)
    }
}
class S_click_friend_reChallenge extends Laya.Script {
    async onClick(e) {
        let adunitId = 'adunit-friendRed_relife'
        await miniApi.video_ready(adunitId)
        miniApi.video_show(adunitId, () => {
            game.server.send(18023)
        }, () => {
            __tips('暂无广告，请稍后再试或开通VIP')
        }, 0);
        let n = __data.vip.isVip ? 'VIP领取' : '参与广告'
        miniApi.trackEvent('Mj_ADClick', { Mj_ADPreference: miniApi.adUserValueLevel, 'Mj_ADScene': '好友红包复活', 'Mj_Participation': n })
    }
}