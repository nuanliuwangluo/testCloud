class HallPlayFriendRuleItem extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall_play/hall_play_friend_ruleItem',
            module: false
        })
        this.__vo = null;
        this.addComponent(S_CLICK_HallPlayFriendRuleItem)
        this._onRuleId;
        this._offRuleId;
        this._ruleIndex;
    }
    onEnable() {
        game.cb.on('update_hallPlay_firend_ruleItemView', this, this.update_hallPlay_firend_ruleItemView)
    }
    onDisable() {
        game.cb.off('update_hallPlay_firend_ruleItemView', this, this.update_hallPlay_firend_ruleItemView)
    }
    set dataSource(vo) {
        if (!vo) return
        this.__vo = vo;
    }
    update_hallPlay_firend_ruleItemView() {
        if (this._offRuleId != null) {
            this.txt_1.color = '#a3a8ce'
            this.img_bg.skin = 'local/hall_play/1/bt_dqbox4.png'
        }
        else if (this._onRuleId == HallPlay.curRuleId) {
            this.txt_1.color = '#ffffff'
            this.img_bg.skin = 'local/hall_play/1/bt_dqbox2.png'
        }
        else if (this._onRuleId != HallPlay.curRuleId) {
            this.txt_1.color = '#a1aefd'
            this.img_bg.skin = 'local/hall_play/1/bt_dqbox1.png'
        }
    }
    clearRuleId() {
        this._onRuleId = null;
        this._offRuleId = null;
    }
    set onRuleId(id) {
        this._onRuleId = id;
        this.update_hallPlay_firend_ruleItemView()
    }
    set offRuleId(id) {
        this._offRuleId = id;
        this.update_hallPlay_firend_ruleItemView()
    }
    updateLabel(playName) {
        this.txt_1.text = playName
    }
}
Laya.ClassUtils.regClass('ui.scene_hall_play.hall_play_friend_ruleItemUI', HallPlayFriendRuleItem);

class S_CLICK_HallPlayFriendRuleItem extends Laya.Script {
    onClick(E) {
        if (this.owner._offRuleId != null) {
            __showScene.show_prompt_single(this.owner.txt_1.text + '正在努力开发中，您可以点击下方按钮催促加急，我们将优先实现加急较多的玩法。', '催促加急', () => {
                __tips('反馈成功')
                let umEventName = excelUtils.getUmEventName(HallPlay.lastCityId)
                miniApi.trackEvent('Mj_UIClick', { Mj_County: umEventName, 'Mj_ClickScene': `催促加急按钮` })
            })
            return
        };
        HallPlay.curRuleId = this.owner._onRuleId;

        // 更换地方存
        let setkey = __data.uid + `:friendRoom:cityId:${HallPlay.lastCityId}-ruleId`
        // trace('缓存好友选择玩法setkey', setkey, e)
        miniApi.setItem(setkey, this.owner._onRuleId)

        game.cb.event('update_hallPlay_firend_ruleItemView')
    }
}