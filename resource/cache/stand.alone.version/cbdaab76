//方正通河射宝
class MahjongEffectShotBao extends Laya.Image {
    constructor() {
        super()

        this.params = {
            "layer": 'bottom',
            "offx": 0,
            "offy": 0,
            "centerx": true,
            "centery": true,
            "up": false,
            "down": false,
            "left": false,
            "right": false
        }

        this.size(263, 496)
        this.scale(game.scale, game.scale)

        let __fontImg = new Laya.Image("bigEffect/sbFont.png")
        __fontImg.x = (this.width - __fontImg.width) / 2;
        __fontImg.y = (this.height - __fontImg.height) / 2 + 30
        this.addChild(__fontImg)

        this.len = 8;
    }

    onEnable() {
        this.startAni();
        this.updateSkin();
    }

    onDisable() { }

    startAni() {
        this.curIndex = 1;
        Laya.timer.loop(120, this, this.changeSkin)
    }

    changeSkin() {
        this.curIndex++;
        if (this.curIndex >= this.len) {
            Laya.timer.clear(this, this.changeSkin)
            this.updateSkin();
            Laya.timer.once(150, this, this.startAni)
        } else this.updateSkin();
    }

    updateSkin() { this.skin = 'bigEffect/sb' + this.curIndex + '.png' }
}



