class MahjongMixedEffect extends Laya.Image {
    constructor() {
        super()

        this.params = {
            "layer": 'bottom',
            "offx": 0,
            "offy": 0,
            "centerx": true,
            "centery": true,
            "up": false,
            "down": false,
            "left": false,
            "right": false
        }

        this.skin = 'local/mahjong_effect/1/kh.png';
    }

    onEnable() {
        this.alpha = this.scaleX = this.scaleY = 1;
        this.pivot(this.width / 2, this.height / 2);
        this.scale(game.scale, game.scale);
        this.x = game.width / 2;
        this.y = game.height / 2;
        Laya.Tween.to(this, { scaleX: 0, scaleY: 0, alpha: 0 }, 300, Laya.Ease.backInOut, new Laya.Handler(this, this.onComplete), 500)
    }
    onDisable() {
        trace(1);
    }

    onComplete() {
        game.utils.remove(this);
    }
}




class MahjongEffectCommon extends game.ModuleBase {
    constructor() {
        super()

        this.createView(game.uiMap['scene_game/mahjong/MahjongEffectCommon']);

        // this.scale(game.scale, game.scale)

        this.codeArr = []
        this.codeArr[0] = 'local/mahjong_effect/1/chi.png'
        this.codeArr[1] = 'local/mahjong_effect/1/peng.png'
        this.codeArr[2] = 'local/mahjong_effect/1/gang.png'
        this.codeArr[3] = 'local/mahjong_effect/1/liangxi.png'
        this.codeArr[4] = 'local/mahjong_effect/1/liangzhang.png'
        this.codeArr[8] = 'local/mahjong_effect/1/zhidui.png'
        this.codeArr[9] = 'local/mahjong_effect/1/t1.png'

        this.codeArr[5] = 'local/mahjong_effect/1/ph.png' //飘胡
        this.codeArr[6] = 'local/mahjong_effect/1/teh.png' //特胡
        this.codeArr[7] = 'local/mahjong_effect/1/lj1.png' //流局

        this.__doTime = 250
        this.__waitTime = 500

        this.__offx = 150;
        this.__offy = 50;
    }

    onEnable() { }

    onDisable() {
        ELD.remove(this);
    }

    /**
     * [start description] 
     * @param  {[type]} code [description]  codeArr 下标
     * @param  {[type]} seat [description]  位置
     * @param  {[type]} keep [description]  是否保持不消失
     * @return {[type]}      [description]
     */
    start(code, seat, keep) {
        trace('特效code：', code)
        this.seat = seat;
        if (seat == 'down') {
            this.x = config.gameW - this.width >> 1
            this.y = __compUtils.getDeskDy() - this.height - this.__offy; // config.gameH - this.height - this.__offy
        } else if (seat == 'up') {
            this.x = config.gameW - this.width >> 1
            this.y = __compUtils.getDeskUy() + this.__offy; // this.__offy
        } else if (seat == 'left') {
            this.x = __compUtils.getDeskLx();
            this.y = (config.gameH - this.height) / 2 - this.height / 1.5
        } else if (seat == 'right') {
            this.x = __compUtils.getDeskRx() - this.width; // config.gameW - this.width - this.__offx
            this.y = (config.gameH - this.height) / 2 - this.height / 1.5
        } else {
            this.x = config.gameW - this.width >> 1
            this.y = config.gameH - this.height >> 1
        }

        this.view.skin = this.codeArr[code]
        this.__keep = (keep == true) ? true : false

        this.view.scaleX = this.view.scaleY = 1.5;
        Laya.Tween.to(this.view, { scaleX: 1, scaleY: 1 }, this.__doTime, null, new Laya.Handler(this, this.waitDisappearHandler))

        ELD.push(this);
    }

    waitDisappearHandler() {
        if (!this.__keep) { Laya.timer.once(this.__waitTime, this, this.disappearHandler) }
    }

    disappearHandler() {
        Laya.Tween.to(this.view, { alpha: 0 }, this.__doTime, Laya.Ease.backInOut, new Laya.Handler(this, this.removeHandler))
    }

    removeHandler() {
        game.utils.remove(this);
    }
}

