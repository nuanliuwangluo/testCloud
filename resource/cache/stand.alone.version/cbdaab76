        game.utils.remove(this);
    }
}





class ELD {
    static push(view) {
        if (view && view.seat) {
            this.list.push(view);
            this.overlay(view.seat);
        }
    }

    static remove(view) {
        let index = this.list.indexOf(view);
        if (index != -1) {
            this.list.splice(index, 1);
            // this.overlay(view.seat)
        }
    }

    static get list() {
        if (!this._list) {
            this._list = [];
        }
        return this._list;
    }
    static clearList() { this._list = []; }

    static get time() { return 0; }


    static overlay(seat) {
        if (seat == 'up') this.uspecial(seat);
        if (seat == 'down') this.vertical(seat);
        else this.horizontal(seat);
    }

    static uspecial(seat) {
        let temp_list = [];
        for (let i = 0; i < this.list.length; i++) {
            if (this.list[i].seat == seat) {
                temp_list.push(this.list[i]);
            }
        }
        while (temp_list.length > 1) {
            let effect = temp_list.shift();
            this.remove(effect);
            game.utils.remove(effect);
            game.scene.remove(effect);
        }
    }

    static horizontal(seat) {
        let temp_list = [];
        let space = 7;
        for (let i = 0; i < this.list.length; i++) {
            if (this.list[i].seat == seat) {
                temp_list.push(this.list[i]);
            }
        }
        // 没有多个不处理
        if (temp_list.length <= 1) return;
        if (seat == 'left') {
            let sx = temp_list[0].x + temp_list[0].width + space;
            for (let i = 1; i < temp_list.length; i++) {
                Laya.Tween.to(temp_list[i], { x: sx }, this.time);
                sx = sx + temp_list[i].width + space;
            }
        } else {
            let sx = temp_list[0].x;
            for (let i = 1; i < temp_list.length; i++) {
                Laya.Tween.to(temp_list[i], { x: sx - temp_list[i].width - space }, this.time);
                sx = sx - temp_list[i].width - space;
            }
        }
    }

    static vertical(seat) {
        let temp_list = [];
        let space = 0;
        for (let i = 0; i < this.list.length; i++) {
            if (this.list[i].seat == seat) {
                temp_list.push(this.list[i]);
            }
        }
        // 没有多个不处理
        if (temp_list.length <= 1) return;
        if (seat == 'up') {
            let sy = temp_list[0].y + temp_list[0].height + space;
            for (let i = 1; i < temp_list.length; i++) {
                Laya.Tween.to(temp_list[i], { y: sy }, this.time);
                sy = sy + temp_list[i].height + space;
            }
        } else {
            let sy = temp_list[0].y;
            for (let i = 1; i < temp_list.length; i++) {
                Laya.Tween.to(temp_list[i], { y: sy - temp_list[i].height - space }, this.time);
                sy = sy - temp_list[i].height - space;
            }
        }
    }
}