class MahjongSet extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_game/mahjong/MahjongSet',
            layer: 'panel'
        })

        this.addComponent(MahjongSetScript);

        this.rgc.addComponent(MahjongGiftSetScript).rg(this.rg_gift);

        this.btn_a.addComponent(S_click_set_btn_a);
        this.btn_b.addComponent(S_click_set_btn_b);
        this.btn_deleteAccount.addComponent(S_set_delete_account);
        this.btn_quitLogin.addComponent(S_set_quit_login);
    }

    onEnable() {
        this.btn_deleteAccount.visible = true;
        this.btn_quitLogin.visible = true;
        if (miniApi.clientType == 'wx') {
            this.btn_quitLogin.visible = false
        }
        let p1 = game.scene.get(Mahjong3DBG)
        if (p1 && p1.parent) {
            this.btn_deleteAccount.visible = false
            this.btn_quitLogin.visible = false
        }
        __tool.labelParentCenterAndSetXY(this.sp_txt_btn, this.width / 2, 50)

        this.rg_music.selectedIndex = LocalUtils.music.value;
        this.rg_sound.selectedIndex = LocalUtils.sound.value;

        this.rg_desk.selectedIndex = LocalUtils.desk.value;
        this.rg_card.selectedIndex = LocalUtils.card.value;
        this.rg_sex.selectedIndex = LocalUtils.sex.value;

        // this.rg_wall.selectedIndex = LocalUtils.wall.value;
        // this.rg_speed.selectedIndex = LocalUtils.speed.value;

        game.cb.on(__eh + 'save_set_data', this, this.updateSet)
    }

    onDisable() {
        game.cb.off(__eh + 'save_set_data', this, this.updateSet)
    }

    updateSet() {
        miniApi.setItem('music', this.rg_music.selectedIndex == 0 ? 'true' : 'false')
        config.isMusic = this.rg_music.selectedIndex == 0
        if (this.rg_music.selectedIndex == 0) {
            __sound.playAllMusic()
        } else {
            __sound.stopAllMusic()
        }

        miniApi.setItem('sound', this.rg_sound.selectedIndex == 0 ? 'true' : 'false')
        config.isSound = this.rg_sound.selectedIndex == 0
        if (this.rg_sound.selectedIndex == 0) {

        } else {
            Laya.SoundManager.stopAllSound()
        }
    }
}

