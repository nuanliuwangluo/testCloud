class MahjongSetScript extends Laya.Script {
    onAwake() {
        this.owner.btn_save.on('click', this, this.saveHandler)
    }

    saveHandler() {
        // 牌发生变化 需要重新载入游戏
        if (this.owner.rg_card.selectedIndex != LocalUtils.card.value && (__data.deskData.roomVo.phase == 'game')) {
            game.scene.add(GameCommonChoicePrompt, ['重新载入后即可生效设置内容', {
                name: '立即重载',
                call: this.refreshHandler.bind(this)
            }])
        } else {
            this.save();
            __tips('保存成功');
        }
    }

    async refreshHandler() {
        this.save();
        __data.lastSceneQueue.push(__showScene.show_hall)
        await __showScene.show_hall_play(HallPlay.lastCityId)
        // await __showScene.load_game_mahjong();
        // __showScene.show_game_mahjong();
        __showScene.wait();
        __reBack_info.read();
    }

    save() {
        LocalUtils.music.value = this.owner.rg_music.selectedIndex;
        LocalUtils.sound.value = this.owner.rg_sound.selectedIndex;
        LocalUtils.desk.value = this.owner.rg_desk.selectedIndex;
        LocalUtils.card.value = this.owner.rg_card.selectedIndex;
        LocalUtils.sex.value = this.owner.rg_sex.selectedIndex;
        LocalUtils.gift.value = this.owner.rg_gift.selectedIndex;
        // LocalUtils.wall.value = this.owner.rg_wall.selectedIndex;
        // LocalUtils.speed.value = this.owner.rg_speed.selectedIndex;

        LocalUtils.save(LocalUtils.music.key, LocalUtils.music.value)
        LocalUtils.save(LocalUtils.sound.key, LocalUtils.sound.value)
        LocalUtils.save(LocalUtils.desk.key, LocalUtils.desk.value)
        LocalUtils.save(LocalUtils.card.key, LocalUtils.card.value)
        LocalUtils.save(LocalUtils.wall.key, LocalUtils.wall.value)
        LocalUtils.save(LocalUtils.speed.key, LocalUtils.speed.value)
        LocalUtils.save(LocalUtils.sex.key, LocalUtils.sex.value)
        LocalUtils.save(LocalUtils.gift.key, LocalUtils.gift.value)

        __data.mahjong_set.bgIndex = parseInt(LocalUtils.desk.value);
        __data.mahjong_set.cardIndex = parseInt(LocalUtils.card.value);
        __data.mahjong_set.wallIndex = parseInt(LocalUtils.wall.value);
        __data.mahjong_set.speedIndex = parseInt(LocalUtils.speed.value);
        __data.mahjong_set.sexIndex = parseInt(LocalUtils.sex.value);
        __data.mahjong_set.giftIndex = parseInt(LocalUtils.gift.value);

        // 性别  需要后端保存
        game.server.send(2217, LocalUtils.sex.value + 1);

        game.cb.event(__eh + 'save_set_data');
    }
}


class MahjongGiftSetScript extends Laya.Script {

    rg(_rg) {
        this._rg = _rg;
        return this;
    }

    clickToSave() {
        this._clickToSave = true;
        return this;
    }

    onEnable() {
        this._rg.selectedIndex = LocalUtils.gift.value;
        this._rg.on(Laya.Event.CHANGE, this, this._onCompChange);
        this.init();
    }

    onDisable() {
        this._rg.off(Laya.Event.CHANGE, this, this._onCompChange);
    }

    init() {
        // IOS能支付修改
        // if (!__data.vip.isVip && miniApi.isIOS) {
        //     this.owner.visible = false;
        // } else {
        this.owner.visible = true;
        // }
    }

    _onCompChange() {
        if (this._rg.selectedIndex == 1) {
            if (!__data.vip.isVip) {
                Laya.timer.callLater(this, this._defaultIndex);
                __tips('此功能仅限VIP使用');
            }
        }
        if (this._clickToSave) {
            LocalUtils.gift.value = this._rg.selectedIndex;
            LocalUtils.save(LocalUtils.gift.key, LocalUtils.gift.value);
            game.cb.event(__eh + 'save_set_data');
        }
    }

    _defaultIndex() {
        this._rg.selectedIndex = 0;
    }
}