class S_icon_marketActivity_firstPay extends Laya.Script {
    onClick(e) {
        closeOtherMarketActivityPanel()
        __showScene.show_gameMain_firstPay()
        miniApi.trackEvent('Mj_UIClick', { 'Mj_ClickScene': '首充豪礼图标' })
    }
    onEnable() {
        __data.firstPay.send(1)
        this.update_red();
        game.cb.on('update_firstPay_data', this, this.update_red)
    }
    onDisable() {
        game.cb.off('update_firstPay_data', this, this.update_red)
    }
    update_red() {
        // 是否显示 - 首充豪礼 按钮
        if (!__data.firstPay.isHaveData) {
            this.owner.visible = false;
        }
        else if (
            __data.firstPay.isHasBuy
            // || miniApi.isIOS
        ) {
            this.owner.visible = false;
        } else {
            this.owner.visible = true;
        }
        game.cb.event('icon_marketActivity_sort')
    }
}
