class S_IconNextWeek extends Laya.Script {
    onEnable() {
        effectUtils.breathe(this.owner, 1, 1.1, 500)
        let day = new Date().getDay(); // 0=周日 1=周一 ... 6=周六
        let left = day === 0 ? 1 : 8 - day;
        this.owner.getChildByName('txt_nextWeek').text = `剩${left}天`;
    }

    onDisable(){
        effectUtils.stopBreathe(this.owner)
    }
}