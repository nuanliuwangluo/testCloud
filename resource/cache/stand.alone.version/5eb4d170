class Icon_marketActivity extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/Icon_marketActivity',
        })
        this.panel_icon.vScrollBarSkin = '';
        this.btn_firstPay.addComponent(S_icon_marketActivity_firstPay)
        this.btn_todayDiscount.addComponent(S_icon_marketActivity_todayDiscount)
        this.btn_stepstepGift.addComponent(S_icon_marketActivity_stepstepGift)
        this.btn_goldBox.addComponent(S_icon_marketActivity_goldBox)
        this.btn_surpriseCrit.addComponent(S_icon_marketActivity_surpriseCrit)
        this.btn_inviteRed.addComponent(S_icon_marketActivity_inviteRed)
        this.btn_inviteRed.getChildByName('img_icon').getChildByName('nw').addComponent(S_IconNextWeek);
    }
    onAwake() {
        this.iconArray = [
            this.btn_firstPay,
            this.btn_todayDiscount,
            this.btn_stepstepGift,
            this.btn_goldBox,
            this.btn_surpriseCrit,
            this.btn_inviteRed,
        ]
    }
    onEnable() {
        this.img_line.visible = false;
        game.cb.on('icon_marketActivity_sort', this, this.onSort)
        game.cb.on('marketActivity_panel_close', this, this.marketActivity_panel_close)
        this.onSort()

        let p = this.parent;
        this.img_arrow.visible = this.parent == game.scene.layer['tips'].c;
    }
    onDisable() {
        game.cb.off('icon_marketActivity_sort', this, this.onSort)
        game.cb.off('marketActivity_panel_close', this, this.marketActivity_panel_close)
    }
    onSort() {
        let h = 0
        this.iconArray.forEach(e => {
            if (e.visible) {
                e.y = h;
                h = e.y + e.height;
            }
        });
        this.sp_container.height = h;
        this.panel_icon.refresh()
    }
    isBtnInView(btn) {
        let scrollY = this.panel_icon.vScrollBar.value;
        let panelH = this.panel_icon.height;
        let btnY = btn.y;
        let btnH = btn.height;
        let topVisible = btnY >= scrollY;
        let bottomVisible = btnY + btnH <= scrollY + panelH;
        return topVisible && bottomVisible;
    }
    selectBtn(btnName) {
        let btn = this['btn_' + btnName];
        btn.addChildAt(this.img_arrow, 0)
        this.img_arrow.x = -17;
        this.img_arrow.y = -7;
        if (!this.isBtnInView(btn)) {
            this.panel_icon.scrollTo(0, btn.y - btn.height + this.panel_icon.height);
        }
    }
    marketActivity_panel_close() {
        if (__showScene.sceneType == 'hall') {
            this.img_line.visible = false
            game.scene.layer['bottom'].c.addChild(this)
        } else {
            game.scene.remove(this)
        }
    }
}
let closeOtherMarketActivityPanel = () => {
    game.utils.remove(game.scene.get(GameMainFirstPay))
    game.utils.remove(game.scene.get(Panel_marketActivity_surpriseCrit))
    game.utils.remove(game.scene.get(Panel_marketActivity_goldBox))
    game.utils.remove(game.scene.get(Panel_marketActivity_stepstepGift))
    game.utils.remove(game.scene.get(Panel_marketActivity_todayDiscount))
    game.utils.remove(game.scene.get(Panel_marketActivity_inviteRed))
}
let showActivityPanel = async (name) => {
    await __tool.await(200)
    let iconModule = game.scene.get(Icon_marketActivity)
    if (iconModule && iconModule.parent) {
        game.scene.layer['tips'].c.addChild(iconModule)
        iconModule.img_line.visible = true;
        iconModule.selectBtn(name);
    } else {
        game.scene.add(Icon_marketActivity)
        game.scene.layer['tips'].c.addChild(iconModule)
        iconModule.img_line.visible = true;
        iconModule.selectBtn(name);
    }
}
