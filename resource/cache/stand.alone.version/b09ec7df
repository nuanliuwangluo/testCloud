class GameMainEmailContent extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_emailContent',
            layer: 'panel'
        })
        this.btn_receive.addComponent(S_email_receive_a)
        this.btn_delete.addComponent(S_email_delete_a)
    }
    added(emailVO) {
        this.emailVO = emailVO;
        this.update_email_content()
        game.cb.on('update_email_data', this, this.update_email_content)
    }

    onDisable() {
        game.cb.off('update_email_data', this, this.update_email_content)
    }

    update_email_content() {
        this.txt_title.text = this.emailVO.title;
        this.txt_date.text = new Date(this.emailVO.time).dateFormat("yyyy.MM.dd");
        this.txt_des.text = this.emailVO.des;
        let a = this.emailVO.reward
        this.scene_prop0.visible = false
        this.scene_prop1.visible = false
        this.scene_prop2.visible = false
        this.scene_prop3.visible = false
        this.scene_prop4.visible = false
        this.scene_prop5.visible = false
        for (let index = 0, length = a.length; index < length; index++) {
            const element = a[index];
            this[`scene_prop${index}`].visible = true;
            this[`scene_prop${index}`].vo = {
                propId: element.id,
                num: element.count
            }
        };
        this.btn_receive.visible = false;
        this.btn_delete.visible = false;
        if (!a || !a.length) {
            this.btn_delete.visible = true
        }
        else if (this.emailVO.isReceive) {
            this.btn_delete.visible = true
        }
        else {
            this.btn_receive.visible = true
        }
    }
}
class S_email_receive_a extends Laya.Script {
    onClick(e) {
        game.server.send(2235, this.owner.parent.emailVO.emailId)
    }
}
class S_email_delete_a extends Laya.Script {
