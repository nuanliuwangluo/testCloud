class S_bless_mul_add extends Laya.Script {
    onClick(e) {
        this.owner.parent.__vo.baseMul++;
        this.owner.parent.__vo.baseMul > 10 && (this.owner.parent.__vo.baseMul = 10);
        this.owner.parent.udpate_mul(true);
        this.owner.parent.udpate_btn()
    }
}
class S_bless_mul_reduce extends Laya.Script {
    onClick(e) {
        this.owner.parent.__vo.baseMul--;
        this.owner.parent.udpate_mul(true)
        this.owner.parent.udpate_btn()
    }
}
class S_bless_buy extends Laya.Script {
    async onClick(e) {
        MahjongBless.data.isQuick = 0;
        let vo = this.owner.parent.__vo;
        let a = game.scene.get(MahjongBless_rightDown)
        let isSelect = a.btn_check.selected ? 2 : 1;
        bless_buy_logic(vo, isSelect)
    }
}

let bless_buy_logic = async (vo, isSelect) => {
    let needPrice = vo.baseStoneCost * vo.baseMul;
    if (vo.firstFree === 1 && MahjongBless.data.firstFree_isBuy === 1) {
        // 看视频逻辑：预加载 → 播放 → 成功后发送16023
        let adUnitId = 'adunit-bless_first_free';  // 替换为实际的广告位ID
        await miniApi.video_ready(adUnitId);
        miniApi.video_show(adUnitId, () => {
            // 视频看完，发送16023
            game.server.send(16023, vo.type, 1, isSelect)
        }, () => {
            // 视频播放失败（用户中途关闭等）
            __tips('暂无广告，请稍后再试或开通VIP')
        });

        let n = __data.vip.isVip ? 'VIP领取' : '参与广告'
        miniApi.trackEvent('Mj_ADClick', {
            Mj_ADPreference: miniApi.adUserValueLevel,
            'Mj_ADScene': '首次免费祝福',
            'Mj_Participation': n,
            'Mj_ADNotes': __data.mjSmallGame.level,
        })
    }
    else if (__data.stone >= needPrice) {
        game.server.send(16023, vo.type, vo.baseMul, isSelect)
    } else {
        __showScene.show_payPrompt(needPrice, () => {
            game.server.send(16023, vo.type, vo.baseMul, isSelect)
        })
    }
}
