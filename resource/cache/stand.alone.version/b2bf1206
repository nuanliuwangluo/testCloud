class MahjongBlessItem extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_game/mahjong/MahjongBlessItem',
            module: false
        })
        this.btn_add.addComponent(S_bless_mul_add)
        this.btn_reduce.addComponent(S_bless_mul_reduce)
        this.btn_buy.addComponent(S_bless_buy)
        this.init_img_luck_y = this.img_luck.y
        this.init_txt_luck_y = this.txt_luck.y
    }
    onEnable() {
        game.cb.on('update_bless_data', this, this.update_bless_data)
    }
    onDisable() {
        game.cb.off('update_bless_data', this, this.update_bless_data)
        this.ani2 && this.ani2.stop()
        // ResUtils.clearTextureRes(['cdn.bless_panel', 'cdn.redPacket_light'])
    }
    update_bless_data() {
        if (this.__vo && this.__vo.firstFree === 1) {
            this.udpate_mul()
            if (vo.firstFree === 1 && MahjongBless.data.firstFree_isBuy === 1) {
                this.sp_price.visible = false;
                this.sp_price1.visible = true;
                this.btn_add.disabled = this.btn_reduce.disabled = true;
            } else {
                this.sp_price.visible = true;
                this.sp_price1.visible = false;
                this.btn_add.disabled = this.btn_reduce.disabled = false;
                this.udpate_btn()
            }
        }
    }
    set dataSource(vo) {
        if (!vo) return;
        this.__vo = vo;
        vo.baseMul = 1;
        this.sp_price1.visible = false;
        this.sp_price.visible = false;
        this.img_name.skin = `cdn/bless_panel/${vo.nameImg}.png`
        this.udpate_mul()
        if (vo.firstFree === 1 && MahjongBless.data.firstFree_isBuy === 1) {
            this.sp_price.visible = false;
            this.sp_price1.visible = true;
            this.btn_add.disabled = this.btn_reduce.disabled = true;
        } else {
            this.sp_price.visible = true;
            this.sp_price1.visible = false;
            this.btn_add.disabled = this.btn_reduce.disabled = false;
            this.udpate_btn()
        }

        this.ani2 = this.ani2 || new game.Dragon(`cdn/bless_panel/${vo.dragonId}.sk`, 0, 'Idle', true)
        this.addChildAt(this.ani2, 0)
        this.ani2.play('Idle', true)
        this.ani2.x = this.width / 2;
        this.ani2.y = 680;
        this.ani2.scaleX = this.ani2.scaleY = 0.73
    }
    udpate_btn() {
        this.btn_add.disabled = this.__vo.baseMul >= 10;
        this.btn_reduce.disabled = this.__vo.baseMul <= 1;
    }
    async udpate_mul(isAni) {
        if (this.__vo.baseMul < 1) this.__vo.baseMul = 1;
        this.txt_price2.text = this.__vo.baseStoneCost * this.__vo.baseMul;
        __tool.labelParentCenterAndSetXY(this.sp_price, this.btn_buy.width / 2, 5);
        let finalLuckMul = this.__vo.baseLuckMul * this.__vo.baseMul
        this.txt_luck.text = '×' + finalLuckMul + '%'
        this.txt_mul.text = this.__vo.baseMul + '倍'
        // this.txt_gold.text = bigNumberToCH(this.__vo.giveGold * this.__vo.baseMul, 0) + '金币'
        if (finalLuckMul < 500) {
            this.img_luck.skin = 'cdn/bless_panel/img_ys1.png'
            this.txt_luck.color = '#feeb92'
        } else if (finalLuckMul >= 1500) {
            this.img_luck.skin = 'cdn/bless_panel/img_ys3.png'
            this.txt_luck.color = '#bd5a3d'
        } else {
            this.img_luck.skin = 'cdn/bless_panel/img_ys2.png'
            this.txt_luck.color = '#c977c3'
        }

        this.img_luck.alpha = this.txt_luck.alpha = 0;
        this.img_luck.y = this.init_img_luck_y + 100
        this.txt_luck.y = this.init_txt_luck_y + 100
        Laya.Tween.clearAll(this.img_luck)
        Laya.Tween.clearAll(this.txt_luck)
        Laya.Tween.to(this.img_luck, {
            alpha: 1,
            y: this.init_img_luck_y
        }, 400, Laya.Ease.backOut)
        Laya.Tween.to(this.txt_luck, {
            alpha: 1,
            y: this.init_txt_luck_y
        }, 350)
        this.img_light.clipPlay(0)
    }
}
