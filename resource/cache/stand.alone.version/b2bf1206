class S_bless_pay_sure extends Laya.Script {
    onClick(e) {
        // 购买钻石
        let isSelect = this.owner.parent.isSelect;
        if (__data.pay_curValue + this.owner.parent.shopVO.price > __data.pay_maxValue) {
            __tips(__lang.pay_over_max)
            return;
        }
        pay_stone_logic(this.owner.parent.shopVO.goodsId)
