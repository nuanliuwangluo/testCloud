    //返回牌组对象 刻子{srcPosition, code, type = 1} 顺子{srcPosition, code1, code2(吃的牌), code3, type = 2} 明杠{srcPosition, code, type = 3} 暗杠{code, type = 5}
    menQianPaiChuLi: function(type, position, xgsp, isPlay) { //type为门前牌组的类型; position为门前牌组增加的玩家位置; xgsp是否修改手牌
        var player = __data.deskData.roomVo.getPlayer(position)
        var tileGroup = new Object(); //定义一个牌组对象
        if (type < 80) {
            var srcPosition = Math.floor(type / 20);
            var type2 = type - (srcPosition * 20); //真实类型

            srcPosition += 1; //吃/碰/杠的谁的牌(位置) 也就是牌的来源
            tileGroup.srcPosition = srcPosition; //从哪个位置得到牌

            switch (type2) {
                case 1: //刻子
                    var code = ___frame.byte.readByte(__cmmj_replay_data); //碰的牌
                    tileGroup.code = code; //碰的牌
                    tileGroup.type = 1; //类型1
                    tileGroup.comb = tileGroup.type + "," + code + "," + tileGroup.srcPosition
                    tileGroup.cut = 2
                    tileGroup.deleFlod = code
                    if (xgsp) {
                        this.shouPaiZengJian(code, -2, position); //处理手牌增减 code为要增减的牌; count为增减的数量(负数为减少手牌); position为减少哪个位置玩家的手牌
                    }
                    //处理刻子
                    player && xgsp && (isPlay == 1) && __sound.gameSound(MahjongConfig.getMusicPath(HallPlay.curRuleId) + player.sex + "/peng", 2)
                    break;
                case 2: //顺子
                    var codeA = ___frame.byte.readByte(__cmmj_replay_data); //顺子的第一张牌
                    var codeB = codeA + 1; //顺子的第二张牌
                    var codeC = codeA + 2; //顺子的第三张牌
                    var codeX = ___frame.byte.readByte(__cmmj_replay_data); //吃的牌
                    var codeY1 = 0; //需要在手牌中移除的第一张牌
                    var codeY2 = 0; //需要在手牌中移除的第二张牌

                    tileGroup.deleFlod = codeX //弃牌堆删除

                    if (codeA == codeX) {
                        codeY1 = codeA + 1;
                        codeY2 = codeA + 2;
                    } else if (codeA + 1 == codeX) {
                        codeY1 = codeA;
                        codeY2 = codeA + 2;
                    } else {
                        codeY1 = codeA;
                        codeY2 = codeA + 1;
                    }

                    tileGroup.code1 = codeY1; //显示顺子的第一张牌
                    tileGroup.code2 = codeX; //显示顺子的第二张牌
                    tileGroup.code3 = codeY2; //显示顺子的第三张牌
                    tileGroup.type = 2; //顺子类型
                    tileGroup.cut = 2
                    tileGroup.comb = tileGroup.type + "," + codeA + "," + codeX + "," + tileGroup.srcPosition
                    if (xgsp) {
                        this.shouPaiZengJian(codeY1, -1, position); //处理手牌增减 code为要增减的牌; count为增减的数量(负数为减少手牌); position为减少哪个位置玩家的手牌
                        this.shouPaiZengJian(codeY2, -1, position); //处理手牌增减 code为要增减的牌; count为增减的数量(负数为减少手牌); position为减少哪个位置玩家的手牌
                    }
                    //处理顺子
                    player && xgsp && (isPlay == 1) && __sound.gameSound(MahjongConfig.getMusicPath(HallPlay.curRuleId) + player.sex + "/chi", 2)
                    break;
                case 3: //普通杠子
                    var code = ___frame.byte.readByte(__cmmj_replay_data); //杠的牌
                    tileGroup.code = code; //杠的牌
                    tileGroup.type = 5; //明杠类型
                    tileGroup.cut = 3
                    tileGroup.comb = tileGroup.type + "," + code + "," + tileGroup.srcPosition

                    tileGroup.deleFlod = code //弃牌堆删除

                    if (xgsp) {
                        this.shouPaiZengJian(code, -3, position); //处理手牌增减 code为要增减的牌; count为增减的数量(负数为减少手牌); position为减少哪个位置玩家的手牌
                    }
                    //处理杠子
                    player && xgsp && (isPlay == 1) && __sound.gameSound(MahjongConfig.getMusicPath(HallPlay.curRuleId) + player.sex + "/gang", 2)
                    break;
                case 4: //杠门前杠子 门前杠子的srcPosition代表原来的刻子是碰的哪个位置的玩家
                    var code = ___frame.byte.readByte(__cmmj_replay_data); //杠的牌
                    tileGroup.code = code; //杠的牌
                    tileGroup.type = 88; //明杠类型 这里不是写错了 而是 3与4代表的牌组类型时一样的 只是在处理扣手牌时不同
                    tileGroup.cut = 1
                    tileGroup.comb = tileGroup.type + "," + code + "," + tileGroup.srcPosition
                    if (xgsp) {
                        this.shouPaiZengJian(code, -1, position); //处理手牌增减 code为要增减的牌; count为增减的数量(负数为减少手牌); position为减少哪个位置玩家的手牌
                    }
                    //处理杠子 记得删掉门前与code相同的刻子
                    player && xgsp && (isPlay == 1) && __sound.gameSound(MahjongConfig.getMusicPath(HallPlay.curRuleId) + player.sex + "/gang", 2)
                    break;
                case 5: //门前有个两张一样的牌
                    var code = ___frame.byte.readByte(__cmmj_replay_data); //粘的牌
                    tileGroup.code = code; //粘的牌
                    tileGroup.type = 3; //粘类型
                    tileGroup.comb = tileGroup.type + "," + code + "," + tileGroup.srcPosition
                    tileGroup.deleFlod = code //弃牌堆删除
                    if (xgsp) {
                        this.shouPaiZengJian(code, -1, position); //处理手牌增减 code为要增减的牌; count为增减的数量(负数为减少手牌); position为减少哪个位置玩家的手牌
                    }
                    break;
            }


        } else {

            //没有从其他人那里得到牌的类型牌组没有srcPosition属性
            switch (type) {
                case 80: //暗杠
                    var code = ___frame.byte.readByte(__cmmj_replay_data); //杠的牌
                    tileGroup.code = code; //杠的牌
                    tileGroup.type = 5; //暗杠类型5
                    tileGroup.comb = tileGroup.type + "," + code + "," + "5"
                    tileGroup.cut = 4
                    if (xgsp) {
                        this.shouPaiZengJian(code, -4, position); //处理手牌增减 code为要增减的牌; count为增减的数量(负数为减少手牌); position为减少哪个位置玩家的手牌
                    }
                    //处理杠子
                    player && xgsp && (isPlay == 1) && __sound.gameSound(MahjongConfig.getMusicPath(HallPlay.curRuleId) + player.sex + "/gang", 2)
                    break;
                case 81: //亮掌
                    var code = ___frame.byte.readByte(__cmmj_replay_data); //亮掌的牌
                    tileGroup.code = code; //亮掌的牌
                    tileGroup.type = 81; //亮掌类型
                    tileGroup.comb = tileGroup.type + "," + code + "," + __data.deskData.roomVo.recordViewerID
                    if (xgsp) {
                        this.shouPaiZengJian(code, -2, position); //处理手牌增减 code为要增减的牌; count为增减的数量(负数为减少手牌); position为减少哪个位置玩家的手牌
                    }
                    player && xgsp && (isPlay == 1) && __sound.gameSound(MahjongConfig.getMusicPath(HallPlay.curRuleId) + player.sex + "/fz_liangzhang")
                    break;
                case 82: //亮喜
                    tileGroup.code1 = ___frame.byte.readByte(__cmmj_replay_data); //亮喜的牌
                    tileGroup.code2 = ___frame.byte.readByte(__cmmj_replay_data); //亮喜的牌
                    tileGroup.code3 = ___frame.byte.readByte(__cmmj_replay_data); //亮喜的牌
                    tileGroup.type = 82; //亮喜类型
                    tileGroup.comb = tileGroup.type + "," + tileGroup.code1 + "," + tileGroup.code2 + "," + tileGroup.code3
                    if (xgsp) {
                        this.shouPaiZengJian(tileGroup.code1, -1, position); //处理手牌增减 code为要增减的牌; count为增减的数量(负数为减少手牌); position为减少哪个位置玩家的手牌
                        this.shouPaiZengJian(tileGroup.code2, -1, position); //处理手牌增减 code为要增减的牌; count为增减的数量(负数为减少手牌); position为减少哪个位置玩家的手牌
                        this.shouPaiZengJian(tileGroup.code3, -1, position); //处理手牌增减 code为要增减的牌; count为增减的数量(负数为减少手牌); position为减少哪个位置玩家的手牌
                    }
                    player && xgsp && (isPlay == 1) && __sound.gameSound(MahjongConfig.getMusicPath(HallPlay.curRuleId) + player.sex + "/fz_liangxi")
                    break;
            }
        }

        game.cb.event(__eh + 'remove_video_operation')
        return tileGroup;
    }
