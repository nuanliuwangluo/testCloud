    shouPaiZengJian: function(code, count, position) { //处理手牌增减 code为要增减的牌; count为增减的数量(负数为减少手牌); position为减少哪个位置玩家的手牌
        //处理手牌增减
        if (__data.deskData.roomVo.isRecordPlaying) {
            //在手牌中增加count张code
            var vo = __data.deskData.roomVo.getPlayer(__data.deskData.roomVo.recordViewerID)
            if (vo && position == vo.position) { //////////////////////////////////////////////////////////////////////
                //在手牌中增加count张code
                //增加手牌数量
                if (count > 0) {
                    vo.handValue += (vo.handValue == "") ? code : "," + code
                } else if (count < 0) { //手牌数量减少
                    var handArr = vo.handValue.split(",")
                    var index
                    for (var i = 0; i < Math.abs(count); i++) {
                        index = handArr.indexOf(code.toString())
                        if (index == -1) continue
                        handArr.splice(index, 1)
                    }
                    vo.handValue = handArr.join(",")
                }
            } else {
                //在手牌中增加count张code
                //增加手牌数量
                var vo = __data.deskData.roomVo.getPlayer(position)
                if (vo && count > 0) {
                    vo.handValue += (vo.handValue == "") ? code : "," + code
                } else if (vo && count < 0) { //手牌数量减少
                    var handArr = vo.handValue.split(",")
                    var index
                    for (var i = 0; i < Math.abs(count); i++) {
                        index = handArr.indexOf(code.toString())
                        if (index == -1) continue
                        handArr.splice(index, 1)
                    }
                    vo.handValue = handArr.join(",")
                }
            }

            game.cb.event(__eh + "update_all_handlist_card")
        } else {
            var vo = __data.deskData.roomVo.getPlayer(__data.deskData.roomVo.recordViewerID)
            if (vo && position == vo.position) { //////////////////////////////////////////////////////////////////////
                //在手牌中增加count张code

                //增加手牌数量
                if (count > 0) {
                    vo.handValue += (vo.handValue == "") ? code : "," + code
                } else if (count < 0) { //手牌数量减少
                    var handArr = vo.handValue.split(",")
                    var index
                    for (var i = 0; i < Math.abs(count); i++) {
                        index = handArr.indexOf(code.toString())
                        if (index == -1) continue
                        handArr.splice(index, 1)
                    }
                    vo.handValue = handArr.join(",")
                }
            } else {
                var vo = __data.deskData.roomVo.getPlayer(position)
