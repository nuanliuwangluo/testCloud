class S_update_value extends Laya.Script {
    onAwake() {
        this.text_value = 0;
    }
    onEnable() {
        this.update();
        game.cb.on(this.eventName, this, this.update)
    }
    onDisable() {
        game.cb.off(this.eventName, this, this.update)
        this.clearAwait && this.clearAwait();
    }
    async update() {
        let lastValue = S_update_value[`last_${this.valueName}_value`]
        lastValue = String(lastValue)
        let curValue = __data[this.valueName];
        curValue = String(curValue)
        if (lastValue == -1 || curValue == lastValue) {
            let ns = bigNumberToCH(curValue)
            this.owner.text = ns
        } else if (__bigNumberCal.gt(curValue, lastValue)) {
            let startv = 0
            let endv = 0
            let suffix = ''
            for (let index = bigNumberLengthConfig.length - 1; index >= 0; index--) {
                const e = bigNumberLengthConfig[index];
                if (lastValue.length >= e.len && curValue.length >= e.len) {
                    if (e.suffix) {
                        startv = __bigNumberCal.divide(lastValue, e.divide, 2)
                        endv = __bigNumberCal.divide(curValue, e.divide, 2)
                    } else {
                        startv = __bigNumberCal.divide(lastValue, e.divide, 2)
                        endv = __bigNumberCal.divide(curValue, e.divide, 2)
                    }
                    suffix = e.suffix
                    break;
                }
            };

            let start_ob = {
                v: Number(startv)
            };
            let t = Laya.Tween.to(start_ob, {
                v: Number(endv)
            }, 200)
            t.update = new Laya.Handler(this, function () {
                if (suffix.length) this.owner.text = Number(start_ob.v).toFixed(1) + suffix
                else this.owner.text = Math.floor(start_ob.v) + suffix
            })
            // 如果万-亿 缓动 最后需要修正后缀
            await __tool.await(250, this);

            let ns = bigNumberToCH(curValue)
            this.owner.text = ns
        } else {
            let ns = bigNumberToCH(curValue)
            this.owner.text = ns
        }
        S_update_value[`last_${this.valueName}_value`] = curValue
    }
}

