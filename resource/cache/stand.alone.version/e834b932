class S_show_garden extends Laya.Script {
    init(img_tips1) {
        this.img_tips1 = img_tips1;
    }
    onAwake() {
        this.img_tips1.iy = this.img_tips1.y;
    }
    onClick() {
        miniApi.trackEvent('Mj_UIClick', { 'Mj_ClickScene': '雀神花园图标' });
        let a = game.scene.get(Hall)
        let b = null;
        if (a && a.parent) {
            __data.lastSceneQueue.push(__showScene.show_hall)
        } else {
            __data.lastSceneQueue.push(__showScene.show_mjSmallGame)
        }
        __showScene.show_garden(true)
    }
    onEnable() {
        this.tweening = false;
        gtool.query([15008], 0) // 货币
        gtool.query([15009], 1) // 任务id
        gtool.query([15012], 1) // 章节奖励
        game.cb.on('update_star', this, this.update_red)
        game.cb.on('update_garden_task_data', this, this.update_red)
        this.update_red();
    }
    onDisable() {
        game.cb.off('update_star', this, this.update_red)
        game.cb.off('update_garden_task_data', this, this.update_red)
        Laya.Tween.clearAll(this.img_tips1)
        this.clearAwait && this.clearAwait()
        this.tweening = false;
    }
    update_red() {
        let img_red = this.owner.getChildByName('img_red');
        img_red = img_red || {}; // 兼容小游戏界面 因为那个界面没有红点
        img_red.visible = __data.garden.task.isRedPoint;
        this.img_tips1.visible = img_red.visible
        if (this.img_tips1.visible) {
            this.img_tips1.scaleX = 1
            this.img_tips1.scaleY = 1
            this.addTween()
        } else {
            Laya.Tween.clearAll(this.img_tips1)
            this.clearAwait && this.clearAwait()
            this.tweening = false;
        }
    }
    async addTween() {
        if (this.tweening) return
        this.tweening = true
        this.img_tips1.y = this.img_tips1.iy;

        await __tool.tweenp(this.img_tips1, { y: this.img_tips1.iy - 5 }, 500)
        await __tool.tweenp(this.img_tips1, { y: this.img_tips1.iy + 10 }, 1000)
        await __tool.tweenp(this.img_tips1, { y: this.img_tips1.iy }, 500)

        this.tweening = false;
        this.addTween()
    }
}
