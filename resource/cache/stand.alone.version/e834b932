class S_hall_tween_star extends Laya.Script {
    onEnable() {
        this.owner.text = __data.garden.star + '/' + __data.garden.maxStar
        this.star_v = __data.garden.star
        game.cb.on('update_star', this, this.update_star)
    }
    onDisable() {
        game.cb.off('update_star', this, this.update_star)
    }
    update_star() {
        let start_ob = {
            v: Number(this.star_v)
        };
        let t = Laya.Tween.to(start_ob, {
            v: Number(__data.garden.star)
        }, 200)
        t.update = new Laya.Handler(this, function () {
            this.owner.text = Math.floor(start_ob.v) + '/' + __data.garden.maxStar
        })
    }
}