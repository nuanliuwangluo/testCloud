// 广告时间
class S_hall_adTime extends Laya.Script {
    onClick() {
        __showScene.show_gameMain_ad();
        miniApi.trackEvent('Mj_UIExposure', { 'Mj_ExposureScene': '广告时间界面' })
    }
    onEnable() {
        AdData.send(1)
        this.update_ad()
        this.owner.visible = false
        game.cb.on('update_ad', this, this.update_ad)
        this.update_video_ready({ adUnitId: 'adunit-24f34675f1830a6c', isSuccess: 1 })
        Laya.timer.loop(1000, this, this.updateCountdown)
    }
    onDisable() {
        game.cb.off('update_ad', this, this.update_ad)
        Laya.timer.clearAll(this)
    }
    updateCountdown() {
        let ssm = new Date().setHours(0, 0, 0, 0) - Date.now() + 24 * 3600 * 1000
        if (ssm <= 0) {
            this.owner.visible = false
            game.cb.event('update_ad')
        }
    }
    update_video_ready(r) {
        if (r.adUnitId == 'adunit-24f34675f1830a6c') {
            GameMainAd.videoR = r;
            // this.owner.visible = r && r.isSuccess;
        }
        this.tt()
    }
    update_ad() {
        AdData.testAdActive()
        this.tt()
    }
    tt() {
        this.owner.visible = false;
        if (AdData.isActive) {
            if (GameMainAd.videoR && GameMainAd.videoR.isSuccess) {
                this.owner.visible = true;
                this.owner.getChildByName('img_red').visible = (AdData.time > 0)
            }
        }
        game.cb.event('update_hall_reward_bg_ad')
    }
    onMouseDown(e) {
        e.stopPropagation()
    }
}

class S_hall_freeVip extends Laya.Script {
    onClick() {
