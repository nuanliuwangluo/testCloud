        if (miniApi.clientType == 'app') {
            this.btn_redPacket.visible = false;
            this.btn_chuanqiReward.visible = false;
        }
        this.btn_service.visible = miniApi.clientType != 'wx';
        this.btn_exchangeCode.visible = miniApi.clientType == 'wx' || miniApi.clientType == 'web';
        let a = [this.btn_bag, this.btn_complaint, this.btn_service, this.btn_notice, this.btn_set];
        let w = 20
        for (let index = 0, length = a.length; index < length; index++) {
            if (!a[index].visible) continue;
            a[index].x = w + a[index].width / 2;
            w += a[index].width + 20
        };
        this.img_more.width = w;
    }
}
let hallTestShowPanel = async () => {
    try {
        await __tool.await(150) // 有的面板关闭按钮式btn_close 有100毫秒缓动消失 所以这里也增加延迟

        let canBombbox = () => {
            if (__showScene.sceneType != 'hall') return false;
            let a = game.scene.layer['panel'].c.numChildren;
            let b = game.scene.layer['panel0'].c.numChildren;
            // console.log('a+b', a + b);
            return a + b == 0 ? true : false;
        }
        if (!canBombbox()) return
        if (!__data.newPlayerGift.isReceive) {
            // 如果显示新人大礼包 不检测 hallTestShowPanel
            game.cb.event('hall_play_show_hand')
            return;
        }
        if (!__data.myCityId) {
            game.cb.event('hall_play_show_hand')
            return;
        }

        if (Hall.bombbox_count <= 0) {
            Hall.bombbox_count = 0;
            Hall.test_show_free_panel = 0;
            Hall.test_show_pay_panel = 0;
            Hall.test_show_other_panel = 0;
            Hall.testEndCount = 0;
            return
        }
        // 3.1.20版本暂时关闭惊喜暴击功能
        // let b = miniApi.getItem(__data.uid + ':show_panel_surpriseCrit_loginTime')
        // if (!b) {
        //     b = '[]'
        // }
        // let timeKey = new Date().toDateString();
        // b = JSON.parse(b);
        // let b1 = b.find((e) => {
        //     return e.timeKey == timeKey
        // })
        // if (!b1) {
        //     b.push({ timeKey: new Date().toDateString(), value: 0 })
        //     b = b.slice(-3)
        //     miniApi.setItem(__data.uid + ':show_panel_surpriseCrit_loginTime', JSON.stringify(b))
        // }

        let uidDateString = __data.uid + ':' + new Date().toDateString()
        let a;
        let test_free = async () => {
            if (Hall.test_show_free_panel == 1) {
                if (!canBombbox()) return
                a = miniApi.getItem(__data.uid + ':' + new Date().toDateString() + ':show_panel_winLoseGuide_go')
                if (a != 1) {
                    // 没有点击 输赢界面立即前往
                    a = miniApi.getItem(uidDateString + ':show_panel_winLoseGuideType')
                    // 上次显示 输赢类型
                    // 如果这次需要显示输赢
                    if (GameMainWinLoseGuide.showType) {
                        if (!a) {
                            __showScene.show_gameMain_winLoseGuide()
                            Hall.bombbox_count--;
                            Hall.test_show_free_panel = 0
                            return
                        } else if (a == GameMainWinLoseGuide.showType) {
                            __showScene.show_gameMain_winLoseGuide()
                            Hall.bombbox_count--;
                            Hall.test_show_free_panel = 0
                            return
                        }
                    }
                }

                if (!canBombbox()) return
                await __data.returnPlayerGift.send(1)
                if (__data.returnPlayerGift.isHaveGift == 1) {
                    if (!canBombbox()) return
                    Hall.bombbox_count--;
                    __showScene.show_newPlayerGift('returnPlayer')
                    Hall.test_show_free_panel = 0
                    return
                }

                if (miniApi.isIOS && miniApi.clientType == 'wx') {
                    let d12 = new Date();
                    let b3 = miniApi.getItem(__data.uid + ":" + __tool.getWeeks(d12) + ':iosSpecailBombbox_week')
                    if (b3 != 1) {
                        if (!canBombbox()) return
                        // IOS能支付修改
                        let isCP = await miniApi.isCanPay()
                        if (isCP) {
                            if (!canBombbox()) return
                            await game.server.send(16007)
                            if (__data.game_count_total > 3) {
                                if (!canBombbox()) return
                                __showScene.show_iosSpecailBombbox()
                                Hall.bombbox_count--;
                                Hall.test_show_free_panel = 0
                                return
                            }
                        }
                    }
                }

                a = miniApi.getItem(uidDateString + ':show_panel_helpGold')
                if (!a) {
                    if (!canBombbox()) return
                    await game.server.send(2211)
                    if (__data.helpGold_count > 0 && __bigNumberCal.lt(__data.gold, __data.d_match.showReliefConditionGold)) {
                        if (!canBombbox()) return
                        Hall.bombbox_count--;
                        __showScene.show_gameMain_relief()
                        Hall.test_show_free_panel = 0
                        return
                    }
                }

                a = miniApi.getItem(uidDateString + ':show_panel_seven')
                if (__data.seven.isRedPoint && a != 1 && __data.seven.seven_hasReceiveNum >= 1) {
                    if (!canBombbox()) return
                    Hall.bombbox_count--;
                    __showScene.show_seven()
                    Hall.test_show_free_panel = 0
                    return
                }
                if (miniApi.clientType != 'app') {
                    a = miniApi.getItem(uidDateString + ':show_panel_redPacket')
                    if (a != 1) {
                        if (!canBombbox()) return
                        await __data.redPacket.send(1)
                        if (__data.redPacket.isRedPoint) {
                            if (!canBombbox()) return
                            Hall.bombbox_count--;
                            __showScene.show_redPacket();
                            Hall.test_show_free_panel = 0
                            return
                        }
                    }
                }

                a = miniApi.getItem(uidDateString + ':show_panel_dailyLogin')
                if (a != 1) {
                    if (!canBombbox()) return
                    await __data.dailyLogin.send(1)
                    if (__data.dailyLogin.isRedPoint) {
                        if (!canBombbox()) return
                        Hall.bombbox_count--;
                        __showScene.show_dailyLogin()
                        Hall.test_show_free_panel = 0
                        return
                    }
                }

                if (miniApi.clientType != 'app') {
                    a = miniApi.getItem(uidDateString + ':show_panel_chuanqiReward')
                    if (a != 1) {
                        if (!canBombbox()) return
                        await __data.chuanqi.reward.send(1)
                        if (__data.chuanqi.isRedPoint) {
                            if (!canBombbox()) return
                            Hall.bombbox_count--;
                            __showScene.show_chuanqiReward()
                            Hall.test_show_free_panel = 0
                            return
                        }
                    }
                }

                if (miniApi.clientType != 'app') {
                    a = miniApi.getItem(uidDateString + ':show_panel_freeVip')
                    if (!__data.vip.isReceiveFreeVip && a != 1) {
                        if (Date.now() - parseInt(__data.Mj_registeDateMs) < 24 * 3600 * 1000) {
                            if (!canBombbox()) return
                            Hall.test_show_free_panel = 0;
                            Hall.bombbox_count--;
                            __showScene.show_freeVip();
                            return
                        }
