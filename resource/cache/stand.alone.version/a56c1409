class MM_main_scene extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_mjMatch/MM_main_scene',
        })
        this.btn_start.addComponent(S_mm_start)
        this.btn_start.addComponent(S_mm_show_gameCount)

        this.txt_level = new game.NumText(url_mm_sm_game)
        this.txt_level.x = this.img_level_bg.width / 2
        this.txt_level.y = 25
        this.txt_level.align = 'center'
        this.img_level_bg.addChild(this.txt_level)
    }
    added() {
        mm_verify_starting = false;
        this.updateData()
        game.cb.on('update_mm_todayFreeCount', this, this.updateData)
    }
    onDisable() {
        game.cb.off('update_mm_todayFreeCount', this, this.updateData)
    }
    updateData() {
        this.txt_level.text = `第${__data.mjSmallGame.level}关`
        this.txt_freeCount.text = `今日免费${__data.mjSmallGame.todayFreeCount}/${__data.mjSmallGame.maxFreeCount}次`;
    }
    onDisable() {
    }
}

