class GameMainRecommend extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_recommend',
            layer: 'panel'
        })
        this.btn_close.addComponent(S_click_close_remove_parent)
        this.btn_recommend.addComponent(S_show_wx_recommend)
    }
    added(callback) {
        this.callback = callback;
        miniApi.setItem(__data.uid + ':showRecommendDate', Date.now())
        miniApi.trackEvent('Mj_UIExposure', { 'Mj_ExposureScene': '推荐界面' })
    }
    clickMask() {
    }
    onDisable() {
        ResUtils.clearTextureRes(['cdn.recommend'])
        ResultPanelManager.show();
    }
}
class S_show_wx_recommend extends Laya.Script {
    onClick(e) {
        let c = this.owner.parent.callback
        miniApi.recommend((e) => {
            c && c(e)
            if (e) {
                game.server.send(17003);
                game.scene.remove(GameMainRecommend)
            }
        })
    }
}