    hall_play_show_hand() {
        if (__data.matchCount == 0 && __data.myCityId) {
            let of_item;
            let arrData = excelUtils.getModelByCityIdRuleId(HallPlay.lastCityId, HallPlay.curRuleId)
            if (!arrData) return;
            for (let index = 0; index < arrData.length; index++) {
                const e = arrData[index];
                if (e.maxGold != -1) {
                    if (__bigNumberCal.gte(__data.gold, e.minGold) && __bigNumberCal.lte(__data.gold, e.maxGold)) {
                        of_item = this['match_' + e.matchModelType]
                        break;
                    }
                } else if (__bigNumberCal.gte(__data.gold, e.minGold)) {
                    of_item = this['match_' + e.matchModelType]
                    break;
                }
            };

            if (of_item) {
                this.img_hand.visible = true;
                this.img_hand.clipPlay()
                this.img_hand.x = of_item.x - 10 // + of_item.width / 2 + 80
                // this.img_hand.y = of_item.y - this.img_hand.height / 2
            }
        }
    }
    complete() { }
    updatePlayerNum(d) {
        // let key1 = HallPlay.lastCityId + '-' + HallPlay.curRuleId
        let key1 = HallPlay.curRuleId
        this.hashCityIdPlayeNum[key1] = this.hashCityIdPlayeNum[key1] || {
            playerNumRange1: __tool.randomRange(2000, 2100),
            playerNumRange2: __tool.randomRange(1100, 1200),
            playerNumRange3: __tool.randomRange(700, 800),
            playerNumRange4: __tool.randomRange(400, 500),
            playerNumRange5: __tool.randomRange(80, 120),
            playerNumRange6: __tool.randomRange(10, 30),
        }
        for (let index = 0, length = d.length; index < length; index++) {
            const e = d[index];
            let a = this.hashCityIdPlayeNum[key1][`playerNumRange${e.type}`];
            this[`match_${e.type}`].updatePeopleNum(e.playerNum + a)
        };
