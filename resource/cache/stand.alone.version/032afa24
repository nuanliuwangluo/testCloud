    testShowGuide(isClick) {
        // if (HallPlay.curRuleId == -2 || HallPlay.curRuleId == -3) {
        if (HallPlay.curRuleId == -3) {
            let a = miniApi.getItem(__data.uid + ':show_guideDazhong:' + HallPlay.curRuleId)
            if (a != 1) {
                miniApi.setItem(__data.uid + ':show_guideDazhong:' + HallPlay.curRuleId, 1)
                __showScene.show_guide_rule(isClick)
                return
            }
        }
        this.hall_play_show_hand()
    }
    static get lastCityId() {
        return this._lastCityId || 0;
    }
    static set lastCityId(value) {
        if (!__data.excelConfig.hashCityIdVO[value]) {
            try {
                throw new Error('lastCityId error' + value)
            } catch (error) {
                value = -1;
                miniApi.uploadError(error.stack)
            }
        }
        // @Test 测试用  指定城市
        value = __tool.getHttpParams('cityId') || value;
        this._lastCityId = value;
        __data.gameId.curId = value;
        window.__eh = MahjongConfig.getName(this.lastCityId, this.curRuleId);
        game.cb.event('updateLvInfo');
        miniApi.setItem(__data.uid + '_near_play', value)
    }

    static get curRuleId() {
        return this._curRuleId;
    }

    static set curRuleId(value) {
        // @Test 测试用  指定玩法
        value = __tool.getHttpParams('ruleId') || value;
        this._curRuleId = value;
        window.__eh = MahjongConfig.getName(this.lastCityId, this.curRuleId);
    }
