class S_update_seaon_title extends Laya.Script {
    onEnable() {
        this.update_hall_play_season_time()
        game.cb.on('update_hall_play_season_time', this, this.update_hall_play_season_time)
    }
    onDisable() {
        game.cb.off('update_hall_play_season_time', this, this.update_hall_play_season_time)
    }
    update_hall_play_season_time() {
        this.owner.visible = false
        for (const key in __data.seasonRecord) {
            let e = __data.seasonRecord[key];
            if (e.isIng) {
                this.owner.visible = true

                let sp = this.owner.getChildByName('sp_season_title')
                let y1 = e.year.toString()
                let w = 0
                for (let index = 0, length = y1.length; index < length; index++) {
                    let an = y1.charAt(index)
                    let b = sp.getChildByName('i' + (index + 1))
                    b.skin = GameMainSeasonStart.fontUrl[an]
                    b.x = w;
                    w = b.x + b.width;
                };
                sp.getChildByName('i5').skin = GameMainSeasonStart.fontUrl[GameMainSeasonStart.seasonIdToText[e.season]]

                this.owner.getChildByName('txt_time').text = GameMainSeasonRecordItem.getTime(e.startTimeMs, e.endTimeMs)
                break;
            }
        }
    }
}