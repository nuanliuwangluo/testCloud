    updateMathInfo(isClick) {
        let arrData = excelUtils.getModelByCityIdRuleId(HallPlay.lastCityId, HallPlay.curRuleId)
        if (!arrData) return;
        Laya.Tween.clearAll(this.match_1)
        Laya.Tween.clearAll(this.match_2)
        Laya.Tween.clearAll(this.match_3)
        Laya.Tween.clearAll(this.match_4)

        for (let index = 0, length = arrData.length; index < length; index++) {
            let e = arrData[index];
            // this[`match_${e.matchModelType}`].txt_cupAdd.text = `+${Math.floor(Math.random() * 100)}%`;
            let a1 = bigNumberToCH(e.bottomScore)
            let matchItem = this[`match_${e.matchModelType}`]
            matchItem.txt_bottomScore.text = a1
            matchItem.txt_cost.text = e.maxGold > 0 ? `${bigNumberToCH(e.minGold)}-${bigNumberToCH(e.maxGold)}` : `${bigNumberToCH(e.minGold)}以上`
            matchItem.alpha = 1;
            if (isClick) {
                matchItem.iy = matchItem.iy || matchItem.y
                // matchItem.alpha = 0
                matchItem.y = matchItem.iy + 50;
                Laya.Tween.to(matchItem, { alpha: 1, y: matchItem.iy }, 200, null, null, 0)
            }
        };
        game.server.send(3329, HallPlay.curRuleId)
        // 请求人数什么的服务
        game.server.send(2407, HallPlay.lastCityId, 1)
    }

    updateRuleItem(cityId) {
        this.scene_rule1.visible = false
        this.scene_rule2.visible = false
        this.scene_rule3.visible = false
        this.scene_rule4.visible = false
        let ud = excelUtils.getPlayOnOff(HallPlay.lastCityId);

        for (let index = 0, length = ud.allPlay.length; index < length; index++) {
            const e23 = ud.allPlay[index];

            let e = this[`scene_rule${index + 1}`]
            e.visible = true;
            e._ruleIndex = index;
            e.clearRuleId();
            if (ud.offPlayId.includes(e23.playId)) {
                e.offRuleId = e23.playId
            } else {
                e.onRuleId = e23.playId
            }
            e.updateLabel(e23.playName, e23.playId)
            e.updateImgHot(ud.defaultPlayId)
        };
    }
    updateRuleIndexDefault() {
        // 兼容玩法id算法 如果没有玩法id 就计算 如果有 就pass
        let getkey1 = __data.uid + `:cityId:${HallPlay.lastCityId}-ruleId`
        let youLastSelectRuleId = miniApi.getItem(getkey1)
        let ud = excelUtils.getPlayOnOff(HallPlay.lastCityId);
        try {
            if (!Number.isFinite(parseInt(youLastSelectRuleId))) {
                let getkey = __data.uid + `:cityId:${HallPlay.lastCityId}-ruleIndex`
                let index = miniApi.getItem(getkey)
                if (parseInt(index) >= 0) {
                    // 如果你用上个版本缓存ruleIndex有值 那么重进进行计算获得ruleId;
                    if (ud.onPlayId[index]) {
                        // 再开启列表范围内
                        youLastSelectRuleId = ud.onPlayId[index];
                    } else {
                        // 再开启列表范围外 就是大众经济 提示大众竞技关闭 选择改为红中玩法
                        youLastSelectRuleId = -3;
                        let g1 = __data.uid + ':showOfflineTips:-2'
                        let g2 = miniApi.getItem(g1)
                        if (g2 != 1) {
                            game.scene.add(HallPlay_offlineTips, [-2])
                            miniApi.setItem(g1, 1)
                        }
                    }
                } else {
                    youLastSelectRuleId = ud.defaultPlayId;
                }
                miniApi.setItem(getkey1, youLastSelectRuleId);
            }
        } catch (error) {
        }

        // 检测玩法关闭
        // 讷河 17   104
        // 芜湖 167  252
        // 同江 44   129
        // 汤原 43   21
        // 抚远 77   162
        let ahq = {
            104: 17,
            252: 167,
            129: 44,
            21: 43,
            162: 77,
        }
        let arr1 = Object.keys(ahq)
        if (arr1.includes(String(HallPlay.lastCityId))) {
            let rid = ahq[HallPlay.lastCityId]
            // 检测行为动作通过 没有选区动作 or 新人领取动作
            let a = miniApi.getItem(__data.uid + ':offline_action_change_city')
            // let b = miniApi.getItem(__data.uid + ':offline_action_receive_newPlayer_gift')
            if (a != '1') {
                let g1 = __data.uid + ':showOfflineTips:' + rid
                let g2 = miniApi.getItem(g1)
                if (g2 != 1) {
                    game.scene.add(HallPlay_offlineTips, [rid])
                    miniApi.setItem(g1, 1)
                }
            }
            // HallPlay_offlineTips.action_receive_newPlayer_gift = null;
            // HallPlay_offlineTips.action_change_city = null;
            // if (youLastSelectRuleId == rid) {
            //     if (rid == 167) {
            //         youLastSelectRuleId = -3;
            //     } else {
            //         youLastSelectRuleId = -1;
            //     }
            // }
        }

        // 如果选择玩法不在开启列表改成默认玩法
        if (!ud.onPlayId.includes(String(youLastSelectRuleId))) {
            youLastSelectRuleId = ud.defaultPlayId;
            miniApi.setItem(getkey1, youLastSelectRuleId);
        }

        HallPlay.curRuleId = youLastSelectRuleId;
        game.cb.event('update_hallPlay_ruleItemView', [null])
    }
    updateInfo1001(isClick) {
        this.txt_play.text = __data.excelConfig.hashPlayIdDes[HallPlay.curRuleId];
        this.cal_txt_play_scroll()
        this.updateMathInfo(isClick)
        this.testShowGuide(isClick)
    }
    cal_txt_play_scroll() {
        this.clearAwait && this.clearAwait()
        Laya.timer.clear(this, this.update_txt_scroll)
        this.txt_play.scrollX = 0;
        if (this.txt_play.textWidth > this.txt_play.width) {
            Laya.timer.loop(1000 / 60, this, this.update_txt_scroll)
        }
    }
    async update_txt_scroll() {
        this.txt_play.scrollX += 2
        if (this.txt_play.scrollX >= this.txt_play.textWidth - this.txt_play.width) {
            Laya.timer.clear(this, this.update_txt_scroll)
            await __tool.await(2000, this)
            this.txt_play.scrollX = 0
            Laya.timer.loop(1000 / 60, this, this.update_txt_scroll)
        }
    }
    // cal_ruleIndex(e) {
    // let ud = excelUtils.getPlayOnOff(HallPlay.lastCityId)
    // let b = ud.allPlay.filter((e) => {
    //     return ud.onPlayId.includes(e.playId)
    // })
    // let c = b.map((e) => {
