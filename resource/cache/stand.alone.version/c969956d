class DeskDissolveCheck {
    static async check() {
        // 不在房间内 不处理
        if(!MahjongRoomUpdateUtils.isInDesk){ return; }

        // 正在发起解散
        if (__data.deskData.roomVo.roomStatus == 1) {
            game.scene.add(DeskDissolve);

            let content = [];
            if (__data.deskData.roomVo.promoter) content.push(`${__data.deskData.roomVo.promoter}_1`)

            let agreeNumbers = 0;
            for (let i = 1; i <= 4; i++) {
                var vo = __data.deskData.roomVo.getPlayer(i);
                // 同意
                if (vo && vo.dis_status == 1) { agreeNumbers++; }
                if (!vo || vo.id == __data.deskData.roomVo.promoter) continue;
                content.push(`${vo.id}_${vo.dis_status}`);
            }

            let info = content.join(',');
            game.cb.event(__eh + 'update_room_dissolve_list', [null, info]);

            // 全部同意了
            if (agreeNumbers == __data.deskData.roomVo.roomPlayer) {
                __data.deskData.roomVo.dissolved = this.isAllAgree();
                game.scene.remove(DeskDissolve);
            }
        }else{
            __data.deskData.roomVo.dissolved = this.isAllAgree();
        }
    }


    static isAllAgree(){
        let agreeNumbers = 0;
        for (let i = 1; i <= 4; i++) {
            var vo = __data.deskData.roomVo.getPlayer(i);
            // 同意
            if (vo && vo.dis_status == 1) { agreeNumbers++; }
        }
        // 全部同意了
        if (agreeNumbers == __data.deskData.roomVo.roomPlayer) {
            return true;
        }
    }

    static close() {
        game.scene.remove(DeskDissolve);
        __data.deskData.roomVo.roomStatus = 0;
        __data.deskData.roomVo.promoter = 0;
        for (let i = 1; i <= 4; i++) {
            var vo = __data.deskData.roomVo.getPlayer(i);
            if (!vo) continue;
            delete vo.dis_status;
        }
    }
}

