class DeskCommonRule extends game.ModuleBase {
    constructor() {
        super({
            map: 'desk_common/DeskCommonRule',
            "layer": 'panel',
            "offx": 0,
            "offy": 0,
            "centerx": true,
            "centery": true
        })
    }

    onAwake() {
        this.panel.vScrollBarSkin = '';
    }

    added(list) {
        this.clearPlay();
        this.createPlay(list);
        this.panel.scrollTo(0);
    }


    createPlay(playArr) {
        if (!playArr) {
            return
        }
        let __splitArr = playArr
        let __allH = 0
        for (let i = 0; i < __splitArr.length; i++) {
            //该段文字是文字
            if (typeof __splitArr[i] === 'string') {
                let __txt = this.createPlayTxt(__splitArr[i]);
                this.panel.addChild(__txt).y = __allH + 5
                __allH += __txt.height;
            } else {
                let __img = this.createPlayImg(__splitArr[i].url)
                this.panel.addChild(__img).y = __allH + 5
                __allH += __splitArr[i].height;
                // __allH += __img.height;
            }
        }
    }

    createPlayTxt(str) {
        let __label = new Laya.Label();
        __label.width = this.panel.width;
        __label.wordWrap = true;
        __label.fontSize = 24;
        __label.leading = 10;
        __label.color = '#726856'
        __label.text = str;
        return __label
    }

    createPlayImg(__skin) {
        let __image = new Laya.Image();
        __image.skin = __skin;
        return __image
    }

    clearPlay() {
        while (this.panel.numChildren) {
            let __ele = this.panel.removeChildAt(0);
            __ele = null
        }
    }
}

