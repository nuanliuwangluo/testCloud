        if (value) {
            this.clear();
            this.showIcon(this.kvs[value]);
        }
    }

    showIcon(name) {
        console.log(this[name]);
        this[name] && (this[name].visible = true);
    }

    clear() {
        let values = Object.values(this.kvs);
        values.forEach((value) => { this[value] && (this[value].visible = false); });
    }
}
