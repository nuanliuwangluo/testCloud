class DeskCommonUI_Time extends game.ModuleBase {
    constructor() {
        super({
            map: 'desk_common/DeskCommonTime',
            layer: 'middle',
            right: true,
            up: true,
            offx: -15,
            offy: 20
        })
    }

    onEnable() {
        this._update();
        Laya.timer.loop(60 * 1000, this, this._update);
    }

    onDisable() {
        Laya.timer.clear(this, this._update);
    }

    _update() {
        this.txt_time.text = this.systemTime();
    }

    /**
     * 获取当前时间
     * [curTime description]
     * @param  {[type]} unit [description]
     * @return {[type]}      [description]
     */
    systemTime() {
        let __len = 2;
        let __date = new Date();
        let hours = (__date.getHours() < 10) ? "0" + __date.getHours().toString() : __date.getHours().toString();
        let minutes = (__date.getMinutes() < 10) ? "0" + __date.getMinutes().toString() : __date.getMinutes().toString();
        let seconds = (__date.getSeconds() < 10) ? "0" + __date.getSeconds().toString() : __date.getSeconds().toString();
        return __len == 2 ? hours + ":" + minutes : hours + ":" + minutes + ':' + seconds;
    }
}

