        // this.tips_rate = this.tips_rate || new DeskCostRateTips();
        this.tips_cost.setTxt(`本场门票${data.cost}金币`);
        // this.tips_rate.setTxt(`输赢上限${data.cupMultipty}倍`);

        let cost_x = game.width / game.scale - safe_area - this.tips_cost.width;
        // let rate_x = game.width / game.scale - safe_area - this.tips_rate.width;

        this.addChild(this.tips_cost).pos(cost_x, game.height / game.scale - this.tips_cost.height);
        // this.addChild(this.tips_rate).pos(game.width / game.scale, this.tips_cost.y + this.tips_cost.height + 20);

        ComponentUtils.clearScript(this.tips_cost, DeskCostRateTipsComponent);
        ComponentUtils.clearScript(this.tips_rate, DeskCostRateTipsComponent);
        // this.tips_cost.addComponent(DeskCostRateTipsComponent).toX(cost_x);
        // this.tips_rate.addComponent(DeskCostRateTipsComponent).toX(rate_x);

        this.tips_cost.addComponent(DeskCostRateTipsComponent).hide();
    }

