class DeskCommonUI_Script_talk extends Laya.Script {

    onAwake() {
        this.tips = new DeskRecordTips();
    }

    onEnable() {
        this._btnUI();
        game.cb.on('start_recoder', this, this.start);
        game.cb.on('stop_recoder', this, this.stop);
        game.cb.on('update_vip_data', this, this._btnUI)
        this._onRecoder = false;
        this._updateSkins();
    }

    onDisable() {
        game.cb.off('start_recoder', this, this._addTips);
        game.cb.off('stop_recoder', this, this.stop);
        game.cb.off('update_vip_data', this, this._btnUI)
        this._onRecoder = false;
        this._updateSkins();
    }

    _btnUI() {
        if (!__data.vip.isVip) {
            SkinUtils.gray(this.owner, true, true);
        } else {
            SkinUtils.gray(this.owner, false, true);
        }
    }

    onClick(e) {
        if (!__data.vip.isVip) { __showScene.show_friendRoom_vipSale(FriendRoom_vipSale.voice); return; }
        // if (this._onRecoder) { GameRecoder.stop(); }
        // else { GameRecoder.start(); }
    }

    onMouseDown(e) {
        if (!__data.vip.isVip) { return; }
        if (miniApi.clientType == Platform.APP) AppGameRecoder.start();
        else GameRecoder.start();
    }

    onStageMouseUp(e) {
        if (!__data.vip.isVip) { return; }
        if (!this._onRecoder) { return; }
        if (miniApi.clientType == Platform.APP) AppGameRecoder.stop();
        else GameRecoder.stop();
    }

    start() {
        this._onRecoder = true;
        this._addTips();
        this._updateSkins();
        this._btnUI();
    }

    stop() {
        this._onRecoder = false;
        this._removeTips();
        this._updateSkins();
        this._btnUI();
        this._startTalkCd();
    }

    _updateSkins() {
        SkinUtils.setSkin(this.owner, this._onRecoder ? 'local/game_common/1/img_yy2.png' : 'local/game_common/1/img_yy1.png')
    }

    _addTips() {
        this.layer.addChild(this.tips).pos(Laya.stage.width - this.tips.width >> 1, Laya.stage.height - this.tips.height >> 1);
    }

    _removeTips() {
        game.utils.remove(this.tips);
    }

    _startTalkCd() {
        this._onDis();
        Laya.timer.once(__data.deskData.roomVo.chatTime, this, this._offDis)
    }

    _onDis() { this.owner.disabled = true; }
    _offDis() { this.owner.disabled = false; }

    /**
     * 广播播报的层
     * @return Laya.Sprite
     */
    get layer() {
        return game.scene.layer['middle'].c;
    }
}

