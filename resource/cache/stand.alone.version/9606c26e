    async iconHandle() {

        if (__data.deskData.roomVo.roomModel == __data.deskData.roomVo.FRIEND) {
            this.icons.visible = false;// 好友房隐藏图标
            this.friendIcons = [];
            if (__data.redPacket.canShowInviteRedIcon()) {
                this.inviteRed.visible = true; // 显示可能隐藏过的邀请红包图标
                this.friendIcons.push(this.inviteRed);
            } else {
                this.inviteRed.visible = false; // 隐藏邀请红包图标
            }
            this.friendIcons.push(this.friendRed);
            let [dynamicW, dynamicS] = [20, 20];
            this.friendIcons.map((item, index) => { item.pos(dynamicW, item.y); dynamicW = item.x + item.width * item.scaleX + dynamicS; return item; });
        } else {
            this.inviteRed.visible = false;// 金币房隐藏邀请红包图标
            await __data.firstPay.send(1);
            this.icons.visible = true;// 金币房显示图标

            let numbers = [];
            // 邀请红包和 祈福  2选1
            if (__data.redPacket.canShowInviteRedIcon()) {
                numbers = [6].concat(this.getIconsCanShow());
            } else {
                numbers = [1].concat(this.getIconsCanShow());
            }
            this.icons.array = numbers;
            this.icons.repeatX = numbers.length;
        }
    }

    getIconsCanShow() {
        if (!__data.firstPay.isHasBuy) { return 2; }
        if (__data.activity.todayDiscount.isAllowBuy) { return 3 }
        if (!__data.activity.stepstepGift.isEnd) { return 4 }
        return 5;
    }

    //信号强度
    wifiStrengthHandler(delay, id) {
        return
        if (!id || __data.uid == id) {
            //根据不同延时  文本设置不同颜色
            if (delay >= __data.deskData.roomVo.msData.slowms) {
                this.txt_delay.color = "#ff0000"
                this.txt_delay.text = "延时：>" + __data.deskData.roomVo.msData.slowms + "ms"
            } else if (delay > __data.deskData.roomVo.msData.fastms && delay < __data.deskData.roomVo.msData.slowms) {
                this.txt_delay.color = "#e87912"
                this.txt_delay.text = "延时：" + delay + "ms"
            } else if (delay > __data.deskData.roomVo.msData.veryFastms && delay < __data.deskData.roomVo.msData.fastms) {
                this.txt_delay.color = "#d9c31f"
                this.txt_delay.text = "延时：" + delay + "ms"
            } else if (delay <= __data.deskData.roomVo.msData.veryFastms) {
                this.txt_delay.color = "#25e001"
                this.txt_delay.text = "延时：" + delay + "ms"
            }
        }
    }

