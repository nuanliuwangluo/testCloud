class DeskCommonUI_Script_imgMore extends Laya.Script {
    init(a) {
        this.deskCommon = a;
    }
    onAwake() {
        this.starty = this.deskCommon.btn_set.y - this.deskCommon.btn_set.height / 2;
        this.offy = 15;
        this.downSpace = this.deskCommon.img_more.height - this.deskCommon.btn_out.y
    }
    onEnable() {
        // 用来排序显示的按钮的位置的数组
        this.btnArray = this.list;

        if (this.owner.parent) {
            // 托管显示逻辑
            if (DeskCommonUI.scene == 1) {
                let __vo = __data.deskData.roomVo.getPlayerBySeat(0)


                // 更新托管按钮
                if (__vo && __vo.autoState) {
                    this.owner.parent.btn_tuo.visible = false
                } else {
                    this.owner.parent.btn_tuo.visible = true
                }
                // 更新解散退出按钮
                if (__data.deskData.roomVo.phase == 'ready') {
                    if (__data.deskData.roomVo.roomModel == 6 || __data.deskData.roomVo.roomModel == 7) {
                        this.readyTestShowBtnOutAndBtnDissolve()
                    } else if (__data.deskData.roomVo.roomModel == 5) {
                        this.readyTestShowBtnOutAndBtnDissolve()
                    } else if (__data.deskData.roomVo.roomOwner == __data.uid) {
                        this.readyTestShowBtnOutAndBtnDissolve()
                    } else {
                        this.owner.parent.btn_out.visible = true
                        this.owner.parent.btn_dissolve.visible = false
                    }
                } else if (__data.deskData.roomVo.phase == 'over') {
                    this.owner.parent.btn_out.visible = true
                } else {
                    this.owner.parent.btn_out.visible = false
                    this.owner.parent.btn_dissolve.visible = __data.deskData.roomVo.roomModel == __data.deskData.roomVo.FRIEND ? true : false;
                    this.startedGrayDissolveBtn();
                }
            }
        }
        this.sortBtnPosition()
    }


    get list() {
        if (__data.deskData.roomVo.roomModel == __data.deskData.roomVo.FRIEND) {
            return [this.deskCommon.btn_set, this.deskCommon.btn_tuo, this.deskCommon.btn_rule, this.deskCommon.btn_out, this.deskCommon.btn_dissolve]
        } else {
            return [this.deskCommon.btn_set, this.deskCommon.btn_tuo, this.deskCommon.btn_rule, this.deskCommon.btn_out]
        }
    }


    startedGrayDissolveBtn() {

    }

    // 游戏准备阶段检测 显示退出按钮和解散按钮 的逻辑
    readyTestShowBtnOutAndBtnDissolve() {
        // 1房主 2AA 3体验 4亲友圈 体验馆5
        // 解散退出显示逻辑
        var roomModel = __data.deskData.roomVo.roomModel;
        // 房主模式  aa模式  房主只能解散 没退出
        if (roomModel == __data.deskData.roomVo.FRIEND) {
            // 房主
            if (__data.deskData.roomVo.roomOwner == __data.uid) {
                this.deskCommon.btn_out.visible = false;
                this.deskCommon.btn_dissolve.visible = true;
            }
            // 不是房主
            else {
                this.deskCommon.btn_out.visible = true;
                this.deskCommon.btn_dissolve.visible = false;
            }
        } else if (roomModel == 3) {
            // 体验模式房间  房主可退出可解散
            this.deskCommon.btn_out.visible = true;
        } else if (roomModel == 5) {
            // 体验馆的房间类型  我记得是只有退出好像
            this.deskCommon.btn_out.visible = true;
            //只有一个人
            if (__data.deskData.roomVo.currPlayer == 1) {
                // 体验馆的房间类型  我记得是只有退出好像
                this.deskCommon.btn_out.visible = false;
            }
        } else if (roomModel == 6 || roomModel == 7) {
            // 自动房
            if (__data.deskData.roomVo.roomType == 1) {
                this.deskCommon.btn_out.visible = true;
            }
            // 普通房
            else if (__data.deskData.roomVo.roomType == 2) {
                // 房主 且不是普通用户  只能解散
                if (__data.deskData.roomVo.roomOwner == __data.uid) {
                    let __info = __data.friendData.getInfo(__data.deskData.roomVo.friendId);
                    // 房主 是好友圈普通成员 只能解散
                    if (__info && __info.role == 2) {
                        this.deskCommon.btn_out.visible = false;
                    }
                    // 房主是特殊成员  解散退出都有
                    else if (__info && __info.role != 2) {
                        this.deskCommon.btn_out.visible = true;
                    }
                    // 自己的列表里没有这个好友圈
                    else if (!__info) {
                        this.deskCommon.btn_out.visible = false;
                    }
                }
                // 不是房主
                else {
                    let __info = __data.friendData.getInfo(__data.deskData.roomVo.friendId);
                    //是好友圈普通成员 只能解散
                    if (__info && __info.role == 2) {
                        this.deskCommon.btn_out.visible = true;
                    }
                    //是特殊成员  退出
                    else if (__info && __info.role != 2) {
                        this.deskCommon.btn_out.visible = true;
                    }
                    // 自己的列表里没有这个好友圈
                    else if (!__info) {
                        this.deskCommon.btn_out.visible = true;
                    }
                }

            }
        }
    }

    // 排序显示的按钮位置
    sortBtnPosition() {
        var __h = this.starty;
        var __last_height = 0;
        for (var i = 0; i < this.btnArray.length; i++) {
            if (this.btnArray[i].visible == true) {
                this.btnArray[i].y = __h + __last_height + this.btnArray[i].height / 2;
                __last_height = this.btnArray[i].height / 2; // 上一个按钮的一半距离
                __h = this.btnArray[i].y + this.offy;

                // __h += this.btnArray[i].height + this.offy;
                // trace('this.btnArray[i].height', this.btnArray[i].height)
                // trace('__h', __h)
            }
        }

        this.deskCommon.img_more.height = __h - this.offy + this.downSpace;
        // __h = __h - this.offy;
        // this.deskCommon.img_more.height = __h + this.downSpace;
    }
}

