class DeskRecordTips extends game.ModuleBase {
    constructor() {
        super({
            map: 'desk_common/DeskRecordTips',
            module: false
        })
    }

    onEnable() {
        this.ani.play();
        this.stopTime();
        this.startTime();
    }

    onDisable() {
        this.ani.stop();
        this.stopTime();
    }

    startTime() {
        this.time = 30;
        this._updateTxt();
        Laya.timer.loop(1000, this, this._countdown);
    }

    stopTime() {
        Laya.timer.clear(this, this._countdown);
    }

    _countdown() {
        this.time = Math.max(0, --this.time);
        this._updateTxt();
    }

    _updateTxt() {
        this.txt_voice_time.text = `${this.time}s`;
    }
}

