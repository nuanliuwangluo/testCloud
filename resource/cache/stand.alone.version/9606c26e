class DeskCostRateTipsComponent extends Laya.Script {
    toX(x, time = 200) {
        this._x = x;
        this._time = time;
        this.start();
    }

    start() {
        Laya.Tween.to(this.owner, { x: this._x }, this._time, null, Laya.Handler.create(this, this._disappear));
    }

    _disappear() {
        Laya.Tween.to(this.owner, { alpha: 0 }, this._time / 2, null, Laya.Handler.create(this, this._removeSelf), 1000);
    }

    _removeSelf() {
        game.utils.remove(this.owner);
        this.owner.alpha = 1;
    }

    hide(delay = 1200) {
        Laya.Tween.to(this.owner, { alpha: 0 }, 300, null, Laya.Handler.create(this, this._removeSelf), delay);
    }
}

