class GameMainSeasonStart extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_seasonStart',
            layer: 'panel'
        })
        this.btn_sure.addComponent(S_seasonStart_sure)

        this.txtImg = new game.NumText(GameMainSeasonStart.fontUrl, 'center')
        this.txtImg.x = this.img_bg.x;
        this.txtImg.y = this.img_bg.y;
        this.addChild(this.txtImg)
    }
    added() {
        let person_rank = __data.seasonEndData.index;
        let scoreOld = __data.seasonEndData.maxScore;
        let scoreNew = __data.seasonEndData.newScore;
        let year = __data.seasonEndData.newYear
        let season = GameMainSeasonStart.seasonFontToId[__data.seasonEndData.newSeason.charAt(0)]
        // 个人排名 本地排名 分数 年 季节1-4=春夏秋冬
        let rd = RankUtils.getRankLvDataByScore(scoreOld)

        if (rd.toNextLevelNeedCup == 0 && (scoreOld - rd.minCup) >= __data.rank.rank_exceed_queshen_score) {
            let rd;
            if (person_rank == 1) rd = __data.rank.chuanqiQueshen;
            else rd = __data.rank.xingyaoQueshen
            this.txt_lv_name.text = rd.name;
            this.img_lv_bg.skin = `local/lvNameBg/1/rank_${rd.iconIndex}.png`;
            this.img_sign.skin = `cdn/rank_sign/img_rank_sign_${rd.iconIndex}.png`;
        } else {
            this.txt_lv_name.text = rd.name;
            this.img_lv_bg.skin = `local/lvNameBg/1/rank_${rd.iconIndex}.png`;
            this.img_sign.skin = `cdn/rank_sign/img_rank_sign_${rd.iconIndex}.png`;
        }

        if (rd.toNextLevelNeedCup == 0) {
            this.img_queshen.visible = true
            this.txt_lv_num.visible = false
        } else {
            this.img_queshen.visible = false
            this.txt_lv_num.visible = true
            this.txt_lv_num.text = rd.level;
        }

        rd = RankUtils.getRankLvDataByScore(scoreNew)
        this.txt_lv_name1.text = rd.name;
        this.img_lv_bg1.skin = `local/lvNameBg/1/rank_${rd.iconIndex}.png`;
        this.img_sign1.skin = `cdn/rank_sign/img_rank_sign_${rd.iconIndex}.png`;

        this.txtImg.text = year + GameMainSeasonStart.seasonIdToText[season] + '季赛开始'
        this.txtImg.y = this.img_bg.y - this.txtImg.height / 2

        if (rd.toNextLevelNeedCup == 0) {
            this.img_queshen1.visible = true
            this.txt_lv_num1.visible = false
        } else {
            this.img_queshen1.visible = false
            this.txt_lv_num1.visible = true
            this.txt_lv_num1.text = rd.level;
        }
    }
    clickMask() { }
    onDisable() {
        hallTestShowPanel()
        __data.seasonEndData = {};
    }
}
