class S_hall_play_quick_start extends Laya.Script {
    async onClick() {
        S_hall_play_quick_start__click()
        miniApi.trackEvent('Mj_UIClick', { 'Mj_ClickScene': '快速开始按钮' })
    }
    onEnable() {
        this.update_quick_txt()
        game.cb.on('updateMathInfo', this, this.update_quick_txt);
    }
    onDisable() {
        game.cb.off('updateMathInfo', this, this.update_quick_txt);
    }
    update_quick_txt() {
        let txt_quickPlay = this.owner.getChildByName('txt_quickPlay')
        txt_quickPlay.text = '新手场'
        let arrData = excelUtils.getModelByCityIdRuleId(HallPlay.lastCityId, HallPlay.curRuleId)
        if (!arrData) return;
        // for (let index = arrData.length - 1; index >= 0; index--) {
        for (let index = 0, length = arrData.length; index < length; index++) {
            const e = arrData[index];
            if (e.maxGold != -1) {
                if (__bigNumberCal.gte(__data.gold, e.minGold) && __bigNumberCal.lte(__data.gold, e.maxGold)) {
                    txt_quickPlay.text = __data.hashMatchModelTypeName[e.matchModelType]
                    break;
                }
            } else if (__bigNumberCal.gte(__data.gold, e.minGold)) {
                txt_quickPlay.text = __data.hashMatchModelTypeName[e.matchModelType]
                break;
            }
        };
    }

}
let S_hall_match__click = async (thisType) => {

    if (!__data.playNumbers) {
        __data.d_match.startMatch(thisType, HallPlay.curRuleId, HallPlay.lastCityId, 0);
    } else {
        __data.d_match.preMatch(thisType, HallPlay.curRuleId, HallPlay.lastCityId, 0);
    }
}

let S_hall_play_quick_start__click = async (use_d_match_preMatch) => {
    let type = 1;
    let arrData = excelUtils.getModelByCityIdRuleId(HallPlay.lastCityId, HallPlay.curRuleId)
    // for (let index = arrData.length - 1; index >= 0; index--) {
    for (let index = 0, length = arrData.length; index < length; index++) {
        const e = arrData[index];
        if (e.maxGold != -1) {
            if (__bigNumberCal.gte(__data.gold, e.minGold) && __bigNumberCal.lte(__data.gold, e.maxGold)) {
                type = e.matchModelType
                break;
            }
        } else if (__bigNumberCal.gte(__data.gold, e.minGold)) {
            type = e.matchModelType
            break;
        }
    };
    if (use_d_match_preMatch == 1) {
        __data.d_match.preMatch(type, HallPlay.curRuleId, HallPlay.lastCityId, 0);
        return
    }
    if (!__data.playNumbers) {
        __data.d_match.startMatch(type, HallPlay.curRuleId, HallPlay.lastCityId, 0);
    } else {
        __data.d_match.preMatch(type, HallPlay.curRuleId, HallPlay.lastCityId, 0);
    }

}
