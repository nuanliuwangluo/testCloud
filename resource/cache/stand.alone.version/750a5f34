class Garden_dailySelect extends game.ModuleBase {
    constructor() {
        super({
            map: 'garden/Garden_dailySelect',
            layer: 'panel'
        })
        this.txt_star.addComponent(S_hall_tween_star);
        this.btn_video.addComponent(S_garden_dailySelect_video)
        this.txt_time.addComponent(S_garden_dailySelect_time)
        this.x1 = this.txt_time.x;
    }
    onEnable() {
        this.update()
        game.cb.on('update_garden_dailySelect_data', this, this.update)
    }
    onDisable() {
        game.cb.off('update_garden_dailySelect_data', this, this.update)
        ResUtils.clearAtlas('res/atlas/cdn/collect.atlas')
        ResUtils.clearTextureRes(['cdn.garden_dailySelect', 'cdn.collect'])
    }
    update() {
        if (__data.garden.dailySelect.videoNum) {
            this.btn_video.disabled = true
        } else this.btn_video.disabled = false;
        let a = __data.garden.dailySelect.goods || [];
        let compIdArray = a.map((e) => {
            return e.id
        })
        let hgd = compIdArray.map((e) => {
            return __data.excelConfig.hashGardenDress[e]
        })
        let dd123 = [];
        let typeArr = {};
        for (const key in hgd) {
            let e = hgd[key];

            if (e.typeId) {
                // 有分类
                typeArr[e.typeId] = typeArr[e.typeId] || [];
                typeArr[e.typeId].push({
                    typeId: e.typeId,
                    id: e.compId,
                    positionId: parseInt(e.positionId),
                    isUseing: __data.garden.useCompId.includes(parseInt(e.compId)),
                    isLock: __data.garden.isDressLock(e.compId),
                })
                if (!dd123.includes(typeArr[e.typeId]))
                    dd123.push(typeArr[e.typeId])
            } else {
                // 没有分类
                dd123.push([{
                    id: e.compId,
                    positionId: parseInt(e.positionId),
                    isUseing: __data.garden.useCompId.includes(parseInt(e.compId)),
                    isLock: __data.garden.isDressLock(e.compId),
                }])
            }
        }
        this.goods1.visible = false
        this.goods2.visible = false
        this.goods3.visible = false
        dd123 = dd123.slice(0, 3);
        for (let index = 0, length = dd123.length; index < length; index++) {
            this['goods' + (index + 1)].visible = true;
            this['goods' + (index + 1)].dataSource = dd123[index];
        };
    }
}

