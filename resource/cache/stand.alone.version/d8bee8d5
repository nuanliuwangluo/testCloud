class S_combobox extends Laya.Script {
    init(comboboxName, btn, list) {
        this.comboboxName = comboboxName;
        this.btn = btn;
        this.list = list;
        this.son1 = list.getChildByName('son1')
        game.utils.removeAll(this.son1)
        this.itemArray = []
        return this
    }
    onEnable() {
        game.cb.on('combobox_update_index_' + this.comboboxName, this, this.update_index, 0)
    }
    onDisable() {
        game.cb.off('combobox_update_index_' + this.comboboxName, this, this.update_index)
    }
    update_index(index) {
        this.__index = index;
        this.btn.getChildByName('txt').text = this.data[index];
        this.list.visible = false;
    }
    set selectedIndex(v) {
        game.cb.event('combobox_update_index_' + this.comboboxName, [v])
    }
    get selectedIndex() {
        return this.__index
    }
    set array(v) {
        this.data = v;
        for (const iterator of this.itemArray) {
            game.utils.remove(iterator)
        }
        this.itemArray = [];
        let label;
        for (let index = 0, length = v.length; index < length; index++) {
            const element = v[index];
            label = new Laya.Label();
            this.itemArray[index] = label;
            label.fontSize = this.son1.fontSize;
            label.color = this.son1.color;
            label.width = this.son1.width;
            label.height = this.son1.height;
            label.align = this.son1.align;
            label.valign = this.son1.valign;
            label.bold = this.son1.bold;
            label.text = element;
            label.x = this.son1.x;
            label.y = this.son1.y + index * this.son1.height
            label.index = index;
            label.comboboxName = this.comboboxName;
            label.addComponent(Btn_Move).onAwake()
            label.addComponent(Btn_Sound)
            label.addComponent(S_combobox_item)
            this.list.addChildAt(label, 0);
        };
        this.list.height = label.y + label.height + this.son1.y
    }
}

class S_combobox_item extends Laya.Script {
    onClick(e) {
        game.cb.event('combobox_update_index_' + this.owner.comboboxName, [this.owner.index, e])
    }
}

