class FriendRoom_record_main_gameRecord_item extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_friendRoom/friendRoom_record_main_gameRecord_item',
            module: false
        })
        this.btn_info.addComponent(S_FriendRoom_record_main_gameRecord_item_lookInfo)
    }
    onEnable() {
    }
    onDisable() {
    }
    set dataSource(v) {
        this.vo = v;
        if (!v) return;
        let n2 = excelUtils.getPlayIdName(v.ruleId);
        this.txt_info.text = '【房间号' + v.roomPwd + '】' + n2 + '，' + v.playerNames.length + '人，' + v.roundCount + '局'
        this.txt_time.text = new Date(v.date).dateFormat("yyyy.MM.dd hh:mm:ss");
        [1, 2, 3, 4].forEach((e, index) => {
            try {
                let pl = this['player' + e];
                pl.skin = v.playerHeadUrls[index];
                pl.getChildByName('img_frame').skin = PropIcon.icon[v.playerHeadBorders[index] || 301].skin;
                LabelHiddenUtils.getAdapterContent(pl.getChildByName('txt_name'), v.playerNames[index])
                pl.getChildByName('txt_score').text = v.scores[index];
                if (v.scores[index] > 0) {
                    pl.getChildByName('txt_score').color = '#7ab704'
                } else {
                    pl.getChildByName('txt_score').color = '#e12e2e'
                }
            } catch (error) {
                console.error('FriendRoom_record_main_gameRecord_item', error)
            }
        })
    }
}
Laya.ClassUtils.regClass('ui.scene_friendRoom.friendRoom_record_main_gameRecord_itemUI', FriendRoom_record_main_gameRecord_item);

