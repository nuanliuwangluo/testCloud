class FriendRoom_record_main_gameRecord extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_friendRoom/friendRoom_record_main_gameRecord',
            module: false
        })
        this.__list.vScrollBarSkin = ''
        this.btn_lookReplay.addComponent(S_friendRoom_rm_gr_lookReplay)
        this.btn_vip.addComponent(S_show_friendRoom_vip).init(FriendRoom_vipSale.save_time)
        this.btn_lookTotalScore.addComponent(S_show_friendRoom_vip).init(FriendRoom_vipSale.cal_score)
        this.btn_openVip_7.addComponent(S_show_friendRoom_vip).init(FriendRoom_vipSale.save_time)
        this.btn_selectDate.addComponent(S_clickBtnShow_clickOtherRemove).init(this.img_selectDate)
        this.img_selectDate.addComponent(S_stopPropagation_mousedown)
        this.s_combobox = this.addComponent(S_combobox).init('friend', this.btn_selectDate, this.img_selectDate)
        this.__list.renderHandler = new Laya.Handler(this, this.updateItem);
        this.__list.addComponent(S_fr_click_list)
    }
    async onEnable() {
        game.cb.on('update_vip_data', this, this.updateVip)
        game.cb.on('update_friendRoom_game_record_data', this, this.update_friendRoom_game_record_data)
        game.cb.on('combobox_update_index_' + this.s_combobox.comboboxName, this, this.update_index)
        this.s_combobox.array = [
            '今天',
            '昨天',
            new Date(Date.now() - 2 * 24 * 3600 * 1000).dateFormat("yyyy.MM.dd"),
            new Date(Date.now() - 3 * 24 * 3600 * 1000).dateFormat("yyyy.MM.dd"),
            new Date(Date.now() - 4 * 24 * 3600 * 1000).dateFormat("yyyy.MM.dd"),
            new Date(Date.now() - 5 * 24 * 3600 * 1000).dateFormat("yyyy.MM.dd"),
            new Date(Date.now() - 6 * 24 * 3600 * 1000).dateFormat("yyyy.MM.dd"),
        ]
        await __tool.await(1)
        if (FriendRoom_record_main_gameRecord.save) {
            this.s_combobox.selectedIndex = FriendRoom_record_main_gameRecord.combobox_select_index
        } else {
            this.s_combobox.selectedIndex = 0
        }
        this.updateVip();
    }
    onDisable() {
        game.cb.off('update_vip_data', this, this.updateVip)
        game.cb.off('update_friendRoom_game_record_data', this, this.update_friendRoom_game_record_data)
        game.cb.off('combobox_update_index_' + this.s_combobox.comboboxName, this, this.update_index)
        __data.friendRoom.clear();
        FriendRoom_record_main_gameRecord.save = 0;
    }
    updateItem(cell, index) {
        let array = [];
        for (const key in this.useData) {
            if (parseInt(key) >= 1) {
                array.push(...this.useData[key])
            }
        }
        let nextPage = Math.floor(array.length / 10) + 1;
        if (index == array.length - 2 && nextPage <= 10 && !this.useData[nextPage]) {
            game.server.send(14013, __data.uid, this.s_combobox.selectedIndex, nextPage)
        }
    }
    update_friendRoom_game_record_data() {
        this.useData = __data.friendRoom.gameRecord && __data.friendRoom.gameRecord[this.s_combobox.selectedIndex] || [];
        this.updateList()
        this.updateTotalScore()
    }
    update_index(index, e) {
        if (e) {
            game.server.send(14013, __data.uid, index, 1)
        }
        FriendRoom_record_main_gameRecord.combobox_select_index = index;
        this.update_friendRoom_game_record_data()
    }
    updateList() {
        let n = [];
        for (const key in this.useData) {
            if (parseInt(key) >= 1) {
                n.push(...this.useData[key])
            }
        }
        this.__list.array = n;
        this.img_noData.visible = n.length == 0;

        if (FriendRoom_record_main_gameRecord.save) {
            this.__list.scrollTo(FriendRoom_record_main_gameRecord.item_show_index || 0)
        }
    }
    updateTotalScore() {
        this.updateVip()
    }
    updateVip() {
        if (__data.vip.isVip) {
            this.btn_lookTotalScore.visible = false
            this.btn_openVip_7.visible = false
            this.txt_totalScore.text = this.useData.allScore || 0;
            this.btn_vip.visible = false
        } else {
            this.btn_lookTotalScore.visible = true
            this.btn_openVip_7.visible = true
            this.txt_totalScore.text = '?';
            this.btn_vip.visible = true
        }
    }
}
Laya.ClassUtils.regClass('ui.scene_friendRoom.friendRoom_record_main_gameRecordUI', FriendRoom_record_main_gameRecord);

class S_fr_click_list extends Laya.Script {
    onMouseDown(e) {
        FriendRoom_record_main_gameRecord.save = 0
    }
}

