class S_click_prop_get_sure extends Laya.Script {
    onClick() {
        let a = game.scene.get(GameMainPropGet)
        if (a && a.parent) {
            if (a.queshenRoad_testShowStarBanner == 0 && a.isHaveStar) {
                __showScene.show_garden_mainScene_bombbox(1)
            }
        }

        if (GameMainShop.callbackAfterPay) {
            GameMainShop.callbackAfterPay.callback();
            GameMainShop.callbackAfterPay = null;
        }

        game.scene.remove(GameMainPropGet)
    }
}
class S_click_prop_get_ad extends Laya.Script {
    onClick() {
        let s = this.owner.skin
        if (s.includes('img_bannar.png') || s.includes('img_bannar2.png')) {
            miniApi.trackEvent('Mj_UIClick', { 'Mj_ClickScene': '花园Banner' });
            __data.lastSceneQueue.push(__showScene.show_hall)
            __showScene.show_garden(true)
        }
        else if (s.includes('img_bannar3.png')) {
            __showScene.show_freeVip()
        }
        else if (s.includes('img_bannar4.png') || s.includes('img_bannar5.png')) {
            __showScene.show_vip()
        }
        game.scene.remove(GameMainPropGet)

    }
}
class gameMainPropGetItem extends game.ModuleBase {
    constructor(desScript) {
        super({
            map: 'scene_hall/gameMain_propGetItem',
            module: false
        })
        this.__vo;
        this.addComponent(desScript || S_prop_show_des)
        this.addComponent(S_getProp_click_noRemoveParent)
    }
    set dataSource(vo) {
        if (!vo) return;
        this.__vo = vo;
        let p;

        let w1, h1;
        if (String(vo.propId).includes('dress')) {
            let id = String(vo.propId).replace('dress', '')
            let d1 = __data.excelConfig.hashGardenDress[id]
            let dressId = d1.gardenDressId
            p = {
                des: '',
                skin: `cdn/collect_gardenDress/${dressId}.png`,
            }
            w1 = 170
            h1 = 170
        }
        else if (!PropIcon.icon[vo.propId]) {
            p = PropIcon.icon[1];
            try {
                throw new Error('物品不存在 ' + vo.propId)
            } catch (error) {
                console.error(error.stack)
                miniApi.uploadError(error.stack)
            }
            w1 = fileWHConfig[p.skin].width
            h1 = fileWHConfig[p.skin].height
        } else {
            p = PropIcon.icon[vo.propId]
            w1 = fileWHConfig[p.skin].width
            h1 = fileWHConfig[p.skin].height
        }
        this.txt_num.text = '×' + bigNumberToCH(vo.propNum, 2)
        this.img_prop.skin = p.skin;

        let a = 155 / w1
        let b = 153 / h1
        this.img_prop.scaleX = Math.min(a, b)
        this.img_prop.scaleY = Math.min(a, b)
    }
    get vo() {
        return this.__vo;
    }
}
Laya.ClassUtils.regClass('ui.scene_hall.gameMain_propGetItemUI', gameMainPropGetItem);

