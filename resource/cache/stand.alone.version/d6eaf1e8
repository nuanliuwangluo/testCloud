class GameMainPropGet extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_propGet',
            layer: 'panel'
        })
        this.btn_sure.addComponent(S_click_prop_get_sure);
        this.img_ad.addComponent(S_click_prop_get_ad);
        this.allProps = [];
        // this.addComponent(S_click_prop_get_remove)

        this.container_inity = this.__container.y;
        this.sp_1_inity = this.sp_1.y;
    }

    added(props, queshenRoad_testShowStarBanner = 1) {
        this.queshenRoad_testShowStarBanner = queshenRoad_testShowStarBanner;
        this.img_ad.skin = ''
        let tt = this;
        game.server.send(16007)
        tt.isExpt = 1
        // miniApi.getExptInfoSync('expt_1737530731', {
        //     '0': () => {
        //         tt.isExpt = 0
        //     },
        //     '1': () => {
        //         tt.isExpt = 1
        //     },
        //     'fail': () => {
        //         tt.isExpt = 0
        //     }
        // })
        __sound.gameSound('get');
        for (let index = 0, length = this.allProps.length; index < length; index++) {
            const e = this.allProps[index];
            e.visible = false;
        };
        let w = 0;
        let h = 0
        this.txt_btn.text = '确定'

        let isHaveStar;
        // this.img_title.skin = 'ab/a_panel_prop_get/img_gxhd1.png'
        // let testHaveCard = 1
        for (let index = 0, length = props.length; index < length; index++) {
            const e = props[index];
            let pp = this.allProps[index] || new gameMainPropGetItem()
            this.allProps[index] = pp;
            this.__container.addChild(pp)
            pp.visible = true;
            pp.dataSource = e;
            if (e.propId == 5) {
                isHaveStar = true;
            }
            pp.x = index % 5 * (pp.width + 0)
            pp.y = Math.floor(index / 5) * (pp.height - 20)
            w = Math.max(pp.x + pp.width, w);
            h = Math.max(pp.y + (pp.height - 20), h)
        };
        this.__container.x = (this.width - w) / 2
        this.__container.y = this.container_inity - h / 2;

        // this.isExpt
        // __data.vip.addUpToLoginDayNum
        // __data.game_count_total
        this.isHaveStar = isHaveStar;
        if (isHaveStar) {
            if (!queshenRoad_testShowStarBanner) {
                this.img_ad.visible = false;
                this.sp_1.y = 100;
                return
            };
            miniApi.trackEvent('Mj_UIExposure', { 'Mj_ExposureScene': '花园Banner' })
            this.sp_1.y = this.sp_1_inity;
            this.img_ad.visible = true

            // 这里李哥修改了 说 金币弹框  被别的替换了 所以 只用一个bannar
            // if (__data.garden.task.branchTaskId > 1) {
            this.img_ad.skin = 'cdn/getPropAd/img_bannar.png'
            // } else {
            //     this.img_ad.skin = 'cdn/getPropAd/img_bannar2.png'
            // }
            return
        }
        if (!isHaveStar && !__data.vip.isVip && __data.vip.addUpToLoginDayNum > 3 && __data.game_count_total > 0 && this.isExpt == 1) {
            if (!__data.vip.isReceiveFreeVip && miniApi.clientType != 'app') {
                let a;
                if (Date.now() - parseInt(__data.Mj_registeDateMs) < 24 * 3600 * 1000) {
                    a = 1
                }
                if (!__data.vip.isVip && __data.vip.addUpToLoginDayNum > 7) {
                    a = 1
                }
                if (a == 1) {
                    this.sp_1.y = this.sp_1_inity;
                    this.img_ad.visible = true
                    this.img_ad.skin = 'cdn/getPropAd/img_bannar3.png'
                    return;
                }
            }
            if (
                // IOS能支付修改
                // !miniApi.isIOS &&
                __data.vip.isReceiveFreeVip
            ) {
                this.sp_1.y = this.sp_1_inity;
                this.img_ad.visible = true
                if (Math.random() * 1 < 0.5)
                    this.img_ad.skin = 'cdn/getPropAd/img_bannar4.png'
                else this.img_ad.skin = 'cdn/getPropAd/img_bannar5.png'
                return;
            }
        }
        this.img_ad.visible = false;
        this.sp_1.y = 100;
    }
    onDisable() {
        game.cb.event('props_tips_closed');
        if (miniApi.clientType == 'app')
            game.cb.event('hall_play_show_hand')

        if (GameMainPropGet.type == 'returnPlayer'
            || GameMainPropGet.type == 'chuanqiReward'
            || GameMainPropGet.type == 'fuguiManor'
        ) {
            hallTestShowPanel()
        }
        if (GameMainPropGet.type === 'newPlayer') {
            __showScene.show_newPlayerRedChallenge(1)
        }
        GameMainPropGet.type = null;

        ResUtils.clearTextureRes(['ab.a_panel_prop_get'])
        ResUtils.clearTextureRes(['cdn.getPropAd'])
        ResUtils.clearTextureRes(['cdn.cupAndMedal'])
        ResUtils.clearTextureRes(['bag_icon'])
    }
    clickMask() { }
}
