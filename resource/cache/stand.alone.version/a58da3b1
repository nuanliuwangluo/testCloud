    static get screenInfo(){
        let info = this.bridge ? this.bridge.call("getScreenInfo:", "") : null;
        info = info ? JSON.parse(info) : null;
        return info;
    }

    static get bridge(){ 
        if(!this._bridge){
            try{
                let os = conchConfig.getOS();
                if(os == "Conch-ios"){
                    this._bridge = PlatformClass.createClass("JSBridge")
                }else if(os == "Conch-android"){
                    this._bridge = PlatformClass.createClass("demo.JSBridge")
                }
            }catch(e){
                this._bridge = null;
            }
        }
        return this._bridge; 
    }
