class AppBridge{
    
    static listener(){
        this.bridge && this.bridge.callWithBack(function(ret) {
            ret = JSON.parse(ret);
            if(ret){
                if(ret.name == 'pause'){
                    __heartbeat.reset();
                    __voiceHeartbeat.reset();
                    __sound && __sound.pause();
                    Laya && Laya.stage && (Laya.stage.renderingEnabled = false);
                }else if(ret.name == 'resume'){
                    __sound && __sound.working();
                    Laya && Laya.stage && (Laya.stage.renderingEnabled = true);
                }
            }
        },"listener:", "");
    }

    static appleLogin(callback){
