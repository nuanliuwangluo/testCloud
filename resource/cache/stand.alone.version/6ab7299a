    class Text_Scroll extends Laya.Script {

        constructor() {
            super();

            /** @prop {name:reBack, tips:"是否文本发生改变回到文本上方", type:Boolean, default:false}*/
            let reBack = null;
        }

        onEnable() {
            this.owner.on('change', this, this.changeTextHandler);
            this.changeTextHandler();
        }

        onDisable() {
            this.owner.off('change', this, this.changeTextHandler);
            this.reset();
        }

        reset() {
            this.owner && (this.owner.textField.scrollY = 0);
            this.startX = null;
            this.startY = null;
            this.prevX = null;
            this.prevY = null;
            //阀门关闭
            this.valve = false;
            this.clearTween();
            this.clearScrollTween();
        }

        onMouseDown(e) {
            this.clearTween();
            this.clearScrollTween();
            //阀门开启  留存坐标
            this.valve = true;

            this.time = new Date().getTime();
            this.startX = this.owner.mouseX;
            this.startY = this.owner.mouseY;
            this.prevX = this.owner.mouseX;
            this.prevY = this.owner.mouseY;
        }

        onStageMouseUp() {
            if (isNaN(this.owner.textField.scrollY) || isNaN(this.owner.textField.scrollX)) { return; }
            if (isNaN(this.startX) || isNaN(this.startY)) { return; }

            this.nowX = this.owner.mouseX;
            this.nowY = this.owner.mouseY;

            //阀门关闭
            this.valve = false;
            let time = new Date().getTime();
            let useTime = (time - this.time) / 1000; // 用时
            let moveDistance = Math.abs(this.nowY - this.startY); // 距离
            let speed = moveDistance / useTime * 1;

            speed = parseInt(this.nowY) - parseInt(this.startY) < 0 ? speed : -speed;
            let endY = this.owner.textField.scrollY + speed;
            endY = Math.max(endY, 0);
            endY = Math.min(this.owner.textField.textHeight - this.owner.textField.displayHeight + this.owner.textField.fontSize, endY);
            this.tween = new Laya.Tween().to(this.owner.textField, { scrollY: endY }, 500, Laya.Ease.quartOut, Laya.Handler.create(this, this.clearTween));
            this.tween.update = Laya.Handler.create(this, this.fixScrollXy);
        }

        clearTween() {
            if (this.tween) {
                this.tween.clear();
                this.tween = null;
            }
        }

        onMouseMove(e) {
            if (!this.valve) return //开关阀门  如果为关闭状态不予滚动

            this.nowX = this.owner.mouseX;
            this.nowY = this.owner.mouseY;

            this.owner.textField.scrollX += parseInt(this.prevX) - parseInt(this.nowX);
            this.owner.textField.scrollY += parseInt(this.prevY) - parseInt(this.nowY);

            this.fixScrollXy();

            this.prevX = this.nowX;
            this.prevY = this.nowY;
        }

        onLateUpdate() {
            if (this.owner.mouseX == this.prevX && this.owner.mouseY == this.prevY) {
                this.startX = this.owner.mouseX;
                this.startY = this.owner.mouseY;
            }
        }

        fixScrollXy() {
            if (isNaN(this.owner.textField.scrollY) || isNaN(this.owner.textField.scrollX)) { return; }
            this.owner.textField.scrollY = Math.max(this.owner.textField.scrollY, 0);
            this.owner.textField.scrollY = Math.min(this.owner.textField.textHeight - this.owner.textField.displayHeight + this.owner.textField.fontSize, this.owner.textField.scrollY);

            this.owner.textField.scrollX = Math.max(this.owner.textField.scrollX, 0);
            this.owner.textField.scrollX = Math.min(this.owner.textField.textWidth - this.owner.textField.displayWidth + this.owner.textField.fontSize, this.owner.textField.scrollX);
        }

        // onMouseUp(e) { this.closeScroll(); }

        // onMouseOut(e) { this.closeScroll(); }

        // closeScroll() {
        //     //阀门关闭
        //     this.valve = false;
        //     // this.prevX = this.prevY = this.nowX = this.nowY = 0;
        // }


        changeTextHandler(e) {
            if (this.reBack && this.owner.textField.scrollY > 0) {
                Laya.Tween.to(this.owner.textField, { scrollY: 0 }, 300, Laya.Ease.circIn, new Laya.Handler(this, this.clearScrollTween));
            }
        }

        clearScrollTween() {
            Laya.Tween.clearAll(this.owner.textField);
        }
    }
    window.Text_Scroll = Text_Scroll;

    class PanelAdListener extends Laya.Script {
        constructor() {
            super();
            /** @prop {name:ignore, tips:"需要忽略的广告Name", type:string, default:''}*/
            this.ignore = '';
        }

        onEnable() {
            PanelAdListener.push(this.owner);
        }

        onUpdate() {
            game && game.cb && game.cb.event('AdPanelListener', [true, this.ignore]);
        }

        onDisable() {
            PanelAdListener.remove(this.owner);
            if (!PanelAdListener.ots.length) {
                game && game.cb && game.cb.event('AdPanelListener', [false, this.ignore]);
            }
        }

        static get ots() {
            if (!this._ote) {
                this._ote = [];
            }
            return this._ote;
        }
        static push(view) {
            if (!view) { return; }
            let includes = this.ots.indexOf(view) != -1;
            if (!includes) {
                this.ots.push(view);
            }
        }
        static remove(view) {
            if (!view) { return; }
            let index = this.ots.indexOf(view);
            if (index != -1) {
                this.ots.splice(index, 1);
            }
        }
    }
    window.PanelAdListener = PanelAdListener;

