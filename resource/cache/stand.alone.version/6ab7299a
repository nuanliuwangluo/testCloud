    class VideoCountDown extends Laya.Script {

        constructor() {
            super();
            /** @prop {name:time, tips:"倒计时时间（单位毫秒）", type:Number, default:10000}*/
            this.time = 10000;
        }

        onAwake() {
            this.rect = new Laya.Rectangle();
            this.owner.scrollRect = this.rect;
            this.tween = null;
        }

        onEnable() {
            this._start();
        }

        onDisable() {
            this._clear();
        }

        /**
         * 计时结束后调用
         * @param {function} completeTodo 
         */
        setAfter(after) {
            this._after = after;
        }

        /**
         * 暂停缓动
         */
        pause() {
            this.tween && this.tween.pause();
        }

        /**
         * 恢复缓动
         */
        resume() {
            this.tween && this.tween.resume();
        }

        /**
         * 开始计时
         */
        _start() {
            this.rect.width = this.owner.width;
            this.rect.height = this.owner.height;
            this._countDown();
        }

        /**
         * 清理缓动
         */
        _clear() {
            if (this.tween) {
                this.tween.clear();
                this.tween = null;
            }
        }

        /**
         * 开始计时
         */
        _countDown() {
            Laya.Tween.clearAll(this.rect);
            Laya.Tween.to(this.rect, {
                width: 0
            }, this.time, Laya.Ease.Linear, new Laya.Handler(this, this._complete));
        }

        /**
         * 计时结束
         */
        _complete() {
            this._after && this._after();
        }

        setProgress(progress) {
            this.rect.width = this.owner.width * progress;
        }
    }
    window.VideoCountDown = VideoCountDown;

