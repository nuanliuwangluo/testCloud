    class Panel_Tween_Add extends Laya.Script {
        constructor() {
            super();
            /** @prop {name:tween_time, tips:"tween时间", type:Number, default:100}*/
            this.tween_time = 150;
        }
        updateXY() {
            this.owner.pivotX = this.owner.width / 2;
            this.owner.pivotY = this.owner.height / 2;
            this.owner.scale_after_panelTweenAdd = this.owner.scaleX;
            this.owner.x += this.owner.pivotX * this.owner.scale_after_panelTweenAdd;
            this.owner.y += this.owner.pivotY * this.owner.scale_after_panelTweenAdd;
        }
        async startTween() {
            this.owner.scaleX = this.owner.scaleY = 0.3 * this.owner.scale_after_panelTweenAdd;
            this.owner.alpha = 0;
            Laya.Tween.clearAll(this.owner);

            await __tool.tweenPromise(this.owner, {
                alpha: 1,
                scaleX: this.owner.scale_after_panelTweenAdd,
                scaleY: this.owner.scale_after_panelTweenAdd,
            }, this.tween_time);

            await __tool.tweenPromise(this.owner, {
                alpha: 1,
                scaleX: this.owner.scale_after_panelTweenAdd * 0.985,
                scaleY: this.owner.scale_after_panelTweenAdd * 0.985,
            }, 100);

            await __tool.tweenPromise(this.owner, {
                alpha: 1,
                scaleX: this.owner.scale_after_panelTweenAdd * 1,
                scaleY: this.owner.scale_after_panelTweenAdd * 1,
            }, 100);
        }
    }
    window.Panel_Tween_Add = Panel_Tween_Add;

