    class ClipL extends Laya.Script {
        constructor() {
            super();
            /** @prop {name:urlPrefix, tips:"图片路径 cdn/a_seven_hand/", type:String, default:''}*/
            this.urlPrefix = '';
            /** @prop {name:startIndex, tips:"路径后缀开始索引", type:Number, default:0}*/
            this.startIndex = 0;
            /** @prop {name:endIndex, tips:"路径后缀结束索引", type:Number, default:0}*/
            this.endIndex = 0;
            /** @prop {name:onEnablePlay, tips:"显示自动播放", type:Boolean, default:true}*/
            this.onEnablePlay = true;
            /** @prop {name:onEnablePlayDelay, tips:"首次显示自动播放延迟", type:Number, default:1000}*/
            this.onEnablePlayDelay = 1000;
            /** @prop {name:delay, tips:"播放间隔", type:Number, default:100}*/
            this.delay = 100;
            /** @prop {name:repeat, tips:"重复播放", type:Boolean, default:true}*/
            this.repeat = true;
            /** @prop {name:playComToNextPlayDelay, tips:"播放一遍后下次播放间隔", type:Number, default:5000}*/
            this.playComToNextPlayDelay = 5000;
            /** @prop {name:finallyUseNullSkin, tips:"播放后使用空皮肤", type:Boolean, default:true}*/
            this.finallyUseNullSkin = true;
        }
        onAwake() {
            this.arraySkin = [];
            for (let index = this.startIndex, length = this.endIndex; index <= length; index++) {
                this.arraySkin.push(this.urlPrefix + index + '.png');
            };
            this.finallyUseNullSkin && this.arraySkin.push('');
            this.__index = 0;
            this.__playing = false;
            this.owner.clipPlay = this.play.bind(this);
            this.owner.clipStop = this.stop.bind(this);
        }
        onEnable() {
            if (this.onEnablePlay) {
                // this.owner.visible = false
                Laya.timer.once(this.onEnablePlayDelay, this, this.play, [0]);
            }
        }
        onDisable() {
            this.stop();
        }
        play(value) {
            // this.owner.visible = true;
            parseInt(value) >= 0 && this.index(value);
            this.stop();
            this.__playing = true;
            Laya.timer.loop(this.delay, this, this.clip_update);
        }
        index(value) {
            this.__index = value;
            this.owner.skin = this.arraySkin[value];
        }
        clip_update() {
            this.__index++;
            if (this.__index < this.arraySkin.length) {
                this.owner.skin = this.arraySkin[this.__index];
            } else
                if (this.repeat) {
                    if (this.playComToNextPlayDelay > 0) {
                        this.stop();
                        // this.owner.visible = false;
                        Laya.timer.once(this.playComToNextPlayDelay, this, this.play, [0]);
                    } else {
                        this.__index = 0;
                        this.owner.skin = this.arraySkin[this.__index];
                    }
                } else {
                    this.stop();
                    this.owner.completeHandler && this.owner.completeHandler(this.owner);
                }
        }
        stop() {
            this.__playing = false;
            Laya.timer.clearAll(this);
        }
    }
    window.ClipL = ClipL;

    class Btn_Scale extends Laya.Script {

        constructor() {
            super();

            /** @prop {name:scale_coe, tips:"按钮按下缩放程度", type:Number, default:0.92}*/
            this.scale_coe = 0.92;
            /** @prop {name:scale_time, tips:"按钮按下缩放程度消耗时间", type:Number, default:100}*/
            this.scale_time = 100;
        }
        onAwake() {
            this.owner.right = NaN;
            this.owner.left = NaN;
            this.owner.top = NaN;
            this.owner.bottom = NaN;
            this.owner.centerX = NaN;
            this.owner.centerY = NaN;
            this.scaleX_origin = this.owner.scaleX;
            this.scaleY_origin = this.owner.scaleY;
            if (this.owner.anchorX != undefined) {
                if (this.owner.anchorX != 0.5 && this.owner.anchorY != 0.5) {
                    this.owner.anchorX = 0;
                    this.owner.anchorY = 0;
                    this.owner.anchorX = 0.5;
                    this.owner.anchorY = 0.5;
                    this.owner.x += this.owner.width * this.scaleX_origin / 2;
                    this.owner.y += this.owner.height * this.scaleY_origin / 2;
                }
            } else if (this.owner.pivotX != this.owner.width / 2 && this.owner.pivotY != this.owner.height / 2) {
                this.owner.pivotX = 0;
                this.owner.pivotY = 0;
                this.owner.pivotX = this.owner.width / 2;
                this.owner.pivotY = this.owner.height / 2;
                this.owner.x += this.owner.width * this.scaleX_origin / 2;
                this.owner.y += this.owner.height * this.scaleY_origin / 2;
            }
        }
        onMouseDown(e) {
            Laya.Tween.clearAll(this.owner);
            Laya.Tween.to(this.owner, {
                scaleX: this.scale_coe * this.scaleX_origin,
                scaleY: this.scale_coe * this.scaleY_origin
            }, this.scale_time);
        }
        onMouseOut(e) {
            Laya.Tween.clearAll(this.owner);
            Laya.Tween.to(this.owner, {
                scaleX: 1 * this.scaleX_origin,
                scaleY: 1 * this.scaleY_origin
            }, this.scale_time);
        }
        onMouseUp(e) {
            Laya.Tween.clearAll(this.owner);
            Laya.Tween.to(this.owner, {
                scaleX: 1 * this.scaleX_origin,
                scaleY: 1 * this.scaleY_origin
            }, this.scale_time);
        }
        onDisable() {
            Laya.Tween.clearAll(this.owner);
            this.owner.scaleX = 1 * this.scaleX_origin;
            this.owner.scaleY = 1 * this.scaleY_origin;
        }
    }
    window.Btn_Scale = Btn_Scale;

