    while (e < d) {
        var f = 0;
        e = 0;
        for (var i = 0; i < d; i++) {
            if (!a[i][c] && a[i][c] != 0) e++;
            f += a[i][c] ? Number(a[i][c]) : 0
        }
        if (e < d) b.push(f);
        c++
    }
    return b
}
Calculator.prototype.tosingle2 = function (a) {
    var b = [];
    var c = 0;
    for (var i = 0; i < a.length; i++) {
        var d = a[i] + c;
        if (d >= 0) {
            b.push(d % 10);
            c = parseInt(d / 10)
        } else {
            if (d % 10 == 0) {
                b.push(d % 10);
                c = parseInt(d / 10)
            } else {
                b.push(10 + (d % 10));
                c = parseInt((d / 10) - 1)
            }
        }
    }
    while (c > 9 || c < -9) {
        var d = a[i] + c;
        if (d >= 0) {
            b.push(d % 10);
