    for (var i = 0; i < f; i++) {
        if (!c[i] && c[i] != 0) {
            var a = 0
        } else {
            var a = Number(c[i])
        }
        if (!d[i] && d[i] != 0) {
            var b = 0
        } else {
            var b = Number(d[i])
        }
        e.push(a - b)
    }
    return this.tosingle2(e)
}
Calculator.prototype.contrast = function (a, b) {
    var c = a.length;
    var d = b.length;
    if (c < d) {
        return false
    } else if (c == d) {
        for (var i = c - 1; i > -1; i--) {
            if (Number(a[i]) < Number(b[i])) {
                return false
            } else if (Number(a[i]) > Number(b[i])) {
                return true
            }
        }
    }
    return true
}
