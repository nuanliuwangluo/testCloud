class GameMainSeven extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_seven',
            layer: 'panel'
        })
        this.btn_close.addComponent(S_click_GameMainSeven_close)
        this.btn_videoSelect.addComponent(S_click_GameMainSeven_videoSelect)
        // img, url, delay, repeat, completeHandler
    }

    added() {
        game.server.send(3326, __data.domain)
        miniApi.setItem(__data.uid + ':' + new Date().toDateString() + ':show_panel_seven', 1)
        this.update_seven_data()
        game.cb.on('update_seven_data', this, this.update_seven_data)

        let isVideoSuccess = __data.shareVideoRule.ifVideoSuccessUseRule('adunit-f1c8c5f315e4054e')
        this.update_video_ready({ adUnitId: 'adunit-f1c8c5f315e4054e', isSuccess: isVideoSuccess })
    }

    onDisable() {
        game.cb.off('update_seven_data', this, this.update_seven_data)
        hallTestShowPanel()
        this.img_hand.clipStop()

        let g1 = ResUtils.getFileName(['cdn.a_seven'])
        for (const iterator of g1) {
            Laya.loader.clearTextureRes(iterator)
        }
        // Laya.loader.clearResByGroup('cdn.a_seven')
    }
    update_video_ready(r) {
        this.videoR = r
        if (!r.isSuccess) {
            // __data.shareVideoRule.total_shareShowCount(this.img_share.parent)
            this.img_video.visible = false
            this.img_share.visible = true
        } else {
            this.img_video.visible = true
            this.img_share.visible = false
        }
    }
    clickMask() { }
    update_seven_data() {
        this.img_hand.clipStop()
        this.img_hand.visible = false;
        for (let index = 1, length = 7; index <= length; index++) {
            this[`sevenItem${index}`].dataSource = __data.seven.seven_data[index]
            let vo = __data.seven.seven_data[index];
            if (__data.seven.seven_todayIsHasReceive == 0 && vo.day - 1 == __data.seven.seven_hasReceiveNum) {
                this.img_hand.x = this[`sevenItem${index}`].x + 20
                this.img_hand.y = this[`sevenItem${index}`].y
                this.img_hand.visible = true;
                this.img_hand.clipPlay()

                if (index == 7) {
                    this.img_hand.x = this[`sevenItem${index}`].x + 50
                    this.img_hand.y = this[`sevenItem${index}`].y + 100
                }
            }
        };
    }
}

class S_click_GameMainSeven_close extends Laya.Script {
    onClick() {
        game.scene.remove(GameMainSeven)
    }
}

class S_click_GameMainSeven_videoSelect extends Laya.Script {
    onClick() {
        this.owner.skin = (this.owner.skin == 'common/bt_g1.png') ? 'common/bt_g2.png' : 'common/bt_g1.png';
        game.cb.event('update_seven_select', [this.owner.skin == 'common/bt_g2.png'])
    }
}

class GameMainSevenItem1 extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_sevenItem1',
            module: false
        })
        this.__vo;
        this.addComponent(S_click_GameMainSevenItem)
    }
    onEnable() {
        game.cb.on('update_seven_select', this, this.update_seven_select)
    }
    onDisable() {
        game.cb.on('update_seven_select', this, this.update_seven_select)
        this.clearAwait && this.clearAwait()
    }

    async update_seven_select(isMul) {
        let mul = 1;
        if (isMul) mul = 5

        let start_ob = {
            v: Number(this.curValue)
        };
        let t = Laya.Tween.to(start_ob, {
            v: Number(this.__vo.propNum * mul)
        }, 200)
        t.update = new Laya.Handler(this, function () {
            this.txt_name.text = Math.floor(start_ob.v) + '' + PropIcon.icon[this.__vo.propId].name
        })
        await __tool.tweenp(this.txt_name, { scaleX: 1.2, scaleY: 1.2 }, 100)
        await __tool.tweenp(this.txt_name, { scaleX: 1, scaleY: 1 }, 100)
        this.txt_name.text = bigNumberToCH(this.__vo.propNum * mul) + '' + PropIcon.icon[this.__vo.propId].name
        this.curValue = this.__vo.propNum * mul
    }

    set dataSource(vo) {
        if (!vo) return;
        this.__vo = vo;
        this.txt_day.text = vo.title;
        this.img_hasReceive.visible = false;
        this.img_bg.skin = 'cdn/a_seven/bt_day_a1.png';
        this.txt_day.color = '#28753f'
        this.txt_name.color = '#28753f'

        if (vo.day <= __data.seven.seven_hasReceiveNum) {
            this.img_hasReceive.visible = true;
        } else if (__data.seven.seven_todayIsHasReceive == 0 && vo.day - 1 == __data.seven.seven_hasReceiveNum) {
            this.img_bg.skin = 'cdn/a_seven/bt_day_a2.png';
            this.txt_day.color = '#bc5737'
            this.txt_name.color = '#bc5737'
        }

        let gs = game.scene.get(GameMainSeven)
        let mul = 1
        if (gs.btn_videoSelect.skin == 'common/bt_g2.png') mul = 5
        this.txt_name.text = bigNumberToCH(this.__vo.propNum * mul) + '' + PropIcon.icon[vo.propId].name
        this.img_prop.skin = vo.propIcon
        this.curValue = vo.propNum * mul
    }
}
Laya.ClassUtils.regClass('ui.scene_hall.gameMain_sevenItem1UI', GameMainSevenItem1);

