class S_click_GameMainSevenItem extends Laya.Script {
    async onClick() {
        trace('点击七日登陆奖励item');
        if (this.owner.__vo.day - 1 == __data.seven.seven_hasReceiveNum && __data.seven.seven_todayIsHasReceive == 0) {
            // 能领取
            let gs = game.scene.get(GameMainSeven)
            if (gs.btn_videoSelect.skin == 'common/bt_g2.png') {
                // 视频领取
                // if (__data.vip.isVip) {
                //     game.server.send(2409, 1)
                // } else {
                if (gs.img_video.visible) {
                    let adunitId = gs.videoR.adUnitId
                    await miniApi.video_ready(adunitId)
                    miniApi.video_show(adunitId, () => {
                        game.server.send(2409, 1)
                    }, () => {
                        __tips('暂无广告，请稍后再试或开通VIP')
                    }, 0);
                    let n = __data.vip.isVip ? 'VIP领取' : '参与广告'
                    miniApi.trackEvent('Mj_ADClick', { Mj_ADPreference: miniApi.adUserValueLevel, 'Mj_ADScene': '七日签到', 'Mj_Participation': n })
                } else {
                    // __data.shareVideoRule.total_clickShareCount()
                    miniApi.share({
                        titleId: __tool.randomRange(1, 9),
                        shareVerifyOnShowFnTime: __data.shareVideoRule.isVerifyShareOnShowTime,
                        params: `uid=${__data.uid}&shareRewardType=sevenShare&myCityId=${__data.myCityId}`,
                        shareGroupClickCallback: () => {
                            game.server.send(2409, 2)
                            game.scene.remove(GameMainRedPacket_2)
                        },
                        shareOnShowCallback: () => {
                            game.scene.add(GameMainRedPacket_2)
                        }
                    })
                    miniApi.trackEvent('Mj_ShareClick', { Mj_ADPreference: miniApi.adUserValueLevel, 'Mj_ShareScene': '七日签到', 'Mj_Participation': '参与分享' })
                }
                // }
            } else {
                // 直接发送领取
                game.server.send(2409, 0)
                miniApi.trackEvent('Mj_ADClick', { Mj_ADPreference: miniApi.adUserValueLevel, 'Mj_ADScene': '七日签到', 'Mj_Participation': '免费领取' })
            }
        }
    }
}