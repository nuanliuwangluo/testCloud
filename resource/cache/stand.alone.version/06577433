class GameMainExchangeCode extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_exchangeCode',
            layer: 'panel'
        })
        this.btn_sure.addComponent(S_exchangeCode_sure)
        this.btn_paste.addComponent(S_exchangeCode_paste)
    }
    onAwake() {

    }
    onEnable() {
        this.txt.text = ''
    }
    onDisable() {
        ResUtils.clearTextureRes(['cdn.exchangeCode'])
    }
}
class S_exchangeCode_sure extends Laya.Script {
    onClick(e) {
        let code = this.owner.parent.txt.text;
        if (!code) {
            return __tips('请输入兑换码')
        }
        game.server.send(13006, code)
    }
}
class S_exchangeCode_paste extends Laya.Script {
    onClick(e) {
        miniApi.paste((e) => {
            this.owner.parent.txt.text = e;
        })
    }
}