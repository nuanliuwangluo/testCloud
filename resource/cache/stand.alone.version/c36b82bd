            // 断网 or 超时
            miniApi.alert('提示', '微信登录失败，请重新打开游戏', miniApi.restart, miniApi.exit)
            return
        }
        // type 1正常 0过时 2超前
        // {"protocol":"https","port":"18050","url":"mjxcc.snyngame.com","type":"open"}
        a = a || { data: {} }
        if (a && a.data && a.data.type == 0) {
            // 黄哥增加属性 判断 版本不一致 补进入游戏
