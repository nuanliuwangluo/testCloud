let initSocket = function () {
    return new Promise(async (resolve, reject) => {
        !initSocket_resolve && (initSocket_resolve = resolve);
        game.server = game.server || new game.Net();
        // game.server.registeReadList(HallRead)
        // game.server.registeSendList(HallSend)
        game.cb.on('heart_beat_stop', game, socket_io_disconnect)
        game.cb.on('socketFail', game, socket_io_fail)
        game.cb.on('socketClose', game, socket_io_disconnect)
        game.cb.on('socketError', game, socket_io_error)
        game.cb.on('socketConnect', game, socket_io_connect)
        game.cb.on('socketTimeOut', game, socket_io_timeout)

        game.server.clear();
        game.server.registeSendMsg(__socket_msg_hall_send, __socket_match_send)
        game.server.registeReadMsg(__socket_msg_hall_read, __socket_match_read)
        game.server.connect(config.protocol, config.ip, config.port)
    })
}
let clearConnect = () => {
