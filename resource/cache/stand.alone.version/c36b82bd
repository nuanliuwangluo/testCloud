let checkBranchSwitch = (data, platform) => {
    let version = data[0];
    if (platform == Platform.APP) {
        if (version && version.appLoginState == 0) { return false; }
    } else if (platform == Platform.WX) {
        if (version && version.miniLoginState == 0) { return false; }
    }
    return true;
}
let reqVerCfg = () => {
    return new Promise(async (resolve, reject) => {
        if (__data.versionInfo) {
            return resolve(__data.versionInfo)
        }
        let a1 = await miniApi.axios({
            url: `https://${config.reqIpUrl}:8111/server/reqVerCfg`,
            method: 'get',
        }).catch((e) => { })

        let vercfg = __tool.gdp(a1, 'data.vercfg')
        if (!vercfg) {
            miniApi.trackEvent('Mj_Error', { 'Mj_ErrorType': `undefined`, 'Mj_ErrorInfo': `获取http黄哥版本信息服务失败` })
            __showScene.show_prompt_select("获取版本信息失败，请重新打开游戏", miniApi.restart, miniApi.exit)
            return null
        }
        let disableLoginInfo = __tool.gdp(a1, 'data.disableLoginInfo')
        let serverOpen = __tool.gdp(a1, 'data.serverOpen')
        if (!serverOpen || serverOpen === 'false') {
            __showScene.show_prompt_single(disableLoginInfo, '确定', miniApi.exit)
            return null
        }
        let b1 = JSON.parse(vercfg)
        let branchOpen = checkBranchSwitch(b1, miniApi.clientType);// 分支开关是否 开启
        if (!branchOpen) { // 如果关闭状态  不允许进入游戏
            __showScene.show_prompt_single(disableLoginInfo, '确定', miniApi.exit)
            return null
        }

        console.log('versioninfo', config.reqIpUrl, b1)
        let versionConfig = { wx: [], app: [] }
        __data.redPacket.updateState(b1);// 留存状态

        for (let index = 0, length = b1.length; index < length; index++) {
            let e = b1[index]
            if (e.wx_tag) {
                versionConfig.wx[e.wx_tag] = {
                    tag: e.wx_tag,
                    version: e.wx_version,
                    isCheck: !e.status,
                    content: e.content,
                }
            }
            if (e.ios_tag) {
                versionConfig.app[e.ios_tag] = {
                    tag: e.ios_tag,
                    version: e.ios_version,
                    isCheck: !e.status,
                    content: e.content,
                }
            }
        };
        function compareVersion(v1, v2) {
            v1 = v1.split('.')
            v2 = v2.split('.')
            const len = Math.max(v1.length, v2.length)

            while (v1.length < len) {
                v1.push('0')
            }
            while (v2.length < len) {
                v2.push('0')
            }

            for (let i = 0; i < len; i++) {
                const num1 = parseInt(v1[i])
                const num2 = parseInt(v2[i])

                if (num1 > num2) {
                    return 1
                } else if (num1 < num2) {
                    return -1
                }
            }
            return 0
        }
        let useC;
        if (miniApi.clientType == 'web') {
            useC = versionConfig.wx
        }
        else if (miniApi.clientType == 'wx') {
            useC = versionConfig.wx
        }
        else if (miniApi.clientType == 'app') {
            useC = versionConfig.app
        }
        let a = useC[config.clientVersion]
        if (!a) {
            let m = Object.keys(useC);
            m.sort(compareVersion)
            m.reverse()
            a = useC[m[0]]
        }
        if (config.useVersionIP) {
            if (a.isCheck) {
                config.reqIpUrl = 'testgame.snyngame.com';
                config.ip = config.reqIpUrl;
            } else {
                config.reqIpUrl = 'mjxcc.snyngame.com';
                config.ip = config.reqIpUrl;
            }
        }
        trace('config.reqIpUrl', config.reqIpUrl)
        // game.scene.get(Loading).update_version(a.version)
        __data.versionInfo = { version: a.version, content: a.content };
        resolve(__data.versionInfo);
    })
}
let verify_version = async () => {
    let { version, content } = await reqVerCfg()
    let v = version;
    v = v.replace('（', '(');
    v = v.replace('）', ')');
    let l_k = v.indexOf('(');
    let r_k = v.indexOf(')');
    let letterIndex = l_k;
    if (l_k > -1) v = v.replace('(', '')
    if (r_k > -1) v = v.replace(')', '')
    let v_1 = v.charAt(letterIndex).toUpperCase() // V P S F
    let v2 = v.replace(v_1, '') // 3.1.12.123
    let v3 = v2.toArray('.') // [3,1,12,123]
    let v4 = v3.slice(0, 3).join('.') // 3.1.12
    if (config.clientVersion == v4) {
        let n1 = config.versionK.slice(1) // 去掉.
        let n2 = v3[3] // 去掉.
        if (Number(n1) > Number(n2)) {
            firstLoadConnect()
        }
        else if (n1 != n2) {
            if (miniApi.clientType == 'wx') {
                if (v_1 == 'P' || v_1 == 'S') {
                    firstLoadConnect()
                } else if (v_1 == 'V' || v_1 == 'F') {
                    // 加载界面 手动重启弹框
                    __showScene.show_prompt_frame({
                        content: "当前游戏版本已停用，请尝试重启游戏以便更新至最新版本",
                        success: miniApi.exit,
                        btn_num: 1,
                    })
                }
            } else if (miniApi.clientType == 'app') {
                if (v_1 == 'P') {
                    // 加载界面提示更新 玩家可以不更新
                    __showScene.show_prompt_frame({
                        title: '发现新版本',
                        content: content,
                        success: miniApi.toMarket,
                        fail: firstLoadConnect,
                        btn_num: 2,
                        txt_sure: '立即更新',
                        txt_cancel: '下次再说',
                    })
                } else if (v_1 == 'V') {
                    // 加载界面 强制更新弹框
                    __showScene.show_prompt_frame({
                        title: '发现新版本',
                        content: content,
                        success: miniApi.toMarket,
                        btn_num: 1,
                        txt_sure: '立即更新',
                    })
                } else if (v_1 == 'S') {
                    // 直接进游戏 静默更新
                    window.AppHotUpdate && AppHotUpdate.update()
                    firstLoadConnect()
                } else if (v_1 == 'F') {
                    // 加载界面 强制热更新
                    game.scene.get(Loading).addLoadingBar();
                    game.cb.on('HotUpdate_tips', this, app_hot_update_loading_update_tips);
                    game.cb.on('HotUpdate_progress', this, app_hot_update_loading_update_pro);
                    game.cb.on('HotUpdate_stop', this, app_hot_update_loading_update_stop);
                    window.AppHotUpdate && AppHotUpdate.update(true)
                }
            } else if (miniApi.clientType == 'web') {
                firstLoadConnect()
            }
        } else {
            firstLoadConnect()
        }
    } else {
        if (miniApi.clientType == 'wx') {
            // 加载界面 手动重启弹框
            // __showScene.show_prompt_single("当前游戏版本已停用，请尝试重启游戏以便更新至最新版本", '确定', miniApi.exit)
            __showScene.show_prompt_frame({
                title: '发现新版本',
                content: content,
                success: miniApi.restart,
                fail: miniApi.exit,
                btn_num: 2,
                txt_sure: '立即更新',
                txt_cancel: '下次再说',
            })
        } else if (miniApi.clientType == 'app') {
            // 加载界面 强制更新弹框
            __showScene.show_prompt_frame({
                title: '发现新版本',
                content: content,
                success: miniApi.toMarket,
                btn_num: 1,
                txt_sure: '立即更新',
            })
        } else if (miniApi.clientType == 'web') {
            // 加载界面 强制更新弹框
            __showScene.show_prompt_frame({
                title: '发现新版本',
                content: content,
                success: miniApi.toMarket,
                btn_num: 1,
                txt_sure: '立即更新',
            })
        }
    }
}
