            game.scene.remove(LoadingAwait)
            // miniApi.alert('提示', '未知版本错误' + a.data.error, miniApi.exit, miniApi.exit)
            return
        }
        // if (config.useVersionIP) {
        if (a.data.port) {
            // https审核里面复制了 这里只用端口
            // config.ip = a.data.url;
            config.port = a.data.port;
        }
        // 设置openid如果没有保留上次的
        a.data.uuid && (__data.openid = a.data.uuid);
        a.data.appleid && (__data.openid = a.data.appleid);
        a.data.account && (__data.openid = a.data.account);
        // 统计上报uuid openid
        a.data.uuid && miniApi.adsdk_setUUID(a.data.uuid)
        a.data.openid && miniApi.adsdk_setOpenID(a.data.openid)
        a.data.openid && miniApi.setOpenid(a.data.openid)

        window.wx && wx.adsdk && wx.adsdk.onAppStart()
        if (!__data.openid) {
