class Mahjong_Limit_Time_Script extends Laya.Script {
    constructor() {
        super();

        this.__mark = new Laya.Sprite();
        this.__pie = new Laya.Sprite();

        this.__label = new Laya.Label();
        this.__label.fontSize = 30;
        this.__label.color = '#ffffff'
        this.__label.align = 'center'
        this.__label.valign = 'middle'
        this.__label.width = this.__label.height = 60;

        //多少毫秒执行一次重绘cd效果
        this.__time_unit = 100;
        //半径
        this.__radius = 0;
        //起始的角度
        this.__startAngle = 0;
        //每次改变的角度
        this.__eventAngle = 0;
        //总时间
        this.__allTime = 0;
        //回调函数
        this.__callback = null
    }

    onEnable() {
        if (!this.owner) {
            return
        }
        this.__radius = Math.hypot(this.owner.width / 2, this.owner.height / 2)
        // let __radius = Math.sqrt( (this.owner.width / 2)*(this.owner.width / 2) + (this.owner.height / 2)*(this.owner.height / 2)) / 2
        this.__mark.graphics.drawRect(0, 0, this.owner.width, this.owner.height, '#000000')
        //中心点 x，y ，radius，startAngel， endAngel
        this.__pie.graphics.drawPie(this.owner.width / 2, this.owner.height / 2, this.__radius, 0, 360, '#fff000')
        this.__mark.alpha = .3
        // this.owner.addChild(this.__mark)
        // this.__mark.mask = this.__pie;
    }

    onDisable() {
        game.utils.remove(this.__mark)
        game.utils.remove(this.__label)
        Laya.timer.clear(this, this.updateLabelHandler)
        Laya.timer.clear(this, this.updatePieHandler)
    }

    start(time, showTxt, callback) {
        this.__startAngle = 0;
        this.__eventAngle = 360 / ((time * 1000) / this.__time_unit)
        this.updatePieHandler();
        Laya.timer.loop(this.__time_unit, this, this.updatePieHandler)

        if (showTxt) {
            this.owner.addChild(this.__label)
            this.__label.x = this.owner.width - this.__label.width >> 1
            this.__label.y = this.owner.height - this.__label.height >> 1
        } else {
            game.utils.remove(this.__label)
        }

        this.__allTime = time
        this.updateLabelHandler();
        Laya.timer.loop(1000, this, this.updateLabelHandler)

        this.__callback = callback
    }

    updatePieHandler() {
        this.__startAngle += this.__eventAngle
        this.__pie.graphics.clear();
        this.__pie.graphics.drawPie(this.owner.width / 2, this.owner.height / 2, this.__radius, this.__startAngle, 360, '#fff000')
        this.__mark.mask = this.__pie;
    }

    updateLabelHandler() {
        this.__allTime -= 1;
        this.__label.text = this.__allTime.toString();
        //游戏结束
        if (this.__allTime < 0) {
            game.utils.remove(this.__mark)
            game.utils.remove(this.__label)
            this.__callback && this.__callback();
            Laya.timer.clear(this, this.updateLabelHandler)
            Laya.timer.clear(this, this.updatePieHandler)
            this.destroy();
            // this.owner.getComponent(Mahjong_Limit_Time_Script).destroy();
        }
    }
}



class Mahjong_VoiceAni_Script extends Laya.Script {
    constructor() {
        super();
        this.__ani = new Laya.Image();
        this.flagName = 'ts';
    }

    onEnable() {
        let head = this.owner.getChildByName('head');
        this.__time = 0
        this.__ani.skin = 'local/desk_common_ui/1/mica1.png'
        this.__ani.size(head.width * 0.88, head.height * 0.88)
        this.__ani.x = head.x + (head.width - this.__ani.width) / 2;
        this.__ani.y = head.y + (head.height - this.__ani.height) / 2;
        try {
            this.owner.addChildAt(this.__ani, this.getIndex());
        } catch (e) {
            this.owner.addChild(this.__ani);
        }
    }

    onDestroy() {
        game.utils.remove(this.__ani);
    }

    getIndex() {
        let flagView = this.owner.getChildByName(this.flagName);
        let flagIndex = this.owner.getChildIndex(flagView);
        return flagIndex + 1;
