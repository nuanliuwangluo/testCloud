class Hand_Strategy_Script extends Laya.Script {

    onEnable() {
        game.cb.on(__eh + 'out_card', this, this.destroySelf);
    }
    onDisable() {
        this.clear();
        game.cb.off(__eh + 'out_card', this, this.destroySelf);
    }

    destroySelf() {
        this.destroy();
    }

    strategy(strategy) {
        this._strategy = strategy;
        this.offy = 10;
        this.createImage();
        this.calibration();
        // this.tween();
    }

    createImage() {
        this.image = new Laya.Image(this.getSkin());
        this.image.pivot(this.image.width / 2, this.image.height);
        this.container.addChild(this.image);
    }

    getSkin() {
        // 推荐
        let inCommon = this._strategy.commonKeys.some(value => value == this.owner.card);
        if (inCommon) return `cdn/mahjong_ting/img_jian.png`;
        // 大
        let inMaxRate = this._strategy.maxRateKeys.some(value => value == this.owner.card);
        if (inMaxRate) return `cdn/mahjong_ting/img_da.png`;
        // 多
        let inMaxNum = this._strategy.maxNumSumKeys.some(value => value == this.owner.card);
        if (inMaxNum) return `cdn/mahjong_ting/img_duo.png`;
        return "";
    }

    onLateUpdate() {
        this.calibration();
    }

    calibration() {
        let point = this.convertLocalToLocal(this.owner, this.container);
        let isChange = false;
        if (point.x != this.originalX) { isChange = true; this.originalX = point.x; }
        if (point.y != this.originalY) { isChange = true; this.originalY = point.y; }
        if (this.image && this.owner && isChange) {
            this.image.pos(point.x + this.owner.width / 2, this.originalY - this.offy);
            // Laya.Tween.clearAll(this.image);
            // this.tween();
        }
        return point;
    }

    get container() {
        if (!this._desk) {
            let uniqueId = MahjongConfig.getUniqueId(__data.gameId.lastId, __data.gameId.lastRuleId);
            this._desk = game.scene.get(window['MahjongDesk' + uniqueId + '3D']).game.getChildByName('desk');
        }
        return this._desk;
    }

    /**
     * 将A对象的本地坐标转换到B对象的本地坐标
     * @param aObj 源对象
     * @param bObj 目标对象
     * @returns 目标对象的本地坐标
     */
    convertLocalToLocal(aObj, bObj) {
        // 1. A的本地坐标 -> 全局坐标
        const globalPos = aObj.localToGlobal(new Laya.Point());
        // 2. 全局坐标 -> B的本地坐标
        const bLocalPos = bObj.globalToLocal(globalPos);
        return bLocalPos;
    }

    tween() {
        // 上升：快速 (300ms)
        Laya.Tween.to(this.image,
            { y: this.originalY - this.offy - 25 },
            400,
            Laya.Ease.circOut,
            Laya.Handler.create(this, () => {
                // 下落：慢速 (450ms)
                Laya.Tween.to(this.image,
                    { y: this.originalY - this.offy },
                    400,
                    Laya.Ease.circIn,
                    Laya.Handler.create(this, this.tween)
                );
            })
        );
    }

    clear() {
        // Laya.Tween.clearAll(this.image);
        game.utils.remove(this.image);
        this.image = null;
    }

    onDestroy() {
        this.clear();
    }
}










class Hand_Drag_Script extends Laya.Script {

    constructor() {
        super();
        this.__noEvent = false;
    }

    onEnable() {
        this.__choiceOffy = 30
        this.__vague = { x: 5, y: 5 };
        this.__value = this.owner
        this.relocation();
    }

    onDisable() { }

    onDestroy() {
        this.__noEvent = false;
    }

    relocation() {
        this.__inity = this.owner.y
    }

    onMouseDown(e) {
        this.__initx = this.owner.x
        game.cb.event(__eh + 'show_hu_preview');
        //不可以操作哦
        if (this.__noEvent) {
            return
        }
        // 自动打牌状态 如果为true   表示在自动打牌不可以进行操作
        if (this.autoStatus) { __tips('请先取消自动摸打/胡牌'); return }

        __sound.gameSound('click_card')

        this.value = true

        this.__value.parent.addChild(this.__value)

        let __off_point = this.__value.globalToLocal(new Laya.Point(Laya.stage.mouseX, Laya.stage.mouseY))
        this.__offx = __off_point.x
        this.__offy = __off_point.y

        this.update();

        this.__choice = true;
        game.cb.event(__eh + 'hand_card_choice', [this.__value])

        game.cb.event(__eh + 'show_choice_ot', [this.__value.card])
    }

    onMouseMove(e) {
        // if (!this.value) { return }
        // this.update();
    }

    onUpdate() {
        if (this.value) {
            if (Laya.stage.mouseX >= Laya.stage.width - this.__vague.x || Laya.stage.mouseX <= this.__vague.x) { this.reset(); return; }
            if (Laya.stage.mouseY >= Laya.stage.height - this.__vague.y || Laya.stage.mouseY <= this.__vague.y) { this.reset(); return; }
            this.update();
        }
    }

    update() {
        let __aim_point = this.__value.parent.globalToLocal(new Laya.Point(Laya.stage.mouseX, Laya.stage.mouseY))

        this.__value.x = __aim_point.x - this.__offx
        this.__value.y = __aim_point.y - this.__offy
    }


    onDoubleClick(e) {
        trace('双击')
    }

    onStageClick(e) {
        if (e && e.target != this.owner) {
            if (this.__choice) {
                this.cancelChoice();
                game.cb.event(__eh + 'show_hu_preview');
                game.cb.event(__eh + 'show_choice_ot');
            }
        }
    }

    onMouseUp(e) {
        // this.reset();
    }

    onStageMouseUp(e) {
        if (!this.value) return
        this.reset();
    }

    onMouseOut(e) {
        // if (this.value) {
        //     this.reset();
        // };
    }

    cancelChoice() {
        if (!this.__value) return
        this.__choice = false;
        this.__value.y = this.__inity
    }

    reset() {
        if (!this.__value) return

        this.value = false;
        if (this.__value.y <= this.__inity - this.__choiceOffy && __data.deskData.isCanPlay) {
            // let __tempPoint = this.__value.parent.localToGlobal(new Laya.Point(this.__initx + this.__value.width / 2, this.__inity));
            let __tempPoint = this.__value.parent.localToGlobal(new Laya.Point(this.__value.x + this.__value.width / 2, this.__value.y + this.__value.height / 2));
            game.cb.event(__eh + 'out_card', [this.owner, __tempPoint])
            game.cb.event(__eh + 'show_choice_ot')
            return
        }

        this.__value.x = this.__initx
        this.__value.y = this.__inity

        if (this.__choice) {
            let __tempPoint = this.__value.parent.localToGlobal(new Laya.Point(this.__value.x + this.__value.width / 2, this.__value.y - this.__choiceOffy - 10));
            game.cb.event(__eh + 'show_hu_preview', [this.__value.card, __tempPoint]);
            this.__value.y = this.__inity - this.__choiceOffy
        }


    }

    //不可以操作牌
    unuse(notArr) {
        if (!notArr) {
            return;
        } else if (this.__value && parseInt(this.__value.card) >= 0) {
            for (let i = 0; i < notArr.length; i++) {
                if (parseInt(this.__value.card) == parseInt(notArr[i])) {
                    this.__noEvent = true;
                }
            }
        }
    }

    get autoStatus() {
        let myVo = __data.deskData.roomVo.getPlayerBySeat(0);
        return myVo ? myVo.tingAutoStatus : false;
    }
}



