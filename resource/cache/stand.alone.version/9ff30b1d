class MahjongDesk_Compass_Scipt extends Laya.Script {

    onEnable() {
        this.__compass = this.owner.game.getChildByName('compass_box').getChildByName('compass')
        this.__compassDir = this.owner.game.getChildByName('compass_box').getChildByName('compass_dir')

        game.cb.on(__eh + 'change_compass', this, this.changeCompass)
        game.cb.on(__eh + 'change_dir', this, this.changeDir)
    }

    onDisable() {
        game.cb.on(__eh + 'change_compass', this, this.changeCompass)
        game.cb.on(__eh + 'change_dir', this, this.changeDir)
    }

    changeDir() {
        //获取位置上第一个人的信息  东始终指向位置1的人 
        let __vo = __data.deskData.roomVo.getPlayer(1);
        if (!__vo) return
        if (__vo.seat_tag == 'down') {
            this.__compass.rotation = 180
        } else if (__vo.seat_tag == 'right') {
            this.__compass.rotation = 90
        } else if (__vo.seat_tag == 'up') {
            this.__compass.rotation = 0
        } else if (__vo.seat_tag == 'left') {
            this.__compass.rotation = 270
        }
    }

    //改变操作者  value  操作者的id  或者位置
    changeCompass(value) {
        let __vo = __data.deskData.roomVo.getPlayer(value);
        if (!__vo) return
        if (__vo.seat_tag == 'down') {
            this.__compassDir.rotation = 0
        } else if (__vo.seat_tag == 'right') {
            this.__compassDir.rotation = 270
        } else if (__vo.seat_tag == 'up') {
            this.__compassDir.rotation = 180
        } else if (__vo.seat_tag == 'left') {
            this.__compassDir.rotation = 90
        }

        trace('操作者： ', __vo.seat_tag, this.__compassDir.rotation)
    }
}




class MahjongDesk_Compass3D_Scipt extends Laya.Script {

    onAwake() {
        this.downMaterial = new Laya.UnlitMaterial();
        this.rightMaterial = new Laya.UnlitMaterial();
        this.upMaterial = new Laya.UnlitMaterial();
        this.leftMaterial = new Laya.UnlitMaterial();

        this.downMaterial.renderMode = this.rightMaterial.renderMode = this.upMaterial.renderMode = this.leftMaterial.renderMode = Laya.UnlitMaterial.RENDERMODE_TRANSPARENT

        this.defaultMaterial = new Laya.UnlitMaterial();
        this.defaultMaterial.renderMode = Laya.UnlitMaterial.RENDERMODE_TRANSPARENT;
    }

    onEnable() {
        this.compass = __data.deskData.roomVo.scene.getChildByName('Desk').getChildByName('compass');

        this.createMaterial();
        this.compass.meshRenderer.material.albedoTexture = this.defaultMaterial.albedoTexture;
        // this.compass.transform.localPosition = new Laya.Vector3(0, 0.5, 0);
        game.cb.on(__eh + 'change_compass', this, this.changeCompass)
        game.cb.on(__eh + 'change_dir', this, this.changeDir)
        game.cb.on(__eh + 'ready_to_clear', this, this.clearCompass)
    }

    onDisable() {
        this.sureDir = false;
        game.cb.off(__eh + 'change_compass', this, this.changeCompass)
        game.cb.off(__eh + 'change_dir', this, this.changeDir)
        game.cb.off(__eh + 'ready_to_clear', this, this.clearCompass)
    }

    changeDir() {

        //获取位置上第一个人的信息  东始终指向位置1的人 
        let __vo = __data.deskData.roomVo.getPlayer(1);
        if (!__vo) return
        this.sureDir = true;
        if (__vo.seat_tag == 'down') {
            this.compass.transform.rotationEuler = new Laya.Vector3(0, 90, 0);
        } else if (__vo.seat_tag == 'right') {
            this.compass.transform.rotationEuler = new Laya.Vector3(0, 180, 0)
        } else if (__vo.seat_tag == 'up') {
            this.compass.transform.rotationEuler = new Laya.Vector3(0, 270, 0)
        } else if (__vo.seat_tag == 'left') {
            this.compass.transform.rotationEuler = new Laya.Vector3(0, 0, 0)
        }

        this.createMaterial(__vo.seat_tag)
    }

    createMaterial(type) {
        this.defaultMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/compress.png')
        switch (type) {
            case 'down':
                this.downMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/dong.png')
                this.rightMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/nan.png')
                this.upMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/xi.png')
                this.leftMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/bei.png')
                break;
            case 'right':
                this.downMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/bei.png')
                this.rightMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/dong.png')
                this.upMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/nan.png')
                this.leftMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/xi.png')
                break;
            case 'up':
                this.downMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/xi.png')
                this.rightMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/bei.png')
                this.upMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/dong.png')
                this.leftMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/nan.png')
                break;
            case 'left':
                this.downMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/nan.png')
                this.rightMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/xi.png')
                this.upMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/bei.png')
                this.leftMaterial.albedoTexture = Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Textures/dong.png')
                break;
        }
    }

    //改变操作者  value  操作者的id  或者位置
    changeCompass(value) {
        if (!this.sureDir) this.changeDir();
        let __vo = __data.deskData.roomVo.getPlayer(value);
        if (!__vo) return

        if (__vo.seat_tag == 'down') {
            this.compass.meshRenderer.material.albedoTexture = this.downMaterial.albedoTexture;
        } else if (__vo.seat_tag == 'right') {
            this.compass.meshRenderer.material.albedoTexture = this.rightMaterial.albedoTexture;
        } else if (__vo.seat_tag == 'up') {
            this.compass.meshRenderer.material.albedoTexture = this.upMaterial.albedoTexture;
        } else if (__vo.seat_tag == 'left') {
            this.compass.meshRenderer.material.albedoTexture = this.leftMaterial.albedoTexture;
        }
        // trace('操作者： ', __vo.seat_tag, this.__compassDir.rotation)
    }

    clearCompass() {
        this.compass.meshRenderer.material.albedoTexture = this.defaultMaterial.albedoTexture;
    }
}





class MahjongDesk_Pop_Scipt extends Laya.Script {

    onAwake() {
        //清除pop
        this.owner.ready.getChildByName('popContainer').getChildByName('pop_down').visible = false
        this.owner.ready.getChildByName('popContainer').getChildByName('pop_right').visible = false
        this.owner.ready.getChildByName('popContainer').getChildByName('pop_up').visible = false
        this.owner.ready.getChildByName('popContainer').getChildByName('pop_left').visible = false

        this.owner.game.getChildByName('popContainer').getChildByName('pop_down').visible = false
        this.owner.game.getChildByName('popContainer').getChildByName('pop_right').visible = false
        this.owner.game.getChildByName('popContainer').getChildByName('pop_up').visible = false
        this.owner.game.getChildByName('popContainer').getChildByName('pop_left').visible = false
    }

    onEnable() {
        game.cb.on('mahjong_' + "add_chat_content", this, this.chatHandler)
    }

    onDisable() {
        game.cb.off('mahjong_' + "add_chat_content", this, this.chatHandler)
    }

    chatHandler(type, id, chat_id) {
        let __target = __data.deskData.roomVo.getPlayer(id)
        //用户不存在
        if (!__target) return
        let __name = (__target.seat == __data.deskData.roomVo.countSeatBaseValue + __data.deskData.roomVo.seatInitPosition) ? 'pop_down' : (__target.seat == __data.deskData.roomVo.countSeatBaseValue + __data.deskData.roomVo.seatInitPosition + 1) ? 'pop_right' : (__target.seat == __data.deskData.roomVo.countSeatBaseValue + __data.deskData.roomVo.seatInitPosition + 2) ? 'pop_up' : (__target.seat == __data.deskData.roomVo.countSeatBaseValue + __data.deskData.roomVo.seatInitPosition + 3) ? 'pop_left' : ''

        let __phase = __data.deskData.roomVo.phase == 'ready' ? this.owner.ready.getChildByName('popContainer') : this.owner.game.getChildByName('popContainer');
        trace(__phase.getChildByName(__name))
        //pop不存在
        if (!__phase.getChildByName(__name)) return
        if (type == 'word') {
            //获取聊天信息
            let __info = Chat.wordConfig.filter(function (value) {
                return value.id == chat_id
            })
            if (!__info) return
            __info = __info[0]
            //显示聊天内容
            __phase.getChildByName(__name).getChildByName('txt').text = __info ? __info.content : ''
            //设置文本的宽高 和 泡泡框的宽高
            __phase.getChildByName(__name).getChildByName('txt').width = 350
            __phase.getChildByName(__name).getChildByName('frame').width = 400
            __phase.getChildByName(__name).getChildByName('frame').height = __phase.getChildByName(__name).getChildByName('txt').lines * 80

            // if(__phase.getChildByName(__name).visible)Laya.timer.clear(this, clearPop)
            //显示聊天泡
            __phase.getChildByName(__name).visible = true
            //隐藏表情和显示文本
            __phase.getChildByName(__name).getChildByName('face').visible = false
            __phase.getChildByName(__name).getChildByName('txt').visible = true

            __sound.gameSound(`t${Chat.INDEX}` + '/c' + __target.sex + '/chat_' + chat_id)

        } else if (type == 'face') {
            //确定当前聊天泡的正反方向
            let __flog = __phase.getChildByName(__name).getChildByName('frame').skin == 'local/chat/1/pop1.png' ? -1 : 1

            //表情皮肤更换
            __phase.getChildByName(__name).getChildByName('face').skin = 'local/chat/1/imoji' + chat_id.toString() + '.png'
            //设置泡泡框的宽高
            __phase.getChildByName(__name).getChildByName('frame').width = __phase.getChildByName(__name).getChildByName('face').width + 70
            __phase.getChildByName(__name).getChildByName('frame').height = __phase.getChildByName(__name).getChildByName('face').height + 30
            //根据聊天泡正反  设置表情位置
            __phase.getChildByName(__name).getChildByName('face').x = __flog == 1 ? 10 + __phase.getChildByName(__name).getChildByName('frame').width / 2 : -5 - __phase.getChildByName(__name).getChildByName('frame').width / 2
            __phase.getChildByName(__name).getChildByName('face').y = __phase.getChildByName(__name).getChildByName('frame').height / 2 - 5

            // if(__phase.getChildByName(__name).visible)Laya.timer.clear(this, clearPop)
            // 显示聊天泡
            __phase.getChildByName(__name).visible = true
            //显示表情和隐藏文本
            __phase.getChildByName(__name).getChildByName('face').visible = true
            __phase.getChildByName(__name).getChildByName('txt').visible = false
        }

        // function clearPop(){ __phase.getChildByName(__name).visible = false }

        // Laya.timer.once(__data.deskData.roomVo.chatTime, this, clearPop)

        __phase.getChildByName(__name).doPop = __phase.getChildByName(__name).doPop ? __phase.getChildByName(__name).doPop : this.createData(__phase.getChildByName(__name))
        __phase.getChildByName(__name).doPop.clear();
        __phase.getChildByName(__name).doPop.start();
    }

    createData(target) {
        return {
            start() {
                Laya.timer.once(__data.deskData.roomVo.chatTime, this, this.hidePop)
            },

            clear() {
                Laya.timer.clear(this, this.clear)
            },

            hidePop() {
                Laya.timer.clear(this, this.clear)
                target.visible = false
            }
        }
    }
}
