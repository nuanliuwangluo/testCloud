// 帧动画
class PlayComponent extends Laya.Script {

    // {startIndex,endIndex,loop,frame,prefix,tail,complete}
    start(params) {
        this.params = params;
        this._play();
        return this;
    }

    stop() {
        Laya.timer.clearAll(this);
    }

    _play() {
        this.index = this.params.startIndex;
        this._updateUI();
        Laya.timer.frameLoop(this.params.frame, this, this._onFrameLoop);
    }

    _end() {
        this.params.complete && this.params.complete();
        this.destroy();
    }

    onDestroy() {
        Laya.timer.clear(this, this._onFrameLoop);
        Laya.timer.clearAll(this);
    }

    _onFrameLoop() {
        this.index++;
        if (this.index > this.params.endIndex) {
            if (this.params.loop) {// 需要一直循环
                this.index = this.params.startIndex;
                if (this.params.delayFrame) {// 帧延迟执行下一个循环
                    this.index = this.params.endIndex;
                    Laya.timer.clear(this, this._onFrameLoop);
                    Laya.timer.frameOnce(this.params.delayFrame, this, this._play);
                } else if (this.params.delayTime) {// 时间延迟执行下一个循环
                    this.index = this.params.endIndex;
                    Laya.timer.clear(this, this._onFrameLoop);
                    Laya.timer.once(this.params.delayTime, this, this._play);
                }
            } else {// 一轮结束后直接终止
                this.index = this.params.endIndex;
                this._end();
            }
        }
        this._updateUI();
        this.params.update && this.params.update(this.index);
    }

    _updateUI() {
        let prefix = this.params.prefix;
        let tail = this.params.tail;
        this.owner && SkinUtils.setSkin(this.owner, `${prefix}${this.index}.${tail}`);
    }
}