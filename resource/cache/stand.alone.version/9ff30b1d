class ResListener extends Laya.Script {
    constructor() {
        super();
    }

    layer(_name) { this._name = _name; return this; }
    listen(type) { this._resType = type; return this; }
    start(callback) { this._start_callback = callback; return this; }
    every(callback) { this._every_callback = callback; return this; }
    then(callback) { this._end_callback = callback; return this; }

    getTypeIcon() {
        if (this._resType == 'cup') {
            return 'cdn/mahjong_result/mahjong_result/img_jb.png';
        }
    }

    onEnable() {
        game.cb.on('RESOURCE_RISE', this, this._riseAnimation);
    }

    onDisable() {
        game.cb.off('RESOURCE_RISE', this, this._riseAnimation);
    }

    /**
     * 
     * @param {number|string} type 资源类型
     * @param {number} number 资源数量
     * @param {Laya.Point} point 舞台位置
     * @param {number} vn 出现的数量
     */
    _riseAnimation(type, number, point, vn = 5) {
        this.resArr = [];
        // 类型匹配
        if (this._resType == type) {
            // 将图标的位置换到到舞台坐标
            let icon = this.owner;
            let iconPoint = this.getCenterPoint(icon);
            icon.parent.localToGlobal(iconPoint);
            // 获取动画播放的层
            let layer = game.scene.layer[this._name].c;
            // 坐标转换 到动画层
            layer.globalToLocal(iconPoint);
            layer.globalToLocal(point);
            this._startAnimation(layer, number, point, vn, iconPoint);
        }
    }


    /**
     * 
     * @param {Laya.Box} layer 
     * @param {number} number 
     * @param {Laya.Point} point 
     * @param {number} vn 
     * @param {Laya.Point} iconPoint 
     */
    _startAnimation(layer, number, point, vn, iconPoint) {
        this.random_edge = 150;
        for (let i = 0; i < vn; i++) {
            // let _res = new Laya.Image();
            let _res = Laya.Pool.getItemByClass(this.SIGN, Laya.Image);
            SkinUtils.setSkin(_res, this.getTypeIcon());
            _res.pivot(_res.width / 2, _res.height / 2);
            _res.pos(point.x, point.y);
            layer.addChild(_res);
            this.resArr.push(_res);
            _res.addComponent(ResFlyScript).start(iconPoint, i, i == vn - 1, this.SIGN, () => {
                this._start_callback && this._start_callback();
            }, (number) => {
                this._every_callback && this._every_callback(number);
            }, () => {
                this._end_callback && this._end_callback();
            });
        }
    }

    /**
     * 获取对象的中心点的真实坐标(切记对象需要能回去到宽高，已经设定锚点的对象会设置宽高，没有的sprite对象可能存在宽高为0的情况)
     * @param {Laya.Image} icon 
     */
    getCenterPoint(view) {
        let point = this.getAnchorPoint(view);
        // 没有设定锚点返回view 的中心点
        return new Laya.Point(view.x + view.width / 2 - point.x, view.y + view.height / 2 - point.y);
    }

    /**
     * 获取对象的锚点距离
     * @param {Laya.Image} view 
     */
    getAnchorPoint(view) {
        // 便宜位置  默认0
        let anchor = new Laya.Point(0, 0);
        // 已经设定锚点了
        if (view.pivotX != 0 || view.pivotY != 0) {
            anchor.x = view.pivotX || 0;
            anchor.y = view.pivotY || 0;
        }
        // 已经设定锚点了
        else if (!isNaN(view.anchorX) && !isNaN(view.anchorY)) {
            anchor.x = view.anchorX * view.width;
            anchor.y = view.anchorY * view.height;
        }
        return anchor;
    }

    get SIGN() { return "RES_ANIMATION_IMAGE" + this._resType; }
}

class ResFlyScript extends Laya.Script {
    start(iconPoint, i, isEnd, sign, firstComplete, everyComplete, complete) {
        this._iconPoint = iconPoint;
        this._isEnd = isEnd;
        this._i = i;
        this._sign = sign;
        this._complete = complete;
        this._everyComplete = everyComplete;
        this._firstComplete = firstComplete;
        this._startMove();
    }


    /**
     * 开始移动
     */
    _startMove() {
        this._clearTween();
        this.tween = new Laya.Tween().to(this.owner, { x: this._iconPoint.x, y: this._iconPoint.y }, 750, Laya.Ease.expoOut, Laya.Handler.create(this, this._moveComplete, [], false), this._i * 200, false, false);
    }

    /**
     * 
     */
    _moveComplete() {
        this.started = false;
        game.scene.remove(this.owner);
        Laya.Pool.recover(this._sign, this.owner);
        (this._i == 0) && this._firstComplete && this._firstComplete();
        (this._isEnd) && this._complete && this._complete();
        this._everyComplete && this._everyComplete(this._i + 1);
        this.destroy();
    }


    _clearTween() {
        if (this.tween) {
            this.tween.clear();
            this.tween = null;
        }
    }
}


