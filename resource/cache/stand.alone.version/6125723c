    let queueLogic = {
        hash_uid: {},
        uid_key: {},
        add: function (uid, key, caller, fn, params, isQueue, overTime) {
            var t = this;
            return new Promise(async function (res, rej) {
                var o = {
                    uid,
                    key,
                    caller,
                    fn,
                    params,
                    callback: res,
                    overTime,
                    otcfn: null,
                    start_overTimeCal(otcfn) {
                        this.otcfn = otcfn
                        Laya.timer.once(this.overTime, this, this.overTimeFn)
                    },
                    clear_overTimeCal() {
                        Laya.timer.clearAll(this)
                    },
                    overTimeFn() {
                        console.error('队列 超时', this.uid, this.key, this.caller, this.fn.name, this.params)
                        this.callback(null)
                        this.otcfn && this.otcfn();
                    }
                }
                if (isQueue) {
                    t.hash_uid[uid] = t.hash_uid[uid] || [];
                    t.hash_uid[uid][key] = t.hash_uid[uid][key] || [];
                    t.hash_uid[uid][key].push(o);
                    t.execNext(uid, key);
                } else {
                    let r = 0
                    try {
                        o.start_overTimeCal()
                        r = await fn.apply(caller, params)
                        o.clear_overTimeCal()
                    } catch (e) {
                        console.error('queue不走队列 错误：', uid, key, caller, fn.name, params, isQueue = 1)
                    }
                    res(r)
                }
            })
        },
        async execNext(uid, key) {
            if (this.uid_key[uid + '_' + key]) {
                let fff = this.uid_key[uid + '_' + key]
                trace('队列promise', fff.name, uid, key)
            } else {
                if (this.hash_uid[uid][key].length) {
                    var o = this.hash_uid[uid][key].shift();
                    this.uid_key[uid + '_' + key] = o.fn;
                    await this.excO(o)
                    delete this.uid_key[uid + '_' + key];
                    this.execNext(uid, key)
                }
            }
        },
        excO(o) {
            return new Promise(async (res, rej) => {
                try {
                    o.start_overTimeCal(() => {
                        res(null)
                    })
                    let r = await o.fn.apply(o.caller, o.params)
                    o.callback(r)
                    o.clear_overTimeCal()
                    res(r)
                } catch (error) {
                    res(null)
                    console.error('', error)
                }
            });
        }
    }
    /**
     * label容器里面各种label设置坐标 并且容器居中
     * @param {各种label容器} labelParent 
     * @param {label容器相对于居中的x坐标} centerX 
     * @param {子元素间隔} dis 
     */
    exports.labelParentCenterAndSetXY = function (labelParent, centerX = 0, dis = 0, updateLabelParentXY = true) {
        let childs = [];
        for (let index = 0, length = labelParent.numChildren; index < length; index++) {
            const element = labelParent.getChildAt(index)
            if (element.visible)
                childs.push(element)
        };
        childs.sort((a, b) => {
            return a.x - b.x;
        })
        let w = 0;
        childs.forEach((e, index) => {
            if (e.textField) {
                e.x = w;
                w += e.textField.textWidth + dis
            } else {
                e.x = w + e.width * e.scaleX * (e.anchorX || 0);
                w += e.width * e.scaleX + dis
            }
        });
        w -= dis;
        if (updateLabelParentXY)
            labelParent.x = centerX - w / 2;
        labelParent.width = w;
    }

