    /**
     * let anm = __tool.createOverload()
     * anm.addFn('number', () => { console.log(123); })
     * anm.addFn('number', 'number',() => { console.log(456); })
     * anm(1)
     * anm(1, 2)
     * @param  {...any} args 
     * @returns 
     */
    exports.createOverload = function (...args) {
        const fnMap = new Map()
        function overload(...args) {
            const key = args.map((it) => {
                return typeof it
            }).join(',')
            const fn = fnMap.get(key)
            if (!fn) {
                throw new TypeError('没有找到对应的实现方法')
            }
            return fn.apply(this, args)
        }
        overload.addFn = function (...args) {
            const fn = args.pop()
            if (typeof fn !== 'function') {
                throw new TypeError('最后一个参数不是function')
            }
            const key = args.join(',')
            fnMap.set(key, fn)
        }
        return overload
    }

