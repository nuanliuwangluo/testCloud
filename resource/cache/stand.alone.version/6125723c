                            script.onreadystatechange = null;
                            loadAScriptComplete(url_);
                        }
                    }
                } else {
                    script.onload = function () {
                        loadAScriptComplete(url_);
                    }
                } //非IE
                script.src = url_;
                document.body.appendChild(script);
            }

            function loadAScriptComplete(value) {
                exports.scriptLoadedArr[value] = 1
                loadedCount++
                progress && progress(loadedCount / loadLength, value)
                if (loadedCount == loadLength) complete && setTimeout(complete, 1)
                else loadNextJS(urls.shift())
            }
            for (var i = 0; i < maxLoaderCount; i++) loadNextJS(urls.shift())
        }
