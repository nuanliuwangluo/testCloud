            return MahjongBeforeTingDetailsData.getDetails(this.code);
        }else{
            return MahjongAfterTingDetailsData.getDetails();
        }
    }

    getMaxRate(){
        let rate = 0;
        for(let i = 0;i < this.list.array.length;i++){
            rate = Math.max(this.list.array[i].rate);
        }
        return rate;
    }

    getMaxNumber(){
        let number = 0;
        for(let i = 0;i < this.list.array.length;i++){
            let suprs = Math.max(4 - this.list.array[i].num, 0);
            number += suprs;
        }
        return number;
    }

