class RateScaleAni extends Laya.Script {
    constructor() {
        super();
        this.tween = new Laya.Tween();
    }
    onEnable() {
        this.update();
        game.cb.on('init_rate_numbers', this, this.update);
        game.cb.on('rate_recount', this, this.recount);
    }

    onDisable() {
        game.cb.off('init_rate_numbers', this, this.update);
        game.cb.off('rate_recount', this, this.recount);
    }

    recount(seatName) {
        if (seatName != this._seatName) return;
        if (!this.rate) this.update();
        else {
            let __vo = __data.deskData.roomVo.getPlayer(this._seatName);
            let rate = 0;
            if (__vo && __vo.hupai && __vo.hupai.length > 0) {
                for (var i = 0; i < __vo.hupai.length; i++) { rate = Math.max(__vo.hupai[i].rate, rate); }
            }
            if (this.rate != rate) { this.start(rate); }
        }
    }

    update() {
        // let vo = __data.deskData.roomVo.getPlayer(this._seatName);
        // this.rate = MahjongCollectUtils.rate(vo);
        this.rate = 0;
        let __vo = __data.deskData.roomVo.getPlayer(this._seatName);
        if (__vo && __vo.hupai && __vo.hupai.length > 0) {
            for (var i = 0; i < __vo.hupai.length; i++) { this.rate = Math.max(__vo.hupai[i].rate, this.rate); }
            this.txt_rate.text = this.rate;
        }
    }

    setSeatName(name) { this._seatName = name; }

    start(rate) {
        this.tween.clear();
        this.tween.to(this.owner, { scaleX: 1.35, scaleY: 1.35 }, 300, null, Laya.Handler.create(this, this._toBigDone));
        let t = Laya.Tween.to(this, { rate: rate }, 300)
        t.update = new Laya.Handler(this, function () { this.txt_rate.text = Math.floor(this.rate) })
    }

    _toBigDone() {
        // this.update();
        this.tween.to(this.owner, { scaleX: 1, scaleY: 1 }, 300, null);
        game.cb.event('update_rate_fires', [this._seatName]);
    }

    get txt_rate() {
        if (!this._txt_rate) {
            this._txt_rate = this.owner.getChildByName('txt_rate');
        }
        return this._txt_rate;
    }
}
