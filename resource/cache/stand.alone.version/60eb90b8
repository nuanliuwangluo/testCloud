class HuIconComponent extends Laya.Script {

    bind(origin, panel) {
        this.origin = origin;
        this.panel = panel;
    }

    onClick(e) {
        e && e.stopPropagation();
        Laya.timer.callLater(this, this._onUpdate)
    }

    onStageClick() {
        game.utils.remove(this.panel);
    }

    _onUpdate() {
        if (this.origin && this.panel && !this.panel.parent) {
            game.cb.event(__eh + 'show_hu_preview'); // 3.1.18.1需求，红中赖子
            this.origin.parent.addChild(this.panel);
            let __vo = __data.deskData.roomVo.getPlayerBySeat(0);
            game.cb.event(__eh + "update_hu_number", [FriendRoomPlays.copyObject(__vo.hupai)])
            Laya.timer.callLater(this, ()=>{
                if(RateOpenRules.indexOf(HallPlay.curRuleId) >= 0){
                    this.panel.pos(this.origin.parent.width - this.panel.width >> 1, this.origin.parent.height - this.panel.height >> 1);
                }else{
                    this.panel.pos(this.origin.x, this.origin.y - this.panel.height - 15);
                }
            })
        } else {
            game.utils.remove(this.panel);
        }
    }
}





