    constructor() {
        super({
            map: 'scene_game/mahjong/MahjongRateSelfTipsItem',
            module: false
        });

        this.signRules = [{ rule:FriendRoomPlays.AREA.FUJIN, name:'混分', sign:'+' }];
        this.sign = 'x';
        this.middle_space = 5;
    }
    set dataSource(value){
        if(value){
            this.signHandle(value);
            this.txt_name.text = value.description;
            this.txt_rate.text = `${this.sign}${value.score}`;
            this.txt_middle.text = '--------------------------------------------------';
            this.txt_middle.x = this.txt_name.x + this.txt_name.width + this.middle_space;
            this.txt_middle.width = this.width - this.txt_rate.textField.textWidth - this.txt_middle.x - this.middle_space;
        }
    }

    signHandle(value){
        if (!value || !value.description) return;
        // 遍历 signRules 数组，查找匹配的规则
        for (let i = 0; i < this.signRules.length; i++) {
            let ruleObj = this.signRules[i];
            // 如果 description 和 name 相同，且 HallPlay.curRuleId 和 rule 相同
            if (value.description == ruleObj.name && HallPlay.curRuleId == ruleObj.rule) {
                this.sign = ruleObj.sign;
                return;
            }
        }
        // 如果没有找到匹配的规则，使用默认符号
        this.sign = 'x';
    }
