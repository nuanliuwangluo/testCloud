class MahjongLxPanel extends game.ModuleBase {
    constructor() {
        super();
        this.size(config.gameW, config.gameH)
        this.params = {
            "layer": 'bottom',
            "offx": 0,
            "offy": 0,
            "centerx": true,
            "centery": true,
            "up": false,
            "down": false,
            "left": false,
            "right": false
        }

        this.otherImg = new Laya.Image();
        this.otherImg.skin = 'local/mahjong_common/1/wait_others.png'
        this.addChild(this.otherImg)

        this.mineImg = new Laya.Image();
        this.mineImg.skin = 'local/mahjong_common/1/wait_mine.png'
        this.addChild(this.mineImg)

        this.otherImg.x = this.width - this.otherImg.width >> 1
        this.otherImg.y = this.height * .25 - this.otherImg.height / 2
        this.mineImg.x = this.width - this.mineImg.width >> 1
        this.mineImg.y = this.height * .55 - this.mineImg.height / 2

        this.btn_lx = new MahjongBlueImageButton('亮喜')
        this.btn_lx.x = this.width - this.btn_lx.width >> 1


        this.scale(game.scale, game.scale)

        this.mouseThrough = true
    }

    onEnable() {
        game.utils.remove(this.mineImg)
        game.cb.on(__eh + 'show_lx_mine_tips', this, this.showLxHandler)
        game.cb.on(__eh + 'hide_lx_mine_tips', this, this.hideLxHandler)
        game.cb.on('show_lx_btn_guide', this, this.showGuideHand);
        game.cb.on('remove_lx_btn_guide', this, this.removeGuideHand);
        this.btn_lx.on('click', this, this.decideLxGroup)
    }

    onDisable() {
        game.utils.remove(this.btn_lx)
        game.utils.remove(this.guideHand)
        game.cb.off(__eh + 'show_lx_mine_tips', this, this.showLxHandler)
        game.cb.off(__eh + 'hide_lx_mine_tips', this, this.hideLxHandler)
        game.cb.off('show_lx_btn_guide', this, this.showGuideHand);
        game.cb.off('remove_lx_btn_guide', this, this.removeGuideHand);
        this.btn_lx.on('click', this, this.decideLxGroup)
    }

    fixPosition() {
        let isPad = false;
        try {
            var u = navigator.userAgent;
            isPad = u.indexOf('Pad') > -1 || u.indexOf('Macintosh') > -1 || game.scale < 1; //pad终端
        } catch (e) { }
        if (isPad) {
            this.btn_lx.y = this.height * .75
        } else {
            this.btn_lx.y = this.height * .68
        }
    }

    decideLxGroup(e) {
        __sound && __sound.gameSound();
        game.cb.event(__eh + 'decide_lx_group')
    }

    who(isMine) {
        isMine && this.showLxHandler()
        //亮喜阶段已经结束  那么就不在需要显示 等待其他玩家亮喜的UI
        if (!__data.deskData.roomVo.islx) game.utils.remove(this.otherImg)
        else this.addChild(this.otherImg)
    }

    showLxHandler() {
        this.addChild(this.btn_lx)
        this.addChild(this.mineImg)
        this.fixPosition();
    }

    hideLxHandler() {
        game.utils.remove(this.btn_lx)
        game.utils.remove(this.mineImg)
        game.utils.remove(this.guideHand);
    }

    showGuideHand() {
        this.guideHand = this.guideHand || new GuideHand();
        this.addChild(this.guideHand).pos(this.btn_lx.x - (this.guideHand.width) / 2, this.btn_lx.y - (this.guideHand.height) / 2);
    }
    removeGuideHand() {
        game.utils.remove(this.guideHand);
    }
}


class MahjongLxPanel1 extends MahjongLxPanel {
    constructor() {
        super();

        this.explainImg = new Laya.Image();
        this.explainImg.skin = 'local/mahjong_common/1/img_lxyd.png'

        this.explainImg.x = this.width - this.explainImg.width >> 1
        this.explainImg.y = this.height * .55 - this.explainImg.height / 2
    }

    onEnable() {
        super.onEnable();
        game.cb.on('disabled_lx_button', this, this._disabledButton)
        game.cb.on('allow_lx_button', this, this._allowButton)
    }

    onDisable() {
        super.onDisable();
        game.cb.off('disabled_lx_button', this, this._disabledButton)
        game.cb.off('allow_lx_button', this, this._allowButton)
    }

    _disabledButton() {
        this._buttonDisabled = true;
        SkinUtils.gray(this.btn_lx, true, true);
    }

    _allowButton() {
        this._buttonDisabled = false;
        SkinUtils.gray(this.btn_lx, false);
    }

    decideLxGroup(e) {
        if (this._buttonDisabled) { __tips('请选择3张不同花色的幺或九'); return; }
        super.decideLxGroup();
    }

    fixPosition() {
        let isPad = false;
        try {
            var u = navigator.userAgent;
            isPad = u.indexOf('Pad') > -1 || u.indexOf('Macintosh') > -1 || game.scale < 1; //pad终端
        } catch (e) { }

        let uniqueId = MahjongConfig.getUniqueId(__data.gameId.curId, HallPlay.curRuleId);
        let scene = window['MahjongDesk' + uniqueId + '3D'];
        let desk = game.scene.get(scene);
        let lp = desk.downlist.parent.localToGlobal(new Laya.Point(desk.downlist.x, desk.downlist.y));
        let ip = this.localToGlobal(new Laya.Point(this.explainImg.x, this.explainImg.y + this.explainImg.height));
        let areaH = (lp.y - ip.y) / 2;
        // if (isPad) {
        // this.btn_lx.y = this.explainImg.y + this.explainImg.height + this.btn_lx.height / 2 + this.btn_lx.height / 3;
        // } else {
        this.btn_lx.y = this.explainImg.y + this.explainImg.height + areaH - 15;
        // }
    }

    who(isMine) {
        if (isMine) {
            if (this.isExplain) {
                this.addChild(this.btn_lx)
                this.addChild(this.explainImg)
                game.utils.remove(this.mineImg)
            } else {
                this.addChild(this.btn_lx)
                this.addChild(this.mineImg)
            }
            this.fixPosition();
        }
        //亮喜阶段已经结束  那么就不在需要显示 等待其他玩家亮喜的UI
        if (!__data.deskData.roomVo.islx) game.utils.remove(this.otherImg)
        else this.addChild(this.otherImg)
    }

    showLxHandler() {
        this.who(true);
    }

    hideLxHandler() {
        game.utils.remove(this.btn_lx)
        game.utils.remove(this.mineImg)
        game.utils.remove(this.guideHand);
        game.utils.remove(this.explainImg)
    }

    get isExplain() {
        let cup = __data.hashCityLevelCup[HallPlay.lastCityId].cup;
        let localNumber = LocalUtils.get('liangxi_show_times' + __data.uid) || 1;
        // 不是好友房  在大众玩法  黄铜以下  显示次数没有超出限制
        if (__data.deskData.roomVo.roomModel != __data.deskData.roomVo.FRIEND && HallPlay.curRuleId == -2 && cup < 260 && localNumber <= 5) {
            return true;
        } else {
            return false;
        }
    }
}
















