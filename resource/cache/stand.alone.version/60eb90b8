class Mahjong3DBG extends Laya.Sprite {
    constructor() {
        super();

        this.params = {
            "layer": 'bottom',
            "offx": 0,
            "offy": 0,
            "centerx": true,
            "centery": true,
            "up": false,
            "down": false,
            "left": false,
            "right": false
        }
        this.width = config.gameW
        this.height = config.gameH

        this.uScene = null;
        this.wallArr = [];

        this.addComponent(AITalkingComponent);
    }

    onEnable() {
        game.cb.on(__eh + 'save_set_data', this, this.updateBackGround)
        this.init();
        clear_hall_hallPlay_garden_scene_res()
    }

    onDisable() {
        __data.deskData.roomVo.isOut = false;
        game.cb.off(__eh + 'save_set_data', this, this.updateBackGround)
        this.clear();
        this.reset();
    }

    init() {
        this.uScene = this.uScene || Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/MahjongTilePack.ls');
        this.addChild(this.uScene);

        // if (this.uScene.getChildByName('Main Camera').transform.rotationEuler.z !== 180) {
        //     let tempRotationZ = game.scene.c.rotation === 180 ? 180 : 0
        //     this.uScene.getChildByName('Main Camera').transform.rotationEuler = new Laya.Vector3(this.uScene.getChildByName('Main Camera').transform.localRotationEulerX, this.uScene.getChildByName('Main Camera').transform.localRotationEulerY, tempRotationZ)
        // }

        // this.uScene.getChildByName('Main Camera').aspectRatio = 16 / 9

        __data.deskData.roomVo.material = __data.mahjong_set.cardIndex.toString() === '0' ? Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Materials/MahjongTile_Mobile_Legacy.lmat') : Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Materials/MahjongTile02.lmat')

        __data.deskData.roomVo.scene = this.uScene;

        this.clear();

        this.wallNameArr = ['upWall', 'rightWall', 'downWall', 'leftWall']

        for (let name = 0; name < this.wallNameArr.length; name++) {
            for (let i = 1; i <= 28; i++) { this.wallArr.push(this.uScene.getChildByName('wall').getChildByName(this.wallNameArr[name]).getChildByName(i.toString())) }
        }

        this.updateBackGround();
        this.fixCamera();
    }

    fixCamera() {
        let camera = __data.deskData.roomVo.scene.getChildByName('Main Camera');
        let orgin = this.cameraInitPosition;
        let xs = Math.abs(orgin.y / orgin.z);
        let pull = 50;

        let isPad = false;
        let isPc = false;
        try {
            var u = navigator.userAgent;
            isPad = u.indexOf('Pad') > -1 || u.indexOf('Macintosh') > -1 || game.scale < 1; //pad终端
            const systemInfo = wx.getSystemInfoSync();
            if (systemInfo.platform === 'windows' || systemInfo.platform === 'mac') { isPc = true; }
        } catch (e) { }
        if (isPad && !isPc) {
            camera.fieldOfView = 23;
        }
        // let camera = __data.deskData.roomVo.scene.getChildByName('Main Camera');
        // let orgin = this.cameraInitPosition;
        // let xs = Math.abs(orgin.y / orgin.z);
        // let pull = 50;

        // let isPad = false;
        // try {
        //     var u = navigator.userAgent;
        //     isPad = u.indexOf('Pad') > -1 || u.indexOf('Macintosh') > -1 || game.scale < 1; //pad终端
        // } catch (e) {}
        // if (isPad) {
        //     camera.transform.localPosition = new Laya.Vector3(orgin.x, orgin.y + pull, orgin.z - pull / xs);
        // }
        // trace('test--------->', camera.transform.localPosition)
        // trace(pull, pull / xs)
    }

    clear() {
        while (__data.deskData.roomVo.scene && __data.deskData.roomVo.scene.getChildByName('container').numChildren) {
            let ele = __data.deskData.roomVo.scene.getChildByName('container').getChildAt(0)
            if (ele && 'active' in ele) {
                ele.active = false;
                ele.destroy();
            }
            __data.deskData.roomVo.scene.getChildByName('container').removeChildAt(0);
        }

        for (let i = 0; i < this.wallArr.length; i++) { this.wallArr[i].active = true; }
    }

    reset() {
        game.utils.remove(this.uScene);
        this.uScene = null;
        __data.deskData.roomVo.scene = null;
    }

    updateBackGround() {
        this.uScene.getChildByName('Desk').getChildByName('table').meshRenderer.material = __data.mahjong_set.bgIndex.toString() === '0' ? Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Materials/desk1.lmat') : Laya.loader.getRes(MahjongConfig.resHead + 'unityScenes/LayaScene_MahjongTilePack/Conventional/Assets/MahjongTiles/Materials/desk2.lmat')
    }

    get cameraInitPosition() {
        if (!this._cameraInitPosition) {
            let camera = __data.deskData.roomVo.scene.getChildByName('Main Camera');
            this._cameraInitPosition = new Laya.Vector3(camera.transform.localPosition.x, camera.transform.localPosition.y, camera.transform.localPosition.z)
        }
        return this._cameraInitPosition;
    }
}


class MahjongJxMondayPiece extends game.ModuleBase {
