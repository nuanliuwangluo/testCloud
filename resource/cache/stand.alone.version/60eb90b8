class PrayAnimationComponent extends Laya.Script {
    onAwake() {
        this.layer = new Laya.Sprite();
        this.bottom = new Laya.Sprite();
        this.middle = new Laya.Sprite();
        this.top = new Laya.Sprite();
        this.layer.mouseEnabled = false;
        this.bottom.mouseEnabled = false;
        this.middle.mouseEnabled = false;
        this.top.mouseEnabled = false;
        this.layer.addChild(this.bottom);
        this.layer.addChild(this.middle);
        this.layer.addChild(this.top);
        this.fortuneIcon = new MahjongFortuneIcon(false);
    }
    onEnable() {
        game.cb.on('show_pray_dragon', this, this._showDragon);
    }

    onDisable() {
        this.clearLayer();
        game.cb.off('show_pray_dragon', this, this._showDragon);
    }

    initLayer() {
        this.layer.size(this.owner.width * game.scale, this.owner.height * game.scale);
        game.scene.layer['tips'].c.addChild(this.layer).pos(this.owner.x, this.owner.y);
        
        // this.owner.addChild(this.layer);
    }

    clearLayer() {
        game.utils.remove(this.layer);
    }

    _showDragon(type, value) {
        this._type = type;
        this._value = value;
        this.initLayer();
        this._showAni0();
    }

    _getDragonRes(type) {
        switch (type) {
            case 1:
                return 'cdn/bless_panel/Jinchan.sk';
            case 2:
                return 'cdn/bless_panel/Facaishu.sk';
            case 3:
                return 'cdn/bless_panel/Long.sk';
            case 4:
                return 'cdn/bless_panel/Caishen.sk';
        }
    }   

    _showAni0() {
        let dragon = new game.Dragon(this._getDragonRes(this._type), 0, 'Pray', false);
        this.top.addChild(dragon).pos(this.layer.width / 2, this.layer.height * .75);
        __sound.gameSound("pray");
        dragon.play('Pray', false, () => { dragon.clear(); this._showAni1(); });
    }

    _showAni1() {
        let image = new FrameAnimationImage(0, 10, 50, 'cdn/redPacket_light/tx_cl', '.png', 2, { frame: 8, todo: this._showAni2.bind(this), once: 'destroy' });
        this.middle.addChild(image).pos(this.layer.width / 2, this.layer.height / 2);
        image.start();
    }

    _showAni2() {
        let image = new FrameAnimationImage(1, 9, 75, 'cdn/bless_panel/img_a', '.png', 1);
        this.bottom.addChild(image).pos(this.layer.width / 2, this.layer.height / 2);
        image.start();
        Laya.timer.once(300, this, this._showAni3, [image], false);
    }

    _showAni3(image) {
        image && image.clearSelf();
        //  正在结算界面展示
        if(FriendMahjongSmallResult.isShow){
            this._showAni5();
        }else if(MahjongSmallResult.isShow){
            this._showAni5();
        }else if(__data.deskData.roomVo.roomModel != __data.deskData.roomVo.FRIEND){
            this._showAni5();
        } else if (this.target) {
            let point = this.convertLocalToLocal(this.target, this.bottom);
            this.targetPoint = { x:point.x, y:point.y, width:this.target.width, height:this.target.height };
            image = new FrameAnimationImage(1, 6, 75, 'cdn/bless_panel/img_b', '.png', 1);
            this.bottom.addChild(image).pos(this.layer.width / 2, this.layer.height / 2);
            image.start();
            Laya.Tween.to(image, { x: this.targetPoint.x + this.targetPoint.width * game.scale / 2, y: this.targetPoint.y + this.targetPoint.height * game.scale / 2 }, 300, Laya.Ease.QuadIn, Laya.Handler.create(this, this._showAni4, [image]));
        } else {
            this._showAni5();
        }
    }

    _showAni4(image) {
        image && image.clearSelf();
        image = new FrameAnimationImage(1, 18, 25, 'cdn/bless_panel/img_c', '.png', 1, { frame: 8, todo: this.__complete.bind(this), once: 'destroy' });
        this.bottom.addChild(image).pos(this.targetPoint.x + this.targetPoint.width * game.scale / 2, this.targetPoint.y + this.targetPoint.height * game.scale / 2);
        image.start();
    }

    _showAni5(){
        this.layer.addChild(this.fortuneIcon).pos(this.layer.width - this.fortuneIcon.width >> 1, this.layer.height - this.fortuneIcon.height >> 1);
        this.fortuneIcon.animation(()=>{ Laya.timer.once(1000, this, this.__delayToRemoveFortune) });
    }

    __complete() {
        this.clearLayer();
        game.cb.event('show_grow_animation', [this._value]);
    }

    __delayToRemoveFortune(){
        game.utils.remove(this.fortuneIcon);
        this.__complete();
    }

    /**
     * 将A对象的本地坐标转换到B对象的本地坐标
     * @param aObj 源对象
     * @param bObj 目标对象
     * @returns 目标对象的本地坐标
     */
    convertLocalToLocal(aObj, bObj) {
        // 1. A的本地坐标 -> 全局坐标
        const globalPos = aObj.localToGlobal(new Laya.Point());
        // 2. 全局坐标 -> B的本地坐标
        const bLocalPos = bObj.globalToLocal(globalPos);
        return bLocalPos;
    }

    get target() {
        if (this.owner.ready.parent) {
            return this.owner.ready.getChildByName('player_down')
        } else if (this.owner.game.parent) {
            return this.owner.game.getChildByName('player_down')
        } else {
            return null;
        }
    }
}

class FrameAnimationImage extends Laya.Image {
    constructor(__min, __max, __time, __prefix, __tail, __scale, __data) {
        super();
        this.__min = __min;
        this.__max = __max;
        this.__time = __time;
        this.__prefix = __prefix;
        this.__tail = __tail;
        this.__scale = __scale;
        this.__data = __data;
        this.__index = __min;
        this.anchorX = this.anchorY = 0.5;
        this.scale(this.__scale, this.__scale);

        this._updateSkin();
    }

    start() {
        Laya.timer.loop(this.__time, this, this._updateSkin);
    }

    _updateSkin() {
        SkinUtils.setSkin(this, this.__prefix + this.__index + this.__tail);
        this.__index++;
        if (this.__index > this.__max) {
            this.__index = this.__min;
            this._once();
        }
        if (this.__data) {
            if (this.__index == this.__data.frame && this.__data.todo) {
                this._todo();
            } else if (this.__index == this.__max && this.__data.todo) {
                this._todo();
            }
        }
    }

    _once() {
        if (this.__data) {
            if (typeof this.__data.once === 'function') {
                this.__data.once();
            } else if (typeof this.__data.once === 'string') {
                if (this.__data.once == 'destroy') {
                    this.clearSelf();
                }
            }
        }
    }

    _todo() {
        this.__data.todo && this.__data.todo();
        this.__data.todo = null;
        delete this.__data.todo;
    }

    clearSelf() {
        Laya.timer.clearAll(this);
        game.utils.remove(this);
    }
}



