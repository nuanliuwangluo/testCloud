class GameMainFreeVipTips extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_freeVipTips',
            layer: 'panel'
        })
        this.btn_sure.addComponent(S_freevipTips_click_sure)
        this.btn_cancel.addComponent(S_freevipTips_click_cancel)
        // this.btn_close.addComponent(S_freevipTips_click_cancel)
        this.btn_no.addComponent(S_freevipTips_click_no)
        this.btn_select.addComponent(S_click_single_select_box)
    }
    onEnable() {
        if (__data.sub.isSubActivity) {
            this.btn_select.visible = false;
            this.txt_select.visible = false;
            this.btn_select.isSelect = false;
        } else {
            this.btn_select.visible = miniApi.clientType != 'app';
            this.txt_select.visible = miniApi.clientType != 'app';
        }
    }
    onDisable() {
        // hallTestShowPanel()
    }
    clickMask() { }
}
class S_freevipTips_click_sure extends Laya.Script {
    onClick(e) {
        game.scene.remove(GameMainFreeVipTips)
        __showScene.show_freeVip()
    }
}
class S_freevipTips_click_cancel extends Laya.Script {
    onClick(e) {
        game.scene.remove(GameMainFreeVipTips)
        game.scene.remove(GameMainFreeVip)
    }
}
class S_freevipTips_click_no extends Laya.Script {
    async onClick(e) {
        if (!this.owner.parent.btn_select.visible || !this.owner.parent.btn_select.isSelect) {
            game.scene.remove(GameMainFreeVipTips)
            game.scene.remove(GameMainFreeVip)
        } else {
            if (!__data.sub.isSubActivity) {
                let a = await miniApi.activitySubscribe()
                if (a == 1) {
                    game.server.send(16006, 1)
                    game.scene.remove(GameMainFreeVipTips)
                }
            }
        }
    }
}