class GameMainFreeVip extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_freeVip',
            layer: 'panel'
        })
        this.btn_close.addComponent(S_freevip_click_close)
        this.btn_receive.addComponent(S_freevip_click_receive)
    }
    async onEnable() {
        miniApi.setItem(__data.uid + ':' + new Date().toDateString() + ':show_panel_freeVip', 1)
        this.index = 0
        if (Date.now() - parseInt(__data.Mj_registeDateMs) < 24 * 3600 * 1000) {
            this.txt_time.visible = true;
        } else {
            this.txt_time.visible = false;
        }
        if (this.txt_time.visible) {
            this.update_time()
            Laya.timer.loop(1000, this, this.update_time)
        }
        await __tool.await(10)
        this.nextPlay()
    }
    onDisable() {
        this.clearAwait && this.clearAwait();
        Laya.timer.clearAll(this)
    }
    update_time() {
        let a = Date.now() - parseInt(__data.Mj_registeDateMs);
        let n = 24 * 3600 * 1000 - a
        if (n <= 0) {
            this.txt_time.visible = false;
            Laya.timer.clearAll(this)
        }
        this.txt_time.text = '活动剩余时间：' + game.utils.numberToTime(parseInt(n / 1000))
    }
    clickMask() { }
    async nextPlay() {
        this.img_hand.visible = false;
        this.img_light.visible = false
        this.img_hand.clipStop()
        this.img_light.clipStop()
        let nindex = this.index % 4
        this.img_tips.skin = `cdn/freeVip/img_sp${nindex + 1}.png`
        if (nindex <= 2) {
            this.img_hand.visible = true;
            this.img_hand.clipPlay(0)
            if (nindex == 0) {
                this.img_hand.x = 893
                this.img_hand.y = 244
            } else if (nindex == 1) {
                this.img_hand.x = 947
                this.img_hand.y = 268
            } else if (nindex == 2) {
                this.img_hand.x = 675
                this.img_hand.y = 278
            }
        } else {
            this.img_light.visible = true;
            this.img_light.clipPlay(0)
        }

        await __tool.await(2000, this)
        this.index++
        this.nextPlay()
    }
}
