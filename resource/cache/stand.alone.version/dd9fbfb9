class S_rmc_show_btn extends Laya.Script {
    init(type) {
        this.type = type;
    }
    onAwake() {
        this.ix1 = this.ix1 || this.owner.parent.ix1;
        this.ix2 = this.ix2 || this.owner.parent.ix2;
        this.btn_red = this.owner.btn_red;
        this.img_redPoint = this.owner.btn_red.getChildByName('img_red');
        this.btn_red_add_time = this.owner.btn_red_add_time;
        this.img_tips = this.owner.img_tips || {}
        this.txt_tips = this.owner.txt_tips || {}
        this.s_btnred_scale = this.btn_red.getComponent(Btn_Scale)
        this.s_btnred_scale.enabled = true
        if (miniApi.getWxDeviceName() === 'windows') return
    }
    onEnable() {
        effectUtils.stopBreathe(this.btn_red)
        this.owner.visible = false
        this.img_redPoint.visible = false;
        // console.log('miniApi.getWxDeviceName()', miniApi.getWxDeviceName());
        if (miniApi.getWxDeviceName() === 'windows') return
        game.cb.on('show_newPlayerRed_allPlayerRed_ani', this, this.show_newPlayerRed_allPlayerRed_ani)

        game.cb.on('update_newPlayerRedChallenge_data', this, this.updateIconShow)
        game.cb.on('update_allPlayerRed_data', this, this.updateIconShow)
    }
    onDisable() {
        game.cb.off('update_newPlayerRedChallenge_data', this, this.updateIconShow)
        game.cb.off('update_allPlayerRed_data', this, this.updateIconShow)
        game.cb.off('show_newPlayerRed_allPlayerRed_ani', this, this.show_newPlayerRed_allPlayerRed_ani)
        Laya.timer.clearAll(this)
        effectUtils.stopBreathe(this.btn_red)
    }
    updateIconShow() {
        Laya.loader.load('res/atlas/cdn/redIcon.atlas',
            Laya.Handler.create(this, () => {

                this.owner.visible = false
                Laya.timer.clearAll(this)

                if (__data.newPlayerRedChallenge.isHaveData === false) return;
                if (__data.allPlayerRed.isHaveData === false) return;

                this.btn_red.visible = false
                this.btn_red_add_time.visible = false;
                this.btn_red.filters = []
                this.img_tips.visible = false;

                let inDesk = (game.scene.get(Mahjong3DBG) && game.scene.get(Mahjong3DBG).parent && __data.deskData.roomVo.roomModel == __data.deskData.roomVo.FRIEND)
                if (miniApi.clientType == 'app' || inDesk) {

                } else {
                    let hallbg__ = game.scene.get(HallBg)
                    if (hallbg__ && hallbg__.parent) {
                        // if (!miniApi.isIOS) {
                        //     this.owner.x = this.ix2
                        // } else {
                        //     this.owner.x = this.ix1
                        // }
                    }

                    this.updateEndTime()
                    Laya.timer.loop(1000, this, this.updateEndTime)
                }

            }))
    }
    show_newPlayerRed_allPlayerRed_ani() {
        this.colorFilter = this.colorFilter || new Laya.ColorFilter([]);
        this.colorValue = 0
        this.colorValueOff = 10
        this.colorFilter.color(this.colorValue, this.colorValue, this.colorValue, 1)
        this.btn_red.filters = [this.colorFilter];
        Laya.timer.loop(30, this, this.updateColorFilter)
    }
    updateColorFilter() {
        this.colorValue += this.colorValueOff
        if (this.colorValue <= 0) {
            this.colorValue = 0
            this.colorValueOff = 10
            Laya.timer.clear(this, this.updateColorFilter)
            this.btn_red.filters = []
        }
        if (this.colorValue >= 255) {
            this.colorValue = 255
            this.colorValueOff = -10
            miniApi.setItem(__data.uid + ':newPlayerRed_ani_remove', '1')
            this.updateEndTime()
        }
        this.colorFilter.color(this.colorValue, this.colorValue, this.colorValue, 1)
    }
    updateEndTime() {
        // trace('新人红包开关：', this.rookieState);
        // trace('每日红包开关：', this.everyState);
        if (__data.newPlayerRedChallenge.isRemove()) {
            if (__data.redPacket.everyState) {
                this.owner.visible = true;
                this.btn_red_add_time.visible = false;
                this.img_tips.visible = false;
                this.btn_red.visible = true;

                // if (this.type == 1) {
                //     this.btn_red.skin = 'cdn/redIcon/bt_hb.png'
                // } else
                //     this.btn_red.skin = 'cdn/redIcon/bt_qhb.png'
                let tt = this.owner.txt_time;
                tt.visible = true;
                tt.text = '全民红包'

                let n = __data.allPlayerRed.isTimeIn(-1)
                if (n > 0) {
                    let n1 = __data.allPlayerRed.redNum[n - 1] || 0;
                    if (n1 > 0) {
                        let taskStatus = __data.allPlayerRed.taskData[n - 1].taskStatus
                        if (taskStatus === 0) {
                            tt.text = '挑战中'
                        } else if (taskStatus === 1) {
                            tt.text = '挑战成功'
                        } else if (taskStatus === -1) {
                            tt.text = '挑战失败'
                            this.img_tips.visible = true;
                            this.txt_tips.text = `还剩${n1}个红包`
                        }
                    }
                }

                this.img_redPoint.visible = __data.allPlayerRed.isRed()

                let sr = game.scene.get(MahjongSmallResult);
                if (sr && sr.parent && this.img_redPoint.visible) {

                    let n = __data.allPlayerRed.isTimeIn(-1)
                    let a1 = n && __data.allPlayerRed.taskData[n - 1].taskStatus == 1 && !__data.allPlayerRed.taskData[n - 1].isHasReceive && __data.allPlayerRed.redNum[n - 1] > 0;
                    if (a1) {
                        effectUtils.breathe(this.btn_red, 1, 1.1, 300)
                        this.s_btnred_scale.enabled = false;
                    }
                }
                if (!this.img_redPoint.visible || !sr || !sr.parent) {
                    effectUtils.stopBreathe(this.btn_red)
                }
            }
        } else if (__data.newPlayerRedChallenge.isEnd()) {
            if (__data.redPacket.rookieState) {
                this.owner.visible = true
                this.btn_red.visible = true
                this.btn_red_add_time.visible = false
                this.img_tips.visible = false;
                this.img_redPoint.visible = false
                let tt = this.owner.txt_time;
                tt.text = '已结束';
                effectUtils.stopBreathe(this.btn_red)
                if (S_rmc_show_btn.last_newPlayerRed_countdown_ing) {
                    // 上次显示倒计时
                    this.img_redPoint.visible = true;
                } else {
                    // 新人离线期间活动结束且未过当日24点，此时图标依然是新人红包，但不显示”已结束“而是显示红点
                    tt.text = ''
                    this.img_redPoint.visible = true;
                }
            }
        } else {
            if (__data.redPacket.rookieState) {
                S_rmc_show_btn.last_newPlayerRed_countdown_ing = true;
                // let ssm = __data.newPlayerRedChallenge.endTime - Date.now()
                this.owner.visible = true
                this.btn_red.visible = true
                // var minute = Math.floor(ssm / 60 / 1000) % 60;
                // var miao = Math.floor(ssm / 1000) % 60;
                // let str1 = minute + ':' + (miao < 10 ? '0' + miao : miao)

                let ssm = __data.newPlayerRedChallenge.endTime - Date.now()
                var hour = Math.floor(ssm / 3600 / 1000);
                var minute = Math.floor(ssm / 60 / 1000) % 60;
                var miao = Math.floor(ssm / 1000) % 60;
                let timeStr = (hour >= 10 ? hour : '0' + hour) + ':'
                timeStr += (minute >= 10 ? minute : '0' + minute) + ':'
                timeStr += miao >= 10 ? miao : '0' + miao

                let tt = this.owner.txt_time;
                tt.text = timeStr;

                let a = this.btn_red_add_time.visible
                this.btn_red_add_time.visible = __data.newPlayerRedChallenge.isShowAddTime();

                this.img_redPoint.visible = __data.newPlayerRedChallenge.isRed()
                let sr = game.scene.get(MahjongSmallResult);
                if (sr && sr.parent && this.img_redPoint.visible && __data.newPlayerRedChallenge.pro >= __data.newPlayerRedChallenge.need) {
                    effectUtils.breathe(this.btn_red, 1, 1.1, 300)
                    this.s_btnred_scale.enabled = false;
                }
                if (!this.img_redPoint.visible || !sr || !sr.parent) {
                    effectUtils.stopBreathe(this.btn_red)
                }
                if (__data.newPlayerRedChallenge.taskStatus == -1) {
                    tt.text = '挑战失败'
                } else if (__data.newPlayerRedChallenge.pro >= __data.newPlayerRedChallenge.need) {
                    tt.text = '挑战成功'
                }
                // if (this.type == 1 && !this.btn_red_add_time.visible) {
                if (!this.btn_red_add_time.visible) {
                    let n = __data.newPlayerRedChallenge.rewards.filter((e) => {
                        return e.hasGet == 1
                    })
                    if (n.length == 0) {
                        if (__data.newPlayerRedChallenge.pro == 0 || __data.newPlayerRedChallenge.pro == 1) {
                            this.txt_tips.text = '胜利抽现金红包'
                            this.img_tips.visible = true
                        }
                    }
                    if (n.length == 1) {
                        if (__data.newPlayerRedChallenge.pro == 1) {
                            this.txt_tips.text = '再玩1局可抽奖'
                            this.img_tips.visible = true
                        }
                    }
                    if (n.length == 2) {
                        if (__data.newPlayerRedChallenge.pro == 1) {
                            this.txt_tips.text = '再赢1局可抽奖'
                            this.img_tips.visible = true
                        }
                    }
                    if (n.length == 3) {
                        if (__data.newPlayerRedChallenge.pro >= __data.newPlayerRedChallenge.need) {

                        } else {
                            this.img_tips.visible = true
                            this.txt_tips.text = '再抽奖必得红包'
                        }
                    }
                } else {
                    this.img_tips.visible = false;
                }
            }
        }
    }
}
