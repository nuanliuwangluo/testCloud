class S_hall_newPlayerRedChallenge_add_time_move extends Laya.Script {
    onAwake() {
        this.ix = this.owner.x;
    }
    async onEnable() {
        if (miniApi.getWxDeviceName() === 'windows') return
        this.tweening = false;
        await __tool.await(1)
        this.startMove()
    }
    onDisable() {
        this.clearAwait && this.clearAwait();
        Laya.Tween.clearAll(this.owner)
    }
    async startMove() {
        if (this.tweening) return
        this.tweening = true
        this.owner.x = this.ix
        await __tool.tweenp(this.owner, { x: this.ix - 5 }, 500)
        await __tool.tweenp(this.owner, { x: this.ix + 10 }, 1000)
        await __tool.tweenp(this.owner, { x: this.ix }, 500)
        this.tweening = false;
        this.startMove()
    }
}
