class GameMainNewPlayerRedChallenge extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_newPlayerChallenge',
            layer: 'panel'
        })
        this.btn_go.addComponent(S_gnprc_go)
        this.btn_close.addComponent(S_click_close_remove_parent)
        this.btn_raffle.addComponent(S_click_rec_raffle)
        this.btn_reChallenge.addComponent(S_click_rec_reChallenge)
        // this.btn_subscribe.addComponent(S_click_rec_subscribe)
        this.btn_open_allPlayerRed.addComponent(S_rec_open_allPlayerRed)
        this.srm = this.addComponent(S_rec_startLightMove)
        this.btn_add_time.addComponent(S_newPlayerRedChallenge_add_time)
        this.sbar = this.img_bar.addComponent(S_progress_bar)
        // this.img_tips.addComponent(S_rec_move_ani)
    }
    onAwake() {
        this.itemArray = [this.item0, this.item1, this.item2, this.item3]
    }
    async added(firstShow) {
        game.server.send(20002)
        effectUtils.stopBreathe(this.btn_raffle)
        effectUtils.stopBreathe(this.btn_reChallenge)
        this.firstShow = firstShow
        this.img_light.visible = false
        this.updateEndTime()
        Laya.timer.loop(1000, this, this.updateEndTime)

        this.update_newPlayerRedChallenge_data()
        game.cb.on('16007__', this, this.update_btn)
        game.cb.on('update_newPlayerRedChallenge_data', this, this.update_newPlayerRedChallenge_data)
    }
    onDisable() {
        effectUtils.stopBreathe(this.btn_raffle)
        effectUtils.stopBreathe(this.btn_reChallenge)
        game.cb.event('hall_play_show_hand')
        this.clearAwait && this.clearAwait()
        Laya.timer.clearAll(this)
        this.img_hand.clipStop()
        game.cb.off('update_newPlayerRedChallenge_data', this, this.update_newPlayerRedChallenge_data)
        ResUtils.clearAtlas('res/atlas/cdn/newPlayerChallenge/newPlayerChallenge.atlas')
        ResUtils.clearTextureRes(['cdn.newPlayerChallenge.newPlayerChallenge'])
        ResultPanelManager.show();
    }
    update_newPlayerRedChallenge_data() {
        this.update_btn()
        this.updateItemData()
        this.updateTask()
    }
    updateTask() {
        this.txt_task_name.text = __data.newPlayerRedChallenge.taskName
        this.img_fail.visible = false;
        if (__data.newPlayerRedChallenge.isRemove()) {
            this.sp_pro.visible = false
            this.sp_end.visible = false
            this.img_end.visible = false
        } else if (__data.newPlayerRedChallenge.isEnd()) {
            this.sp_pro.visible = false
            this.sp_end.visible = true;
            this.img_end.visible = true;
        } else if (__data.newPlayerRedChallenge.isFail() === 1) {
            this.sp_end.visible = false
            this.img_end.visible = false
            this.sp_pro.visible = true
            this.img_fail.visible = true;
            this.txt_pro.text = '挑战失败'
            this.sbar.progress = 0
        } else if (__data.newPlayerRedChallenge.pro >= __data.newPlayerRedChallenge.need
            && __data.newPlayerRedChallenge.need != 0) {
            this.sp_end.visible = false
            this.img_end.visible = false
            this.sp_pro.visible = true
            this.txt_pro.text = '挑战成功'
            this.sbar.progress = 1
        } else {
            this.sp_end.visible = false;
            this.img_end.visible = false;
            this.sp_pro.visible = true;
            this.txt_pro.text = __data.newPlayerRedChallenge.pro + ' / ' + __data.newPlayerRedChallenge.need;
            this.sbar.progress = __data.newPlayerRedChallenge.pro / __data.newPlayerRedChallenge.need;
        }
        let n1 = __data.newPlayerRedChallenge.rewards.filter((e) => {
            return e.hasGet == 1
        })
        // this.txt_tips.text = n1 <= 0 ? '首次抽奖\n必得红包' : '抽4次\n必得所有奖励'
        this.img_font_tips.skin = n1 <= 0 ?
            'cdn/newPlayerChallenge/newPlayerChallenge/img_sccj.png' :
            'cdn/newPlayerChallenge/newPlayerChallenge/img_csc.png'
    }
    update_btn() {
        this.img_hand.visible = false
        this.img_hand.clipStop()
        this.btn_reChallenge.visible = false
        if (this.firstShow === 1) {
            if (__data.game_count_total <= 0) {
                this.img_hand.visible = true
                this.img_hand.clipPlay(0)
                this.btn_raffle.visible = false;
                effectUtils.stopBreathe(this.btn_raffle)
                effectUtils.stopBreathe(this.btn_reChallenge)
                this.btn_go.visible = true;
            }
        } else {
            if (__data.newPlayerRedChallenge.isEnd()) {
                this.btn_go.visible = false
                this.btn_raffle.visible = false
                effectUtils.stopBreathe(this.btn_raffle)
                effectUtils.stopBreathe(this.btn_reChallenge)
                this.btn_reChallenge.visible = false
            }
            else if (__data.newPlayerRedChallenge.isFail() === 1) {
                this.btn_go.visible = false
                this.btn_raffle.visible = false
                effectUtils.stopBreathe(this.btn_raffle)
                this.btn_reChallenge.visible = true
                effectUtils.breathe(this.btn_reChallenge, 1, 1.1, 300)
            } else if (__data.newPlayerRedChallenge.pro >= __data.newPlayerRedChallenge.need
                && __data.newPlayerRedChallenge.need != 0
            ) {
                this.btn_go.visible = false
                this.btn_raffle.visible = true
                this.btn_raffle.gray = false
                effectUtils.breathe(this.btn_raffle, 1, 1.1, 300)
                effectUtils.stopBreathe(this.btn_reChallenge)
                // if (this.firstShow === 2) {
                this.img_hand.visible = true;
                this.img_hand.clipPlay(0)
                __sound.playGameYx('cheer')
                // }
            } else {
                this.btn_go.visible = true
                this.btn_raffle.visible = false
                effectUtils.stopBreathe(this.btn_raffle)
                effectUtils.stopBreathe(this.btn_reChallenge)
            }
        }
    }
    updateItemData() {
        for (let index = 0, length = this.itemArray.length; index < length; index++) {
            const e = this.itemArray[index];
            e.dataSource = __data.newPlayerRedChallenge.rewards[index]
        };
    }
    async startLightAni() {
        let tt = 500
        this.img_light.visible = true
        this.img_light.alpha = 0
        await __tool.await(tt, this)
        this.img_light.alpha = 1
        await __tool.await(tt, this)
        // if (!this.clearAwait) return;
        this.startLightAni()
    }
    stopLightAni() {
        this.clearAwait && this.clearAwait('stopLightAni 2')
        this.img_light.alpha = 0
        this.img_light.alpha = false
    }
    showReward() {
        let vo = this.img_light.rewardVO;
        if (vo && vo.type == 1) {
            game.scene.add(GameMainPropGet, [
                [{
                    propId: 1,
                    propNum: vo.num
                }]
            ])
            __data.addMoney(1, vo.num)
            game.server.send(18001)
        } else if (vo && (vo.type === 2 || vo.type === 3)) {
            // 第一次是随机奖励  第二次是开启红包
            game.server.send(18002)
        }
        this.stopLightAni()
        game.cb.event('newPlayerRed_raffle_end')
    }
    updateEndTime() {
        if (__data.newPlayerRedChallenge.isRemove()) {
            this.img_time_tips.visible = false
            this.img_time.visible = false
        } else if (__data.newPlayerRedChallenge.isEnd()) {
            this.img_time_tips.visible = false
            this.img_time.visible = false
        } else {
            this.img_time.visible = true;
            let ssm = __data.newPlayerRedChallenge.endTime - Date.now()
            var hour = Math.floor(ssm / 3600 / 1000);
            var minute = Math.floor(ssm / 60 / 1000) % 60;
            var miao = Math.floor(ssm / 1000) % 60;
            let timeStr = (hour >= 10 ? hour : '0' + hour) + ':'
            timeStr += (minute >= 10 ? minute : '0' + minute) + ':'
            timeStr += miao >= 10 ? miao : '0' + miao
            this.txt_time.text = '限时参与：' + timeStr
            this.img_time_tips.visible = __data.newPlayerRedChallenge.isShowAddTime()
        }
    }
}
