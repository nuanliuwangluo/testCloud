class S_rec_startLightMove extends Laya.Script {
    onAwake() {
        this.s1 = [700];
        for (let index = 0; index < 12; index++) {
            this.s1.push(500 - index * 50)
        }
        // this.s2 = [];
        // for (let index = 0; index < 18; index++) {
        //     this.s2.push(50)
        // }
        this.s3 = this.s1.slice().reverse()
        // this.s4 = [...this.s1, ...this.s2, ...this.s3]
    }
    onEnable() {
        game.cb.on('newPlayerRedChallenge_raffle', this, this.startLightMove)
    }
    onDisable() {
        game.cb.off('newPlayerRedChallenge_raffle', this, this.startLightMove)
        this.allowAni = false
        this.clearAwait && this.clearAwait()
    }
    startLightMove(r1) {
        if (this.allowAni) return;
        this.itemArray = []
        for (let index = 0, length = __data.newPlayerRedChallenge.rewards.length; index < length; index++) {
            const e = __data.newPlayerRedChallenge.rewards[index];
            if (e.hasGet === 0) {
                this.itemArray.push(this.owner.itemArray[index])
            }
        };
        this.s2 = [];
        for (let index = 0; index < 18; index++) {
            this.s2.push(50)
        }
        this.s4 = [...this.s1, ...this.s2, ...this.s3]
        // 强制循环开始位置
        let n1 = this.s4.length % this.itemArray.length;
        this.s2.splice(0, n1)
        // 增加到道具位置
        for (let index = 0; index < r1 - 1; index++) {
            const e = __data.newPlayerRedChallenge.rewards[index];
            if (e.hasGet === 0) {
                this.s2.push(50)
            }
        }
        this.s4 = [...this.s1, ...this.s2, ...this.s3]

        if (this.itemArray.length === 1) {
            this.s4 = [100]
        }

        this.owner.stopLightAni()
        this.allowAni = true
        this.startTime = 0
        this.index = 0;
        this.delay = 0;
        this.img_index = 0
        this.owner.img_light.visible = true;
        this.owner.img_light.alpha = 1;
        this.owner.img_light.x = this.itemArray[0].x
        this.owner.img_light.y = this.itemArray[0].y
        __sound.playGameYx('ding')
    }
    async onUpdate() {
        if (this.allowAni) {
            if (!this.startTime) {
                this.startTime = Date.now()
            }
            this.delay = Date.now() - this.startTime;

            if (this.index < this.s4.length) {
                if (this.delay >= this.s4[this.index]) {
                    this.index++;
                    this.delay = 0;
                    this.startTime = Date.now()
                    this.img_index++;
                    let b = this.img_index % this.itemArray.length;
                    this.owner.img_light.x = this.itemArray[b].x
                    this.owner.img_light.y = this.itemArray[b].y
                    this.owner.img_light.rewardVO = this.itemArray[b].vo
                    __sound.playGameYx('ding')
                }
            } else {
                this.allowAni = false;
                await __tool.await(500, this)
                this.owner.startLightAni()
                await __tool.await(1200, this)
                this.owner.showReward()
            }
        }
    }
}
