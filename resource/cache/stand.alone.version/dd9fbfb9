class S_rmc_receive extends Laya.Script {
    async onClick(e) {
        let type = this.owner.parent.type
        const redPacketTypes = {
            newPlayerRed: '领取新人红包',
            allPlayerRed: '领取全民红包',
            luckRed: '领取幸运红包',
            friendRed: '领取好友红包',
            inviteRed: '领取邀请红包',
        };
        let b = redPacketTypes[type] || '未知';
        miniApi.trackEvent('Mj_UIClick', { 'Mj_ClickScene': b, 'Mj_ClickOther': this.owner.parent.vo.num });

        let fn_recommend = async () => {
            if (type == 'allPlayerRed' || type == 'luckRed') {
                let a2 = await __data.recommend.canShow()
                if (a2) __showScene.show_recommend()
            }
        }
        if (window.wx) {
            if (wx.requestMerchantTransfer) {
                wx.requestMerchantTransfer({
                    mchId: '1294910601',
                    appId: 'wxcd3feed2af7f80c6',
                    package: this.owner.parent.vo.package_info,
                    async success(res) {
                        fn_recommend()
                        if (type == 'inviteRed') {
                            // 重新查询邀请红包信息
                            __data.activity.inviteRed.addInviteNumbers();
                            game.server.send(18027)
                        }
                        // game.scene.remove(GameMainNewPlayerRedChallengeReceive)
                        // game.scene.remove(LoadingSmall)
                        // game.server.send(20002)
                    },
                    fail(res) {
                        trace('wx.requestMerchantTransfer', JSON.stringify(res))
                        game.scene.remove(GameMainNewPlayerRedChallengeReceive)
                        game.scene.remove(LoadingSmall)
                        // game.server.send(20002)
                    }
                })
            } else {
                wx.showModal({
                    title: '提示',
                    content: '当前微信版本过低，无法使用该功能，请升级到最新微信版本后重试。'
                })
            }
        } else {
            game.server.send(20004, __data.redPacket.redVO.redId)
            fn_recommend()
            if (type == 'inviteRed') {
                // 重新查询邀请红包信息
                __data.activity.inviteRed.addInviteNumbers();
                game.server.send(18027)
            }
        }
        game.scene.add(LoadingSmall)
        // game.scene.remove(GameMainNewPlayerRedChallengeReceive)
    }
}