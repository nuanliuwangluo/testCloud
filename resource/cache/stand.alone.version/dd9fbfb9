class S_click_rec_raffle extends Laya.Script {
    onEnable() {
        this.ing = false
        game.cb.on('newPlayerRed_raffle_end', this, this.end111)
    }
    onDisable() {
        game.cb.off('newPlayerRed_raffle_end', this, this.end111)
    }
    end111() {
        this.ing = false
    }
    async onClick(e) {
        if (__data.newPlayerRedChallenge.pro < __data.newPlayerRedChallenge.need) {
            __tips('请先完成挑战任务')
            return
        }
        let b = game.scene.get(Mahjong3DBG)
        let sr = game.scene.get(MahjongSmallResult);
        if (b && b.parent && (!sr || !sr.parent)) {
            __tips('请返回大厅界面抽奖')
            return
        }

        if (this.ing) return
        this.ing = true
        await game.server.send(18002)
