class GameMainVipSales extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_vipSales',
            layer: 'panel0'
        })
        this.btn_sure.addComponent(S_click_GameMainVipSales_sure)
        this.btn_close.addComponent(S_click_close_remove_parent)
    }
    added(type) {
        this.type = type;
        miniApi.setItem(__data.uid + ':' + new Date().toDateString() + ':show_panel_vip' + type, 1)
        miniApi.trackEvent('Mj_UIExposure', { 'Mj_ExposureScene': `VIP促销${type}界面` })
        this.img_title.skin = `cdn/vip_sales/img_vipcx${type}.png`;
        if (type == 1) {
            // type1的促销界面有3天期限
            miniApi.setItem(__data.uid + ':show_panel_vipSale3', Date.now())
        }
    }
    onDisable() {
        ResUtils.clearTextureRes(['cdn.vip_sales'])
        hallTestShowPanel()
    }
    clickMask() { }
}
