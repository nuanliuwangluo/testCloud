class GameMainVipReceiveRecord extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_vipReceiveRecord',
            layer: 'panel'
        })
    }
    onAwake() {
        this.__list.vScrollBarSkin = ''
        this.__list.renderHandler = new Laya.Handler(this, this.updateItem);
    }
    added() {
        this.update()
        game.cb.on('update_vip_receive_record', this, this.update)
    }
    onDisable() {
        game.cb.off('update_vip_receive_record', this, this.update)
    }
    update() {
        this.useData = __data.vip.receiveRecord.map((e) => {
            return {
                time: e.dateTime,
                gold: (e.item && e.item.count || 0),
            }
        })
        this.__list.array = this.useData || [];
        this.img_noData.visible = this.useData.length == 0;
        this.title1.visible = this.useData.length > 0
        this.title2.visible = this.useData.length > 0
    }
    clickMask() { }
    updateItem(cell, index) {
        cell.getChildByName('time').text = new Date(this.useData[index].time).dateFormat("yyyy.MM.dd hh:mm:ss")
        cell.getChildByName('gold').text = this.useData[index].gold
    }
}