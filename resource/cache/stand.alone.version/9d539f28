class S_allpr_horn extends Laya.Script {
    onAwake(E) {
        this.ww = this.owner.width;
        this.horn = this.owner.getChildByName('horn')
        this.horn_info = this.owner.getChildByName('sp_horn_info')
        this.head = this.horn_info.getChildByName('img_head')
        this.txt1 = this.horn_info.getChildByName('txt1')
        this.txt2 = this.horn_info.getChildByName('txt2')
        this.yy = this.horn_info.y;
    }
    async onEnable() {
        this.owner.visible = false;
        this.horn.visible = false;
        this.horn_info.visible = false;
        await __tool.await(300, this)
        await game.server.send(18015)
        // if (!this.clearAwait) return;
        this.next()
    }
    onDisable() {
        this.clearAwait && this.clearAwait()
        Laya.Tween.clearAll(this.horn_info)
        Laya.Tween.clearAll(this.owner)
    }
    async next() {
        if (!__data.allPlayerRed.robRedRecordList.length) return;
        this.vo = __data.allPlayerRed.robRedRecordList.shift()
        __data.allPlayerRed.robRedRecordList.push(this.vo)

        Laya.Tween.clearAll(this.horn_info)
        Laya.Tween.clearAll(this.owner)
        // avatar: 'local/head/1/defaultHead.png'
        // today:  true
        // value: 0.53
        this.head.skin = __data.getHeadTestDefault(this.vo.avatar)
        if (this.vo.today) {
            this.txt1.text = '今日抢红包'
        } else {
            this.txt1.text = '昨日抢红包'
        }
        this.txt2.text = this.vo.value + '元!'
        this.owner.visible = true
        this.owner.width = 100
        this.horn_info.visible = false;
        this.horn.visible = false;
        Laya.Tween.to(this.owner, { width: this.ww }, 200);
        await __tool.await(200, this)
        this.horn.visible = true;
        // if (!this.clearAwait) return;
        this.horn_info.visible = true;
        this.horn_info.scaleX = 0;
        this.horn_info.scaleY = 0;
        Laya.Tween.to(this.horn_info, { scaleX: 1, scaleY: 1 }, 200)
        await __tool.await(5000, this)
        // if (!this.clearAwait) return;
        this.next()
    }
}
