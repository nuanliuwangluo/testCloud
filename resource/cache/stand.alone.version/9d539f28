class GameMainAllPlayerRedRank extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_allPlayerRed_rank',
            layer: 'panel'
        })
        this.__list.vScrollBarSkin = ''
    }
    added() {
        this.__list.array = [];
        this.item_me.visible = false;
        this.img_noData.visible = false;
        game.cb.on('update_allPlayerRed_rank_data', this, this.update_rank_data)
    }
    onDisable() {
        game.cb.off('update_allPlayerRed_rank_data', this, this.update_rank_data)
    }
    update_rank_data(useData) {
        // let useData = __data.allPlayerRed.rankData;
        let data = []
        for (const page in useData) {
            if (page == `my`) continue;
            data.push(...useData[page])
        }
        this.__list.array = data;
        this.img_noData.visible = !data.length
        if ('isMy' in useData['my']) {
            this.item_me.visible = true
            useData[`my`].isMy = true;
            this.item_me.dataSource = useData[`my`]
            this.item_me.img_line.visible = false;
        } else {
            this.item_me.visible = false;
        }
    }
}
class GameMainAllPlayerRedRankItem extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_allPlayerRed_rankItem',
            module: false
        })
        // this.addComponent(S_click_HallPlayRankItem_showPlayerInfo)
    }
    onEnable() { }

    onDisable() { }

    set dataSource(vo) {
        if (!vo) return;
        this.__vo = vo;

        LabelHiddenUtils.getAdapterContent(this.txt_rank_name, vo.name)
        // this.txt_rank_name.text = vo.name;
        this.img_head.skin = __data.getHeadTestDefault(vo.head);
        this.txt_money.text = vo.score <= 0 ? '暂无红包' : vo.score + '元';
        this.txt_rank.visible = false;
        this.img_rank.visible = false;
        this.txt_noRank.visible = false;

        if (vo.rank == -1) {
            this.txt_rank.visible = true;
            this.txt_rank.text = `--`;
        } else if (vo.rank <= 3) {
            this.img_rank.visible = true;
            this.img_rank.skin = `local/rank_ui/1/img_${vo.rank}.png`
        } else if (vo.rank <= 10) {
            this.txt_rank.visible = true;
            this.txt_rank.text = vo.rank
        } else {
            this.txt_noRank.visible = true;
        }
        this.txt_mjName.text = vo.mjName;
        if (vo.isMy) {
            this.img_line.visible = false;
        }
        this.img_head_frame.skin = PropIcon.icon[vo.headFrameId || 301].skin
    }
}
Laya.ClassUtils.regClass('ui.scene_hall.gameMain_allPlayerRed_rankItemUI', GameMainAllPlayerRedRankItem);