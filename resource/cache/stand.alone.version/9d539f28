class GameMainAllPlayerRed extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_allPlayerRed',
            layer: 'panel'
        })
        this.btn_close.addComponent(S_click_close_remove_parent)
        this.btn_rank.addComponent(S_allpr_rank)
        this.btn_receive_task.addComponent(S_allpr_receive_task)
        // this.btn_raffle.addComponent(S_click_rec_raffle)
        this.btn_robRed.addComponent(S_allpr_robRed)
        this.btn_rob2.addComponent(S_allpr_robRed)
        this.btn_reChallenge.addComponent(S_click_allpr_reChallenge)
        this.btn_subscribe.addComponent(S_click_allpr_subscribe)
        this.btn_game2.addComponent(S_allpr_game2)
        this.btn_goOther.addComponent(S_allpr_goOther)
        this.img_horn.addComponent(S_allpr_horn)
        // this.srm = this.addComponent(S_rec_startLightMove)
        this.sbar = this.img_bar.addComponent(S_progress_bar)

        this.__tab.selectHandler = new Laya.Handler(this, this.onSelect);
        this.btn_rank.alpha = 0
    }
    onAwake() {
    }
    async added(type) {
        game.server.send(20002)
        this.type = type;
        miniApi.setItem(__data.uid + ':' + new Date().toDateString() + ':show_allPlayerRed', 1)
        effectUtils.stopBreathe(this.btn_robRed)
        effectUtils.stopBreathe(this.btn_receive_task)
        effectUtils.stopBreathe(this.btn_reChallenge)
        await __tool.await(1)
        // this.img_light.visible = false
        // this.updateEndTime()
        // Laya.timer.loop(1000, this, this.updateEndTime)

        // this.update_allPlayerRed_data()
        // game.cb.on('16007__', this, this.update_btn)
        game.cb.on('update_allPlayerRed_data', this, this.update_allPlayerRed_123data123)

        this.__tab.selectedIndex = -1;
        let n = __data.allPlayerRed.isTimeIn(-1)
        this.__tab.selectedIndex = n - 1 >= 0 ? n - 1 : 0
    }
    onDisable() {
        if (this.type == 'show_btn_ani') {
            game.cb.event('show_newPlayerRed_allPlayerRed_ani')
        }
        this.clearAwait && this.clearAwait()
        effectUtils.stopBreathe(this.btn_robRed)
        effectUtils.stopBreathe(this.btn_receive_task)
        effectUtils.stopBreathe(this.btn_reChallenge)
        // Laya.timer.clearAll(this)
        // this.img_hand.clipStop()
        game.cb.off('update_allPlayerRed_data', this, this.update_allPlayerRed_123data123)
        ResUtils.clearAtlas('res/atlas/cdn/allPlayerRed/allPlayerRed.atlas')
        ResUtils.clearAtlas('res/atlas/cdn/newPlayerChallenge/newPlayerChallenge.atlas')
        ResUtils.clearTextureRes(['cdn.allPlayerRed.allPlayerRed'])
        // game.cb.off('update_video_ready', this, this.update_video_ready)
    }
    update_allPlayerRed_123data123() {
        this.onSelect(this.__tab.selectedIndex)
    }
    onSelect(index) {
        let curData = __data.allPlayerRed.taskData[index]
        if (curData) {
            this.txt_time.text = `每日${curData.timeStart}:00-${curData.timeEnd}:00`
            this.txt_des_red_num.text = curData.redMaxNum + '个';
            let ax = this.sp_des1.x;
            __tool.labelParentCenterAndSetXY(this.sp_des1, 0, 0)
            this.sp_des1.x = ax;
        } else {
            return
        }
        this.update_allPlayerRed_data(index)
    }
    update_allPlayerRed_data(index) {
        // 852
        // 880
        // 检测上次未打开红包
        this.sp_pro.visible = false;
        this.sp_pro.x = 880
        this.sp_end.visible = false;
        this.sp_goOther.visible = false;
        this.btn_robRed.visible = false;
        this.btn_rob2.visible = false;
        this.btn_game2.visible = false;
        this.btn_reChallenge.visible = false;
        this.btn_receive_task.visible = false;
        this.img_tips.visible = false;
        this.img_fail.visible = false;
        this.txt_red_num.text = `剩余${__data.allPlayerRed.redNum[index]}个`
        // 如果不在时间段内 任务清空
        let { pro, taskStatus, need, hard } = __data.allPlayerRed.taskData[index];
        let isHasReceive = __data.allPlayerRed.taskData.some(e => e.isHasReceive)
        this.txt_task_name.text = `接下来${need}场全胜`
        for (let index = 0, length = 5; index < length; index++) {
            const e = this[`img_star${index}`]
            e.visible = index < hard;
        };
        if (__data.allPlayerRed.isTimeEnd(index)) {
            this.sp_end.visible = true;
            this.txt_end.text = '本场' + __data.allPlayerRed.taskData[index].name + '已结束，更多红包活动即将开启，敬请期待！'
        }
        else if (isHasReceive) {
            this.sp_goOther.visible = true;
        }
        else if (__data.allPlayerRed.redNum[index] <= 0) {
            this.sp_end.visible = true;
            this.txt_end.text = '本场' + __data.allPlayerRed.taskData[index].name + '已抢光，更多红包活动即将开启，敬请期待！'
        }
        else if (taskStatus == -2) {
            this.btn_receive_task.visible = true;
            let ns = __data.allPlayerRed.isTimeIn(-1)
            if (ns - 1 == index)
                effectUtils.breathe(this.btn_receive_task, 1, 1.1, 300)
            else {
                effectUtils.stopBreathe(this.btn_receive_task)
            }
            this.img_tips.visible = true
            this.sp_pro.visible = true;
            this.txt_pro.text = 0 + ' / ' + need;
            this.sbar.progress = 0 / need;
        }
        else if (taskStatus == -1) {
            this.btn_reChallenge.visible = true;
            effectUtils.breathe(this.btn_reChallenge, 1, 1.1, 300);
            this.sp_pro.visible = true;
            this.img_fail.visible = true
            this.txt_pro.text = '挑战失败';
            this.sbar.progress = 0 / need;
        }
        else if (taskStatus == 0) {
            this.sp_pro.visible = true;
            this.txt_pro.text = pro + ' / ' + need;
            this.sbar.progress = pro / need;
            this.btn_rob2.visible = true
            this.btn_rob2.gray = true;
            this.btn_game2.visible = true;
            this.sp_pro.x = 852
        }
        else if (taskStatus == 1) {
            this.sp_pro.visible = true;
            this.btn_robRed.visible = true;
            this.btn_robRed.gray = false;
            this.txt_pro.text = '挑战成功';
            this.sbar.progress = 1;
            effectUtils.breathe(this.btn_robRed, 1, 1.1, 300)
        }
    }
    // update_video_ready(r) {
    //     this.btn_reChallenge.videoR = r;
    //     let img_video1 = this.btn_reChallenge.getChildByName('img_video')
    //     let img_share1 = this.btn_reChallenge.getChildByName('img_share')
    //     if (!r.isSuccess) {
    //         // __data.shareVideoRule.total_shareShowCount(img_share1.parent)
    //         img_video1.visible = false
    //         img_share1.visible = true
    //     } else {
    //         img_video1.visible = true
    //         img_share1.visible = false
    //     }
    // }
    updateEndTime() {
        if (__data.newPlayerRedChallenge.isRemove()) {
            this.img_time_tips.visible = false
            this.img_time.visible = false
        } else if (__data.newPlayerRedChallenge.isEnd()) {
            this.img_time_tips.visible = false
            this.img_time.visible = false
            let a = new Date(__data.newPlayerRedChallenge.endTime + 24 * 3600 * 1000)
            a.setHours(0, 0, 0, 0)
            let ssm = a.getTime() - Date.now()
            var hour = Math.floor(ssm / 3600 / 1000)
            var minute = Math.floor(ssm / 60 / 1000) % 60;
            var miao = Math.floor(ssm / 1000) % 60;
            let timeStr = ''
            timeStr += hour + '时'
            timeStr += (minute < 10 ? '0' + minute : minute) + '分'
            timeStr += (miao < 10 ? '0' + miao : miao) + '秒'
            this.txt_openAllPeopleRed_time.text = timeStr
            this.txt_12.x = this.txt_openAllPeopleRed_time.x + this.txt_openAllPeopleRed_time.textField.textWidth + 5;
        } else {
            this.img_time.visible = true;
            let ssm = __data.newPlayerRedChallenge.endTime - Date.now()
            var minute = Math.floor(ssm / 60 / 1000) % 60;
            var miao = Math.floor(ssm / 1000) % 60;
            let timeStr = ''
            timeStr += minute + '分'
            timeStr += miao + '秒'
            this.txt_time.text = timeStr + '后结束'
            this.img_time_tips.visible = __data.newPlayerRedChallenge.isShowAddTime()
        }
    }
}
