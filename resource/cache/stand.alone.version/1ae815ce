class MahjongTexture2D {
    static createTexture(data, group = ''){
        if(this.textures[`${group}_${data.value}`]){
            return this.textures[`${group}_${data.value}`];
        }else{
            // 1. 创建一个临时的 2D Sprite 容器
            let textSprite = new Laya.Sprite();
            // 2. 添加文字组件
            let txt = new Laya.Label();
            txt.font = "Arial";
            txt.fontSize = data.fontSize || 48;
            txt.padding = '2,0,0,0';
            txt.color = data.color || "#ffffff";
            txt.bold = data.bold || true;
            txt.overflow = 'visible';
            txt.align = "left";   // 水平居中
            txt.valign = "middle";  // 垂直居中
            txt.text = data.value || ' ';

            let width = data.width || Math.max(txt.textField.textWidth, txt.textField.textHeight);  // 贴图宽度
            let height = data.height || Math.max(txt.textField.textWidth, txt.textField.textHeight); // 贴图高度
            textSprite.size(width, height);
            // 可选：添加描边效果，增强在 3D 场景中的可读性
            textSprite.addChild(txt).pos(width - txt.textField.textWidth >> 1, height - txt.textField.textHeight >> 1);
            let texture = textSprite.drawToTexture(width, height, 0, 0);
            this.textures[`${group}_${data.value}`] = texture.bitmap;
            return this.textures[`${group}_${data.value}`];

