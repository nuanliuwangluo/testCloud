    static get HEILONGJIANG_COMMON() { return '-1'; }


    static getUniqueId(gameId, ruleId) {
        // 那就是个通用玩法
        if (ruleId < 0) {
            // 负号不可以用 所以转换一下前端
            ruleId = ruleId.toString().replace('-', '$');
            return ruleId;
        } else {
            return gameId;
        }
    }

    static getRes() {
        let __resArr = [];
        // 麻将牌资源
        __resArr = MahjongConfig.res_3D_Arr.concat({
            'url': 'res/atlas/local/mahjong_2D_' + (__data.mahjong_set.cardIndex + 2).toString() + '_card/1.atlas' + __version.res,
            type: Laya.Loader.ATLAS
        });
        //通河方正特殊特效
        // if (__data.domain == 8 || __data.domain == 10) { __resArr = __resArr.concat({ 'url': 'res/atlas/bigEffect.atlas' + __version.res, type: Laya.Loader.ATLAS }) }
        trace('所需资源：', __resArr)
        return __resArr;
    }

    static getSrc(gameId, ruleId) {
        if (config.isCoreMinJS) { return []; }
        let uniqueId = this.getUniqueId(gameId, ruleId);
        if (MahjongConfig['res_' + uniqueId + '_' + '3D']) {
            return MahjongConfig['res_' + uniqueId + '_' + '3D'];
        } else {
            console.warn('Id异常!!!');
        }
    }

    static getName(gameId, ruleId) {
        if (ruleId < 0) {
            return excelUtils.getCityName_mj(gameId, ruleId) || ''
        } else if (__data.excelConfig.hashCityIdVO[gameId]) {
            return excelUtils.getCityName_mj(gameId, ruleId) || ''
        } else {
            return "";
        }
    }

    static getMusicPath(ruleId) {
        let number = __data.excelConfig.hashPlayIdMusic[ruleId] || '2';
        return `s${number}/`;
    }
}


















