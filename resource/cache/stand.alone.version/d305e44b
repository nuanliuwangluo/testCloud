class S_click_marketActivity_panel_subscribeBtn extends Laya.Script {
    async onClick() {
        // 邀请红包待完成(点击订阅按钮)
        if (!__data.allPlayerRed.isSub) {
            let a = await miniApi.activitySubscribe()
            if (a == 1) {
                game.server.send(18005)
                game.scene.remove(Panel_marketActivity_inviteRed_subscribe)
            }
        } else {
            __tips('订阅成功')
            game.scene.remove(Panel_marketActivity_inviteRed_subscribe)
        }
    }
}
