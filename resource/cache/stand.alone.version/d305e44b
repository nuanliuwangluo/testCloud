class Panel_marketActivity_inviteRed extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/Panel_marketActivity_inviteRed',
            layer: 'panel'
        })
        this.btn_close.addComponent(S_click_marketActivity_panel_closeBtn)
        this.btn_help.addComponent(S_click_marketActivity_panel_explainBtn)
        this.addComponent(Panel_marketActivity_inviteRed_Comp);

        this.btn_redRank.addComponent(S_click_marketActivity_panel_rankBtn)
        this.btn_accept.addComponent(S_click_marketActivity_panel_acceptBtn)
        this.btn_applyExtra.addComponent(S_click_marketActivity_panel_applyExtraBtn)
        this.btn_again.addComponent(S_click_marketActivity_panel_againBtn)
    }

    onEnable() {
        this.activeClose = false;
		game.server.send(20002)
        miniApi.setItem(__data.uid + ':' + new Date().toDateString() + ':show_inviteRed', 1)
        miniApi.trackEvent('Mj_UIExposure', { 'Mj_ExposureScene': '瓜分礼金界面' })
        // miniApi.trackEvent('Mj_Marketing', { 'Mj_MarketingScene': '瓜分礼金', 'Mj_MarketingType': '营销活动', 'Mj_MarketingStatus': '曝光' })
        showActivityPanel('inviteRed')
        game.cb.on('marketActivity_panel_close', this, this.marketActivity_panel_close);
    }

    onDisable() {
        game.scene.remove(Panel_marketActivity_inviteRed_explain);
        game.cb.off('marketActivity_panel_close', this, this.marketActivity_panel_close);
        this.saveCount();
        this.checkinghallTestShowPanel();
    }

    marketActivity_panel_close() {
        this.activeClose = true;
    }

    saveCount(){
        if(__data.activity.inviteRed.taskData.state == 1){// 已经接取任务的状态下，记录关闭次数
            let count = LocalUtils.getByToday('close_inviteRed_count_by_tasking') || 0;
            count = parseInt(count) + 1
            LocalUtils.saveByToday('close_inviteRed_count_by_tasking', count);
        }
    }

    checkinghallTestShowPanel() {
        // 非主动关闭，直接检测是否需要显示其它弹出面板
        if(!this.activeClose){
            hallTestShowPanel();
        }else{// 主动关闭的时候，需要检测是否弹出海报
            let done = LocalUtils.getByToday('show_poster_page');
            // 如果已经展示过海报，就不需要再展示
            if(done){ hallTestShowPanel(); }
            else{
                if (miniApi.clientType == 'app') return;
                if (miniApi.getWxDeviceName() === 'windows') return;
                let state = __data.activity.inviteRed.taskData.state;// 任务状态
                let count = LocalUtils.getByToday('close_inviteRed_count_by_tasking') || 0;
                let inviteNumbers = __data.activity.inviteRed.taskData.data ? __data.activity.inviteRed.taskData.data.filter(item => item.lq > 0) : [];
                if(state == 1 && count >= 2 && inviteNumbers.length < 3){// 关闭次数超过2次，展示海报
                    __showScene.show_imageSharePre(hallTestShowPanel);
                }else{// 不满足条件 ，检测弹出面板
                    hallTestShowPanel();
                }
            }
        }
    }

    clickMask() { }
}

