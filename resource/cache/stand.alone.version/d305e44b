class Panel_marketActivity_inviteRed_rankItem extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/Panel_marketActivity_inviteRed_rankItem',
            module: false
        })
    }

    set dataSource(vo) {
        if (!vo) return;
        this.__vo = vo;

        LabelHiddenUtils.getAdapterContent(this.txt_rank_name, vo.name)
        SkinUtils.setSkin(this.img_head, vo.avatar ? vo.avatar : '');
        SkinUtils.setSkin(this.img_head_frame, PropIcon.icon[vo.headFrameId || 301].skin);
        this.txt_money.text = `${parseFloat(vo.value)}元`;

        this.txt_rank.visible = false;
        this.img_rank.visible = false;

        if (vo.index == -1) {
            this.txt_rank.visible = true;
            this.txt_rank.text = `--`;
        } else if (vo.index <= 3) {
            this.img_rank.visible = true;
            this.img_rank.skin = `local/rank_ui/1/img_${vo.index}.png`
        } else {
            this.txt_rank.visible = true;
            this.txt_rank.text = vo.index
        }
        this.txt_mjName.text = excelUtils.getCityName_mj(vo.game); // cityId
    }
}
Laya.ClassUtils.regClass('ui.scene_hall.Panel_marketActivity_inviteRed_rankItemUI', Panel_marketActivity_inviteRed_rankItem);


