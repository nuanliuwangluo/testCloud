// 邀请红包排名
class Panel_marketActivity_inviteRed_rank extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/Panel_marketActivity_inviteRed_rank',
            layer: 'panel0'
        })
        this.__list.vScrollBarSkin = '';
    }

    added() {
        this.request();
        this.__list.array = [];
        this.img_noData.visible = false;
        game.cb.on('update_inviteRed_rank_data', this, this.update_rank_data)
    }
    onDisable() {
        game.cb.off('update_inviteRed_rank_data', this, this.update_rank_data)
    }

    request() {
        game.server.send(18026);// 请求邀请红包排名数据
    }
    update_rank_data() {
        if (__data.activity.inviteRed.rankData.top_list.length == 0) {
            this.img_noData.visible = true;
        } else {
            this.img_noData.visible = false;
            this.__list.array = __data.activity.inviteRed.rankData.top_list;
        }
    }
}
