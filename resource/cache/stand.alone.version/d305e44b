// 邀请红包说明
class Panel_marketActivity_inviteRed_playerItem extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/Panel_marketActivity_inviteRed_playerItem',
            module: false
        })

        this.btn_get.on(Laya.Event.CLICK, this, this.clickGet);
        this.btn_invite.on(Laya.Event.CLICK, this, this.clickInvite);
        this.wait.on(Laya.Event.CLICK, this, this.clickInvite);
    }

    set dataSource(value) {
        if (value) {
            this.value = value;
            // 隐藏加号
            this.wait.visible = false;
            // 设置头像
            if(value.data && value.data.avatar){
                SkinUtils.setSkin(this.head, value.data.avatar);
            }else{
                SkinUtils.setSkin(this.head, '');
            }
            
            if (value.lq == 0) {// 未邀请
                // 显示加号
                this.wait.visible = true;
                this.btn_invite.visible = true;
                this.btn_get.visible = false;
                this.geted.visible = false;
            } else if (value.lq == 1) {// 已邀请  且已完成任务
                this.btn_get.visible = true;
                this.btn_invite.visible = false;
                this.geted.visible = false;
            } else if (value.lq == 2) {// 已领取
                this.geted.visible = true;
                this.btn_get.visible = false;
                this.btn_invite.visible = false;
            }
            // geted 已领取标志
        } else {
            // 显示加号
            this.wait.visible = true;
            this.geted.visible = false;
            this.btn_get.visible = false;
            this.btn_invite.visible = true;
        }
    }

    clickGet() {
        game.server.send(18029, this.value.index);
    }

    clickInvite() {
        miniApi.share({
            titleId: __tool.randomRange(1, 10),
            params: `uid=${__data.uid}&myCityId=${__data.myCityId}`
        });
    }

    set index(value) { this.__index = value; }
    get index() { return this.__index; }
}
Laya.ClassUtils.regClass('ui.scene_hall.Panel_marketActivity_inviteRed_playerItemUI', Panel_marketActivity_inviteRed_playerItem);


class Panel_marketActivity_inviteRed_Comp extends Laya.Script {

    onEnable() {
        game.cb.on('update_inviteRed_taskStatus', this, this.updateUI);
        this.updateUI();
    }

    onDisable() {
        game.cb.off('update_inviteRed_taskStatus', this, this.updateUI);
    }

    updateUI() {
        this.showUI();
        this.setSurplusReds(__data.activity.inviteRed.taskData.hb_count);// 设置剩余红包
        this.setAchievement(__data.activity.inviteRed.taskData.all_invite, __data.activity.inviteRed.taskData.total);// 设置完成情况以及获得的奖励
    }

    // 根据不同状态显示不同UI
    showUI() {
        if (__data.activity.inviteRed.taskStatus == __data.activity.inviteRed.STATUS_READY) {
            this.owner.ready.visible = true;
            this.owner.ing.visible = false;
            this.owner.btn_again.visible = false;
            // 还有红包个数  显示接受任务按钮 反之显示申请额外红包按钮
            this.owner.btn_accept.visible = __data.activity.inviteRed.taskData.hb_count != 0;
            this.owner.btn_applyExtra.visible = !this.owner.btn_accept.visible;
        } else if (__data.activity.inviteRed.taskStatus == __data.activity.inviteRed.STATUS_ING) {
            // 所有邀请人都已完成任务，且都领取了奖励，显示结束按钮
            if (__data.activity.inviteRed.isAllDone) {
                this.owner.ready.visible = false;
                this.owner.ing.visible = true;
                this.owner.btn_again.visible = true;
            } else {// 有邀请人未完成任务  或者还有奖励未领取
                this.owner.ready.visible = false;
                this.owner.ing.visible = true;
                this.owner.btn_again.visible = false;
            }
            // 显示邀请人列表
            this.setList(__data.activity.inviteRed.taskData.data);
        }
    }

    setList(arrays) {
        while (arrays.length < 3) arrays.push({});// 补充空项
        arrays.map((item, index) => { item.index = index + 1; })
        this.owner.list.array = arrays;
    }

    setSurplusReds(num) {
        HtmlTextUtils.text(
            this.owner.txt_surplus_reds, { align: 'left', valign: 'top', fontSize: 50, bold: true, width: this.owner.width, color: '#ffffff', stroke: 4, strokeColor: '##730000' },
            '本轮剩余待锁定红包&nbsp;', {},
            num, { color: '#fff000' },
            '&nbsp;个', {}
        )
        Laya.timer.callLater(this, this.relocation);
    }

    setAchievement(num, cash) {
        HtmlTextUtils.text(
            this.owner.txt_achievement, { align: 'left', valign: 'top', fontSize: 40, bold: false, width: this.owner.width, color: '#e5ff00' },
            '已成功邀请&nbsp;', {},
            num, { color: '#ffffff' },
            '&nbsp;人，获得&nbsp;', {},
            parseFloat(cash), { color: '#ffffff' },
            '&nbsp;元', {}
        )
        Laya.timer.callLater(this, this.relocation);
    }

    relocation() {
        this.owner.txt_surplus_reds.x = this.owner.btn_redRank.x - this.owner.txt_surplus_reds.contextWidth / 2;
        this.owner.txt_surplus_reds.y = this.owner.btn_redRank.y - this.owner.btn_redRank.height / 2 - this.owner.txt_surplus_reds.contextHeight - 10;

        this.owner.txt_achievement.x = this.owner.width - this.owner.txt_explain.x - this.owner.txt_achievement.contextWidth;
        this.owner.txt_achievement.y = this.owner.txt_explain.y;
    }
}

