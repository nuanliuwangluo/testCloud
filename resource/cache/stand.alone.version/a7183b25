    statusBarRatio() {
        // return 0.1
        if (miniApi.clientType == 'app') {
            if (window.ratio) { return window.ratio; }
            let ratio = 0;

            if (window.APP_PACKAGE && window.APP_PACKAGE == window.ORIGIN_APP) {
                let distance = AppBridge.statusBarHeight;
                let screenWidth = AppBridge.screenInfo ? AppBridge.screenInfo.width : Laya.stage.width;
                if (distance > 0) {
                    ratio = (distance / 1.35 / screenWidth);
                } else {
                    ratio = (AppBridge.statusBarHeight / 1.35 / screenWidth);
                }
            } else if (window.AppDevice) {
                let distance = AppDevice.left || AppDevice.statusBarHeight;
                if (distance > 0) {
                    if (api.systemType == 'ios') {
                        ratio = (distance / 1.35 / AppDevice.windowWidth);
                    } else {
                        ratio = (distance / AppDevice.windowWidth);
                    }
                } else {
                    if (api.systemType == 'ios') {
                        ratio = (AppDevice.statusBarHeight / 1.35 / AppDevice.windowWidth);
                    } else {
                        ratio = (AppDevice.statusBarHeight / AppDevice.windowWidth);
                    }
                }
            }

            console.log('比例：', ratio)
            window.ratio = ratio;
            return ratio;
        }
        return 0;
    },
