    isCanPay() {
        return new Promise((resolve, reject) => {
            if (miniApi.clientType == 'web') {
                return resolve(1);
            }
            if (miniApi.clientType == 'app') {
                return resolve(1);
            }
            if (miniApi.clientType == 'wx') {
                if (wx.checkIsSupportMidasPayment) {
                    wx.checkIsSupportMidasPayment({
                        success(res) {
                            console.log('支持检查结果:', res)
                            if (res.data.allow_pay) {
                                console.log('当前环境支持支付')
                                return resolve(1);
                                // 可以继续调用支付相关接口
                            } else {
                                console.log('当前环境不支持支付')
                                return resolve(0);
                                // 请自行适配用户提示文案
                            }
                        },
                        fail(err) {
                            console.error('检查支持情况失败:', err)
                            return resolve(0);
                        },
                        complete() {
                            console.log('检查完成')
                        }
                    })
                } else {
                    return resolve(0);
                }
            }
        })
    },
