class GameMainAllPlayerRed_luckRed extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_allPlayerRed_luckRed',
            layer: 'panel'
        })
        this.btn_close.addComponent(S_click_close_remove_parent)
        this.btn_receive.addComponent(S_luck_receive)
    }
    onAwake() {
        this.rect = new Laya.Rectangle()
        this.rect.width = this.img_bar.width;
        this.rect.height = this.img_bar.height;
        this.img_bar.scrollRect = this.rect;
    }
    onEnable() {
        game.server.send(20002)
        this.updateTime(false)
        Laya.timer.loop(1000, this, this.updateTime)
        this.updateData()
        game.cb.on('update_allPlayerRed_data', this, this.updateData)
    }
    onDisable() {
        Laya.timer.clearAll(this)
        game.cb.off('update_allPlayerRed_data', this, this.updateData)
    }
    updateData(e) {
        let luck = __data.allPlayerRed.luck
        if (luck == undefined || luck == null || luck == NaN || luck == -1) {
            // 没资格
            this.txt_des.text = '今日已领取'
            this.img_money.visible = false
            this.btn_receive.gray = true
        } else if (luck == -2) {
            // 今天领过激励金了
            this.txt_des.text = '今日已领取'
            let cur = 10;
            let max = 10
            this.rect.width = (cur / max) * this.img_bar.width;
            this.txt_pro.text = cur + ' / ' + max;

            this.img_money.visible = false
            this.btn_receive.gray = true
        } else if (luck >= 10) {
            // 就代表可以领取了
            this.txt_des.text = '领专属红包'
            let cur = 10;
            let max = 10
            this.rect.width = (cur / max) * this.img_bar.width;
            this.txt_pro.text = cur + ' / ' + max;

            this.img_money.visible = true
            this.btn_receive.gray = false
        } else if (luck >= 0) {
            // 有资格 并且 已经完成了 n次  
            this.txt_des.text = '领专属红包'

            let cur = luck;
            let max = 10
            this.rect.width = (cur / max) * this.img_bar.width;
            this.txt_pro.text = cur + ' / ' + max;

            this.img_money.visible = true
            this.btn_receive.gray = false
        }

    }
    updateTime(isTestRemove = true) {
        const now = new Date();
        const endOfDay = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 23, 0, 0);
        const secondsLeft = Math.floor((endOfDay - now) / 1000);
        if (secondsLeft >= 0) {
            let a = game.utils.numberToTime(secondsLeft)
            this.txt_time.text = a;
        } else {
            if (isTestRemove) {
                game.scene.remove(this)
            }
        }
    }
}
class S_luck_receive extends Laya.Script {
    onClick(e) {
        let luck = __data.allPlayerRed.luck
        if (luck == undefined || luck == null || luck == NaN || luck == -1) {
            // 没资格
        } else if (luck == -2) {
            // 今天领过激励金了
            __tips('今日已领取过幸运激励金')
        } else if (luck >= 10) {
            // 就代表可以领取了
            game.server.send(18016)
        } else if (luck >= 0) {
            // 有资格 并且 已经完成了 n次  
            __tips('尚未达到领取条件')
        }
    }
    onRightClick(e) {
        if (miniApi.clientType === 'web') {
            game.server.send(18018)
            game.server.send(18007);
        }
    }
}