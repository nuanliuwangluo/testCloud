        //多种操作
        if (value.length > 1) {

            //获取一个sprite 容器
            let container = Laya.Pool.getItemByClass(__cName.opc, Laya.Sprite)

            let c_w, c_h, l_w, l_h
            for (let i = 0; i < value.length; i++) {
                //获取一个选择容器
                let frame = Laya.Pool.getItemByClass(__cName.opt, FjmjMahjongChoiceFrame)
                    //将当前的操作集合传递过去
                frame.setChoice(this.owner.__number, value[i])
                    //排序
                frame.x = (i % 5) * frame.width
                frame.y = -Math.floor(i / 5) * frame.height

                c_w = frame.width
                c_h = frame.height
                container.addChild(frame)
            }

            l_w = value.length > this.__len - 1 ? this.__len : value.length
            l_h = Math.ceil(value.length / this.__len)
            container.size(l_w * c_w, l_h * c_h)
            container.x = Laya.stage.designWidth - container.width >> 1
            container.y = game.height - game.height * 0.4;
            game.scene.layer['bottom'].c.addChild(container)
            window.frameContiner = container;
        }
    }
}















class FjmjMahjongVideoOperation extends Laya.Sprite {
    constructor() {
        super();
        this.__offx = 210 * game.scale;
        this.__offy = 180;
    }

    onEnable() {
        while (this.numChildren) this.removeChildAt(0)
    }

    operation(position, opArr, choice) {
        let __vo = __data.deskData.roomVo.getPlayer(position)
        if (!__vo) {
            game.utils.remove(this);
            console.error('video miss operation position！');
            return
        }

        //排序
        opArr = __compUtils.sort(opArr)

        trace('随机位置：', position)
        trace('随机数组：', opArr)
        trace('随机选择：', choice)

        this.__width = this.__height = 0
        if (__vo.seat_tag == 'down' || __vo.seat_tag == 'up') {
            for (var i = 0; i < opArr.length; i++) {
                var __v = Laya.Pool.getItemByClass(__cName.opv, FjmjMahjongVideoOperationBtn)
                __v.opt = opArr[i]
                __v.choice = choice
                __v.create();
                this.addChild(__v).x = __v.width * i
                this.__width += __v.width
                this.__height = __v.height
            }
        } else {
            for (var i = 0; i < opArr.length; i++) {
                var __v = Laya.Pool.getItemByClass(__cName.opv, FjmjMahjongVideoOperationBtn)
                __v.opt = opArr[i]
                __v.choice = choice
                __v.create();
                this.addChild(__v).y = __v.height * i
                this.__width = __v.width
                this.__height += __v.height
            }
        }
        this.size(this.__width, this.__height)
        // this.scale(game.scale, game.scale)

        if (__vo.seat_tag == 'down') {
            this.x = config.gameW - this.width - this.__offx;
            this.y = config.gameH - this.height - this.__offy + this.ty;
        } else if (__vo.seat_tag == 'up') {
            this.x = config.gameW - this.width + 300 >> 1;
            this.y = -this.ty + 120;
        } else if (__vo.seat_tag == 'left') {
            this.x = this.__offx + 10;
            this.y = config.gameH - this.height >> 1;
        } else if (__vo.seat_tag == 'right') {
            this.x = config.gameW - this.width - this.__offx;
            this.y = config.gameH - this.height >> 1;
        }
    }

    get ty(){
        let py = this.parent.localToGlobal(new Laya.Point(0, 0));
        return py.y;
    }

    get by(){
        let py = this.parent.localToGlobal(new Laya.Point(0, 0));
        return py.y;
    }
}


