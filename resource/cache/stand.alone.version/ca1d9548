class FjmjMahjongChoiceFrame extends game.ModuleBase {
    constructor() {
        super();
        this.createView(game.uiMap['scene_game/mahjong/MahjongChoiceFrame']);
        this.scale(game.scale, game.scale)
            //点击效果
        this.addComponent(Btn_Scale_Sound)
            //3张  4张  2张选择  的编号   比如 92 吃   需要3张的   100 杠  需要4张的 
        this.threeArr = [92, 98, 113]
        this.fourArr = [97, 100, 103]
        this.twoArr = [114]
    }

    onEnable() {
        this.on('click', this, this.choiceHandler)
    }

    onDisable() {
        this.off('click', this, this.choiceHandler)
    }

    choiceHandler() {
        trace(this.__choiceArr)
        game.utils.remove(this.parent)
        let start
        switch (this.__number) {
            case "92":
                start = this.__choiceArr[0];
                trace('发送消息：', 6001, this.__number, start)
                game.server.send(6001, this.__number, start)
                break;
            case "98":
                start = this.__choiceArr[0];
                trace('发送消息：', 6001, this.__number, start)
                game.server.send(6001, this.__number, start)
                break;
            case "97":
                start = this.__choiceArr[0];
                trace('发送消息：', 6001, this.__number, start)
                game.server.send(6001, this.__number, start)
                break;
            case "100":
                start = this.__choiceArr[0];
                trace('发送消息：', 6001, this.__number, start)
                game.server.send(6001, this.__number, start)
                break;
            case "103":
                start = this.__choiceArr[0];
                trace('发送消息：', 6001, this.__number, start)
                game.server.send(6001, this.__number, start)
                break;
            case "113":
                start = this.__choiceArr[0].split('_');
                trace('发送消息：', 6001, this.__number, start[0], start[1], start[2])
                game.server.send(6001, this.__number, start[0], start[1], start[2])
                break;
            case "114":
                start = this.__choiceArr[0];
                trace('发送消息：', 6001, this.__number, start)
                game.server.send(6001, this.__number, start)
                break;
        }
    }

    setChoice(value, optArr) {

        let __inThree = this.threeArr.some(function(a) { return a == value })
        let __inFour = this.fourArr.some(function(a) { return a == value })
        let __inTwo = this.twoArr.some(function(a) { return a == value })

        let __arr = optArr.split(',')
        this.__number = value;
        this.__choiceArr = __arr;


        //2 张的情况
        if (__inTwo) {
            game.utils.remove(this.four)
            game.utils.remove(this.three)
            this.addChild(this.two)

            for (let i = 0; i < 2; i++) {
                this['two_' + (i + 1)].texture = Mahjong2DRes.getRes('udo', __arr.toString());
            }
        } else if (__inThree) {
            game.utils.remove(this.four)
            game.utils.remove(this.two)
            this.addChild(this.three)
                //如果不是亮喜  扣出最后一张   最后一张的使用情况为  标记哪一张为吃 的牌
            let __len = __arr.length - 1
                //如果是亮喜  全部都显示出来 
            if (value == 113) {
                __arr = optArr.split('_');
                __len = __arr.length
            }
            for (let i = 0; i < __len; i++) {
                this['three_' + (i + 1)].texture = Mahjong2DRes.getRes('udo', __arr[i]);
                //如果这张牌为要吃的牌  向上位移
                if (__arr[i] == __arr[__arr.length - 1] && value != 113) { this['three_' + (i + 1)].y = -10 } else this['three_' + (i + 1)].y = 0
            }
        } else if (__inFour) {
            game.utils.remove(this.three)
            game.utils.remove(this.two)
            this.addChild(this.four)

            for (let i = 0; i < 4; i++) {
                this['four_' + (i + 1)].texture = Mahjong2DRes.getRes('udo', __arr.toString());
            }
        }

    }

}


