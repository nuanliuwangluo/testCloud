'use strict';

class FjmjMahjongOperation extends Laya.Sprite {
    constructor() {
        super();

        this.list = [];

        this.opArr = ['92', '93', '94', '95', '96', '97', '98', '99', '100', '102', '103', '113', '114', '155']

        //过按钮和其它按钮增加间距
        this.__passOffx = 10

        //排序规则   按当前顺序进行排序 
        this.__rearArr = ["113", "114", "98", "99", "102", "103", "155", "96", "250"]
            // this.scale(game.scale, game.scale)
    }

    onEnable() {}

    onDisable() {

    }

    /**
     * [show_operation description]
     * @param  {[type]} value        [description]  可以进行的操作   92吃 93碰 94明杠 96胡 100暗杠 102杠听 103杠听 155听 97薛 98吃听 99碰听 113亮喜 114亮掌 250过
     * @param  {[type]} operationArr [description]  操作的集合   比如吃听  碰听的几种组合
     * @return {[type]}              [description]
     */
    show_operation(value, operationArr) {

        this.width = 0

        this.list = [];
        while (this.numChildren) this.removeChildAt(0)

        // value = '92,97,98,114,113,100,250'
        // operationArr = [];
        // operationArr['92'] = '20,21,22,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22'
        // operationArr['98'] = '20,21,22,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22;21,22,23,22'
        // operationArr['97'] = '1,2,3,4,5,6,7,8'
        // operationArr['100'] = '1,2,3,4,5,6,7,8'
        // operationArr['114'] = '1,2,3,4,5,6,7,8'
        // operationArr['113'] = '40_40_40,40_40_40,40_40_40,40_40_40,40_40_40,40_40_40,40_40_40,40_40_40,40_40_40,40_40_40,40_40_40,40_40_40'
        // operationArr['113'] = '40_40_40'
        // operationArr['92'] = '20,21,22,22'

        this.__operation = value.split(',');
        this.__operationArr = operationArr;

        //根据顺序处理一下
        for (let r = 0; r < this.__rearArr.length; r++) {
            let index = this.__operation.indexOf(this.__rearArr[r])
            if (index > -1)
                this.__operation.push(this.__operation.splice(index, 1).toString())
        }

        for (let i = 0; i < this.__operation.length; i++) {
            //抓牌的自定义消息跳过
            if (parseInt(this.__operation[i]) == 1000) continue

            let __o = this.__operation[i].toString();
            let __r = this.opArr.some(function(value) { return value.toString() == __o })
            if (!__r && parseInt(this.__operation[i]) != 250) continue

            let __btn = Laya.Pool.getItemByClass(__cName.ope, FjmjMahjongOperationButton)
                //设置皮肤
            __btn.sign = this.__operation[i];
            //可操作的列表  比如多种吃  吃听   亮喜 等
            __btn.group = operationArr[this.__operation[i]];
            //设置位置
            this.addChild(__btn).x = this.list.length > 0 ? this.list[this.list.length - 1].x + this.list[this.list.length - 1].width : 0

            if (this.__operation[i] == 250) __btn.x += this.__passOffx
            this.list.push(__btn)

            this.width = __btn.x + __btn.width + this.__passOffx;
            this.height = __btn.height;
        }
    }
}


