    2501() {
        try {
            let result = this.readString(); // 胜利 失败
            let state = this.readString(); // Mj_State
            let cards = this.readString(); // Mj_Cards
            let strategy = this.readString(); // 策略
            let countyName = excelUtils.getUmEventName(__data.gameId.curId)
            let typeName = __data.hashMatchModelTypeName[__data.deskData.roomVo.indexId] || '未知';
            let uid = __data.uid.toString();
            let gameMethod = excelUtils.getPlayIdName(__data.deskData.roomVo.modelId);
            let coins = parseInt(__data.deskData.roomVo.smallResultData.myScore);
            let winNumber = Math.max(0, window.keepWinNumber); // 
            let deskData = __data.getMatchDataById(__data.prev_match_modelId, __data.gameId.curId, __data.prev_match_lv);
            let deskCost = deskData ? deskData.cost : 0;
            let truthRate = Math.round(__data.deskData.roomVo.smallResultData.myScore / __data.deskData.roomVo.bottomScore);
            let vip = __data.vip.isVip ? '是' : '否';
            let victoryMethod = '未知';
            let vms = ['接炮', '自摸', '摸宝', '漏宝', '射宝', '对宝', '大风', '红中', '天胡'];
            let capping = '';
            let surplus = __data.deskData.roomVo.smallResultData.surplus;
            let isPochan = '否';
            let specialCard = 0;
            let time = Math.floor(Date.now() / 1000);
            for (let i = 0; i < __data.deskData.roomVo.smallResultData.playerArray.length; i++) {
                let player = __data.deskData.roomVo.smallResultData.playerArray[i];
                let winner = player.winPosition.indexOf(player.position) != -1;
                if (winner) {
                    let explains = player.scoreInfo.split(' ');
                    for (let j = 0; explains && j < explains.length; j++) {
                        if (victoryMethod != '未知') continue;
                        let explain = explains[j];
                        for (let z = 0; z < vms.length; z++) {
                            if (victoryMethod != '未知') continue;
                            // 找到这个描述文字了
                            if (explain.indexOf(vms[z]) != -1) {
                                victoryMethod = vms[z];
                                break;
                            }
                        }
                    }
                }
                if (player.id == __data.uid) {
                    capping = player.isMaxMatch ? '是' : '否';
                }
                if (player.id == __data.uid) {
                    isPochan = __data.gold < __data.d_match.showReliefConditionGold ? '是' : '否';
                }
                // 方正
                if (player.id == __data.uid && (__data.gameId.curId == 8 || __data.gameId.curId == 10)) {
                    for (let s = 0; s < player.tileGroupArray.length; s++) {
                        let group = player.tileGroupArray[s];
                        let isXi = group.startsWith('82');
                        isXi && specialCard++;
                    }
                }
                // 富锦
                if (player.id == __data.uid && __data.gameId.curId == 13) {
                    let hands = [].concat(player.handTileArray);
                    let picks = __compUtils.pickup(hands, __data.deskData.roomVo.mixedArr);
                    specialCard = picks.pickups ? picks.pickups.length : 0;
                }
                // 泰来
                if (player.id == __data.uid && HallPlay.lastCityId == 111) {
                    for (let s = 0; s < player.tileGroupArray.length; s++) {
                        let group = player.tileGroupArray[s];
                        let isXi = group.startsWith('82');
                        isXi && specialCard++;
                    }
                }
                // 汤原 经典黑龙江
                if (player.id == __data.uid && (HallPlay.lastCityId == 21 || HallPlay.curRuleId == -1)) {
                    for (let s = 0; s < player.tileGroupArray.length; s++) {
                        let group = player.tileGroupArray[s];
                        let isGang = group.startsWith('5');
                        isGang && specialCard++;
                    }
                }
            }

            // 我赢了 需要Mj_VictoryMethod字段
            if (__data.deskData.roomVo.smallResultData.myResult) {

                // 赢家找到的 是未知
                if (victoryMethod == '未知') {
                    for (let i = 0; i < __data.deskData.roomVo.smallResultData.playerArray.length; i++) {
                        let player = __data.deskData.roomVo.smallResultData.playerArray[i];
                        let loser = player.winPosition.indexOf(player.position) == -1;
                        if (loser) {
                            let explains = player.scoreInfo.indexOf('炮');
                            if (explains != -1) { // 输家的描述中找到了 炮字
                                victoryMethod = '接炮';
                                break;
                            }
                        }
                    }
                }

                miniApi.trackEvent('Mj_Gameanalysis', {
                    'Mj_County': countyName,
                    'Mj_GameType': typeName,
                    'Mj_Time': time,
                    'Mj_State': state,
                    'Mj_Cards': cards,
                    'Mj_Results': result,
                    'Mj_UserID': uid,
                    'Mj_Strategy': strategy,
                    'Mj_GameMethod': gameMethod,
                    'Mj_GoldCoins': coins,
                    'Mj_Victories': winNumber,
                    'Mj_Fee': parseInt(deskCost),
                    'Mj_TrueMultiple': parseInt(truthRate),
                    'Mj_VictoryMethod': victoryMethod,
                    'Mj_VIP': vip,
                    'Mj_Remainder': surplus,
                    'Mj_Capping': capping,
                    'Mj_Bankrupt': isPochan,
                    'Mj_SpecialCard': specialCard
                });
            }
            // 我输了   不要Mj_VictoryMethod 这个字段
            else {
                miniApi.trackEvent('Mj_Gameanalysis', {
                    'Mj_County': countyName,
                    'Mj_GameType': typeName,
                    'Mj_Time': time,
                    'Mj_State': state,
                    'Mj_Cards': cards,
                    'Mj_Results': result,
                    'Mj_UserID': uid,
                    'Mj_Strategy': strategy,
                    'Mj_GameMethod': gameMethod,
                    'Mj_GoldCoins': coins,
                    'Mj_Victories': winNumber,
                    'Mj_Fee': parseInt(deskCost),
                    'Mj_TrueMultiple': parseInt(truthRate),
                    'Mj_VIP': vip,
                    'Mj_Remainder': surplus,
                    'Mj_Capping': capping,
                    'Mj_Bankrupt': isPochan,
                    'Mj_SpecialCard': specialCard
                });
            }

            __data.deskData.roomVo.smallResultData && (__data.deskData.roomVo.smallResultData.playerState = state);
        } catch (e) {

        }
    },

