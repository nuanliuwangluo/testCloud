    }
}
class GameMainRedPacket_4 extends game.ModuleBase {
    constructor() {
        super({
            map: 'scene_hall/gameMain_redPacket_4',
            layer: 'panel'
        })
    }
    onDisable() {
        hallTestShowPanel()
        ResUtils.clearTextureRes(['cdn.redPacket', 'cdn.shareReceiveTips'])
    }
}
class S_GameMainRedPacket_3_open extends Laya.Script {
    onClick(e) {
        game.server.send(16002, GameMainRedPacket_1.goldNum)
        game.scene.remove(GameMainRedPacket_3)
    }
}
class S_GameMainRedPacket_1_share extends Laya.Script {
    onClick(e) {
        // __data.shareVideoRule.total_clickShareCount()
        miniApi.share({
            titleId: __tool.randomRange(1, 9),
            shareVerifyOnShowFnTime: __data.shareVideoRule.isVerifyShareOnShowTime,
            params: `uid=${__data.uid}&shareRewardType=redPacketShare&myCityId=${__data.myCityId}`,
            shareGroupClickCallback: () => {
                game.scene.remove(GameMainRedPacket_1)
                game.scene.remove(GameMainRedPacket_2)
                game.scene.add(GameMainRedPacket_3)
            },
            shareOnShowCallback: () => {
                game.scene.remove(GameMainRedPacket_1)
                game.scene.add(GameMainRedPacket_2)
            }
        })
        miniApi.trackEvent('Mj_ShareClick', { Mj_ADPreference: miniApi.adUserValueLevel, 'Mj_ShareScene': '红包', 'Mj_Participation': '参与分享' })
    }
}